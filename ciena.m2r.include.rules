						}
						$cienaCesChassisHealthSubCategory = $4
						$cienaCesChassisHealthStatuslook = "cienaCesChassisHealthStatus." + $5
						$cienaCesChassisHealthStatus = lookup($cienaCesChassisHealthStatuslook,CienaVarbindValTable)
						if(match($cienaCesChassisHealthStatus,"UNKNOWN")) {
							$cienaCesChassisHealthStatus = $5
						} else {
							$cienaCesChassisHealthStatus = $cienaCesChassisHealthStatus + " ( " + $5 + " )"
						}
						$cienaCesChassisHealthStatusLastlook = "cienaCesChassisHealthStatusLast." + $6
						$cienaCesChassisHealthStatusLast = lookup($cienaCesChassisHealthStatusLastlook,CienaVarbindValTable)
						if(match($cienaCesChassisHealthStatusLast,"UNKNOWN")) {
							$cienaCesChassisHealthStatusLast = $6
						} else {
							$cienaCesChassisHealthStatusLast = $cienaCesChassisHealthStatusLast + " ( " + $6 + " )"
						}
						@AlertGroup = "Ciena OME Traps"
						@Agent = "ciena.m2r.include.rules"
						@Summary = "cienaCesChassisHealthStatusUnknownNotification: Chassis Health status is in an unknown state"
						@Severity = 4
						@Type = 1
						@Identifier = @Node + @Summary
						details($*)

					case "14": ### - cienaCesChassisHealthStatusWarningNotification
						# SNMPv2
						# This notification is sent whenever the health manager status changes to warning for the specified cienaCesChassisHealthCategory and
						# cienaCesChassisHealthSubCategory. The cienaCesChassisHealthStatus indicates a warning status while the cienaCesChassisHealthStatusLast
						# indicates the previous health status. The health status can be one of unknown, normal, warning, degraded or faulted. A warning status
						# indicates that the monitored item is experiencing some errors or is deviated from specified ranges, but is still functional.
						# To enable the device to send this trap:
						# -       cienaCesChassisHealthTrapState needs to be set to enabled
