						}
						@AlertGroup = "Ciena OME Traps"
						@Agent = "ciena.m2r.include.rules"
						@Summary = "cienaCesChassisIOMBuzzerStateChangeNotification: Chassis Input / Output Module buzzer state has changed"
						@Severity = 3
						@Type = 1
						@Identifier = @Node + @Summary
						details($*)

					case "22": ### - cienaCesChassisIOMAlarmOutputStateChangeNotification
						# SNMPv2
