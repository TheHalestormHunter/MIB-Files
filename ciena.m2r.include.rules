						}
						@AlertGroup = "Ciena OME Traps"
						@Agent = "ciena.m2r.include.rules"
						@Summary = "cienaCesChassisHealthStatusGoodNotification: Chassis health status has changed to normal"
						@Severity = 3
						@Type = 1
						@Identifier = @Node + @Summary
						details($*)

					case "18": ### - cienaCesChassisRebootNotification
						# SNMPv2
						# A cienaCesChassisRebootNotification is sent whenever device is rebooted using CLI.
						$cienaGlobalSeveritylook = "cienaGlobalSeverity." + $1
						$cienaGlobalSeverity = lookup($cienaGlobalSeveritylook,CienaVarbindValTable)
						if(match($cienaGlobalSeverity,"UNKNOWN")) {
							$cienaGlobalSeverity = $1
						} else {
							$cienaGlobalSeverity = $cienaGlobalSeverity + " ( " + $1 + " )"
						}
						$cienaCesChassisMacAddress = $2
						$cienaCesChassisRebootReasonErrorTypelook = "cienaCesChassisRebootReasonErrorType." + $3
						$cienaCesChassisRebootReasonErrorType = lookup($cienaCesChassisRebootReasonErrorTypelook,CienaVarbindValTable)
						if(match($cienaCesChassisRebootReasonErrorType,"UNKNOWN")) {
							$cienaCesChassisRebootReasonErrorType = $3
						} else {
							$cienaCesChassisRebootReasonErrorType = $cienaCesChassisRebootReasonErrorType + " ( " + $3 + " )"
						}
						@AlertGroup = "Ciena OME Traps"
						@Agent = "ciena.m2r.include.rules"
						@Summary = "cienaCesChassisRebootNotification: Chassis has been rebooted via cli"
						@Severity = 4
						@Type = 1
						@Identifier = @Node + @Summary
						details($*)

					case "19": ### - cienaCesChassisIOMStateChangeNotification
						# SNMPv2
						# This notification is generated when the value of cienaCesChassisIOMState changes.
						$cienaGlobalSeveritylook = "cienaGlobalSeverity." + $1
						$cienaGlobalSeverity = lookup($cienaGlobalSeveritylook,CienaVarbindValTable)
						if(match($cienaGlobalSeverity,"UNKNOWN")) {
							$cienaGlobalSeverity = $1
						} else {
							$cienaGlobalSeverity = $cienaGlobalSeverity + " ( " + $1 + " )"
						}
						$cienaCesChassisIOMStatelook = "cienaCesChassisIOMState." + $2
						$cienaCesChassisIOMState = lookup($cienaCesChassisIOMStatelook,CienaVarbindValTable)
						if(match($cienaCesChassisIOMState,"UNKNOWN")) {
							$cienaCesChassisIOMState = $2
						} else {
							$cienaCesChassisIOMState = $cienaCesChassisIOMState + " ( " + $2 + " )"
						}
						@AlertGroup = "Ciena OME Traps"
						@Agent = "ciena.m2r.include.rules"
						@Summary = "cienaCesChassisIOMStateChangeNotification: Chassis Input / Output Module state changed to " + $cienaCesChassisIOMState
						@Severity = 4
						@Type = 1
						@Identifier = @Node + @Summary
						details($*)

					case "20": ### - cienaCesChassisIOMBuzzerEnableChangeNotification
						# SNMPv2
						# This notification is generated when the value of cienaCesChassisIOMBuzzerEnable changes.
						$cienaGlobalSeveritylook = "cienaGlobalSeverity." + $1
						$cienaGlobalSeverity = lookup($cienaGlobalSeveritylook,CienaVarbindValTable)
						if(match($cienaGlobalSeverity,"UNKNOWN")) {
							$cienaGlobalSeverity = $1
						} else {
							$cienaGlobalSeverity = $cienaGlobalSeverity + " ( " + $1 + " )"
						}
						$cienaCesChassisIOMBuzzerEnablelook = "cienaCesChassisIOMBuzzerEnable." + $2
						$cienaCesChassisIOMBuzzerEnable = lookup($cienaCesChassisIOMBuzzerEnablelook,CienaVarbindValTable)
						if(match($cienaCesChassisIOMBuzzerEnable,"UNKNOWN")) {
							$cienaCesChassisIOMBuzzerEnable = $2
						} else {
							$cienaCesChassisIOMBuzzerEnable = $cienaCesChassisIOMBuzzerEnable + " ( " + $2 + " )"
						}
						@AlertGroup = "Ciena OME Traps"
						@Agent = "ciena.m2r.include.rules"
						@Summary = "cienaCesChassisIOMBuzzerEnableChangeNotification: Chassis Input / Output Module buzzer enable has changed"
						@Severity = 3
						@Type = 1
						@Identifier = @Node + @Summary
						details($*)

					case "21": ### - cienaCesChassisIOMBuzzerStateChangeNotification
						# SNMPv2
						# This notification is generated when the value of cienaCesChassisIOMBuzzerState changes.
						$cienaGlobalSeveritylook = "cienaGlobalSeverity." + $1
						$cienaGlobalSeverity = lookup($cienaGlobalSeveritylook,CienaVarbindValTable)
