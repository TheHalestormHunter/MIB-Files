						details($*)

					case "9": ### - cienaCesModuleSensorNormalTempNotification
						# SNMPv2
						# This notification is sent if the cienaCesModule temperature changes
						# from previously reported high or low temperature exceeding thresholds to normal temperature.
						# To enable the device to send this notification:
						# - cienaCesModuleAllModulesTrapState needs to be set to enabled.
						# - cienaCesModuleSensorTrapState needs to be set to enabled.
						# The above values are set to enabled by default. Variable bindings include:
						# cienaGlobalSeverity, cienaGlobalMacAddress, cienaCesModuleChassisNotifIndx,
						# cienaCesModuleShelfNotifIndx, cienaCesModuleSlotNotifIndx,
						# cienaCesModuleSensorNotifIndx, cienaCesModuleSensorDescription,
						# cienaCesModuleSensorCurrentTemp, cienaCesModuleSensorLowTemp,
						# and cienaCesModuleSensorHighTemp.
						$cienaGlobalSeveritylook = "cienaGlobalSeverity." + $1
						$cienaGlobalSeverity = lookup($cienaGlobalSeveritylook,CienaVarbindValTable)
						if(match($cienaGlobalSeverity,"UNKNOWN")) {
							$cienaGlobalSeverity = $1
						} else {
							$cienaGlobalSeverity = $cienaGlobalSeverity + " ( " + $1 + " )"
						}
						$cienaGlobalMacAddress = $2
						$cienaCesModuleChassisNotifIndx = $3
						$cienaCesModuleShelfNotifIndx = $4
						$cienaCesModuleSlotNotifIndx = $5
						$cienaCesModuleSensorNotifIndx = $6
						$cienaCesModuleSensorDescription = $7
						$cienaCesModuleSensorCurrentTemp = $8
						$cienaCesModuleSensorLowTemp = $9
						$cienaCesModuleSensorHighTemp = $10
						@AlertGroup = "Ciena OME Traps"
						@Agent = "ciena.m2r.include.rules"
						@Summary = "cienaCesModuleSensorNormalTempNotification: Module in slot: " + $cienaCesModuleSlotNotifIndx + " restored to normal temperature"
						@Severity = 3
						@Type = 1
						@Identifier = @Node + @Summary
						details($*)

					case "10": ### - cienaCesModuleHASwitchOverNotification
						# SNMPv2
						# This notification is sent for CTM switchover.
						# To enable the device to send this notification:
						# - cienaCesModuleAllModulesTrapState needs to be set to enabled.
						# - cienaCesModuleHATrapState needs to be set to enabled.
						# The above values are set to enabled by default. Variable bindings include:
						# cienaGlobalSeverity, cienaGlobalMacAddress, cienaCesModuleChassisNotifIndx,
						# cienaCesModuleShelfNotifIndx, cienaCesModuleSlotNotifIndx,
						# cienaCesModuleSwitchOverReason, cienaCesModuleAdminState,
						# and cienaCesModuleOperState.
						$cienaGlobalSeveritylook = "cienaGlobalSeverity." + $1
						$cienaGlobalSeverity = lookup($cienaGlobalSeveritylook,CienaVarbindValTable)
						if(match($cienaGlobalSeverity,"UNKNOWN")) {
							$cienaGlobalSeverity = $1
						} else {
							$cienaGlobalSeverity = $cienaGlobalSeverity + " ( " + $1 + " )"
						}
						$cienaGlobalMacAddress = $2
						$cienaCesModuleChassisNotifIndx = $3
						$cienaCesModuleShelfNotifIndx = $4
						$cienaCesModuleSlotNotifIndx = $5
						$cienaCesModuleSwitchOverReasonlook = "cienaCesModuleSwitchOverReason." + $6
						$cienaCesModuleSwitchOverReason = lookup($cienaCesModuleSwitchOverReasonlook,CienaVarbindValTable)
						if(match($cienaCesModuleSwitchOverReason,"UNKNOWN")) {
							$cienaCesModuleSwitchOverReason = $6
						} else {
							$cienaCesModuleSwitchOverReason = $cienaCesModuleSwitchOverReason + " ( " + $6 + " )"
						}
						$cienaCesModuleAdminStatelook = "cienaCesModuleAdminState." + $7
						$cienaCesModuleAdminState = lookup($cienaCesModuleAdminStatelook,CienaVarbindValTable)
						if(match($cienaCesModuleAdminState,"UNKNOWN")) {
							$cienaCesModuleAdminState = $7
						} else {
							$cienaCesModuleAdminState = $cienaCesModuleAdminState + " ( " + $7 + " )"
						}
						$cienaCesModuleOperStatelook = "cienaCesModuleOperState." + $8
						$cienaCesModuleOperState = lookup($cienaCesModuleOperStatelook,CienaVarbindValTable)
						if(match($cienaCesModuleOperState,"UNKNOWN")) {
							$cienaCesModuleOperState = $8
						} else {
							$cienaCesModuleOperState = $cienaCesModuleOperState + " ( " + $8 + " )"
						}
						@AlertGroup = "Ciena OME Traps"
						@Agent = "ciena.m2r.include.rules"
						@Summary = "cienaCesModuleHASwitchOverNotification: Module in slot: " + $cienaCesModuleSlotNotifIndx + " has switched over because of: " + $cienaCesModuleSwitchOverReason
						@Severity = 4
						@Type = 1
						@Identifier = @Node + @Summary
						details($*)

					case "11": ### - cienaCesModuleProtectionModeColdNotification
						# SNMPv2
						# This notification is sent when the protection mode of the system changes to cold.
						# A COLD protection level is the lowest level of protection.  It implies that the secondary CTM is ready to assume the
						# function of the primary CTM but a failure causing a failover would be service impacting.  The secondary CTM has been
						# synchronized with the same software package, configuration files, etc such that it will return the same state
						# as the previous primary CTM.
						# The protection state of the primary CTM shall not transition from NONE to PROTECTED until the secondary CTM
						# has completed the synchronization.  In the case of a failure on the primary CTM, the secondary CTM will
						# immediately assume primary status, finish its initialization and reboot the PSLMs.  The primary CTM will
						# reapply the configuration to the PSLMs after they have booted. Any unsaved configuration changes will NOT be lost
						# on a failover as configuration changes are propagated to the secondary CTM configuration.
						# To enable the device to send this notification:
						# - cienaCesModuleAllModulesTrapState needs to be set to enabled.
						# - cienaCesModuleProtectionModeTrapState needs to be set to enabled.
						# The above values are set to enabled by default. Variable bindings include:
						# cienaGlobalSeverity, cienaGlobalMacAddress, and cienaCesModuleSystemProtectionMode.
						$cienaGlobalSeveritylook = "cienaGlobalSeverity." + $1
						$cienaGlobalSeverity = lookup($cienaGlobalSeveritylook,CienaVarbindValTable)
						if(match($cienaGlobalSeverity,"UNKNOWN")) {
							$cienaGlobalSeverity = $1
						} else {
							$cienaGlobalSeverity = $cienaGlobalSeverity + " ( " + $1 + " )"
						}
						$cienaGlobalMacAddress = $2
						$cienaCesModuleSystemProtectionModelook = "cienaCesModuleSystemProtectionMode." + $3
						$cienaCesModuleSystemProtectionMode = lookup($cienaCesModuleSystemProtectionModelook,CienaVarbindValTable)
						if(match($cienaCesModuleSystemProtectionMode,"UNKNOWN")) {
							$cienaCesModuleSystemProtectionMode = $3
						} else {
							$cienaCesModuleSystemProtectionMode = $cienaCesModuleSystemProtectionMode + " ( " + $3 + " )"
						}
						@AlertGroup = "Ciena OME Traps"
						@Agent = "ciena.m2r.include.rules"
						@Summary = "cienaCesModuleProtectionModeColdNotification: Module protection level changed to cold (service impacting failover supported)"
						@Severity = 4
						@Type = 1
						@Identifier = @Node + @Summary
						details($*)

					case "12": ### - cienaCesModuleProtectionModeWarmNotification
						# SNMPv2
						# This notification is sent when the protection mode of the system changes to warm.
						# This state is not supported on the 5410 platform.
						# To enable the device to send this notification:
						# - cienaCesModuleAllModulesTrapState needs to be set to enabled.
						# - cienaCesModuleProtectionModeTrapState needs to be set to enabled.
						# The above values are set to enabled by default. Variable bindings include:
						# cienaGlobalSeverity, cienaGlobalMacAddress, and cienaCesModuleSystemProtectionMode.
						$cienaGlobalSeveritylook = "cienaGlobalSeverity." + $1
						$cienaGlobalSeverity = lookup($cienaGlobalSeveritylook,CienaVarbindValTable)
						if(match($cienaGlobalSeverity,"UNKNOWN")) {
							$cienaGlobalSeverity = $1
						} else {
							$cienaGlobalSeverity = $cienaGlobalSeverity + " ( " + $1 + " )"
						}
						$cienaGlobalMacAddress = $2
						$cienaCesModuleSystemProtectionModelook = "cienaCesModuleSystemProtectionMode." + $3
						$cienaCesModuleSystemProtectionMode = lookup($cienaCesModuleSystemProtectionModelook,CienaVarbindValTable)
						if(match($cienaCesModuleSystemProtectionMode,"UNKNOWN")) {
							$cienaCesModuleSystemProtectionMode = $3
						} else {
							$cienaCesModuleSystemProtectionMode = $cienaCesModuleSystemProtectionMode + " ( " + $3 + " )"
						}
						@AlertGroup = "Ciena OME Traps"
						@Agent = "ciena.m2r.include.rules"
						@Summary = "cienaCesModuleProtectionModeWarmNotification: Module protection level changed to warm (partial failover supported)"
						@Severity = 3
						@Type = 1
						@Identifier = @Node + @Summary
						details($*)

					case "13": ### - cienaCesModuleProtectionModeUnprotectedNotification
						# SNMPv2
						# This notification is sent when the protection mode of the system changes to unprotected.
						# A protection level of unprotected implies that there is no secondary CTM present in the system or
						# that the current secondary CTM is not in a state to provide any protection.  In the case of the CTM failure,
						# the primary CTM will reboot and subsequently reboot all the PSLMs, causing loss of existing switched traffic patterns.
						# To enable the device to send this notification:
						# - cienaCesModuleAllModulesTrapState needs to be set to enabled.
						# - cienaCesModuleProtectionModeTrapState needs to be set to enabled.
						# The above values are set to enabled by default. Variable bindings include:
						# cienaGlobalSeverity, cienaGlobalMacAddress, and cienaCesModuleSystemProtectionMode.
						$cienaGlobalSeveritylook = "cienaGlobalSeverity." + $1
						$cienaGlobalSeverity = lookup($cienaGlobalSeveritylook,CienaVarbindValTable)
						if(match($cienaGlobalSeverity,"UNKNOWN")) {
							$cienaGlobalSeverity = $1
						} else {
							$cienaGlobalSeverity = $cienaGlobalSeverity + " ( " + $1 + " )"
						}
						$cienaGlobalMacAddress = $2
						$cienaCesModuleSystemProtectionModelook = "cienaCesModuleSystemProtectionMode." + $3
						$cienaCesModuleSystemProtectionMode = lookup($cienaCesModuleSystemProtectionModelook,CienaVarbindValTable)
						if(match($cienaCesModuleSystemProtectionMode,"UNKNOWN")) {
							$cienaCesModuleSystemProtectionMode = $3
						} else {
							$cienaCesModuleSystemProtectionMode = $cienaCesModuleSystemProtectionMode + " ( " + $3 + " )"
						}
						@AlertGroup = "Ciena OME Traps"
						@Agent = "ciena.m2r.include.rules"
						@Summary = "cienaCesModuleProtectionModeUnprotectedNotification: Module protection level changed to unprotected (No failover supported)"
						@Severity = 4
						@Type = 1
						@Identifier = @Node + @Summary
						details($*)

					case "14": ### - cienaCesModuleProtectionModeHotNotification
						# SNMPv2
						# This notification is sent when the protection mode of the system changes to hot.
						# A HOT protection level is the highest level of protection.  It implies that the secondary CTM is ready to assume the
						# function of the primary CTM and a failure causing a failover would NOT be service impacting.  The secondary CTM has been
						# synchronized with the same software package, configuration files, etc such that it will return the same state
						# as the previous primary CTM.
						# The protection state of the primary CTM shall not transition from NONE to PROTECTED until the secondary CTM
						# has completed the synchronization.  In the case of a failure on the primary CTM, the secondary CTM will
						# immediately assume primary status, finish its initialization and audit the PSLMs.  All current established traffic patterns
						# will be maintained with a minimal loss of traffic.  Any unsaved configuration changes will NOT be lost
						# on a failover as configuration changes are propagated to the secondary CTM configuration.
						# To enable the device to send this notification:
						# - cienaCesModuleAllModulesTrapState needs to be set to enabled.
						# - cienaCesModuleProtectionModeTrapState needs to be set to enabled.
						# The above values are set to enabled by default. Variable bindings include:
						# cienaGlobalSeverity, cienaGlobalMacAddress, and cienaCesModuleSystemProtectionMode.
						$cienaGlobalSeveritylook = "cienaGlobalSeverity." + $1
						$cienaGlobalSeverity = lookup($cienaGlobalSeveritylook,CienaVarbindValTable)
						if(match($cienaGlobalSeverity,"UNKNOWN")) {
							$cienaGlobalSeverity = $1
						} else {
							$cienaGlobalSeverity = $cienaGlobalSeverity + " ( " + $1 + " )"
						}
						$cienaGlobalMacAddress = $2
						$cienaCesModuleSystemProtectionModelook = "cienaCesModuleSystemProtectionMode." + $3
						$cienaCesModuleSystemProtectionMode = lookup($cienaCesModuleSystemProtectionModelook,CienaVarbindValTable)
						if(match($cienaCesModuleSystemProtectionMode,"UNKNOWN")) {
							$cienaCesModuleSystemProtectionMode = $3
						} else {
							$cienaCesModuleSystemProtectionMode = $cienaCesModuleSystemProtectionMode + " ( " + $3 + " )"
						}
						@AlertGroup = "Ciena OME Traps"
						@Agent = "ciena.m2r.include.rules"
						@Summary = "cienaCesModuleProtectionModeHotNotification: Module protection level changed to hot (Non service impacting failover supported)"
						@Severity = 3
						@Type = 1
						@Identifier = @Node + @Summary
						details($*)

					case "15": ### - cienaCesModulePostErrorNotification
						# SNMPv2
						# This notification is sent when a module POST error is detected.
						# To enable the device to send this notification:
						# - cienaCesModuleAllModulesTrapState needs to be set to enabled.
						# - cienaCesModulePOSTErrorTrapState needs to be set to enabled.
						# The above values are set to enabled by default. Variable bindings include:
						# cienaGlobalSeverity, cienaGlobalMacAddress, cienaCesModuleChassisNotifIndx,
						# cienaCesModuleShelfNotifIndx, cienaCesModuleSlotNotifIndx, and
						# cienaCesModulePOSTErrorDescription.
						$cienaGlobalSeveritylook = "cienaGlobalSeverity." + $1
						$cienaGlobalSeverity = lookup($cienaGlobalSeveritylook,CienaVarbindValTable)
						if(match($cienaGlobalSeverity,"UNKNOWN")) {
							$cienaGlobalSeverity = $1
						} else {
							$cienaGlobalSeverity = $cienaGlobalSeverity + " ( " + $1 + " )"
						}
						$cienaGlobalMacAddress = $2
						$cienaCesModuleChassisNotifIndx = $3
						$cienaCesModuleShelfNotifIndx = $4
						$cienaCesModuleSlotNotifIndx = $5
						$cienaCesModulePOSTErrorDescription = $6
						@AlertGroup = "Ciena OME Traps"
						@Agent = "ciena.m2r.include.rules"
						@Summary = "cienaCesModulePostErrorNotification: Module POST error detected"
						@Severity = 4
						@Type = 1
						@Identifier = @Node + @Summary
						details($*)

					case "16": ### - cienaCesModuleFastReloadUnsuccessfulNotification
						# SNMPv2
						# This notification is sent when the deprov (cold switchover or failover) fails.
						# To enable the device to send this notification:
						# - cienaCesModuleAllModulesTrapState needs to be set to enabled.
						# - cienaCesModuleHATrapState needs to be set to enabled.
						# The above values are set to enabled by default. Variable bindings include:
						# cienaGlobalSeverity, cienaGlobalMacAddress, cienaCesModuleChassisNotifIndx,
						# cienaCesModuleShelfNotifIndx, cienaCesModuleSlotNotifIndx,
						# cienaCesModuleAdminState, and cienaCesModuleOperState.
						$cienaGlobalSeveritylook = "cienaGlobalSeverity." + $1
						$cienaGlobalSeverity = lookup($cienaGlobalSeveritylook,CienaVarbindValTable)
						if(match($cienaGlobalSeverity,"UNKNOWN")) {
							$cienaGlobalSeverity = $1
						} else {
							$cienaGlobalSeverity = $cienaGlobalSeverity + " ( " + $1 + " )"
						}
						$cienaGlobalMacAddress = $2
						$cienaCesModuleChassisNotifIndx = $3
						$cienaCesModuleShelfNotifIndx = $4
						$cienaCesModuleSlotNotifIndx = $5
						$cienaCesModuleAdminStatelook = "cienaCesModuleAdminState." + $6
						$cienaCesModuleAdminState = lookup($cienaCesModuleAdminStatelook,CienaVarbindValTable)
						if(match($cienaCesModuleAdminState,"UNKNOWN")) {
							$cienaCesModuleAdminState = $6
						} else {
							$cienaCesModuleAdminState = $cienaCesModuleAdminState + " ( " + $6 + " )"
						}
						$cienaCesModuleOperStatelook = "cienaCesModuleOperState." + $7
						$cienaCesModuleOperState = lookup($cienaCesModuleOperStatelook,CienaVarbindValTable)
						if(match($cienaCesModuleOperState,"UNKNOWN")) {
							$cienaCesModuleOperState = $7
						} else {
							$cienaCesModuleOperState = $cienaCesModuleOperState + " ( " + $7 + " )"
						}
						@AlertGroup = "Ciena OME Traps"
						@Agent = "ciena.m2r.include.rules"
						@Summary = "cienaCesModuleFastReloadUnsuccessfulNotification: Module cold failover / switchover failed"
						@Severity = 3
						@Type = 1
						@Identifier = @Node + @Summary
						details($*)

					case "17": ### - cienaCesModuleHitlessModeUnsuccessfulNotification
						# SNMPv2
						# This notification is sent when the audit (hot failover or switchover) fails.
						# To enable the device to send this notification:
						# - cienaCesModuleAllModulesTrapState needs to be set to enabled.
						# - cienaCesModuleHATrapState needs to be set to enabled.
						# The above values are set to enabled by default. Variable bindings include:
						# cienaGlobalSeverity, cienaGlobalMacAddress, cienaCesModuleChassisNotifIndx,
						# cienaCesModuleShelfNotifIndx, cienaCesModuleSlotNotifIndx,
						# cienaCesModuleAdminState, and cienaCesModuleOperState.
						$cienaGlobalSeveritylook = "cienaGlobalSeverity." + $1
						$cienaGlobalSeverity = lookup($cienaGlobalSeveritylook,CienaVarbindValTable)
						if(match($cienaGlobalSeverity,"UNKNOWN")) {
							$cienaGlobalSeverity = $1
						} else {
							$cienaGlobalSeverity = $cienaGlobalSeverity + " ( " + $1 + " )"
						}
						$cienaGlobalMacAddress = $2
						$cienaCesModuleChassisNotifIndx = $3
						$cienaCesModuleShelfNotifIndx = $4
						$cienaCesModuleSlotNotifIndx = $5
						$cienaCesModuleAdminStatelook = "cienaCesModuleAdminState." + $6
						$cienaCesModuleAdminState = lookup($cienaCesModuleAdminStatelook,CienaVarbindValTable)
						if(match($cienaCesModuleAdminState,"UNKNOWN")) {
							$cienaCesModuleAdminState = $6
						} else {
							$cienaCesModuleAdminState = $cienaCesModuleAdminState + " ( " + $6 + " )"
						}
						$cienaCesModuleOperStatelook = "cienaCesModuleOperState." + $7
						$cienaCesModuleOperState = lookup($cienaCesModuleOperStatelook,CienaVarbindValTable)
						if(match($cienaCesModuleOperState,"UNKNOWN")) {
							$cienaCesModuleOperState = $7
						} else {
							$cienaCesModuleOperState = $cienaCesModuleOperState + " ( " + $7 + " )"
						}
						@AlertGroup = "Ciena OME Traps"
						@Agent = "ciena.m2r.include.rules"
						@Summary = "cienaCesModuleHitlessModeUnsuccessfulNotification: Module hot failover / switchover failed"
						@Severity = 3
						@Type = 1
						@Identifier = @Node + @Summary
						details($*)

					case "18": ### - cienaCesModuleSwitchFabricDisruptedUnrecoverableNotification
						# SNMPv2
						# This notification is sent when the switch fabric detects a game-over failure and the system
						# cannot automatically correct without resetting certain fabric subsystems. This kind of a
						# disruption can cause a major service interruption.
						# To enable the device to send this notification:
						# - cienaCesModuleAllModulesTrapState needs to be set to enabled
						# - cienaCesModuleSwitchFabricDisruptedTrapState needs to be set to enabled.
						# The above values are set to enabled by default. Variable bindings include: cienaGlobalSeverity,
						# cienaGlobalMacAddress, cienaCesModuleChassisNotifIndx, cienaCesModuleShelfNotifIndx,
						# and cienaCesModuleSlotNotifIndx.
						$cienaGlobalSeveritylook = "cienaGlobalSeverity." + $1
						$cienaGlobalSeverity = lookup($cienaGlobalSeveritylook,CienaVarbindValTable)
						if(match($cienaGlobalSeverity,"UNKNOWN")) {
							$cienaGlobalSeverity = $1
						} else {
							$cienaGlobalSeverity = $cienaGlobalSeverity + " ( " + $1 + " )"
						}
						$cienaGlobalMacAddress = $2
						$cienaCesModuleChassisNotifIndx = $3
						$cienaCesModuleShelfNotifIndx = $4
						$cienaCesModuleSlotNotifIndx = $5
						@AlertGroup = "Ciena OME Traps"
						@Agent = "ciena.m2r.include.rules"
						@Summary = "cienaCesModuleSwitchFabricDisruptedUnrecoverableNotification: Critical failure where system cannot auto correct without fabric subsystem reset. Major service interruption likely"
						@Severity = 5
						@Type = 1
						@Identifier = @Node + @Summary
						details($*)

					case "19": ### - cienaCesModuleSwitchFabricDisruptedRecoverableNotification
						# SNMPv2
						# This notification is sent when the switch fabric detects game-over failure and the system
						# can automatically correct it.
						# To enable the device to send this notification:
						# - cienaCesModuleAllModulesTrapState needs to be set to enabled
						# - cienaCesModuleSwitchFabricDisruptedTrapState needs to be set to enabled.
						# The above values are set to enabled by default. Variable bindings include: cienaGlobalSeverity,
						# cienaGlobalMacAddress, cienaCesModuleChassisNotifIndx, cienaCesModuleShelfNotifIndx,
						# and cienaCesModuleSlotNotifIndx.
						$cienaGlobalSeveritylook = "cienaGlobalSeverity." + $1
						$cienaGlobalSeverity = lookup($cienaGlobalSeveritylook,CienaVarbindValTable)
						if(match($cienaGlobalSeverity,"UNKNOWN")) {
							$cienaGlobalSeverity = $1
						} else {
							$cienaGlobalSeverity = $cienaGlobalSeverity + " ( " + $1 + " )"
						}
						$cienaGlobalMacAddress = $2
						$cienaCesModuleChassisNotifIndx = $3
						$cienaCesModuleShelfNotifIndx = $4
						$cienaCesModuleSlotNotifIndx = $5
						@AlertGroup = "Ciena OME Traps"
						@Agent = "ciena.m2r.include.rules"
						@Summary = "cienaCesModuleSwitchFabricDisruptedRecoverableNotification: Critical failure but system can auto correct "
						@Severity = 3
						@Type = 1
						@Identifier = @Node + @Summary
						details($*)

					case "20": ### - cienaCesModuleBladeInsertedNotification
						# SNMPv2
						# This notification is sent when a line module is inserted.
						# To enable the device to send this notification:
						# - cienaCesModuleAllModulesTrapState needs to be set to enabled.
						# - cienaCesModuleBladeInsertedTrapState needs to be set to enabled.
						# The above values are set to enabled by default. Variable bindings include:
						# cienaGlobalSeverity, cienaGlobalMacAddress, cienaCesModuleChassisNotifIndx,
						# cienaCesModuleShelfNotifIndx, cienaCesModuleSlotNotifIndx, and
						# cienaCesModuleModel.
						$cienaGlobalSeveritylook = "cienaGlobalSeverity." + $1
						$cienaGlobalSeverity = lookup($cienaGlobalSeveritylook,CienaVarbindValTable)
						if(match($cienaGlobalSeverity,"UNKNOWN")) {
							$cienaGlobalSeverity = $1
						} else {
							$cienaGlobalSeverity = $cienaGlobalSeverity + " ( " + $1 + " )"
						}
						$cienaGlobalMacAddress = $2
						$cienaCesModuleChassisNotifIndx = $3
						$cienaCesModuleShelfNotifIndx = $4
						$cienaCesModuleSlotNotifIndx = $5
						$cienaCesModuleModel = $6
						@AlertGroup = "Ciena OME Traps"
						@Agent = "ciena.m2r.include.rules"
						@Summary = "cienaCesModuleBladeInsertedNotification: Line module inserted"
						@Severity = 3
						@Type = 1
						@Identifier = @Node + @Summary
						details($*)

					case "21": ### - cienaCesModuleBladeRemovedNotification
						# SNMPv2
						# This notification is sent when a line module is removed.
						# To enable the device to send this notification:
						# - cienaCesModuleAllModulesTrapState needs to be set to enabled.
						# - cienaCesModuleBladeRemovedTrapState needs to be set to enabled.
						# The above values are set to enabled by default. Variable bindings include:
						# cienaGlobalSeverity, cienaGlobalMacAddress, cienaCesModuleChassisNotifIndx,
						# cienaCesModuleShelfNotifIndx, and cienaCesModuleSlotNotifIndx, and
						# cienaCesModuleModel.
						$cienaGlobalSeveritylook = "cienaGlobalSeverity." + $1
						$cienaGlobalSeverity = lookup($cienaGlobalSeveritylook,CienaVarbindValTable)
						if(match($cienaGlobalSeverity,"UNKNOWN")) {
							$cienaGlobalSeverity = $1
						} else {
							$cienaGlobalSeverity = $cienaGlobalSeverity + " ( " + $1 + " )"
						}
						$cienaGlobalMacAddress = $2
						$cienaCesModuleChassisNotifIndx = $3
						$cienaCesModuleShelfNotifIndx = $4
						$cienaCesModuleSlotNotifIndx = $5
						$cienaCesModuleModel = $6
						@AlertGroup = "Ciena OME Traps"
						@Agent = "ciena.m2r.include.rules"
						@Summary = "cienaCesModuleBladeRemovedNotification: line module removed"
						@Severity = 4
						@Type = 1
						@Identifier = @Node + @Summary
						details($*)

					case "22": ### - cienaCesModuleSwitchFabricDisruptedRecoverableClrNotification
						# SNMPv2
						# This notification is sent when the game-over failure is automatically corrected.
						# To enable the device to send this notification:
						# - cienaCesModuleAllModulesTrapState needs to be set to enabled
						# - cienaCesModuleSwitchFabricDisruptedTrapState needs to be set to enabled.
						# The above values are set to enabled by default. Variable bindings include: cienaGlobalSeverity,
						# cienaGlobalMacAddress, cienaCesModuleChassisNotifIndx, cienaCesModuleShelfNotifIndx,
						# and cienaCesModuleSlotNotifIndx.
						$cienaGlobalSeveritylook = "cienaGlobalSeverity." + $1
						$cienaGlobalSeverity = lookup($cienaGlobalSeveritylook,CienaVarbindValTable)
						if(match($cienaGlobalSeverity,"UNKNOWN")) {
							$cienaGlobalSeverity = $1
						} else {
							$cienaGlobalSeverity = $cienaGlobalSeverity + " ( " + $1 + " )"
						}
						$cienaGlobalMacAddress = $2
						$cienaCesModuleChassisNotifIndx = $3
						$cienaCesModuleShelfNotifIndx = $4
						$cienaCesModuleSlotNotifIndx = $5
						@AlertGroup = "Ciena OME Traps"
						@Agent = "ciena.m2r.include.rules"
						@Summary = "cienaCesModuleSwitchFabricDisruptedRecoverableClrNotification: Critical error corrected"
						@Severity = 3
						@Type = 1
						@Identifier = @Node + @Summary
						details($*)

					case "23": ### - cienaCesModuleConfigEntryCreatedNotification
						# SNMPv2
						# This notification is sent when a line module configuration entry is created.
						# To enable the device to send this notification:
						# - cienaCesModuleAllModulesTrapState needs to be set to enabled.
						# - cienaCesModuleConfigEntryCreatedTrapState needs to be set to enabled.
						# The above values are set to enabled by default. Variable bindings include:
						# cienaGlobalSeverity, cienaGlobalMacAddress, cienaCesModuleChassisNotifIndx,
						# cienaCesModuleShelfNotifIndx, and cienaCesModuleSlotNotifIndx, and
						# cienaCesModuleModel.
						$cienaGlobalSeveritylook = "cienaGlobalSeverity." + $1
						$cienaGlobalSeverity = lookup($cienaGlobalSeveritylook,CienaVarbindValTable)
						if(match($cienaGlobalSeverity,"UNKNOWN")) {
							$cienaGlobalSeverity = $1
						} else {
							$cienaGlobalSeverity = $cienaGlobalSeverity + " ( " + $1 + " )"
						}
						$cienaGlobalMacAddress = $2
						$cienaCesModuleChassisNotifIndx = $3
						$cienaCesModuleShelfNotifIndx = $4
						$cienaCesModuleSlotNotifIndx = $5
						$cienaCesModuleModel = $6
						@AlertGroup = "Ciena OME Traps"
						@Agent = "ciena.m2r.include.rules"
						@Summary = "cienaCesModuleConfigEntryCreatedNotification: line module config added"
						@Severity = 3
						@Type = 1
						@Identifier = @Node + @Summary
						details($*)

					case "24": ### - cienaCesModuleConfigEntryDeletedNotification
						# SNMPv2
						# This notification is sent when a line module configuration entry is deleted.
						# To enable the device to send this notification:
						# - cienaCesModuleAllModulesTrapState needs to be set to enabled.
						# - cienaCesModuleConfigEntryDeletedTrapState needs to be set to enabled.
						# The above values are set to enabled by default. Variable bindings include:
						# cienaGlobalSeverity, cienaGlobalMacAddress, cienaCesModuleChassisNotifIndx,
						# cienaCesModuleShelfNotifIndx, and cienaCesModuleSlotNotifIndx, and
						# cienaCesModuleModel.
						$cienaGlobalSeveritylook = "cienaGlobalSeverity." + $1
						$cienaGlobalSeverity = lookup($cienaGlobalSeveritylook,CienaVarbindValTable)
						if(match($cienaGlobalSeverity,"UNKNOWN")) {
							$cienaGlobalSeverity = $1
						} else {
							$cienaGlobalSeverity = $cienaGlobalSeverity + " ( " + $1 + " )"
						}
						$cienaGlobalMacAddress = $2
						$cienaCesModuleChassisNotifIndx = $3
						$cienaCesModuleShelfNotifIndx = $4
						$cienaCesModuleSlotNotifIndx = $5
						$cienaCesModuleModel = $6
						@AlertGroup = "Ciena OME Traps"
						@Agent = "ciena.m2r.include.rules"
						@Summary = "cienaCesModuleConfigEntryDeletedNotification: line module config removed"
						@Severity = 3
						@Type = 1
						@Identifier = @Node + @Summary
						details($*)

						case "25": ### - cienaCesClockRateMismatchNotification
					# SNMPv2
					# This notification is sent when it is discovered that clock rate is not same on all cards.
					# This kind of error may affect traffic on the whole system and is a critical interruption.
					# To enable the device to send this notification:
					# - cienaCesModuleAllModulesTrapState needs to be set to enabled
					# The above value is set to enabled by default. Variable bindings include: cienaGlobalSeverity,
					# cienaGlobalMacAddress, cienaCesModuleChassisNotifIndx, cienaCesModuleShelfNotifIndx,
					# and cienaCesModuleSlotNotifIndx.
					$cienaGlobalSeveritylook = "cienaGlobalSeverity." + $1
					$cienaGlobalSeverity = lookup($cienaGlobalSeveritylook,CienaVarbindValTable)
					if(match($cienaGlobalSeverity,"UNKNOWN")) {
						$cienaGlobalSeverity = $1
					} else {
						$cienaGlobalSeverity = $cienaGlobalSeverity + " ( " + $1 + " )"
					}
					$cienaGlobalMacAddress = $2
					$cienaCesModuleChassisNotifIndx = $3
					$cienaCesModuleShelfNotifIndx = $4
					$cienaCesModuleSlotNotifIndx = $5
					@AlertGroup = "Ciena OME Traps"
					@Agent = "ciena.m2r.include.rules"
					@Summary = "cienaCesClockRateMismatchNotification: Clock rate is not same on all cards"
					@Severity = 4
					@Type = 1
					@Identifier = @Node + @Summary
					details($cienaGlobalSeverity,$cienaGlobalMacAddress,$cienaCesModuleChassisNotifIndx,$cienaCesModuleShelfNotifIndx,$cienaCesModuleSlotNotifIndx)

					default:
						@Summary = "Unknown specific trap number (" + $specific-trap + ") received for enterprise " + $enterprise
						@Identifier = @Node + $enterprise + $generic-trap + $specific-trap + @Agent + @Manager
						@Severity = 3
						@Type = 1
						details($*)
				}

			######
			# cienaCesChassisMIBNotifications traps
			######
			case ".1.3.6.1.4.1.1271.2.2.4":	### - cienaCesChassisMIBNotificationPrefix
				switch($specific-trap) {
					case "1": ### - cienaCesChassisPowerSupplyFaultedNotification
						# SNMPv2
						# A cienaCesChassisPowerSupplyFaultedNotification is sent if a
						# power supply state changes to one of these:
						# - faulted (2)
						# - offline (3)
						# - unequipped(4)
						# To enable the device to send this trap:
						# -       cienaCesChassisAllPowerSupplyTrapState needs to be set to enabled
						# cienaCesChassisAllPowerSupplyTrapState is set to enabled by default.
						$cienaGlobalSeveritylook = "cienaGlobalSeverity." + $1
						$cienaGlobalSeverity = lookup($cienaGlobalSeveritylook,CienaVarbindValTable)
						if(match($cienaGlobalSeverity,"UNKNOWN")) {
							$cienaGlobalSeverity = $1
						} else {
							$cienaGlobalSeverity = $cienaGlobalSeverity + " ( " + $1 + " )"
						}
						$cienaCesChassisMacAddress = $2
						$cienaCesChassisPowerSupplyNotifIndx = $3
						$cienaCesChassisPowerSupplyStatelook = "cienaCesChassisPowerSupplyState." + $4
						$cienaCesChassisPowerSupplyState = lookup($cienaCesChassisPowerSupplyStatelook,CienaVarbindValTable)
						if(match($cienaCesChassisPowerSupplyState,"UNKNOWN")) {
							$cienaCesChassisPowerSupplyState = $4
						} else {
							$cienaCesChassisPowerSupplyState = $cienaCesChassisPowerSupplyState + " ( " + $4 + " )"
						}
						$cienaCesChassisPowerSupplyTypelook = "cienaCesChassisPowerSupplyType." + $5
						$cienaCesChassisPowerSupplyType = lookup($cienaCesChassisPowerSupplyTypelook,CienaVarbindValTable)
						if(match($cienaCesChassisPowerSupplyType,"UNKNOWN")) {
							$cienaCesChassisPowerSupplyType = $5
						} else {
							$cienaCesChassisPowerSupplyType = $cienaCesChassisPowerSupplyType + " ( " + $5 + " )"
						}
						@AlertGroup = "Ciena OME Traps"
						@Agent = "ciena.m2r.include.rules"
						@Summary = "cienaCesChassisPowerSupplyFaultedNotification: Power supply state changed to error state - " + $cienaCesChassisPowerSupplyState
						@Severity = 4
						@Type = 1
						@Identifier = @Node + @Summary
						details($*)

					case "2": ### - cienaCesChassisPowerSupplyOnlineNotification
						# SNMPv2
						# A cienaCesChassisPowerSupplyOnlineNotification is sent if a
						# power supply state changes to online(1).
						# To enable the device to send this trap:
						# -       cienaCesChassisAllPowerSupplyTrapState needs to be set to enabled
						# cienaCesChassisAllPowerSupplyTrapState is set to enabled by default.
						$cienaGlobalSeveritylook = "cienaGlobalSeverity." + $1
						$cienaGlobalSeverity = lookup($cienaGlobalSeveritylook,CienaVarbindValTable)
						if(match($cienaGlobalSeverity,"UNKNOWN")) {
							$cienaGlobalSeverity = $1
						} else {
							$cienaGlobalSeverity = $cienaGlobalSeverity + " ( " + $1 + " )"
						}
						$cienaCesChassisMacAddress = $2
						$cienaCesChassisPowerSupplyNotifIndx = $3
						$cienaCesChassisPowerSupplyStatelook = "cienaCesChassisPowerSupplyState." + $4
						$cienaCesChassisPowerSupplyState = lookup($cienaCesChassisPowerSupplyStatelook,CienaVarbindValTable)
						if(match($cienaCesChassisPowerSupplyState,"UNKNOWN")) {
							$cienaCesChassisPowerSupplyState = $4
						} else {
							$cienaCesChassisPowerSupplyState = $cienaCesChassisPowerSupplyState + " ( " + $4 + " )"
						}
						$cienaCesChassisPowerSupplyTypelook = "cienaCesChassisPowerSupplyType." + $5
						$cienaCesChassisPowerSupplyType = lookup($cienaCesChassisPowerSupplyTypelook,CienaVarbindValTable)
						if(match($cienaCesChassisPowerSupplyType,"UNKNOWN")) {
							$cienaCesChassisPowerSupplyType = $5
						} else {
							$cienaCesChassisPowerSupplyType = $cienaCesChassisPowerSupplyType + " ( " + $5 + " )"
						}
						@AlertGroup = "Ciena OME Traps"
						@Agent = "ciena.m2r.include.rules"
						@Summary = "cienaCesChassisPowerSupplyOnlineNotification: Power supply state changed to online"
						@Severity = 3
						@Type = 1
						@Identifier = @Node + @Summary
						details($*)

					case "3": ### - cienaCesChassisFanHiTempNotification
						# SNMPv2
						# A cienaCesChassisFanTempNotification is sent if the cienaCesChassisFanTemp is changed to high.
						# To enable the device to send this trap:
						# -       cienaCesChassisAllFanTempTrapState needs to be set to enabled
						# The above object is set to enabled by default.
						$cienaGlobalSeveritylook = "cienaGlobalSeverity." + $1
						$cienaGlobalSeverity = lookup($cienaGlobalSeveritylook,CienaVarbindValTable)
						if(match($cienaGlobalSeverity,"UNKNOWN")) {
							$cienaGlobalSeverity = $1
						} else {
							$cienaGlobalSeverity = $cienaGlobalSeverity + " ( " + $1 + " )"
						}
						$cienaCesChassisMacAddress = $2
						$cienaCesChassisFanTempTrayNotifIndx = $3
						$cienaCesChassisFanTempNotifId = $4
						$cienaCesChassisFanTemp = $5
						$cienaCesChassisFanTempHiThreshold = $6
						@AlertGroup = "Ciena OME Traps"
						@Agent = "ciena.m2r.include.rules"
						@Summary = "cienaCesChassisFanHiTempNotification: High Chassis fan temp detected. Temp: " + $cienaCesChassisFanTemp
						@Severity = 4
						@Type = 1
						@Identifier = @Node + @Summary
						details($*)

					case "4": ### - cienaCesChassisFanNormalTempNotification
						# SNMPv2
						# A cienaCesChassisFanTempNotification is sent if the cienaCesChassisFanTemp is changed to normal.
						# To enable the device to send this trap:
						# -       cienaCesChassisAllFanTempTrapState needs to be set to enabled
						# The above object is set to enabled by default.
						$cienaGlobalSeveritylook = "cienaGlobalSeverity." + $1
						$cienaGlobalSeverity = lookup($cienaGlobalSeveritylook,CienaVarbindValTable)
						if(match($cienaGlobalSeverity,"UNKNOWN")) {
							$cienaGlobalSeverity = $1
						} else {
							$cienaGlobalSeverity = $cienaGlobalSeverity + " ( " + $1 + " )"
						}
						$cienaCesChassisMacAddress = $2
						$cienaCesChassisFanTempTrayNotifIndx = $3
						$cienaCesChassisFanTempNotifId = $4
						$cienaCesChassisFanTemp = $5
						$cienaCesChassisFanTempLoThreshold = $6
						$cienaCesChassisFanTempHiThreshold = $7
						@AlertGroup = "Ciena OME Traps"
						@Agent = "ciena.m2r.include.rules"
