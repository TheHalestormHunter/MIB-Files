#####################################################################
# Ciena.m2r.include.rules
#####################################################################

			######
			# lldpNotificationPrefix traps
			######
			case ".1.2.0":	### - lldpNotifications
				switch($specific-trap) {
					case "1": ### - lldpRemTablesChange
						# SNMPv2
						# A lldpRemTablesChange notification is sent when the value
						# of lldpStatsRemTableLastChangeTime changes.  It can be
						# utilized by an NMS to trigger LLDP remote systems table
						# maintenance polls.
						#
						# Note that transmission of lldpRemTablesChange
						# notifications are throttled by the agent, as specified by the
						# 'lldpNotificationInterval' object.
						$lldpStatsRemTablesInserts = $1
						$lldpStatsRemTablesDeletes = $2
						$lldpStatsRemTablesDrops = $3
						$lldpStatsRemTablesAgeouts = $4
						@AlertGroup = "Ciena OME Traps"
						@Agent = "ciena.m2r.include.rules"
						@Summary = "lldpRemTablesChange"
						@Severity = 3
						@Type = 1
						@Identifier = @Node + @Summary
						details($*)

					default:
						@Summary = "Unknown specific trap number (" + $specific-trap + ") received for enterprise " + $enterprise
						@Identifier = @Node + $enterprise + $generic-trap + $specific-trap + @Agent + @Manager
						@Severity = 3
						@Type = 1
						details($*)
				}

			######
			# mplsLsrNotifications traps
			######
			case ".1.3.6.1.2.1.10.166.2":	### - mplsLsrStdMIB
				switch($specific-trap) {
					case "1": ### - mplsXCUp
						# SNMPv2
						# This notification is generated when the
						# mplsXCOperStatus object for one or more contiguous
						# entries in mplsXCTable are about to enter the up(1)
						# state from some other state. The included values of
						# mplsXCOperStatus MUST both be set equal to this
						# new state (i.e: up(1)).  The two instances of
						# mplsXCOperStatus in this notification indicate the range
						# of indexes that are affected.  Note that all the indexes
						# of the two ends of the range can be derived from the
						# instance identifiers of these two objects.  For
						# cases where a contiguous range of cross-connects
						# have transitioned into the up(1) state at roughly
						# the same time, the device SHOULD issue a single
						# notification for each range of contiguous indexes in
						# an effort to minimize the emission of a large number
						# of notifications.  If a notification has to be
						# issued for just a single cross-connect entry, then
						# the instance identifier (and values) of the two
						# mplsXCOperStatus objects MUST be the identical.
						$mplsXCOperStatuslook = "mplsXCOperStatus." + $1
						$mplsXCOperStatus = lookup($mplsXCOperStatuslook,CienaVarbindValTable)
						if(match($mplsXCOperStatus,"UNKNOWN")) {
							$mplsXCOperStatus = $1
						} else {
							$mplsXCOperStatus = $mplsXCOperStatus + " ( " + $1 + " )"
						}
						$mplsXCOperStatuslook = "mplsXCOperStatus." + $2
						$mplsXCOperStatus = lookup($mplsXCOperStatuslook,CienaVarbindValTable)
						if(match($mplsXCOperStatus,"UNKNOWN")) {
							$mplsXCOperStatus = $2
						} else {
							$mplsXCOperStatus = $mplsXCOperStatus + " ( " + $2 + " )"
						}
						@AlertGroup = "Ciena OME Traps"
						@Agent = "ciena.m2r.include.rules"
						@Summary = "mplsXCUp"
						@Severity = 3
						@Type = 1
						@Identifier = @Node + @Summary
						details($*)

					case "2": ### - mplsXCDown
						# SNMPv2
						# This notification is generated when the
						# mplsXCOperStatus object for one or more contiguous
						# entries in mplsXCTable are about to enter the
						# down(2) state from some other state. The included values
						#
						# of mplsXCOperStatus MUST both be set equal to this
						# down(2) state.  The two instances of mplsXCOperStatus
						# in this notification indicate the range of indexes
						# that are affected.  Note that all the indexes of the
						# two ends of the range can be derived from the
						# instance identifiers of these two objects.  For
						# cases where a contiguous range of cross-connects
						# have transitioned into the down(2) state at roughly
						# the same time, the device SHOULD issue a single
						# notification for each range of contiguous indexes in
						# an effort to minimize the emission of a large number
						# of notifications.  If a notification has to be
						# issued for just a single cross-connect entry, then
						# the instance identifier (and values) of the two
						# mplsXCOperStatus objects MUST be identical.
						$mplsXCOperStatuslook = "mplsXCOperStatus." + $1
						$mplsXCOperStatus = lookup($mplsXCOperStatuslook,CienaVarbindValTable)
						if(match($mplsXCOperStatus,"UNKNOWN")) {
							$mplsXCOperStatus = $1
						} else {
							$mplsXCOperStatus = $mplsXCOperStatus + " ( " + $1 + " )"
						}
						$mplsXCOperStatuslook = "mplsXCOperStatus." + $2
						$mplsXCOperStatus = lookup($mplsXCOperStatuslook,CienaVarbindValTable)
						if(match($mplsXCOperStatus,"UNKNOWN")) {
							$mplsXCOperStatus = $2
						} else {
							$mplsXCOperStatus = $mplsXCOperStatus + " ( " + $2 + " )"
						}
						@AlertGroup = "Ciena OME Traps"
						@Agent = "ciena.m2r.include.rules"
						@Summary = "mplsXCDown"
						@Severity = 4
						@Type = 1
						@Identifier = @Node + @Summary
						details($*)

					default:
						@Summary = "Unknown specific trap number (" + $specific-trap + ") received for enterprise " + $enterprise
						@Identifier = @Node + $enterprise + $generic-trap + $specific-trap + @Agent + @Manager
						@Severity = 3
						@Type = 1
						details($*)
				}

			######
			# mplsTeNotifications traps
			######
			case ".1.3.6.1.2.1.10.166.3":	### - mplsTeStdMIB
				switch($specific-trap) {
					case "1": ### - mplsTunnelUp
						# SNMPv2
						# This notification is generated when a
						# mplsTunnelOperStatus object for one of the
						# configured tunnels is about to leave the down state
						# and transition into some other state (but not into
						# the notPresent state).  This other state is
						# indicated by the included value of
						# mplsTunnelOperStatus.
						$mplsTunnelAdminStatuslook = "mplsTunnelAdminStatus." + $1
						$mplsTunnelAdminStatus = lookup($mplsTunnelAdminStatuslook,CienaVarbindValTable)
						if(match($mplsTunnelAdminStatus,"UNKNOWN")) {
							$mplsTunnelAdminStatus = $1
						} else {
							$mplsTunnelAdminStatus = $mplsTunnelAdminStatus + " ( " + $1 + " )"
						}
						$mplsTunnelOperStatuslook = "mplsTunnelOperStatus." + $2
						$mplsTunnelOperStatus = lookup($mplsTunnelOperStatuslook,CienaVarbindValTable)
						if(match($mplsTunnelOperStatus,"UNKNOWN")) {
							$mplsTunnelOperStatus = $2
						} else {
							$mplsTunnelOperStatus = $mplsTunnelOperStatus + " ( " + $2 + " )"
						}
						@AlertGroup = "Ciena OME Traps"
						@Agent = "ciena.m2r.include.rules"
						@Summary = "mplsTunnelUp"
						@Severity = 0
						@Type = 1
						@Identifier = @Node + @Summary
						details($*)

					case "2": ### - mplsTunnelDown
						# SNMPv2
						# This notification is generated when a
						# mplsTunnelOperStatus object for one of the
						# configured tunnels is about to enter the down state
						# from some other state (but not from the notPresent
						# state).  This other state is indicated by the
						# included value of mplsTunnelOperStatus.
						$mplsTunnelAdminStatuslook = "mplsTunnelAdminStatus." + $1
						$mplsTunnelAdminStatus = lookup($mplsTunnelAdminStatuslook,CienaVarbindValTable)
						if(match($mplsTunnelAdminStatus,"UNKNOWN")) {
							$mplsTunnelAdminStatus = $1
						} else {
							$mplsTunnelAdminStatus = $mplsTunnelAdminStatus + " ( " + $1 + " )"
						}
						$mplsTunnelOperStatuslook = "mplsTunnelOperStatus." + $2
						$mplsTunnelOperStatus = lookup($mplsTunnelOperStatuslook,CienaVarbindValTable)
						if(match($mplsTunnelOperStatus,"UNKNOWN")) {
							$mplsTunnelOperStatus = $2
						} else {
							$mplsTunnelOperStatus = $mplsTunnelOperStatus + " ( " + $2 + " )"
						}
						@AlertGroup = "Ciena OME Traps"
						@Agent = "ciena.m2r.include.rules"
						@Summary = "mplsTunnelDown"
						@Severity = 4
						@Type = 1
						@Identifier = @Node + @Summary
						details($*)

					case "3": ### - mplsTunnelRerouted
						# SNMPv2
						# This notification is generated when a tunnel is
						# rerouted. If the mplsTunnelARHopTable is used, then
						# this tunnel instance's entry in the
						# mplsTunnelARHopTable MAY contain the new path for
						# this tunnel some time after this trap is issued by
						# the agent.
						$mplsTunnelAdminStatuslook = "mplsTunnelAdminStatus." + $1
						$mplsTunnelAdminStatus = lookup($mplsTunnelAdminStatuslook,CienaVarbindValTable)
						if(match($mplsTunnelAdminStatus,"UNKNOWN")) {
							$mplsTunnelAdminStatus = $1
						} else {
							$mplsTunnelAdminStatus = $mplsTunnelAdminStatus + " ( " + $1 + " )"
						}
						$mplsTunnelOperStatuslook = "mplsTunnelOperStatus." + $2
						$mplsTunnelOperStatus = lookup($mplsTunnelOperStatuslook,CienaVarbindValTable)
						if(match($mplsTunnelOperStatus,"UNKNOWN")) {
							$mplsTunnelOperStatus = $2
						} else {
							$mplsTunnelOperStatus = $mplsTunnelOperStatus + " ( " + $2 + " )"
						}
						@AlertGroup = "Ciena OME Traps"
						@Agent = "ciena.m2r.include.rules"
						@Summary = "mplsTunnelRerouted"
						@Severity = 4
						@Type = 1
						@Identifier = @Node + @Summary
						details($*)

					case "4": ### - mplsTunnelReoptimized
						# SNMPv2
						# This notification is generated when a tunnel is
						# reoptimized. If the mplsTunnelARHopTable is used,
						# then this tunnel instance's entry in the
						# mplsTunnelARHopTable MAY contain the new path for
						# this tunnel some time after this trap is issued by
						# the agent.
						$mplsTunnelAdminStatuslook = "mplsTunnelAdminStatus." + $1
						$mplsTunnelAdminStatus = lookup($mplsTunnelAdminStatuslook,CienaVarbindValTable)
						if(match($mplsTunnelAdminStatus,"UNKNOWN")) {
							$mplsTunnelAdminStatus = $1
						} else {
							$mplsTunnelAdminStatus = $mplsTunnelAdminStatus + " ( " + $1 + " )"
						}
						$mplsTunnelOperStatuslook = "mplsTunnelOperStatus." + $2
						$mplsTunnelOperStatus = lookup($mplsTunnelOperStatuslook,CienaVarbindValTable)
						if(match($mplsTunnelOperStatus,"UNKNOWN")) {
							$mplsTunnelOperStatus = $2
						} else {
							$mplsTunnelOperStatus = $mplsTunnelOperStatus + " ( " + $2 + " )"
						}
						@AlertGroup = "Ciena OME Traps"
						@Agent = "ciena.m2r.include.rules"
						@Summary = "mplsTunnelReoptimized"
						@Severity = 4
						@Type = 1
						@Identifier = @Node + @Summary
						details($*)

					default:
						@Summary = "Unknown specific trap number (" + $specific-trap + ") received for enterprise " + $enterprise
						@Identifier = @Node + $enterprise + $generic-trap + $specific-trap + @Agent + @Manager
						@Severity = 3
						@Type = 1
						details($*)
				}

			######
			# mplsLdpNotifications traps
			######
			case ".1.3.6.1.2.1.10.166.4":	### - mplsLdpStdMIB
				switch($specific-trap) {
					case "1": ### - mplsLdpInitSessionThresholdExceeded
						# SNMPv2
						# This notification is generated when the value of
						# the 'mplsLdpEntityInitSessionThreshold' object
						# is not zero, and the number of Session
						# Initialization messages exceeds the value
						# of the 'mplsLdpEntityInitSessionThreshold' object.
						$mplsLdpEntityInitSessionThreshold = $1
						@AlertGroup = "Ciena OME Traps"
						@Agent = "ciena.m2r.include.rules"
						@Summary = "mplsLdpInitSessionThresholdExceeded"
						@Severity = 3
						@Type = 1
						@Identifier = @Node + @Summary
						details($*)

					case "2": ### - mplsLdpPathVectorLimitMismatch
						# SNMPv2
						# This notification is sent when the
						# 'mplsLdpEntityPathVectorLimit' does NOT match
						# the value of the 'mplsLdpPeerPathVectorLimit' for
						# a specific Entity.
						$mplsLdpEntityPathVectorLimit = $1
						$mplsLdpPeerPathVectorLimit = $2
						@AlertGroup = "Ciena OME Traps"
						@Agent = "ciena.m2r.include.rules"
						@Summary = "mplsLdpPathVectorLimitMismatch: 'mplsLdpEntityPathVectorLimit' does NOT match the value of the 'mplsLdpPeerPathVectorLimit' for a specific Entity."
						@Severity = 3
						@Type = 1
						@Identifier = @Node + @Summary
						details($*)

					case "3": ### - mplsLdpSessionUp
						# SNMPv2
						# If this notification is sent when the
						# value of 'mplsLdpSessionState' enters
						# the 'operational(5)' state.
						$mplsLdpSessionStatelook = "mplsLdpSessionState." + $1
						$mplsLdpSessionState = lookup($mplsLdpSessionStatelook,CienaVarbindValTable)
						if(match($mplsLdpSessionState,"UNKNOWN")) {
							$mplsLdpSessionState = $1
						} else {
							$mplsLdpSessionState = $mplsLdpSessionState + " ( " + $1 + " )"
						}
						$mplsLdpSessionDiscontinuityTime = $2
						$mplsLdpSessionStatsUnknownMesTypeErrors = $3
						$mplsLdpSessionStatsUnknownTlvErrors = $4
						@AlertGroup = "Ciena OME Traps"
						@Agent = "ciena.m2r.include.rules"
						@Summary = "mplsLdpSessionUp: MPLS session state enterered operational"
						@Severity = 3
						@Type = 1
						@Identifier = @Node + @Summary
						details($*)

					case "4": ### - mplsLdpSessionDown
						# SNMPv2
						# This notification is sent when the
						# value of 'mplsLdpSessionState' leaves
						# the 'operational(5)' state.
						$mplsLdpSessionStatelook = "mplsLdpSessionState." + $1
						$mplsLdpSessionState = lookup($mplsLdpSessionStatelook,CienaVarbindValTable)
						if(match($mplsLdpSessionState,"UNKNOWN")) {
							$mplsLdpSessionState = $1
						} else {
							$mplsLdpSessionState = $mplsLdpSessionState + " ( " + $1 + " )"
						}
						$mplsLdpSessionDiscontinuityTime = $2
						$mplsLdpSessionStatsUnknownMesTypeErrors = $3
						$mplsLdpSessionStatsUnknownTlvErrors = $4
						@AlertGroup = "Ciena OME Traps"
						@Agent = "ciena.m2r.include.rules"
						@Summary = "mplsLdpSessionDown: 'mplsLdpSessionState' no longer in 'operational(5)' state"
						@Severity = 4
						@Type = 1
						@Identifier = @Node + @Summary
						details($*)

					default:
						@Summary = "Unknown specific trap number (" + $specific-trap + ") received for enterprise " + $enterprise
						@Identifier = @Node + $enterprise + $generic-trap + $specific-trap + @Agent + @Manager
						@Severity = 3
						@Type = 1
						details($*)
				}

			######
			# pwNotifications traps
			######
			case ".1.3.6.1.2.1.10.246":	### - pwStdMIB
				switch($specific-trap) {
					case "1": ### - pwDown
						# SNMPv2
						# This notification is generated when the pwOperStatus
						# object for one or more contiguous entries in the pwTable are
						# about to enter the down(2) or lowerLayerDown(6) state from
						# any other state, except for transition from the
						# notPresent(5) state.  For the purpose of deciding when
						# these notifications occur, the lowerLayerDown(6) state
						# and the down(2) state are considered to be equivalent;
						# i.e., there is no notification on transition from
						# lowerLayerDown(6) into down(2), and there is a trap on
						# transition from any other state except down(2) (and
						# notPresent) into lowerLayerDown(6).
						#
						# The included values of pwOperStatus MUST each be equal to
						# down(2) or lowerLayerDown(6).  The two instances of
						# pwOperStatus in this notification indicate the range of
						# indexes that are affected.  Note that all the indexes of
						# the two ends of the range can be derived from the
						# instance identifiers of these two objects.  For cases
						# where a contiguous range of cross-connects have
						# transitioned into the down(2) and lowerLayerDown(6) states
						# at roughly the same time, the device SHOULD issue a single
						# notification for each range of contiguous indexes in an
						# effort to minimize the emission of a large number of
						# notifications.  If a notification has to be issued for
						# just a single cross-connect entry, then the instance
						# identifier (and values) of the two pwOperStatus objects
						# MUST be identical.
						$pwOperStatuslook = "pwOperStatus." + $1
						$pwOperStatus = lookup($pwOperStatuslook,CienaVarbindValTable)
						if(match($pwOperStatus,"UNKNOWN")) {
							$pwOperStatus = $1
						} else {
							$pwOperStatus = $pwOperStatus + " ( " + $1 + " )"
						}
						$pwOperStatuslook = "pwOperStatus." + $2
						$pwOperStatus = lookup($pwOperStatuslook,CienaVarbindValTable)
						if(match($pwOperStatus,"UNKNOWN")) {
							$pwOperStatus = $2
						} else {
							$pwOperStatus = $pwOperStatus + " ( " + $2 + " )"
						}
						@AlertGroup = "Ciena OME Traps"
						@Agent = "ciena.m2r.include.rules"
						@Summary = "pwDown: Pseudowire has entered down state"
						@Severity = 3
						@Type = 1
						@Identifier = @Node + @Summary
						details($*)

					case "2": ### - pwUp
						# SNMPv2
						# This notification is generated when the pwOperStatus
						# object for one or more contiguous entries in the pwTable are
						# about to enter the up(1) state from some other state
						# except the notPresent(5) state and given that the pwDown
						# notification been issued for these entries.  The included
						# values of pwOperStatus MUST both be set equal to this
						# new state (i.e., up(1)).  The two instances of pwOperStatus
						# in this notification indicate the range of indexes that
						# are affected.  Note that all the indexes of the two ends
						# of the range can be derived from the instance identifiers
						# of these two objects.  For cases where a contiguous range
						# of cross-connects have transitioned into the up(1) state
						# at roughly the same time, the device SHOULD issue a single
						# notification for each range of contiguous indexes in an
						# effort to minimize the emission of a large number of
						# notifications.  If a notification has to be issued for
						# just a single cross-connect entry, then the instance
						# identifier (and values) of the two pwOperStatus objects
						# MUST be identical.
						$pwOperStatuslook = "pwOperStatus." + $1
						$pwOperStatus = lookup($pwOperStatuslook,CienaVarbindValTable)
						if(match($pwOperStatus,"UNKNOWN")) {
							$pwOperStatus = $1
						} else {
							$pwOperStatus = $pwOperStatus + " ( " + $1 + " )"
						}
						$pwOperStatuslook = "pwOperStatus." + $2
						$pwOperStatus = lookup($pwOperStatuslook,CienaVarbindValTable)
						if(match($pwOperStatus,"UNKNOWN")) {
							$pwOperStatus = $2
						} else {
							$pwOperStatus = $pwOperStatus + " ( " + $2 + " )"
						}
						@AlertGroup = "Ciena OME Traps"
						@Agent = "ciena.m2r.include.rules"
						@Summary = "pwUp: Pseudowire has entered up state"
						@Severity = 3
						@Type = 1
						@Identifier = @Node + @Summary
						details($*)

					case "3": ### - pwDeleted
						# SNMPv2
						# This notification is generated when the PW has been
						# deleted, i.e., when the pwRowStatus has been set to
						# destroy(6) or the PW has been deleted by a non-MIB
						# application or due to an auto-discovery process.
						$pwTypelook = "pwType." + $1
						$pwType = lookup($pwTypelook,CienaVarbindValTable)
						if(match($pwType,"UNKNOWN")) {
							$pwType = $1
						} else {
							$pwType = $pwType + " ( " + $1 + " )"
						}
						$pwID = $2
						$pwPeerAddrTypelook = "pwPeerAddrType." + $3
						$pwPeerAddrType = lookup($pwPeerAddrTypelook,CienaVarbindValTable)
						if(match($pwPeerAddrType,"UNKNOWN")) {
							$pwPeerAddrType = $3
						} else {
							$pwPeerAddrType = $pwPeerAddrType + " ( " + $3 + " )"
						}
						$pwPeerAddr = $4
						@AlertGroup = "Ciena OME Traps"
						@Agent = "ciena.m2r.include.rules"
						@Summary = "pwDeleted: Pseudowire has been deleted"
						@Severity = 3
						@Type = 1
						@Identifier = @Node + @Summary
						details($*)

					default:
						@Summary = "Unknown specific trap number (" + $specific-trap + ") received for enterprise " + $enterprise
						@Identifier = @Node + $enterprise + $generic-trap + $specific-trap + @Agent + @Manager
						@Severity = 3
						@Type = 1
						details($*)
				}

			######
			# dot1dNotifications traps
			######
			case ".1.3.6.1.2.1.17":	### - dot1dBridge
				switch($specific-trap) {
					case "1": ### - newRoot
						# SNMPv2
						# The newRoot trap indicates that the sending agent has
						# become the new root of the Spanning Tree; the trap is
						# sent by a bridge soon after its election as the new
						# root, e.g., upon expiration of the Topology Change Timer,
						# immediately subsequent to its election.  Implementation
						# of this trap is optional.
						@AlertGroup = "Ciena OME Traps"
						@Agent = "ciena.m2r.include.rules"
						@Summary = "newRoot"
						@Severity = 3
						@Type = 1
						@Identifier = @Node + @Summary
					case "2": ### - topologyChange
						# SNMPv2
						# A topologyChange trap is sent by a bridge when any of
						# its configured ports transitions from the Learning state
						# to the Forwarding state, or from the Forwarding state to
						# the Blocking state.  The trap is not sent if a newRoot
						# trap is sent for the same transition.  Implementation of
						# this trap is optional.
						@AlertGroup = "Ciena OME Traps"
						@Agent = "ciena.m2r.include.rules"
						@Summary = "topologyChange: Sending agent has been promoted to Spanning Tree root"
						@Severity = 3
						@Type = 1
						@Identifier = @Node + @Summary
					default:
						@Summary = "Unknown specific trap number (" + $specific-trap + ") received for enterprise " + $enterprise
						@Identifier = @Node + $enterprise + $generic-trap + $specific-trap + @Agent + @Manager
						@Severity = 3
						@Type = 1
						details($*)
				}

			######
			# alarmNotifications traps
			######
			case ".1.3.6.1.2.1.118":	### - alarmMIB
				switch($specific-trap) {
					case "2": ### - alarmActiveState
						# SNMPv2
						# An instance of the alarm indicated by
						# alarmActiveModelPointer has been raised
						# against the entity indicated by
						# alarmActiveResourceId.
						#
						# The agent must throttle the generation of
						# consecutive alarmActiveState traps so that there is at
						# least a two-second gap between traps of this
						# type against the same alarmActiveModelPointer and
						# alarmActiveResourceId.  When traps are throttled,
						# they are dropped, not queued for sending at a future time.
						#
						# A management application should periodically check
						# the value of alarmActiveLastChanged to detect any
						# missed alarmActiveState notification-events, e.g.,
						# due to throttling or transmission loss.
						$alarmActiveModelPointer = $1
						$alarmActiveResourceId = $2
						@AlertGroup = "Ciena OME Traps"
						@Agent = "ciena.m2r.include.rules"
						@Summary = "alarmActiveState"
						@Severity = 4
						@Type = 1
						@Identifier = @Node + @Summary
						details($*)

					case "3": ### - alarmClearState
						# SNMPv2
						# An instance of the alarm indicated by
						# alarmActiveModelPointer has been cleared against
						#
						# the entity indicated by alarmActiveResourceId.
						#
						# The agent must throttle the generation of
						# consecutive alarmActiveClear traps so that there is at
						# least a two-second gap between traps of this
						# type against the same alarmActiveModelPointer and
						# alarmActiveResourceId.  When traps are throttled,
						# they are dropped, not queued for sending at a future time.
						#
						# A management application should periodically check
						# the value of alarmActiveLastChanged to detect any
						# missed alarmClearState notification-events, e.g.,
						# due to throttling or transmission loss.
						$alarmActiveModelPointer = $1
						$alarmActiveResourceId = $2
						@AlertGroup = "Ciena OME Traps"
						@Agent = "ciena.m2r.include.rules"
						@Summary = "alarmClearState"
						@Severity = 0
						@Type = 1
						@Identifier = @Node + @Summary
						details($*)

					default:
						@Summary = "Unknown specific trap number (" + $specific-trap + ") received for enterprise " + $enterprise
						@Identifier = @Node + $enterprise + $generic-trap + $specific-trap + @Agent + @Manager
						@Severity = 3
						@Type = 1
						details($*)
				}

			######
			# isisNotifications traps
			######
			case ".1.3.6.1.2.1.138":	### - isisMIB
				switch($specific-trap) {
					case "1": ### - isisDatabaseOverload
						# SNMPv2
						# This notification is generated when the system
						# enters or leaves the Overload state.  The number
						# of times this has been generated and cleared is kept
						# track of by isisSysStatLSPDbaseOloads.
						$isisNotificationSysLevelIndexlook = "isisNotificationSysLevelIndex." + $1
						$isisNotificationSysLevelIndex = lookup($isisNotificationSysLevelIndexlook,CienaVarbindValTable)
						if(match($isisNotificationSysLevelIndex,"UNKNOWN")) {
							$isisNotificationSysLevelIndex = $1
						} else {
							$isisNotificationSysLevelIndex = $isisNotificationSysLevelIndex + " ( " + $1 + " )"
						}
						$isisSysLevelStatelook = "isisSysLevelState." + $2
						$isisSysLevelState = lookup($isisSysLevelStatelook,CienaVarbindValTable)
						if(match($isisSysLevelState,"UNKNOWN")) {
							$isisSysLevelState = $2
						} else {
							$isisSysLevelState = $isisSysLevelState + " ( " + $2 + " )"
						}
						@AlertGroup = "Ciena OME Traps"
						@Agent = "ciena.m2r.include.rules"
						@Summary = "isisDatabaseOverload: System entered or left the Overload state"
						@Severity = 3
						@Type = 1
						@Identifier = @Node + @Summary
						details($*)

					case "2": ### - isisManualAddressDrops
						# SNMPv2
						# This notification is generated when one of the
						# manual areaAddresses assigned to this system is
						# ignored when computing routes.  The object
						# isisNotificationAreaAddress describes the area that
						# has been dropped.
						#
						# The number of times this event has been generated
						# is counted by isisSysStatManAddrDropFromAreas.
						#
						# The agent must throttle the generation of
						# consecutive isisManualAddressDrops notifications
						# so that there is at least a 5-second gap between
						# notifications of this type.  When notifications
						# are throttled, they are dropped, not queued for
						# sending at a future time.
						$isisNotificationAreaAddress = $1
						@AlertGroup = "Ciena OME Traps"
						@Agent = "ciena.m2r.include.rules"
						@Summary = "isisManualAddressDrops: One of the manual areaAddresses assigned was ignored when computing routes"
						@Severity = 3
						@Type = 1
						@Identifier = @Node + @Summary
						details($*)

					case "3": ### - isisCorruptedLSPDetected
						# SNMPv2
						# This notification is generated when we find that
						# an LSP that was stored in memory has become
						# corrupted.  The number of times this has been
						# generated is counted by isisSysCorrLSPs.
						#
						# We forward an LSP ID.  We may have independent
						# knowledge of the ID, but in some implementations
						# there is a chance that the ID itself will be
						# corrupted.
						$isisNotificationSysLevelIndexlook = "isisNotificationSysLevelIndex." + $1
						$isisNotificationSysLevelIndex = lookup($isisNotificationSysLevelIndexlook,CienaVarbindValTable)
						if(match($isisNotificationSysLevelIndex,"UNKNOWN")) {
							$isisNotificationSysLevelIndex = $1
						} else {
							$isisNotificationSysLevelIndex = $isisNotificationSysLevelIndex + " ( " + $1 + " )"
						}
						$isisPduLspId = $2
						@AlertGroup = "Ciena OME Traps"
						@Agent = "ciena.m2r.include.rules"
						@Summary = "isisCorruptedLSPDetected: LSP stored in memory is corrupted"
						@Severity = 3
						@Type = 1
						@Identifier = @Node + @Summary
						details($*)

					case "4": ### - isisAttemptToExceedMaxSequence
						# SNMPv2
						# When the sequence number on an LSP we generate
						# wraps the 32-bit sequence counter, we purge and
						# wait to re-announce this information.  This
						# notification describes that event.  Since these
						# should not be generated rapidly, we generate
						# an event each time this happens.
						#
						# While the first 6 bytes of the LSPID are ours,
						# the other two contain useful information.
						$isisNotificationSysLevelIndexlook = "isisNotificationSysLevelIndex." + $1
						$isisNotificationSysLevelIndex = lookup($isisNotificationSysLevelIndexlook,CienaVarbindValTable)
						if(match($isisNotificationSysLevelIndex,"UNKNOWN")) {
							$isisNotificationSysLevelIndex = $1
						} else {
							$isisNotificationSysLevelIndex = $isisNotificationSysLevelIndex + " ( " + $1 + " )"
						}
						$isisPduLspId = $2
						@AlertGroup = "Ciena OME Traps"
						@Agent = "ciena.m2r.include.rules"
						@Summary = "isisAttemptToExceedMaxSequence: Generated LSP wrapped 32 but counter and was purged"
						@Severity = 3
						@Type = 1
						@Identifier = @Node + @Summary
						details($*)

					case "5": ### - isisIDLenMismatch
						# SNMPv2
						# A notification sent when we receive a PDU
						# with a different value for the System ID Length.
						# This notification includes an index to identify
						# the circuit where we saw the PDU and the header of
						# the PDU, which may help a network manager identify
						# the source of the confusion.
						#
						# The agent must throttle the generation of
						# consecutive isisIDLenMismatch notifications
						# so that there is at least a 5-second gap between
						# notifications of this type.  When notifications
						# are throttled, they are dropped, not queued for
						# sending at a future time.
						$isisNotificationSysLevelIndexlook = "isisNotificationSysLevelIndex." + $1
						$isisNotificationSysLevelIndex = lookup($isisNotificationSysLevelIndexlook,CienaVarbindValTable)
						if(match($isisNotificationSysLevelIndex,"UNKNOWN")) {
							$isisNotificationSysLevelIndex = $1
						} else {
							$isisNotificationSysLevelIndex = $isisNotificationSysLevelIndex + " ( " + $1 + " )"
						}
						$isisPduFieldLen = $2
						$isisNotificationCircIfIndex = $3
						$isisPduFragment = $4
						@AlertGroup = "Ciena OME Traps"
						@Agent = "ciena.m2r.include.rules"
						@Summary = "isisIDLenMismatch: PDU with different System ID length recieved"
						@Severity = 3
						@Type = 1
						@Identifier = @Node + @Summary
						details($*)

					case "6": ### - isisMaxAreaAddressesMismatch
						# SNMPv2
						# A notification sent when we receive a PDU
						# with a different value for the Maximum Area
						# Addresses.  This notification includes the
						# header of the packet, which may help a
						# network manager identify the source of the
						# confusion.
						#
						# The agent must throttle the generation of
						# consecutive isisMaxAreaAddressesMismatch
						# notifications so that there is at least a 5-second
						# gap between notifications of this type.  When
						# notifications are throttled, they are dropped, not
						# queued for sending at a future time.
						$isisNotificationSysLevelIndexlook = "isisNotificationSysLevelIndex." + $1
						$isisNotificationSysLevelIndex = lookup($isisNotificationSysLevelIndexlook,CienaVarbindValTable)
						if(match($isisNotificationSysLevelIndex,"UNKNOWN")) {
							$isisNotificationSysLevelIndex = $1
						} else {
							$isisNotificationSysLevelIndex = $isisNotificationSysLevelIndex + " ( " + $1 + " )"
						}
						$isisPduMaxAreaAddress = $2
						$isisNotificationCircIfIndex = $3
						$isisPduFragment = $4
						@AlertGroup = "Ciena OME Traps"
						@Agent = "ciena.m2r.include.rules"
						@Summary = "isisMaxAreaAddressesMismatch: PDU with diffrent value for the maximum area address recieved"
						@Severity = 3
						@Type = 1
						@Identifier = @Node + @Summary
						details($*)

					case "7": ### - isisOwnLSPPurge
						# SNMPv2
						# A notification sent when we receive a PDU
						# with our systemID and zero age.  This
						# notification includes the circuit Index
						# and router ID from the LSP, if available,
						# which may help a network manager
						# identify the source of the confusion.
						$isisNotificationSysLevelIndexlook = "isisNotificationSysLevelIndex." + $1
						$isisNotificationSysLevelIndex = lookup($isisNotificationSysLevelIndexlook,CienaVarbindValTable)
						if(match($isisNotificationSysLevelIndex,"UNKNOWN")) {
							$isisNotificationSysLevelIndex = $1
						} else {
							$isisNotificationSysLevelIndex = $isisNotificationSysLevelIndex + " ( " + $1 + " )"
						}
						$isisNotificationCircIfIndex = $2
						$isisPduLspId = $3
						@AlertGroup = "Ciena OME Traps"
						@Agent = "ciena.m2r.include.rules"
						@Summary = "isisOwnLSPPurge: PDU recieved with our systemID and zero age"
						@Severity = 3
						@Type = 1
						@Identifier = @Node + @Summary
						details($*)

					case "8": ### - isisSequenceNumberSkip
						# SNMPv2
						# When we receive an LSP with our System ID
						# and different contents, we may need to reissue
						# the LSP with a higher sequence number.
						#
						# We send this notification if we need to increase
						# the sequence number by more than one.  If two
						# Intermediate Systems are configured with the same
						# System ID, this notification will fire.
						$isisNotificationSysLevelIndexlook = "isisNotificationSysLevelIndex." + $1
						$isisNotificationSysLevelIndex = lookup($isisNotificationSysLevelIndexlook,CienaVarbindValTable)
						if(match($isisNotificationSysLevelIndex,"UNKNOWN")) {
							$isisNotificationSysLevelIndex = $1
						} else {
							$isisNotificationSysLevelIndex = $isisNotificationSysLevelIndex + " ( " + $1 + " )"
						}
						$isisNotificationCircIfIndex = $2
						$isisPduLspId = $3
						@AlertGroup = "Ciena OME Traps"
						@Agent = "ciena.m2r.include.rules"
						@Summary = "isisSequenceNumberSkip: LSP recieved with our System ID and different contents"
						@Severity = 3
						@Type = 1
						@Identifier = @Node + @Summary
						details($*)

					case "9": ### - isisAuthenticationTypeFailure
						# SNMPv2
						# A notification sent when we receive a PDU
						# with the wrong authentication type field.
						# This notification includes the header of the
						# packet, which may help a network manager
						# identify the source of the confusion.
						#
						# The agent must throttle the generation of
						# consecutive isisAuthenticationTypeFailure
						# notifications so that there is at least a 5-second
						# gap between notifications of this type.  When
						# notifications are throttled, they are dropped, not
						# queued for sending at a future time.
						$isisNotificationSysLevelIndexlook = "isisNotificationSysLevelIndex." + $1
						$isisNotificationSysLevelIndex = lookup($isisNotificationSysLevelIndexlook,CienaVarbindValTable)
						if(match($isisNotificationSysLevelIndex,"UNKNOWN")) {
							$isisNotificationSysLevelIndex = $1
						} else {
							$isisNotificationSysLevelIndex = $isisNotificationSysLevelIndex + " ( " + $1 + " )"
						}
						$isisNotificationCircIfIndex = $2
						$isisPduFragment = $3
						@AlertGroup = "Ciena OME Traps"
						@Agent = "ciena.m2r.include.rules"
						@Summary = "isisAuthenticationTypeFailure: PDU recieved with the wrong auth type field"
						@Severity = 3
						@Type = 1
						@Identifier = @Node + @Summary
						details($*)

					case "10": ### - isisAuthenticationFailure
						# SNMPv2
						# A notification sent when we receive a PDU
						# with an incorrect authentication information
						# field.  This notification includes the header
						# of the packet, which may help a network manager
						# identify the source of the confusion.
						#
						# The agent must throttle the generation of
						# consecutive isisAuthenticationFailure
						# notifications so that there is at least a 5-second
						# gap between notifications of this type.  When
						# notifications are throttled, they are dropped, not
						# queued for sending at a future time.
						$isisNotificationSysLevelIndexlook = "isisNotificationSysLevelIndex." + $1
						$isisNotificationSysLevelIndex = lookup($isisNotificationSysLevelIndexlook,CienaVarbindValTable)
						if(match($isisNotificationSysLevelIndex,"UNKNOWN")) {
							$isisNotificationSysLevelIndex = $1
						} else {
							$isisNotificationSysLevelIndex = $isisNotificationSysLevelIndex + " ( " + $1 + " )"
						}
						$isisNotificationCircIfIndex = $2
						$isisPduFragment = $3
						@AlertGroup = "Ciena OME Traps"
						@Agent = "ciena.m2r.include.rules"
						@Summary = "isisAuthenticationFailure: PDU recieved with incorrect auth information"
						@Severity = 3
						@Type = 1
						@Identifier = @Node + @Summary
						details($*)

					case "11": ### - isisVersionSkew
						# SNMPv2
						# A notification sent when we receive a Hello
						# PDU from an IS running a different version
						# of the protocol.  This notification includes
						# the header of the packet, which may help a
						# network manager identify the source of the
						# confusion.
						#
						# The agent must throttle the generation of
						# consecutive isisVersionSkew notifications
						# so that there is at least a 5-second gap
						# between notifications of this type.  When
						# notifications are throttled, they are dropped, not
						# queued for sending at a future time.
						$isisNotificationSysLevelIndexlook = "isisNotificationSysLevelIndex." + $1
						$isisNotificationSysLevelIndex = lookup($isisNotificationSysLevelIndexlook,CienaVarbindValTable)
						if(match($isisNotificationSysLevelIndex,"UNKNOWN")) {
							$isisNotificationSysLevelIndex = $1
						} else {
							$isisNotificationSysLevelIndex = $isisNotificationSysLevelIndex + " ( " + $1 + " )"
						}
						$isisNotificationCircIfIndex = $2
						$isisPduProtocolVersion = $3
						$isisPduFragment = $4
						@AlertGroup = "Ciena OME Traps"
						@Agent = "ciena.m2r.include.rules"
						@Summary = "isisVersionSkew: Hello PDU recieved from an IS running diffrent protocol version"
						@Severity = 3
						@Type = 1
						@Identifier = @Node + @Summary
						details($*)

					case "12": ### - isisAreaMismatch
						# SNMPv2
						# A notification sent when we receive a Hello
						# PDU from an IS that does not share any
						# area address.  This notification includes
						# the header of the packet, which may help a
						# network manager identify the source of the
						# confusion.
						#
						# The agent must throttle the generation of
						# consecutive isisAreaMismatch notifications
						# so that there is at least a 5-second gap
						# between notifications of this type.  When
						# notifications are throttled, they are dropped, not
						# queued for sending at a future time.
						$isisNotificationCircIfIndex = $1
						$isisPduFragment = $2
						@AlertGroup = "Ciena OME Traps"
						@Agent = "ciena.m2r.include.rules"
						@Summary = "isisAreaMismatch: Hello PDU recieved from an IS that doesn't share area addresses"
						@Severity = 3
						@Type = 1
						@Identifier = @Node + @Summary
						details($*)

					case "13": ### - isisRejectedAdjacency
						# SNMPv2
						# A notification sent when we receive a Hello
						# PDU from an IS but do not establish an
						# adjacency for some reason.
						#
						# The agent must throttle the generation of
						# consecutive isisRejectedAdjacency notifications
						# so that there is at least a 5-second gap
						# between notifications of this type.  When
						# notifications are throttled, they are dropped, not
						# queued for sending at a future time.
						$isisNotificationSysLevelIndexlook = "isisNotificationSysLevelIndex." + $1
						$isisNotificationSysLevelIndex = lookup($isisNotificationSysLevelIndexlook,CienaVarbindValTable)
						if(match($isisNotificationSysLevelIndex,"UNKNOWN")) {
							$isisNotificationSysLevelIndex = $1
						} else {
							$isisNotificationSysLevelIndex = $isisNotificationSysLevelIndex + " ( " + $1 + " )"
						}
						$isisNotificationCircIfIndex = $2
						$isisPduFragment = $3
						@AlertGroup = "Ciena OME Traps"
						@Agent = "ciena.m2r.include.rules"
						@Summary = "isisRejectedAdjacency: Hello PDU recieved from an IS but adjacency failed to be established"
						@Severity = 3
						@Type = 1
						@Identifier = @Node + @Summary
						details($*)

					case "14": ### - isisLSPTooLargeToPropagate
						# SNMPv2
						# A notification sent when we attempt to propagate
						# an LSP that is larger than the dataLinkBlockSize
						# for the circuit.
						#
						# The agent must throttle the generation of
						# consecutive isisLSPTooLargeToPropagate notifications
						# so that there is at least a 5-second gap
						# between notifications of this type.  When
						# notifications are throttled, they are dropped, not
						#
						# queued for sending at a future time.
						$isisNotificationSysLevelIndexlook = "isisNotificationSysLevelIndex." + $1
						$isisNotificationSysLevelIndex = lookup($isisNotificationSysLevelIndexlook,CienaVarbindValTable)
						if(match($isisNotificationSysLevelIndex,"UNKNOWN")) {
							$isisNotificationSysLevelIndex = $1
						} else {
							$isisNotificationSysLevelIndex = $isisNotificationSysLevelIndex + " ( " + $1 + " )"
						}
						$isisNotificationCircIfIndex = $2
						$isisPduLspSize = $3
						$isisPduLspId = $4
						@AlertGroup = "Ciena OME Traps"
						@Agent = "ciena.m2r.include.rules"
						@Summary = "isisLSPTooLargeToPropagate: Attempted to propagate an LSP that is larger than the dataLinkBlockSize for the circuit"
						@Severity = 3
						@Type = 1
						@Identifier = @Node + @Summary
						details($*)

					case "15": ### - isisOrigLSPBuffSizeMismatch
						# SNMPv2
						# A notification sent when a Level 1 LSP or Level
						# 2 LSP is received that is larger than the local
						# value for isisSysLevelOrigLSPBuffSize, or when an
						# LSP is received that contains the supported Buffer Size
						# option and the value in the PDU option field does
						# not match the local value for isisSysLevelOrigLSPBuffSize.
						# We pass up the size from the option field and the
						# size of the LSP when one of them exceeds our configuration.
						#
						# The agent must throttle the generation of
						# consecutive isisOrigLSPBuffSizeMismatch notifications
						# so that there is at least a 5-second gap
						# between notifications of this type.  When
						# notifications are throttled, they are dropped, not
						# queued for sending at a future time.
						$isisNotificationSysLevelIndexlook = "isisNotificationSysLevelIndex." + $1
						$isisNotificationSysLevelIndex = lookup($isisNotificationSysLevelIndexlook,CienaVarbindValTable)
						if(match($isisNotificationSysLevelIndex,"UNKNOWN")) {
							$isisNotificationSysLevelIndex = $1
						} else {
							$isisNotificationSysLevelIndex = $isisNotificationSysLevelIndex + " ( " + $1 + " )"
						}
						$isisNotificationCircIfIndex = $2
						$isisPduLspId = $3
						$isisPduOriginatingBufferSize = $4
						$isisPduBufferSize = $5
						@AlertGroup = "Ciena OME Traps"
						@Agent = "ciena.m2r.include.rules"
						@Summary = "isisOrigLSPBuffSizeMismatch: Level 1 or 2 LSP recieved that is larger then the isisSysLevelOrigLSPBuffSize"
						@Severity = 3
						@Type = 1
						@Identifier = @Node + @Summary
						details($*)

					case "16": ### - isisProtocolsSupportedMismatch
						# SNMPv2
						# A notification sent when a non-pseudonode
						# segment 0 LSP is received that has no matching
						# protocols supported.  This may be because the system
						# does not generate the field, or because there are no
						# common elements.  The list of protocols supported
						# should be included in the notification: it may be
						#
						# empty if the TLV is not supported, or if the
						# TLV is empty.
						#
						# The agent must throttle the generation of
						# consecutive isisProtocolsSupportedMismatch
						# notifications so that there is at least a 5-second
						# gap between notifications of this type.  When
						# notifications are throttled, they are dropped, not
						# queued for sending at a future time.
						$isisNotificationSysLevelIndexlook = "isisNotificationSysLevelIndex." + $1
						$isisNotificationSysLevelIndex = lookup($isisNotificationSysLevelIndexlook,CienaVarbindValTable)
						if(match($isisNotificationSysLevelIndex,"UNKNOWN")) {
							$isisNotificationSysLevelIndex = $1
						} else {
							$isisNotificationSysLevelIndex = $isisNotificationSysLevelIndex + " ( " + $1 + " )"
						}
						$isisNotificationCircIfIndex = $2
						$isisPduProtocolsSupported = $3
						$isisPduLspId = $4
						$isisPduFragment = $5
						@AlertGroup = "Ciena OME Traps"
						@Agent = "ciena.m2r.include.rules"
						@Summary = "isisProtocolsSupportedMismatch: Non-pseudonode segment 0 LSP is received that has no matching protocols supported"
						@Severity = 3
						@Type = 1
						@Identifier = @Node + @Summary
						details($*)

					case "17": ### - isisAdjacencyChange
						# SNMPv2
						# A notification sent when an adjacency changes
						# state, entering or leaving state up.
						# The first 6 bytes of the isisPduLspId are the
						# SystemID of the adjacent IS.
						# The isisAdjState is the new state of the adjacency.
						$isisNotificationSysLevelIndexlook = "isisNotificationSysLevelIndex." + $1
						$isisNotificationSysLevelIndex = lookup($isisNotificationSysLevelIndexlook,CienaVarbindValTable)
						if(match($isisNotificationSysLevelIndex,"UNKNOWN")) {
							$isisNotificationSysLevelIndex = $1
						} else {
							$isisNotificationSysLevelIndex = $isisNotificationSysLevelIndex + " ( " + $1 + " )"
						}
						$isisNotificationCircIfIndex = $2
						$isisPduLspId = $3
						$isisAdjStatelook = "isisAdjState." + $4
						$isisAdjState = lookup($isisAdjStatelook,CienaVarbindValTable)
						if(match($isisAdjState,"UNKNOWN")) {
							$isisAdjState = $4
						} else {
							$isisAdjState = $isisAdjState + " ( " + $4 + " )"
						}
						@AlertGroup = "Ciena OME Traps"
						@Agent = "ciena.m2r.include.rules"
						@Summary = "isisAdjacencyChange: Adjacency state changed to " + $isisAdjState
						@Severity = 3
						@Type = 1
						@Identifier = @Node + @Summary
						details($*)

					case "18": ### - isisLSPErrorDetected
						# SNMPv2
						# This notification is generated when we receive
						# an LSP with a parse error.  The isisCircIfIndex
						# holds an index of the circuit on which the PDU
						# arrived.  The isisPduFragment holds the start of the
						# LSP, and the isisErrorOffset points to the problem.
						#
						# If the problem is a malformed TLV, isisErrorOffset
						# points to the start of the TLV, and isisErrorTLVType
						#
						# holds the value of the type.
						#
						# If the problem is with the LSP header, isisErrorOffset
						# points to the suspicious byte.
						#
						# The number of such LSPs is accumulated in
						# isisSysStatLSPErrors.
						$isisNotificationSysLevelIndexlook = "isisNotificationSysLevelIndex." + $1
						$isisNotificationSysLevelIndex = lookup($isisNotificationSysLevelIndexlook,CienaVarbindValTable)
						if(match($isisNotificationSysLevelIndex,"UNKNOWN")) {
							$isisNotificationSysLevelIndex = $1
						} else {
							$isisNotificationSysLevelIndex = $isisNotificationSysLevelIndex + " ( " + $1 + " )"
						}
						$isisPduLspId = $2
						$isisNotificationCircIfIndex = $3
						$isisPduFragment = $4
						$isisErrorOffset = $5
						$isisErrorTLVType = $6
						@AlertGroup = "Ciena OME Traps"
						@Agent = "ciena.m2r.include.rules"
						@Summary = "isisLSPErrorDetected: LSP with parse error recieved"
						@Severity = 3
						@Type = 1
						@Identifier = @Node + @Summary
						details($*)

					default:
						@Summary = "Unknown specific trap number (" + $specific-trap + ") received for enterprise " + $enterprise
						@Identifier = @Node + $enterprise + $generic-trap + $specific-trap + @Agent + @Manager
						@Severity = 3
						@Type = 1
						details($*)
				}

