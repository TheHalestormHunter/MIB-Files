			@Severity = 3
			@Type = 1
			@Identifier = @Node + @Summary
			details($cienaGlobalSeverity,$cienaGlobalMacAddress,$cienaCesPtpIfIndex)

		case "10": ### - cienaCesPtpDeletedNotification
			# SNMPv2
			# This notification is sent when a PTP is deleted.
			$cienaGlobalSeveritylook = "cienaGlobalSeverity." + $1
			$cienaGlobalSeverity = lookup($cienaGlobalSeveritylook,CienaVarbindValTable)
			if(match($cienaGlobalSeverity,"UNKNOWN")) {
				$cienaGlobalSeverity = $1
			} else {
				$cienaGlobalSeverity = $cienaGlobalSeverity + " ( " + $1 + " )"
			}
			$cienaGlobalMacAddress = $2
			$cienaCesPtpIfIndex = $3
			@AlertGroup = "Ciena OME Traps"
			@Agent = "ciena.m2r.include.rules"
			@Summary = "cienaCesPtpDeletedNotification: A PTP has been deleted."
			@Severity = 3
			@Type = 1
			@Identifier = @Node + @Summary
			details($cienaGlobalSeverity,$cienaGlobalMacAddress,$cienaCesPtpIfIndex)

		default:
			@Summary = "Unknown specific trap number (" + $specific-trap + ") received for enterprise " + $enterprise
			@Identifier = @Node + $enterprise + $generic-trap + $specific-trap + @Agent + @Manager
			@Severity = 3
			@Type = 1
			details($*)
	}

	######
	# cienaCesBenchmarkNotifications traps
	######
	case ".1.3.6.1.4.1.1271.2.2.39":	### - cienaCesBenchmarkNotifications
		switch($specific-trap) {
			case "1": ### - cienaCesBenchmarkTestStarted
				# SNMPv2
				# The start command has been issued for the given benchmark generator
				# test instance, either via CLI or SNMP. The cienaCesBenchmarkEntityEntryPortId
				# specifies the port under test when the test instance was started;
				# the s-vid, c-vid and destination mac address used to build the test
				# packet are also provided.
				$cienaGlobalSeveritylook = "cienaGlobalSeverity." + $1
				$cienaGlobalSeverity = lookup($cienaGlobalSeveritylook,CienaVarbindValTable)
				if(match($cienaGlobalSeverity,"UNKNOWN")) {
					$cienaGlobalSeverity = $1
				} else {
					$cienaGlobalSeverity = $cienaGlobalSeverity + " ( " + $1 + " )"
				}
				$cienaGlobalMacAddress = $2
				$cienaCesBenchmarkEntityEntryPortId = $3
				$cienaCesBenchmarkTestInstanceEntryId = $4
				$cienaCesBenchmarkTestInstanceEntryName = $5
				$cienaCesBenchmarkTestInstanceEntrySvid = $6
				$cienaCesBenchmarkTestInstanceEntryCvid = $7
				$cienaCesBenchmarkTestInstanceEntryDstMac = $8
				@AlertGroup = "Ciena OME Traps"
				@Agent = "ciena.m2r.include.rules"
				@Summary = "cienaCesBenchmarkTestStarted: Benchmark test: " + $cienaCesBenchmarkTestInstanceEntryName + " has been started via cli or snmp"
				@Severity = 3
				@Type = 1
				@Identifier = @Node + @Summary
				details($cienaGlobalSeverity,$cienaGlobalMacAddress,$cienaCesBenchmarkEntityEntryPortId,$cienaCesBenchmarkTestInstanceEntryId,$cienaCesBenchmarkTestInstanceEntryName,$cienaCesBenchmarkTestInstanceEntrySvid,$cienaCesBenchmarkTestInstanceEntryCvid,$cienaCesBenchmarkTestInstanceEntryDstMac)

			case "2": ### - cienaCesBenchmarkTestStopped
				# SNMPv2
				# The specified generator test instance has been manually stopped by
				# the user, either via CLI or SNMP, before the testing completed.
				$cienaGlobalSeveritylook = "cienaGlobalSeverity." + $1
				$cienaGlobalSeverity = lookup($cienaGlobalSeveritylook,CienaVarbindValTable)
				if(match($cienaGlobalSeverity,"UNKNOWN")) {
					$cienaGlobalSeverity = $1
				} else {
					$cienaGlobalSeverity = $cienaGlobalSeverity + " ( " + $1 + " )"
				}
				$cienaGlobalMacAddress = $2
				$cienaCesBenchmarkTestInstanceEntryId = $3
				$cienaCesBenchmarkTestInstanceEntryName = $4
				@AlertGroup = "Ciena OME Traps"
				@Agent = "ciena.m2r.include.rules"
				@Summary = "cienaCesBenchmarkTestStopped: Benchmark test: " + $cienaCesBenchmarkTestInstanceEntryName + " has been stopped via cli or snmp prior to completion"
				@Severity = 3
				@Type = 1
				@Identifier = @Node + @Summary
				details($cienaGlobalSeverity,$cienaGlobalMacAddress,$cienaCesBenchmarkTestInstanceEntryId,$cienaCesBenchmarkTestInstanceEntryName)

			case "3": ### - cienaCesBenchmarkTestCompleted
				# SNMPv2
				# The testing for the specified generator test instance has finished the
				# configured number of iterations as configured in the referenced
				# profile interval and duration.
				$cienaGlobalSeveritylook = "cienaGlobalSeverity." + $1
				$cienaGlobalSeverity = lookup($cienaGlobalSeveritylook,CienaVarbindValTable)
				if(match($cienaGlobalSeverity,"UNKNOWN")) {
					$cienaGlobalSeverity = $1
				} else {
					$cienaGlobalSeverity = $cienaGlobalSeverity + " ( " + $1 + " )"
				}
				$cienaGlobalMacAddress = $2
				$cienaCesBenchmarkTestInstanceEntryId = $3
				$cienaCesBenchmarkTestInstanceEntryName = $4
				@AlertGroup = "Ciena OME Traps"
				@Agent = "ciena.m2r.include.rules"
				@Summary = "cienaCesBenchmarkTestCompleted: Benchmark test: " + $cienaCesBenchmarkTestInstanceEntryName + " has completed"
				@Severity = 3
				@Type = 1
				@Identifier = @Node + @Summary
				details($cienaGlobalSeverity,$cienaGlobalMacAddress,$cienaCesBenchmarkTestInstanceEntryId,$cienaCesBenchmarkTestInstanceEntryName)

			case "4": ### - cienaCesBenchmarkTestFailedThroughputKpi
				# SNMPv2
				# The throughput test result for the specified generator test
				# instance is below the specified throughput KPI value for
				# the given PCP and color traffic.
				$cienaGlobalSeveritylook = "cienaGlobalSeverity." + $1
				$cienaGlobalSeverity = lookup($cienaGlobalSeveritylook,CienaVarbindValTable)
				if(match($cienaGlobalSeverity,"UNKNOWN")) {
					$cienaGlobalSeverity = $1
				} else {
					$cienaGlobalSeverity = $cienaGlobalSeverity + " ( " + $1 + " )"
				}
				$cienaGlobalMacAddress = $2
				$cienaCesBenchmarkTestInstanceEntryId = $3
				$cienaCesBenchmarkTestInstanceEntryName = $4
				$cienaCesBenchmarkKpiProfileId = $5
				$cienaCesBenchmarkKpiPcp = $6
				$cienaCesBenchmarkKpiColorlook = "cienaCesBenchmarkKpiColor." + $7
				$cienaCesBenchmarkKpiColor = lookup($cienaCesBenchmarkKpiColorlook,CienaVarbindValTable)
				if(match($cienaCesBenchmarkKpiColor,"UNKNOWN")) {
					$cienaCesBenchmarkKpiColor = $7
				} else {
					$cienaCesBenchmarkKpiColor = $cienaCesBenchmarkKpiColor + " ( " + $7 + " )"
				}
				$cienaCesBenchmarkGenTestSessionCurrentPktSize = $8
				$cienaCesBenchmarkEmixSequenceId = $9
				$cienaCesBenchmarkGenTestSessionThroughputResultsMax = $10
				@AlertGroup = "Ciena OME Traps"
				@Agent = "ciena.m2r.include.rules"
				@Summary = "cienaCesBenchmarkTestFailedThroughputKpi: Throughput test result for the " + $cienaCesBenchmarkTestInstanceEntryName + " test instance is below the specified throughput KPI value for the given PCP and color traffic"
				@Severity = 3
				@Type = 1
				@Identifier = @Node + @Summary
				details($cienaGlobalSeverity,$cienaGlobalMacAddress,$cienaCesBenchmarkTestInstanceEntryId,$cienaCesBenchmarkTestInstanceEntryName,$cienaCesBenchmarkKpiProfileId,$cienaCesBenchmarkKpiPcp,$cienaCesBenchmarkKpiColor,$cienaCesBenchmarkGenTestSessionCurrentPktSize,$cienaCesBenchmarkEmixSequenceId,$cienaCesBenchmarkGenTestSessionThroughputResultsMax)

			case "5": ### - cienaCesBenchmarkTestFailedFramelossKpi
				# SNMPv2
				# The frameloss test result for the specified generator test
				# instance exceeds the specified throughput KPI value for
				# the given PCP and color traffic.
				$cienaGlobalSeveritylook = "cienaGlobalSeverity." + $1
				$cienaGlobalSeverity = lookup($cienaGlobalSeveritylook,CienaVarbindValTable)
				if(match($cienaGlobalSeverity,"UNKNOWN")) {
					$cienaGlobalSeverity = $1
				} else {
					$cienaGlobalSeverity = $cienaGlobalSeverity + " ( " + $1 + " )"
				}
				$cienaGlobalMacAddress = $2
				$cienaCesBenchmarkTestInstanceEntryId = $3
				$cienaCesBenchmarkTestInstanceEntryName = $4
				$cienaCesBenchmarkKpiProfileId = $5
				$cienaCesBenchmarkKpiPcp = $6
				$cienaCesBenchmarkKpiColorlook = "cienaCesBenchmarkKpiColor." + $7
				$cienaCesBenchmarkKpiColor = lookup($cienaCesBenchmarkKpiColorlook,CienaVarbindValTable)
				if(match($cienaCesBenchmarkKpiColor,"UNKNOWN")) {
					$cienaCesBenchmarkKpiColor = $7
				} else {
					$cienaCesBenchmarkKpiColor = $cienaCesBenchmarkKpiColor + " ( " + $7 + " )"
				}
				$cienaCesBenchmarkGenTestSessionCurrentPktSize = $8
				$cienaCesBenchmarkEmixSequenceId = $9
				$cienaCesBenchmarkGenTestSessionFramelossResultsResult = $10
				@AlertGroup = "Ciena OME Traps"
				@Agent = "ciena.m2r.include.rules"
				@Summary = "cienaCesBenchmarkTestFailedFramelossKpi: Frameloss test result for the " + $cienaCesBenchmarkTestInstanceEntryName + " test instance exceeds the specified throughput KPI value for the given PCP and color traffic"
				@Severity = 3
				@Type = 1
				@Identifier = @Node + @Summary
				details($cienaGlobalSeverity,$cienaGlobalMacAddress,$cienaCesBenchmarkTestInstanceEntryId,$cienaCesBenchmarkTestInstanceEntryName,$cienaCesBenchmarkKpiProfileId,$cienaCesBenchmarkKpiPcp,$cienaCesBenchmarkKpiColor,$cienaCesBenchmarkGenTestSessionCurrentPktSize,$cienaCesBenchmarkEmixSequenceId,$cienaCesBenchmarkGenTestSessionFramelossResultsResult)

			case "6": ### - cienaCesBenchmarkTestFailedLatencyKpi
				# SNMPv2
				# The latency test result for the specified generator test
				# instance exceeds the specified throughput KPI value for
				# the given PCP and color traffic.
				$cienaGlobalSeveritylook = "cienaGlobalSeverity." + $1
				$cienaGlobalSeverity = lookup($cienaGlobalSeveritylook,CienaVarbindValTable)
				if(match($cienaGlobalSeverity,"UNKNOWN")) {
					$cienaGlobalSeverity = $1
				} else {
					$cienaGlobalSeverity = $cienaGlobalSeverity + " ( " + $1 + " )"
				}
				$cienaGlobalMacAddress = $2
				$cienaCesBenchmarkTestInstanceEntryId = $3
				$cienaCesBenchmarkTestInstanceEntryName = $4
				$cienaCesBenchmarkKpiProfileId = $5
				$cienaCesBenchmarkKpiPcp = $6
				$cienaCesBenchmarkKpiColorlook = "cienaCesBenchmarkKpiColor." + $7
				$cienaCesBenchmarkKpiColor = lookup($cienaCesBenchmarkKpiColorlook,CienaVarbindValTable)
				if(match($cienaCesBenchmarkKpiColor,"UNKNOWN")) {
					$cienaCesBenchmarkKpiColor = $7
				} else {
					$cienaCesBenchmarkKpiColor = $cienaCesBenchmarkKpiColor + " ( " + $7 + " )"
				}
				$cienaCesBenchmarkGenTestSessionCurrentPktSize = $8
				$cienaCesBenchmarkEmixSequenceId = $9
				$cienaCesBenchmarkGenTestSessionLatencyResultsMax = $10
				@AlertGroup = "Ciena OME Traps"
				@Agent = "ciena.m2r.include.rules"
				@Summary = "cienaCesBenchmarkTestFailedLatencyKpi: Latency test result for the " + $cienaCesBenchmarkTestInstanceEntryName + " test instance exceeds the specified throughput KPI value for the given PCP and color traffic"
				@Severity = 3
				@Type = 1
				@Identifier = @Node + @Summary
				details($cienaGlobalSeverity,$cienaGlobalMacAddress,$cienaCesBenchmarkTestInstanceEntryId,$cienaCesBenchmarkTestInstanceEntryName,$cienaCesBenchmarkKpiProfileId,$cienaCesBenchmarkKpiPcp,$cienaCesBenchmarkKpiColor,$cienaCesBenchmarkGenTestSessionCurrentPktSize,$cienaCesBenchmarkEmixSequenceId,$cienaCesBenchmarkGenTestSessionLatencyResultsMax)

			case "7": ### - cienaCesBenchmarkTestFailedPdvKpi
				# SNMPv2
				# The throughput test result for the specified generator test
				# instance is below the specified throughput KPI value for
				# the given PCP and color traffic.
				$cienaGlobalSeveritylook = "cienaGlobalSeverity." + $1
				$cienaGlobalSeverity = lookup($cienaGlobalSeveritylook,CienaVarbindValTable)
				if(match($cienaGlobalSeverity,"UNKNOWN")) {
					$cienaGlobalSeverity = $1
				} else {
					$cienaGlobalSeverity = $cienaGlobalSeverity + " ( " + $1 + " )"
				}
				$cienaGlobalMacAddress = $2
				$cienaCesBenchmarkTestInstanceEntryId = $3
				$cienaCesBenchmarkTestInstanceEntryName = $4
				$cienaCesBenchmarkKpiProfileId = $5
				$cienaCesBenchmarkKpiPcp = $6
				$cienaCesBenchmarkKpiColorlook = "cienaCesBenchmarkKpiColor." + $7
				$cienaCesBenchmarkKpiColor = lookup($cienaCesBenchmarkKpiColorlook,CienaVarbindValTable)
				if(match($cienaCesBenchmarkKpiColor,"UNKNOWN")) {
					$cienaCesBenchmarkKpiColor = $7
				} else {
					$cienaCesBenchmarkKpiColor = $cienaCesBenchmarkKpiColor + " ( " + $7 + " )"
				}
				$cienaCesBenchmarkGenTestSessionCurrentPktSize = $8
				$cienaCesBenchmarkEmixSequenceId = $9
				$cienaCesBenchmarkGenTestSessionPdvResultsAvg = $10
				@AlertGroup = "Ciena OME Traps"
				@Agent = "ciena.m2r.include.rules"
				@Summary = "cienaCesBenchmarkTestFailedPdvKpi: Throughput test result for the " + $cienaCesBenchmarkTestInstanceEntryName + " test instance is below the specified throughput KPI value for the given PCP and color traffic"
				@Severity = 3
				@Type = 1
				@Identifier = @Node + @Summary
				details($cienaGlobalSeverity,$cienaGlobalMacAddress,$cienaCesBenchmarkTestInstanceEntryId,$cienaCesBenchmarkTestInstanceEntryName,$cienaCesBenchmarkKpiProfileId,$cienaCesBenchmarkKpiPcp,$cienaCesBenchmarkKpiColor,$cienaCesBenchmarkGenTestSessionCurrentPktSize,$cienaCesBenchmarkEmixSequenceId,$cienaCesBenchmarkGenTestSessionPdvResultsAvg)

			case "8": ### - cienaCesBenchmarkTestIterationCompleted
				# SNMPv2
				# An iteration of tests for the given test instance has just completed.
				$cienaGlobalSeveritylook = "cienaGlobalSeverity." + $1
				$cienaGlobalSeverity = lookup($cienaGlobalSeveritylook,CienaVarbindValTable)
				if(match($cienaGlobalSeverity,"UNKNOWN")) {
					$cienaGlobalSeverity = $1
				} else {
					$cienaGlobalSeverity = $cienaGlobalSeverity + " ( " + $1 + " )"
				}
				$cienaGlobalMacAddress = $2
				$cienaCesBenchmarkTestInstanceEntryId = $3
				$cienaCesBenchmarkTestInstanceEntryName = $4
				$cienaCesBenchmarkGenTestSessionThroughputResultsIterations = $5
				@AlertGroup = "Ciena OME Traps"
				@Agent = "ciena.m2r.include.rules"
				@Summary = "cienaCesBenchmarkTestIterationCompleted: An iteration of tests for " + $cienaCesBenchmarkTestInstanceEntryName + " test instance has completed"
				@Severity = 3
				@Type = 1
				@Identifier = @Node + @Summary
				details($cienaGlobalSeverity,$cienaGlobalMacAddress,$cienaCesBenchmarkTestInstanceEntryId,$cienaCesBenchmarkTestInstanceEntryName,$cienaCesBenchmarkGenTestSessionThroughputResultsIterations)

			default:
				@Summary = "Unknown specific trap number (" + $specific-trap + ") received for enterprise " + $enterprise
				@Identifier = @Node + $enterprise + $generic-trap + $specific-trap + @Agent + @Manager
				@Severity = 3
				@Type = 1
				details($*)
		}

		######
		# cienaCesPmMIBNotifications traps
		######
		case ".1.3.6.1.4.1.1271.2.2.40":	### - cienaCesPmMIBNotificationPrefix
			switch($specific-trap) {
				case "1": ### - cienaCesPmAlertTcaNotification
					# SNMPv2
					# This notification is sent when the device reports an Alert
					# Threshold Crossing Alert (TCA) event.
					$cienaGlobalSeveritylook = "cienaGlobalSeverity." + $1
					$cienaGlobalSeverity = lookup($cienaGlobalSeveritylook,CienaVarbindValTable)
					if(match($cienaGlobalSeverity,"UNKNOWN")) {
						$cienaGlobalSeverity = $1
					} else {
						$cienaGlobalSeverity = $cienaGlobalSeverity + " ( " + $1 + " )"
					}
					$cienaGlobalMacAddress = $2
					$cienaCesPmInstanceName = $3
					$cienaCesPmInstanceInterfaceTypelook = "cienaCesPmInstanceInterfaceType." + $4
					$cienaCesPmInstanceInterfaceType = lookup($cienaCesPmInstanceInterfaceTypelook,CienaVarbindValTable)
					if(match($cienaCesPmInstanceInterfaceType,"UNKNOWN")) {
						$cienaCesPmInstanceInterfaceType = $4
					} else {
						$cienaCesPmInstanceInterfaceType = $cienaCesPmInstanceInterfaceType + " ( " + $4 + " )"
					}
					$cienaCesPmInstanceInterfaceName = $5
					$cienaCesPmAlertTcaLastTcaUnitslook = "cienaCesPmAlertTcaLastTcaUnits." + $6
					$cienaCesPmAlertTcaLastTcaUnits = lookup($cienaCesPmAlertTcaLastTcaUnitslook,CienaVarbindValTable)
					if(match($cienaCesPmAlertTcaLastTcaUnits,"UNKNOWN")) {
						$cienaCesPmAlertTcaLastTcaUnits = $6
					} else {
						$cienaCesPmAlertTcaLastTcaUnits = $cienaCesPmAlertTcaLastTcaUnits + " ( " + $6 + " )"
					}
					$cienaCesPmAlertTcaLastTcaBasisValue = $7
					$cienaCesPmAlertTcaLastTcaBoundaryValue = $8
					$cienaCesPmAlertTcaLastTcaWatermarkTypelook = "cienaCesPmAlertTcaLastTcaWatermarkType." + $9
					$cienaCesPmAlertTcaLastTcaWatermarkType = lookup($cienaCesPmAlertTcaLastTcaWatermarkTypelook,CienaVarbindValTable)
					if(match($cienaCesPmAlertTcaLastTcaWatermarkType,"UNKNOWN")) {
						$cienaCesPmAlertTcaLastTcaWatermarkType = $9
					} else {
						$cienaCesPmAlertTcaLastTcaWatermarkType = $cienaCesPmAlertTcaLastTcaWatermarkType + " ( " + $9 + " )"
					}
					$cienaCesPmAlertTcaLastTcaWatermarkStatslook = "cienaCesPmAlertTcaLastTcaWatermarkStats." + $10
					$cienaCesPmAlertTcaLastTcaWatermarkStats = lookup($cienaCesPmAlertTcaLastTcaWatermarkStatslook,CienaVarbindValTable)
					if(match($cienaCesPmAlertTcaLastTcaWatermarkStats,"UNKNOWN")) {
						$cienaCesPmAlertTcaLastTcaWatermarkStats = $10
					} else {
						$cienaCesPmAlertTcaLastTcaWatermarkStats = $cienaCesPmAlertTcaLastTcaWatermarkStats + " ( " + $10 + " )"
					}
					$cienaCesPmAlertTcaLastTcaWatermarkValue = $11
					$cienaCesPmAlertTcaLastTcaStatelook = "cienaCesPmAlertTcaLastTcaState." + $12
					$cienaCesPmAlertTcaLastTcaState = lookup($cienaCesPmAlertTcaLastTcaStatelook,CienaVarbindValTable)
					if(match($cienaCesPmAlertTcaLastTcaState,"UNKNOWN")) {
						$cienaCesPmAlertTcaLastTcaState = $12
					} else {
						$cienaCesPmAlertTcaLastTcaState = $cienaCesPmAlertTcaLastTcaState + " ( " + $12 + " )"
					}
					@AlertGroup = "Ciena OME Traps"
					@Agent = "ciena.m2r.include.rules"
					@Summary = "cienaCesPmAlertTcaNotification: Alert Threshold Crossing Alert (TCA) event detected for " + $cienaCesPmInstanceName
					@Severity = 3
					@Type = 1
					@Identifier = @Node + @Summary
					details($cienaGlobalSeverity,$cienaGlobalMacAddress,$cienaCesPmInstanceName,$cienaCesPmInstanceInterfaceType,$cienaCesPmInstanceInterfaceName,$cienaCesPmAlertTcaLastTcaUnits,$cienaCesPmAlertTcaLastTcaBasisValue,$cienaCesPmAlertTcaLastTcaBoundaryValue,$cienaCesPmAlertTcaLastTcaWatermarkType,$cienaCesPmAlertTcaLastTcaWatermarkStats,$cienaCesPmAlertTcaLastTcaWatermarkValue,$cienaCesPmAlertTcaLastTcaState)

				default:
					@Summary = "Unknown specific trap number (" + $specific-trap + ") received for enterprise " + $enterprise
					@Identifier = @Node + $enterprise + $generic-trap + $specific-trap + @Agent + @Manager
					@Severity = 3
					@Type = 1
					details($*)
			}

			######
			# cienaCesMcastFilterMIBNotification traps
			######
			case ".1.3.6.1.4.1.1271.2.2.100":	### - cienaCesMcastFilterMIBNotificationPrefix
				switch($specific-trap) {
					case "1": ### - cienaCesMcastAddrOverlapNotification
						# SNMPv2
						# A cienaCesMcastAddrOverlapNotification is sent whenever
						# several multicast IP addresses overlap (matches the
						# same L2 address).
						$cienaGlobalSeveritylook = "cienaGlobalSeverity." + $1
						$cienaGlobalSeverity = lookup($cienaGlobalSeveritylook,CienaVarbindValTable)
						if(match($cienaGlobalSeverity,"UNKNOWN")) {
							$cienaGlobalSeverity = $1
						} else {
							$cienaGlobalSeverity = $cienaGlobalSeverity + " ( " + $1 + " )"
						}
						$cienaGlobalMacAddress = $2
						@AlertGroup = "Ciena OME Traps"
						@Agent = "ciena.m2r.include.rules"
						@Summary = "cienaCesMcastAddrOverlapNotification: Several multicast IP addresses overlap (matches the same L2 address)."
						@Severity = 3
						@Type = 1
						@Identifier = @Node + @Summary
						details($cienaGlobalSeverity,$cienaGlobalMacAddress)

					default:
						@Summary = "Unknown specific trap number (" + $specific-trap + ") received for enterprise " + $enterprise
						@Identifier = @Node + $enterprise + $generic-trap + $specific-trap + @Agent + @Manager
						@Severity = 3
						@Type = 1
						details($*)
				}

				######
				# cienaCesTacacsClientMIBNotifications traps
				######
				case ".1.3.6.1.4.1.1271.2.3.2.2":	### - cienaCesTacacsClientMIBNotificationPrefix
					switch($specific-trap) {
						case "1": ### - cienaCesTacacsClientConnectionFailed
							# SNMPv2
							# A cienaCesTacacsClientConnectionFailed notification is sent if the
							# TACACS client is unable to contact the TACACS server.
							$cienaGlobalSeveritylook = "cienaGlobalSeverity." + $1
							$cienaGlobalSeverity = lookup($cienaGlobalSeveritylook,CienaVarbindValTable)
							if(match($cienaGlobalSeverity,"UNKNOWN")) {
								$cienaGlobalSeverity = $1
							} else {
								$cienaGlobalSeverity = $cienaGlobalSeverity + " ( " + $1 + " )"
							}
							$cienaGlobalMacAddress = $2
							$cienaCesTacacsClientServerResolvedInetAddrTypelook = "cienaCesTacacsClientServerResolvedInetAddrType." + $3
							$cienaCesTacacsClientServerResolvedInetAddrType = lookup($cienaCesTacacsClientServerResolvedInetAddrTypelook,CienaVarbindValTable)
							if(match($cienaCesTacacsClientServerResolvedInetAddrType,"UNKNOWN")) {
								$cienaCesTacacsClientServerResolvedInetAddrType = $3
							} else {
								$cienaCesTacacsClientServerResolvedInetAddrType = $cienaCesTacacsClientServerResolvedInetAddrType + " ( " + $3 + " )"
							}
							$cienaCesTacacsClientServerResolvedInetAddr = $4
							@AlertGroup = "Ciena OME Traps"
							@Agent = "ciena.m2r.include.rules"
							@Summary = "cienaCesTacacsClientConnectionFailed: Unable to contact the TACACS server"
							@Severity = 4
							@Type = 1
							@Identifier = @Node + @Summary
							details($cienaGlobalSeverity,$cienaGlobalMacAddress,$cienaCesTacacsClientServerResolvedInetAddrType,$cienaCesTacacsClientServerResolvedInetAddr)

						default:
							@Summary = "Unknown specific trap number (" + $specific-trap + ") received for enterprise " + $enterprise
							@Identifier = @Node + $enterprise + $generic-trap + $specific-trap + @Agent + @Manager
							@Severity = 3
							@Type = 1
							details($*)
					}
