						}
						$cienaCesDpTsMeterFloodContainerNotifAttachmentLiIndexlook = "cienaCesDpTsMeterFloodContainerNotifAttachmentLiIndex." + $5
						$cienaCesDpTsMeterFloodContainerNotifAttachmentLiIndex = lookup($cienaCesDpTsMeterFloodContainerNotifAttachmentLiIndexlook,CienaVarbindValTable)
						if(match($cienaCesDpTsMeterFloodContainerNotifAttachmentLiIndex,"UNKNOWN")) {
							$cienaCesDpTsMeterFloodContainerNotifAttachmentLiIndex = $5
						} else {
							$cienaCesDpTsMeterFloodContainerNotifAttachmentLiIndex = $cienaCesDpTsMeterFloodContainerNotifAttachmentLiIndex + " ( " + $5 + " )"
						}
						$cienaCesDpTsMeterFloodContainerProfileName = $6
						$cienaCesDpTsMeterFloodContainerAttachmentInterfaceName = $7
						@AlertGroup = "Ciena OME Traps"
						@Agent = "ciena.m2r.include.rules"
						@Summary = "cienaCesDpTsMeterFloodContainerBcastThresholdNormal: Number of broadcast packets for profile back within threshold"
						@Severity = 3
						@Type = 1
						@Identifier = @Node + @Summary
						details($*)

					case "5": ### - cienaCesDpTsMeterFloodContainerL2McastThresholdExceeded
						# SNMPv2
						# A cienaCesDpTsMeterFloodContainerL2McastThresholdExceeded is sent
						# when for a given container profile, the number of L2 multicast
						# packets received becomes greater than or equal to the
						# configured packet limit, and the value of L2 multicast packets
						# received at the last sampling interval is less than
						# the configured packet limit. To enable the device to send this
						# notification, cienaCesDataplaneMcastTrapState needs to be set to enabled.
						# The cienaCesDataplaneMcastTrapState is set to enabled by default. Variable
						# bindings include: cienaGlobalSeverity, cienaGlobalMacAddress,
						# cienaCesDpTsMeterFloodContainerNotifProfileIndex,
						# cienaCesDpTsMeterFloodContainerNotifAttachmentLiType,
						# cienaCesDpTsMeterFloodContainerNotifAttachmentLiIndex,
						# cienaCesDpTsMeterFloodContainerProfileName, and
						# cienaCesDpTsMeterFloodContainerAttachmentInterfaceName.

						$cienaGlobalSeveritylook = "cienaGlobalSeverity." + $1
						$cienaGlobalSeverity = lookup($cienaGlobalSeveritylook,CienaVarbindValTable)
						if(match($cienaGlobalSeverity,"UNKNOWN")) {
							$cienaGlobalSeverity = $1
						} else {
							$cienaGlobalSeverity = $cienaGlobalSeverity + " ( " + $1 + " )"
						}
						$cienaGlobalMacAddress = $2
						$cienaCesDpTsMeterFloodContainerNotifProfileIndexlook = "cienaCesDpTsMeterFloodContainerNotifProfileIndex." + $3
						$cienaCesDpTsMeterFloodContainerNotifProfileIndex = lookup($cienaCesDpTsMeterFloodContainerNotifProfileIndexlook,CienaVarbindValTable)
						if(match($cienaCesDpTsMeterFloodContainerNotifProfileIndex,"UNKNOWN")) {
							$cienaCesDpTsMeterFloodContainerNotifProfileIndex = $3
						} else {
							$cienaCesDpTsMeterFloodContainerNotifProfileIndex = $cienaCesDpTsMeterFloodContainerNotifProfileIndex + " ( " + $3 + " )"
						}
						$cienaCesDpTsMeterFloodContainerNotifAttachmentLiTypelook = "cienaCesDpTsMeterFloodContainerNotifAttachmentLiType." + $4
						$cienaCesDpTsMeterFloodContainerNotifAttachmentLiType = lookup($cienaCesDpTsMeterFloodContainerNotifAttachmentLiTypelook,CienaVarbindValTable)
						if(match($cienaCesDpTsMeterFloodContainerNotifAttachmentLiType,"UNKNOWN")) {
							$cienaCesDpTsMeterFloodContainerNotifAttachmentLiType = $4
						} else {
							$cienaCesDpTsMeterFloodContainerNotifAttachmentLiType = $cienaCesDpTsMeterFloodContainerNotifAttachmentLiType + " ( " + $4 + " )"
						}
						$cienaCesDpTsMeterFloodContainerNotifAttachmentLiIndexlook = "cienaCesDpTsMeterFloodContainerNotifAttachmentLiIndex." + $5
						$cienaCesDpTsMeterFloodContainerNotifAttachmentLiIndex = lookup($cienaCesDpTsMeterFloodContainerNotifAttachmentLiIndexlook,CienaVarbindValTable)
						if(match($cienaCesDpTsMeterFloodContainerNotifAttachmentLiIndex,"UNKNOWN")) {
							$cienaCesDpTsMeterFloodContainerNotifAttachmentLiIndex = $5
						} else {
							$cienaCesDpTsMeterFloodContainerNotifAttachmentLiIndex = $cienaCesDpTsMeterFloodContainerNotifAttachmentLiIndex + " ( " + $5 + " )"
						}
						$cienaCesDpTsMeterFloodContainerProfileName = $6
						$cienaCesDpTsMeterFloodContainerAttachmentInterfaceName = $7
						@AlertGroup = "Ciena OME Traps"
						@Agent = "ciena.m2r.include.rules"
						@Summary = "cienaCesDpTsMeterFloodContainerL2McastThresholdExceeded: Number of L2 multicast packets for profile exceeded threshold"
						@Severity = 3
						@Type = 1
						@Identifier = @Node + @Summary
						details($*)

					case "6": ### - cienaCesDpTsMeterFloodContainerL2McastThresholdNormal
						# SNMPv2
						# A cienaCesDpTsMeterFloodContainerL2McastThresholdNormal is sent
						# when for a given container profile, the total number of
						# L2 multicast packets received becomes less than the
						# configured packet limit, and the value of L2 multicast
						# packets received at the last sampling interval
						# is greater than or equal to the configured packet limit.
						# To enable the device to send this notification ,cienaCesDataplaneMcastTrapState
						# needs to be set to enabled. The cienaCesDataplaneMcastTrapState is set to
						# enabled by default. Variable bindings include: cienaGlobalSeverity,
						# cienaGlobalMacAddress, cienaCesDpTsMeterFloodContainerNotifProfileIndex,
						# cienaCesDpTsMeterFloodContainerNotifAttachmentLiType,
						# cienaCesDpTsMeterFloodContainerNotifAttachmentLiIndex,
						# cienaCesDpTsMeterFloodContainerProfileName, and
						# cienaCesDpTsMeterFloodContainerAttachmentInterfaceName.

						$cienaGlobalSeveritylook = "cienaGlobalSeverity." + $1
						$cienaGlobalSeverity = lookup($cienaGlobalSeveritylook,CienaVarbindValTable)
						if(match($cienaGlobalSeverity,"UNKNOWN")) {
							$cienaGlobalSeverity = $1
						} else {
							$cienaGlobalSeverity = $cienaGlobalSeverity + " ( " + $1 + " )"
						}
						$cienaGlobalMacAddress = $2
						$cienaCesDpTsMeterFloodContainerNotifProfileIndexlook = "cienaCesDpTsMeterFloodContainerNotifProfileIndex." + $3
						$cienaCesDpTsMeterFloodContainerNotifProfileIndex = lookup($cienaCesDpTsMeterFloodContainerNotifProfileIndexlook,CienaVarbindValTable)
						if(match($cienaCesDpTsMeterFloodContainerNotifProfileIndex,"UNKNOWN")) {
							$cienaCesDpTsMeterFloodContainerNotifProfileIndex = $3
						} else {
							$cienaCesDpTsMeterFloodContainerNotifProfileIndex = $cienaCesDpTsMeterFloodContainerNotifProfileIndex + " ( " + $3 + " )"
						}
						$cienaCesDpTsMeterFloodContainerNotifAttachmentLiTypelook = "cienaCesDpTsMeterFloodContainerNotifAttachmentLiType." + $4
						$cienaCesDpTsMeterFloodContainerNotifAttachmentLiType = lookup($cienaCesDpTsMeterFloodContainerNotifAttachmentLiTypelook,CienaVarbindValTable)
						if(match($cienaCesDpTsMeterFloodContainerNotifAttachmentLiType,"UNKNOWN")) {
							$cienaCesDpTsMeterFloodContainerNotifAttachmentLiType = $4
						} else {
							$cienaCesDpTsMeterFloodContainerNotifAttachmentLiType = $cienaCesDpTsMeterFloodContainerNotifAttachmentLiType + " ( " + $4 + " )"
						}
						$cienaCesDpTsMeterFloodContainerNotifAttachmentLiIndexlook = "cienaCesDpTsMeterFloodContainerNotifAttachmentLiIndex." + $5
						$cienaCesDpTsMeterFloodContainerNotifAttachmentLiIndex = lookup($cienaCesDpTsMeterFloodContainerNotifAttachmentLiIndexlook,CienaVarbindValTable)
						if(match($cienaCesDpTsMeterFloodContainerNotifAttachmentLiIndex,"UNKNOWN")) {
							$cienaCesDpTsMeterFloodContainerNotifAttachmentLiIndex = $5
						} else {
							$cienaCesDpTsMeterFloodContainerNotifAttachmentLiIndex = $cienaCesDpTsMeterFloodContainerNotifAttachmentLiIndex + " ( " + $5 + " )"
						}
						$cienaCesDpTsMeterFloodContainerProfileName = $6
						$cienaCesDpTsMeterFloodContainerAttachmentInterfaceName = $7
						@AlertGroup = "Ciena OME Traps"
						@Agent = "ciena.m2r.include.rules"
						@Summary = "cienaCesDpTsMeterFloodContainerL2McastThresholdNormal: Number of L2 multicast packets for profile back within threshold"
						@Severity = 3
						@Type = 1
						@Identifier = @Node + @Summary
						details($*)

					case "7": ### - cienaCesDataplaneEgressReflectorEnabled
						# SNMPv2
						# A cienaCesDataplaneEgressReflectorEnabled is sent
						# when the egress reflector feature is enabled for the
						# given sub-port.

						$cienaGlobalSeveritylook = "cienaGlobalSeverity." + $1
						$cienaGlobalSeverity = lookup($cienaGlobalSeveritylook,CienaVarbindValTable)
						if(match($cienaGlobalSeverity,"UNKNOWN")) {
							$cienaGlobalSeverity = $1
						} else {
							$cienaGlobalSeverity = $cienaGlobalSeverity + " ( " + $1 + " )"
						}
						$cienaGlobalMacAddress = $2
						$cienaCesDpSubPortName = $3
						$cienaCesDpSubPortLiIndexlook = "cienaCesDpSubPortLiIndex." + $4
						$cienaCesDpSubPortLiIndex = lookup($cienaCesDpSubPortLiIndexlook,CienaVarbindValTable)
						if(match($cienaCesDpSubPortLiIndex,"UNKNOWN")) {
							$cienaCesDpSubPortLiIndex = $4
						} else {
							$cienaCesDpSubPortLiIndex = $cienaCesDpSubPortLiIndex + " ( " + $4 + " )"
						}
						$cienaCesDpSubPortEgressReflectorMac = $5
						$cienaCesDpSubPortEgressGeneratorMac = $6
						@AlertGroup = "Ciena OME Traps"
						@Agent = "ciena.m2r.include.rules"
						@Summary = "cienaCesDataplaneEgressReflectorEnabled: Egress reflector feature is enabled for sub-port: " + $cienaCesDpSubPortName
						@Severity = 3
						@Type = 1
						@Identifier = @Node + @Summary
						details($*)

					case "8": ### - cienaCesDataplaneEgressReflectorDisabled
						# SNMPv2
						# A cienaCesDataplaneEgressReflectorDisabled is sent
						#
						#
						# when the egress reflector feature is disabled for the
						#
						#
						# given sub-port.
						$cienaGlobalSeveritylook = "cienaGlobalSeverity." + $1
						$cienaGlobalSeverity = lookup($cienaGlobalSeveritylook,CienaVarbindValTable)
						if(match($cienaGlobalSeverity,"UNKNOWN")) {
							$cienaGlobalSeverity = $1
						} else {
							$cienaGlobalSeverity = $cienaGlobalSeverity + " ( " + $1 + " )"
						}
						$cienaGlobalMacAddress = $2
						$cienaCesDpSubPortName = $3
						$cienaCesDpSubPortLiIndexlook = "cienaCesDpSubPortLiIndex." + $4
						$cienaCesDpSubPortLiIndex = lookup($cienaCesDpSubPortLiIndexlook,CienaVarbindValTable)
						if(match($cienaCesDpSubPortLiIndex,"UNKNOWN")) {
							$cienaCesDpSubPortLiIndex = $4
						} else {
							$cienaCesDpSubPortLiIndex = $cienaCesDpSubPortLiIndex + " ( " + $4 + " )"
						}
						@AlertGroup = "Ciena OME Traps"
						@Agent = "ciena.m2r.include.rules"
						@Summary = "cienaCesDataplaneEgressReflectorDisabled: Egress reflector feature is disabled for sub-port: " + $cienaCesDpSubPortName
						@Severity = 3
						@Type = 1
						@Identifier = @Node + @Summary
						details($*)

						case "9": ### - cienaCesDpPortShapingSubscriptionExceedsOperSpeed
						# SNMPv2
						# A cienaCesDpPortShapingSubscriptionExceedsOperSpeed is sent when
						# when ports operational speed becomes lesser than port scheduler
						# cir value. To enable the device to send this notification,
						# cienaCesDataplanePortShapingSubscriptionTrapState needs to be set to enabled. The
						# cienaCesDataplanePortShapingSubscriptionTrapState is set to enabled by default. Variable
						# bindings include: cienaGlobalSeverity, cienaGlobalMacAddress,
						# cienaCesPortPgIdMappingNotifChassisIndex, cienaCesPortPgIdMappingNotifShelfIndex,
						# cienaCesPortPgIdMappingNotifSlotIndex cienaCesPortPgIdMappingNotifPortNumber and
						# cienaCesLogicalPortConfigPortName
						$cienaGlobalSeveritylook = "cienaGlobalSeverity." + $1
						$cienaGlobalSeverity = lookup($cienaGlobalSeveritylook,CienaVarbindValTable)
						if(match($cienaGlobalSeverity,"UNKNOWN")) {
							$cienaGlobalSeverity = $1
						} else {
							$cienaGlobalSeverity = $cienaGlobalSeverity + " ( " + $1 + " )"
						}
						$cienaGlobalMacAddress = $2
						$cienaCesPortPgIdMappingNotifChassisIndex = $3
						$cienaCesPortPgIdMappingNotifShelfIndex = $4
						$cienaCesPortPgIdMappingNotifSlotIndex = $5
						$cienaCesPortPgIdMappingNotifPortNumber = $6
						$cienaCesLogicalPortConfigPortName = $7
						@AlertGroup = "Ciena OME Traps"
						@Agent = "ciena.m2r.include.rules"
						@Summary = "cienaCesDpPortShapingSubscriptionExceedsOperSpeed: Port: " + $cienaCesLogicalPortConfigPortName + " operational speed is below the port scheduler cir value"
						@Severity = 3
						@Type = 1
						@Identifier = @Node + @Summary
						details($cienaGlobalSeverity,$cienaGlobalMacAddress,$cienaCesPortPgIdMappingNotifChassisIndex,$cienaCesPortPgIdMappingNotifShelfIndex,$cienaCesPortPgIdMappingNotifSlotIndex,$cienaCesPortPgIdMappingNotifPortNumber,$cienaCesLogicalPortConfigPortName)

					case "10": ### - cienaCesDpPortShapingSubscriptionWithinOperSpeed
						# SNMPv2
						# A cienaCesDpPortShapingSubscriptionWithinOperSpeed is sent
						# when ports operational speed becomes equal or greater than port scheduler
						# cir value. To enable the device to send this notification,
						# cienaCesDataplanePortShapingSubscriptionTrapState needs to be set to enabled. The
						# cienaCesDataplanePortShapingSubscriptionTrapState is set to enabled by default. Variable
						# bindings include: cienaGlobalSeverity, cienaGlobalMacAddress,
						# cienaCesPortPgIdMappingNotifChassisIndex, cienaCesPortPgIdMappingNotifShelfIndex,
						# cienaCesPortPgIdMappingNotifSlotIndex cienaCesPortPgIdMappingNotifPortNumber and
						# cienaCesLogicalPortConfigPortName
						$cienaGlobalSeveritylook = "cienaGlobalSeverity." + $1
						$cienaGlobalSeverity = lookup($cienaGlobalSeveritylook,CienaVarbindValTable)
						if(match($cienaGlobalSeverity,"UNKNOWN")) {
							$cienaGlobalSeverity = $1
						} else {
							$cienaGlobalSeverity = $cienaGlobalSeverity + " ( " + $1 + " )"
						}
						$cienaGlobalMacAddress = $2
						$cienaCesPortPgIdMappingNotifChassisIndex = $3
						$cienaCesPortPgIdMappingNotifShelfIndex = $4
						$cienaCesPortPgIdMappingNotifSlotIndex = $5
						$cienaCesPortPgIdMappingNotifPortNumber = $6
						$cienaCesLogicalPortConfigPortName = $7
						@AlertGroup = "Ciena OME Traps"
						@Agent = "ciena.m2r.include.rules"
						@Summary = "cienaCesDpPortShapingSubscriptionWithinOperSpeed: Port: " + $cienaCesLogicalPortConfigPortName + " operational speed is equal or greater then the port scheduler cir value"
						@Severity = 3
						@Type = 1
						@Identifier = @Node + @Summary
						details($cienaGlobalSeverity,$cienaGlobalMacAddress,$cienaCesPortPgIdMappingNotifChassisIndex,$cienaCesPortPgIdMappingNotifShelfIndex,$cienaCesPortPgIdMappingNotifSlotIndex,$cienaCesPortPgIdMappingNotifPortNumber,$cienaCesLogicalPortConfigPortName)

					case "11": ### - cienaCesDpTsMeterFloodContainerTotalThresholdExceeded
						# SNMPv2
						# A cienaCesDpTsMeterFloodContainerTotalThresholdExceeded is sent
						# when for a given container profile, the total number of packets
						# received becomes greater than or equal to the aggregate of all
						# packet limits configured for the container profile, and the
						# value of received packets at the last sampling interval is less
						# than the aggregate of configured packet limits. To enable the
						# device to send this notification, cienaCesDataplaneXcastTrapState
						# needs to be set to enabled. The cienaCesDataplaneXcastTrapState
						# is set to enabled by default. Variable bindings include:
						# cienaGlobalSeverity, cienaGlobalMacAddress,
						# cienaCesDpTsMeterFloodContainerNotifProfileIndex,
						# cienaCesDpTsMeterFloodContainerNotifAttachmentLiType,
						# cienaCesDpTsMeterFloodContainerNotifAttachmentLiIndex,
						# cienaCesDpTsMeterFloodContainerProfileName, and
						# cienaCesDpTsMeterFloodContainerAttachmentInterfaceName.
						$cienaGlobalSeveritylook = "cienaGlobalSeverity." + $1
						$cienaGlobalSeverity = lookup($cienaGlobalSeveritylook,CienaVarbindValTable)
						if(match($cienaGlobalSeverity,"UNKNOWN")) {
							$cienaGlobalSeverity = $1
						} else {
							$cienaGlobalSeverity = $cienaGlobalSeverity + " ( " + $1 + " )"
						}
						$cienaGlobalMacAddress = $2
						$cienaCesDpTsMeterFloodContainerNotifProfileIndexlook = "cienaCesDpTsMeterFloodContainerNotifProfileIndex." + $3
						$cienaCesDpTsMeterFloodContainerNotifProfileIndex = lookup($cienaCesDpTsMeterFloodContainerNotifProfileIndexlook,CienaVarbindValTable)
						if(match($cienaCesDpTsMeterFloodContainerNotifProfileIndex,"UNKNOWN")) {
							$cienaCesDpTsMeterFloodContainerNotifProfileIndex = $3
						} else {
							$cienaCesDpTsMeterFloodContainerNotifProfileIndex = $cienaCesDpTsMeterFloodContainerNotifProfileIndex + " ( " + $3 + " )"
						}
						$cienaCesDpTsMeterFloodContainerNotifAttachmentLiTypelook = "cienaCesDpTsMeterFloodContainerNotifAttachmentLiType." + $4
						$cienaCesDpTsMeterFloodContainerNotifAttachmentLiType = lookup($cienaCesDpTsMeterFloodContainerNotifAttachmentLiTypelook,CienaVarbindValTable)
						if(match($cienaCesDpTsMeterFloodContainerNotifAttachmentLiType,"UNKNOWN")) {
							$cienaCesDpTsMeterFloodContainerNotifAttachmentLiType = $4
						} else {
							$cienaCesDpTsMeterFloodContainerNotifAttachmentLiType = $cienaCesDpTsMeterFloodContainerNotifAttachmentLiType + " ( " + $4 + " )"
						}
						$cienaCesDpTsMeterFloodContainerNotifAttachmentLiIndexlook = "cienaCesDpTsMeterFloodContainerNotifAttachmentLiIndex." + $5
						$cienaCesDpTsMeterFloodContainerNotifAttachmentLiIndex = lookup($cienaCesDpTsMeterFloodContainerNotifAttachmentLiIndexlook,CienaVarbindValTable)
						if(match($cienaCesDpTsMeterFloodContainerNotifAttachmentLiIndex,"UNKNOWN")) {
							$cienaCesDpTsMeterFloodContainerNotifAttachmentLiIndex = $5
						} else {
							$cienaCesDpTsMeterFloodContainerNotifAttachmentLiIndex = $cienaCesDpTsMeterFloodContainerNotifAttachmentLiIndex + " ( " + $5 + " )"
						}
						$cienaCesDpTsMeterFloodContainerProfileName = $6
						$cienaCesDpTsMeterFloodContainerAttachmentInterfaceName = $7
						@AlertGroup = "Ciena OME Traps"
						@Agent = "ciena.m2r.include.rules"
						@Summary = "cienaCesDpTsMeterFloodContainerTotalThresholdExceeded: Total number of packets is above threshold configured for the container profile"
						@Severity = 3
						@Type = 1
						@Identifier = @Node + @Summary
						details($cienaGlobalSeverity,$cienaGlobalMacAddress,$cienaCesDpTsMeterFloodContainerNotifProfileIndex,$cienaCesDpTsMeterFloodContainerNotifAttachmentLiType,$cienaCesDpTsMeterFloodContainerNotifAttachmentLiIndex,$cienaCesDpTsMeterFloodContainerProfileName,$cienaCesDpTsMeterFloodContainerAttachmentInterfaceName)

					case "12": ### - cienaCesDpTsMeterFloodContainerTotalThresholdNormal
						# SNMPv2
						# A cienaCesDpTsMeterFloodContainerTotalThresholdNormal is sent
						# when for a given container profile, the total number of packets
						# received becomes less than the aggregate of all packet limits
						# configured for the container profile, and the value of received
						# packets at the last sampling interval is greater than or equal
						# to the aggregate of configured packet limits. To enable the
						# device to send this notification ,cienaCesDataplaneXcastTrapState
						# needs to be set to enabled. The cienaCesDataplaneXcastTrapState
						# is set to enabled by default. Variable bindings include:
						# cienaGlobalSeverity, cienaGlobalMacAddress,
						# cienaCesDpTsMeterFloodContainerNotifProfileIndex,
						# cienaCesDpTsMeterFloodContainerNotifAttachmentLiType,
						# cienaCesDpTsMeterFloodContainerNotifAttachmentLiIndex,
						# cienaCesDpTsMeterFloodContainerProfileName, and
						# cienaCesDpTsMeterFloodContainerAttachmentInterfaceName.
						$cienaGlobalSeveritylook = "cienaGlobalSeverity." + $1
						$cienaGlobalSeverity = lookup($cienaGlobalSeveritylook,CienaVarbindValTable)
						if(match($cienaGlobalSeverity,"UNKNOWN")) {
							$cienaGlobalSeverity = $1
						} else {
							$cienaGlobalSeverity = $cienaGlobalSeverity + " ( " + $1 + " )"
						}
						$cienaGlobalMacAddress = $2
						$cienaCesDpTsMeterFloodContainerNotifProfileIndexlook = "cienaCesDpTsMeterFloodContainerNotifProfileIndex." + $3
						$cienaCesDpTsMeterFloodContainerNotifProfileIndex = lookup($cienaCesDpTsMeterFloodContainerNotifProfileIndexlook,CienaVarbindValTable)
						if(match($cienaCesDpTsMeterFloodContainerNotifProfileIndex,"UNKNOWN")) {
							$cienaCesDpTsMeterFloodContainerNotifProfileIndex = $3
						} else {
							$cienaCesDpTsMeterFloodContainerNotifProfileIndex = $cienaCesDpTsMeterFloodContainerNotifProfileIndex + " ( " + $3 + " )"
						}
						$cienaCesDpTsMeterFloodContainerNotifAttachmentLiTypelook = "cienaCesDpTsMeterFloodContainerNotifAttachmentLiType." + $4
						$cienaCesDpTsMeterFloodContainerNotifAttachmentLiType = lookup($cienaCesDpTsMeterFloodContainerNotifAttachmentLiTypelook,CienaVarbindValTable)
						if(match($cienaCesDpTsMeterFloodContainerNotifAttachmentLiType,"UNKNOWN")) {
							$cienaCesDpTsMeterFloodContainerNotifAttachmentLiType = $4
						} else {
							$cienaCesDpTsMeterFloodContainerNotifAttachmentLiType = $cienaCesDpTsMeterFloodContainerNotifAttachmentLiType + " ( " + $4 + " )"
						}
						$cienaCesDpTsMeterFloodContainerNotifAttachmentLiIndexlook = "cienaCesDpTsMeterFloodContainerNotifAttachmentLiIndex." + $5
						$cienaCesDpTsMeterFloodContainerNotifAttachmentLiIndex = lookup($cienaCesDpTsMeterFloodContainerNotifAttachmentLiIndexlook,CienaVarbindValTable)
						if(match($cienaCesDpTsMeterFloodContainerNotifAttachmentLiIndex,"UNKNOWN")) {
							$cienaCesDpTsMeterFloodContainerNotifAttachmentLiIndex = $5
						} else {
							$cienaCesDpTsMeterFloodContainerNotifAttachmentLiIndex = $cienaCesDpTsMeterFloodContainerNotifAttachmentLiIndex + " ( " + $5 + " )"
						}
						$cienaCesDpTsMeterFloodContainerProfileName = $6
						$cienaCesDpTsMeterFloodContainerAttachmentInterfaceName = $7
						@AlertGroup = "Ciena OME Traps"
						@Agent = "ciena.m2r.include.rules"
						@Summary = "cienaCesDpTsMeterFloodContainerTotalThresholdNormal: Total number of packets is back within threshold configured for the container profile"
						@Severity = 3
						@Type = 1
						@Identifier = @Node + @Summary
						details($cienaGlobalSeverity,$cienaGlobalMacAddress,$cienaCesDpTsMeterFloodContainerNotifProfileIndex,$cienaCesDpTsMeterFloodContainerNotifAttachmentLiType,$cienaCesDpTsMeterFloodContainerNotifAttachmentLiIndex,$cienaCesDpTsMeterFloodContainerProfileName,$cienaCesDpTsMeterFloodContainerAttachmentInterfaceName)

					default:
						@Summary = "Unknown specific trap number (" + $specific-trap + ") received for enterprise " + $enterprise
						@Identifier = @Node + $enterprise + $generic-trap + $specific-trap + @Agent + @Manager
						@Severity = 3
						@Type = 1
						details($*)
				}

			######
			# cienaCesIpInterfaceMIBNotifications traps
			######
			case ".1.3.6.1.4.1.1271.2.2.8":	### - cienaCesIpInterfaceMIBNotificationPrefix
				switch($specific-trap) {
					case "1": ### - cienaCesIpMgmtInterfaceAddrChgNotification
						# SNMPv2
						# A cienaCesIpMgmtInterfaceAddrChgNotification is sent when the
						# IP address of an interface changes. To enable the device to send
						# this notification, cienaCesIPMgmtInterfaceAddrChangeTrapState
						# needs to be set to enabled. The cienaCesIPMgmtInterfaceAddrChangeTrapState
						# is set to enabled by default. Variable bindings include: cienaGlobalSeverity,
						# cienaGlobalMacAddress, cienaCesIpMgmtInterfaceName,
						# cienaCesIpMgmtInterfaceOperIpAddr, and cienaCesIpMgmtInterfaceOperSubnet.
						$cienaGlobalSeveritylook = "cienaGlobalSeverity." + $1
						$cienaGlobalSeverity = lookup($cienaGlobalSeveritylook,CienaVarbindValTable)
						if(match($cienaGlobalSeverity,"UNKNOWN")) {
							$cienaGlobalSeverity = $1
						} else {
							$cienaGlobalSeverity = $cienaGlobalSeverity + " ( " + $1 + " )"
						}
						$cienaGlobalMacAddress = $2
						$cienaCesIpMgmtInterfaceName = $3
						$cienaCesIpMgmtInterfaceOperIpAddr = $4
						$cienaCesIpMgmtInterfaceOperSubnet = $5
						@AlertGroup = "Ciena OME Traps"
						@Agent = "ciena.m2r.include.rules"
						@Summary = "cienaCesIpMgmtInterfaceAddrChgNotification: IP of interface " + $cienaCesIpMgmtInterfaceName + " changed"
						@Severity = 3
						@Type = 1
						@Identifier = @Node + @Summary
						details($*)

					case "2": ### - cienaCesIpMgmtInterfaceGatewayChgNotification
						# SNMPv2
						# A cienaCesIpMgmtInterfaceGatewayChgNotification is sent when the
						# IP address of an interface gateway changes. To enable the device to send
						# this notification, cienaCesIPMgmtInterfaceGatewayAddrChangeTrapState needs
						# to be set to enabled. The cienaCesIPMgmtInterfaceGatewayAddrChangeTrapState
						# is set to enabled by default. Variable bindings include: cienaGlobalSeverity,
						# cienaGlobalMacAddress, and cienaCesIpGatewayAddr.
						$cienaGlobalSeveritylook = "cienaGlobalSeverity." + $1
						$cienaGlobalSeverity = lookup($cienaGlobalSeveritylook,CienaVarbindValTable)
						if(match($cienaGlobalSeverity,"UNKNOWN")) {
							$cienaGlobalSeverity = $1
						} else {
							$cienaGlobalSeverity = $cienaGlobalSeverity + " ( " + $1 + " )"
						}
						$cienaGlobalMacAddress = $2
						$cienaCesIpGatewayAddr = $3
						@AlertGroup = "Ciena OME Traps"
						@Agent = "ciena.m2r.include.rules"
						@Summary = "cienaCesIpMgmtInterfaceGatewayChgNotification: IP of interface gateway: " + $cienaCesIpGatewayAddr + " changed"
						@Severity = 3
						@Type = 1
						@Identifier = @Node + @Summary
						details($*)

					default:
						@Summary = "Unknown specific trap number (" + $specific-trap + ") received for enterprise " + $enterprise
						@Identifier = @Node + $enterprise + $generic-trap + $specific-trap + @Agent + @Manager
						@Severity = 3
						@Type = 1
						details($*)
				}

			######
			# cienaCesPortXcvrMIBNotifications traps
			######
			case ".1.3.6.1.4.1.1271.2.2.9":	### - cienaCesPortXcvrMIBNotificationPrefix
				switch($specific-trap) {
					case "1": ### - cienaCesPortXcvrRemovedNotification
						# SNMPv2
						# A cienaCesPortXcvrRemovedNotification is sent if the transceiver has been removed.
						# To enable the device to send this notification: cienaCesPortXcvrLinkStateChangeTrapState,
						# cienaCesLogicalPortConfigPortAllTrapState, and cienaCesPortAllTrapState need to be set to
						# enabled. These objects are set to enabled by default. Variable bindings include:
						# cienaGlobalSeverity, cienaGlobalMacAddress, cienaCesPortXcvrNotifChassisIndex,
						# cienaCesPortXcvrNotifShelfIndex, cienaCesPortXcvrNotifSlotIndex, and
						# cienaCesPortXcvrNotifPortNumber.
						$cienaGlobalSeveritylook = "cienaGlobalSeverity." + $1
						$cienaGlobalSeverity = lookup($cienaGlobalSeveritylook,CienaVarbindValTable)
						if(match($cienaGlobalSeverity,"UNKNOWN")) {
							$cienaGlobalSeverity = $1
						} else {
							$cienaGlobalSeverity = $cienaGlobalSeverity + " ( " + $1 + " )"
						}
						$cienaGlobalMacAddress = $2
						$cienaCesPortXcvrNotifChassisIndex = $3
						$cienaCesPortXcvrNotifShelfIndex = $4
						$cienaCesPortXcvrNotifSlotIndex = $5
						$cienaCesPortXcvrNotifPortNumber = $6
						@AlertGroup = "Ciena OME Traps"
						@Agent = "ciena.m2r.include.rules"
						@Summary = "cienaCesPortXcvrRemovedNotification: Transceiver removed for port " + $cienaCesPortXcvrNotifPortNumber
						@Severity = 4
						@Type = 1
						@Identifier = @Node + @Summary
						details($*)

					case "2": ### - cienaCesPortXcvrInsertedNotification
						# SNMPv2
						# A cienaCesPortXcvrInsertedNotification is sent if the transceiver has been inserted. To
						# enable the device to send this notification: cienaCesPortXcvrLinkStateChangeTrapState,
						# cienaCesLogicalPortConfigPortAllTrapState, and cienaCesPortAllTrapState need to be set to
						# enabled. These objects are set to enabled by default. Variable bindings include:
						# cienaGlobalSeverity, cienaGlobalMacAddress, cienaCesPortXcvrNotifChassisIndex,
						# cienaCesPortXcvrNotifShelfIndex, cienaCesPortXcvrNotifSlotIndex, and
						# cienaCesPortXcvrNotifPortNumber.
						$cienaGlobalSeveritylook = "cienaGlobalSeverity." + $1
						$cienaGlobalSeverity = lookup($cienaGlobalSeveritylook,CienaVarbindValTable)
						if(match($cienaGlobalSeverity,"UNKNOWN")) {
							$cienaGlobalSeverity = $1
						} else {
							$cienaGlobalSeverity = $cienaGlobalSeverity + " ( " + $1 + " )"
						}
						$cienaGlobalMacAddress = $2
						$cienaCesPortXcvrNotifChassisIndex = $3
						$cienaCesPortXcvrNotifShelfIndex = $4
						$cienaCesPortXcvrNotifSlotIndex = $5
						$cienaCesPortXcvrNotifPortNumber = $6
						@AlertGroup = "Ciena OME Traps"
						@Agent = "ciena.m2r.include.rules"
						@Summary = "cienaCesPortXcvrInsertedNotification: Transceiver inserted for port " + $cienaCesPortXcvrNotifPortNumber
						@Severity = 4
						@Type = 1
						@Identifier = @Node + @Summary
						details($*)

					case "5": ### - cienaCesPortXcvrErrorTypeNotification
						# SNMPv2
						# A cienaCesPortXcvrErrorTypeNotification is sent if the transceiver is detected to be faulted.
						# The reason for the failure is specified by cienaCesPortXcvrErrorType. To enable the device to
						# send this notification: cienaCesPortXcvrErrorTrapState, cienaCesLogicalPortConfigPortAllTrapState,
						# and cienaCesPortAllTrapState need to be set to enabled. These objects are enabled by default.
						# Variable bindings include: cienaGlobalSeverity, cienaGlobalMacAddress,
						# cienaCesPortXcvrNotifChassisIndex, cienaCesPortXcvrNotifShelfIndex, cienaCesPortXcvrNotifSlotIndex,
						# cienaCesPortXcvrNotifPortNumber, and cienaCesPortXcvrErrorType.
						$cienaGlobalSeveritylook = "cienaGlobalSeverity." + $1
						$cienaGlobalSeverity = lookup($cienaGlobalSeveritylook,CienaVarbindValTable)
						if(match($cienaGlobalSeverity,"UNKNOWN")) {
							$cienaGlobalSeverity = $1
						} else {
							$cienaGlobalSeverity = $cienaGlobalSeverity + " ( " + $1 + " )"
						}
						$cienaGlobalMacAddress = $2
						$cienaCesPortXcvrNotifChassisIndex = $3
						$cienaCesPortXcvrNotifShelfIndex = $4
						$cienaCesPortXcvrNotifSlotIndex = $5
						$cienaCesPortXcvrNotifPortNumber = $6
						$cienaCesPortXcvrErrorTypelook = "cienaCesPortXcvrErrorType." + $7
						$cienaCesPortXcvrErrorType = lookup($cienaCesPortXcvrErrorTypelook,CienaVarbindValTable)
						if(match($cienaCesPortXcvrErrorType,"UNKNOWN")) {
							$cienaCesPortXcvrErrorType = $7
						} else {
							$cienaCesPortXcvrErrorType = $cienaCesPortXcvrErrorType + " ( " + $7 + " )"
						}
						@AlertGroup = "Ciena OME Traps"
						@Agent = "ciena.m2r.include.rules"
						@Summary = "cienaCesPortXcvrErrorTypeNotification: Transceiver for port " + $cienaCesPortXcvrNotifPortNumber + " failed because of " + $cienaCesPortXcvrErrorType
						@Severity = 4
						@Type = 1
						@Identifier = @Node + @Summary
						details($*)

					case "6": ### - cienaCesPortXcvrTempHighNotification
						# SNMPv2
						# A cienaCesPortXcvrTempHighNotification is sent if the transceiver temperature exceeds the
						# threshold. To enable the device to send this notification: cienaCesPortXcvrTempChangeTrapState,
						# cienaCesLogicalPortConfigPortAllTrapState, and cienaCesPortAllTrapState need to be set to enabled.
						# These objects are set to enabled by default. Variable bindings include: cienaGlobalSeverity,
						# cienaGlobalMacAddress, cienaCesPortXcvrNotifChassisIndex, cienaCesPortXcvrNotifShelfIndex,
						# cienaCesPortXcvrNotifSlotIndex, and cienaCesPortXcvrNotifPortNumber.
						$cienaGlobalSeveritylook = "cienaGlobalSeverity." + $1
						$cienaGlobalSeverity = lookup($cienaGlobalSeveritylook,CienaVarbindValTable)
						if(match($cienaGlobalSeverity,"UNKNOWN")) {
							$cienaGlobalSeverity = $1
						} else {
							$cienaGlobalSeverity = $cienaGlobalSeverity + " ( " + $1 + " )"
						}
						$cienaGlobalMacAddress = $2
						$cienaCesPortXcvrNotifChassisIndex = $3
						$cienaCesPortXcvrNotifShelfIndex = $4
						$cienaCesPortXcvrNotifSlotIndex = $5
						$cienaCesPortXcvrNotifPortNumber = $6
						@AlertGroup = "Ciena OME Traps"
						@Agent = "ciena.m2r.include.rules"
						@Summary = "cienaCesPortXcvrTempHighNotification: High Transceiver temp for port " + $cienaCesPortXcvrNotifPortNumber + " slot " + $cienaCesPortXcvrNotifSlotIndex
						@Severity = 4
						@Type = 1
						@Identifier = @Node + @Summary
						details($*)

					case "7": ### - cienaCesPortXcvrTempLowNotification
						# SNMPv2
						# A cienaCesPortXcvrTempLowNotification is sent if the transceiver temperature falls below the
						# threshold. To enable the device to send this notification: cienaCesPortXcvrTempChangeTrapState,
						# cienaCesLogicalPortConfigPortAllTrapState, and cienaCesPortAllTrapState need to be set to enabled.
						# These objects are set to enabled by default. Variable bindings include: cienaGlobalSeverity,
						# cienaGlobalMacAddress, cienaCesPortXcvrNotifChassisIndex, cienaCesPortXcvrNotifShelfIndex,
						# cienaCesPortXcvrNotifSlotIndex, and cienaCesPortXcvrNotifPortNumber.
						$cienaGlobalSeveritylook = "cienaGlobalSeverity." + $1
						$cienaGlobalSeverity = lookup($cienaGlobalSeveritylook,CienaVarbindValTable)
						if(match($cienaGlobalSeverity,"UNKNOWN")) {
							$cienaGlobalSeverity = $1
						} else {
							$cienaGlobalSeverity = $cienaGlobalSeverity + " ( " + $1 + " )"
						}
						$cienaGlobalMacAddress = $2
						$cienaCesPortXcvrNotifChassisIndex = $3
						$cienaCesPortXcvrNotifShelfIndex = $4
						$cienaCesPortXcvrNotifSlotIndex = $5
						$cienaCesPortXcvrNotifPortNumber = $6
						@AlertGroup = "Ciena OME Traps"
						@Agent = "ciena.m2r.include.rules"
						@Summary = "cienaCesPortXcvrTempLowNotification: Low Transceiver temp for port " + $cienaCesPortXcvrNotifPortNumber + " slot " + $cienaCesPortXcvrNotifSlotIndex
						@Severity = 4
						@Type = 1
						@Identifier = @Node + @Summary
						details($*)

					case "8": ### - cienaCesPortXcvrTempNormalNotification
						# SNMPv2
						# A cienaCesPortXcvrTempNormalNotification is sent when the transceiver temperature returns to
						# normal state.  To enable the device to send this notification: cienaCesPortXcvrTempChangeTrapState,
						# cienaCesLogicalPortConfigPortAllTrapState, and cienaCesPortAllTrapState need to be set to enabled.
						# These objects are set to enabled by default. Variable bindings include: cienaGlobalSeverity,
						# cienaGlobalMacAddress, cienaCesPortXcvrNotifChassisIndex, cienaCesPortXcvrNotifShelfIndex,
						# cienaCesPortXcvrNotifSlotIndex, and cienaCesPortXcvrNotifPortNumber.
						$cienaGlobalSeveritylook = "cienaGlobalSeverity." + $1
						$cienaGlobalSeverity = lookup($cienaGlobalSeveritylook,CienaVarbindValTable)
						if(match($cienaGlobalSeverity,"UNKNOWN")) {
							$cienaGlobalSeverity = $1
						} else {
							$cienaGlobalSeverity = $cienaGlobalSeverity + " ( " + $1 + " )"
						}
						$cienaGlobalMacAddress = $2
						$cienaCesPortXcvrNotifChassisIndex = $3
						$cienaCesPortXcvrNotifShelfIndex = $4
						$cienaCesPortXcvrNotifSlotIndex = $5
						$cienaCesPortXcvrNotifPortNumber = $6
						@AlertGroup = "Ciena OME Traps"
						@Agent = "ciena.m2r.include.rules"
						@Summary = "cienaCesPortXcvrTempNormalNotification: Transceiver temp for port " + $cienaCesPortXcvrNotifPortNumber + " slot " + $cienaCesPortXcvrNotifSlotIndex + " returned to within threshold"
						@Severity = 4
						@Type = 1
						@Identifier = @Node + @Summary
						details($*)

					case "9": ### - cienaCesPortXcvrVoltageHighNotification
						# SNMPv2
						# A cienaCesPortXcvrVoltageHighNotification is sent if the transceiver voltage exceeds the
						# threshold. To enable the device to send this notification: cienaCesPortXcvrVoltageChangeTrapState,
						# cienaCesLogicalPortConfigPortAllTrapState, cienaCesPortAllTrapState needs to be set to enabled
						# These objects are set to enabled by default. Variable bindings include:
						# cienaGlobalSeverity, cienaGlobalMacAddress, cienaCesPortXcvrNotifChassisIndex,
						# cienaCesPortXcvrNotifShelfIndex, cienaCesPortXcvrNotifSlotIndex, and
						# cienaCesPortXcvrNotifPortNumber.
						$cienaGlobalSeveritylook = "cienaGlobalSeverity." + $1
						$cienaGlobalSeverity = lookup($cienaGlobalSeveritylook,CienaVarbindValTable)
						if(match($cienaGlobalSeverity,"UNKNOWN")) {
							$cienaGlobalSeverity = $1
						} else {
							$cienaGlobalSeverity = $cienaGlobalSeverity + " ( " + $1 + " )"
						}
						$cienaGlobalMacAddress = $2
						$cienaCesPortXcvrNotifChassisIndex = $3
						$cienaCesPortXcvrNotifShelfIndex = $4
						$cienaCesPortXcvrNotifSlotIndex = $5
						$cienaCesPortXcvrNotifPortNumber = $6
						@AlertGroup = "Ciena OME Traps"
						@Agent = "ciena.m2r.include.rules"
						@Summary = "cienaCesPortXcvrVoltageHighNotification: Transceiver high voltage for port: " + $cienaCesPortXcvrNotifPortNumber + " slot " + $cienaCesPortXcvrNotifSlotIndex
						@Severity = 4
						@Type = 1
						@Identifier = @Node + @Summary
						details($*)

					case "10": ### - cienaCesPortXcvrVoltageLowNotification
						# SNMPv2
						# A cienaCesPortXcvrVoltageLowNotification is sent if the transceiver voltage falls below the
						# threshold. To enable the device to send this notification: cienaCesPortXcvrVoltageChangeTrapState,
						# cienaCesLogicalPortConfigPortAllTrapState, and cienaCesPortAllTrapState need to be set to enabled.
						# These objects are set to enabled by default. Variable bindings include: cienaGlobalSeverity,
						# cienaGlobalMacAddress, cienaCesPortXcvrNotifChassisIndex, cienaCesPortXcvrNotifShelfIndex,
						# cienaCesPortXcvrNotifSlotIndex, and cienaCesPortXcvrNotifPortNumber.
						$cienaGlobalSeveritylook = "cienaGlobalSeverity." + $1
						$cienaGlobalSeverity = lookup($cienaGlobalSeveritylook,CienaVarbindValTable)
						if(match($cienaGlobalSeverity,"UNKNOWN")) {
							$cienaGlobalSeverity = $1
						} else {
							$cienaGlobalSeverity = $cienaGlobalSeverity + " ( " + $1 + " )"
						}
						$cienaGlobalMacAddress = $2
						$cienaCesPortXcvrNotifChassisIndex = $3
						$cienaCesPortXcvrNotifShelfIndex = $4
						$cienaCesPortXcvrNotifSlotIndex = $5
						$cienaCesPortXcvrNotifPortNumber = $6
						@AlertGroup = "Ciena OME Traps"
						@Agent = "ciena.m2r.include.rules"
						@Summary = "cienaCesPortXcvrVoltageLowNotification: Transceiver low voltage for port: " + $cienaCesPortXcvrNotifPortNumber + " slot " + $cienaCesPortXcvrNotifSlotIndex
						@Severity = 4
						@Type = 1
						@Identifier = @Node + @Summary
						details($*)

					case "11": ### - cienaCesPortXcvrVoltageNormalNotification
						# SNMPv2
						# A cienaCesPortXcvrVoltageNormalNotification is sent when the transceiver voltage returns back
						# to normal state. To enable the device to send this notification: cienaCesPortXcvrVoltageChangeTrapState,
						# cienaCesLogicalPortConfigPortAllTrapState, and cienaCesPortAllTrapState need to be set to enabled.
						# These objects are set to enabled by default. Variable bindings include: cienaGlobalSeverity,
						# cienaGlobalMacAddress, cienaCesPortXcvrNotifChassisIndex, cienaCesPortXcvrNotifShelfIndex,
						# cienaCesPortXcvrNotifSlotIndex, and cienaCesPortXcvrNotifPortNumber.
						$cienaGlobalSeveritylook = "cienaGlobalSeverity." + $1
						$cienaGlobalSeverity = lookup($cienaGlobalSeveritylook,CienaVarbindValTable)
						if(match($cienaGlobalSeverity,"UNKNOWN")) {
							$cienaGlobalSeverity = $1
						} else {
							$cienaGlobalSeverity = $cienaGlobalSeverity + " ( " + $1 + " )"
						}
						$cienaGlobalMacAddress = $2
						$cienaCesPortXcvrNotifChassisIndex = $3
						$cienaCesPortXcvrNotifShelfIndex = $4
						$cienaCesPortXcvrNotifSlotIndex = $5
						$cienaCesPortXcvrNotifPortNumber = $6
						@AlertGroup = "Ciena OME Traps"
						@Agent = "ciena.m2r.include.rules"
						@Summary = "cienaCesPortXcvrVoltageNormalNotification: Transceiver voltage for port: " + $cienaCesPortXcvrNotifPortNumber + " slot " + $cienaCesPortXcvrNotifSlotIndex + "returned to normal"
						@Severity = 4
						@Type = 1
						@Identifier = @Node + @Summary
						details($*)

					case "12": ### - cienaCesPortXcvrBiasHighNotification
						# SNMPv2
						# A cienaCesPortXcvrBiasHighNotification is sent if the transceiver bias exceeds the
						# threshold. To enable the device to send this notification: cienaCesPortXcvrBiasChangeTrapState,
						# cienaCesLogicalPortConfigPortAllTrapState, and cienaCesPortAllTrapState need to be set to enabled.
						# These objects are set to enabled by default. Variable bindings include: cienaGlobalSeverity,
						# cienaGlobalMacAddress, cienaCesPortXcvrNotifChassisIndex, cienaCesPortXcvrNotifShelfIndex,
						# cienaCesPortXcvrNotifSlotIndex, and cienaCesPortXcvrNotifPortNumber.
						$cienaGlobalSeveritylook = "cienaGlobalSeverity." + $1
						$cienaGlobalSeverity = lookup($cienaGlobalSeveritylook,CienaVarbindValTable)
						if(match($cienaGlobalSeverity,"UNKNOWN")) {
							$cienaGlobalSeverity = $1
						} else {
							$cienaGlobalSeverity = $cienaGlobalSeverity + " ( " + $1 + " )"
						}
						$cienaGlobalMacAddress = $2
						$cienaCesPortXcvrNotifChassisIndex = $3
						$cienaCesPortXcvrNotifShelfIndex = $4
						$cienaCesPortXcvrNotifSlotIndex = $5
						$cienaCesPortXcvrNotifPortNumber = $6
						@AlertGroup = "Ciena OME Traps"
						@Agent = "ciena.m2r.include.rules"
						@Summary = "cienaCesPortXcvrBiasHighNotification: High transceiver bias for port: " + $cienaCesPortXcvrNotifPortNumber + " slot " + $cienaCesPortXcvrNotifSlotIndex
						@Severity = 3
						@Type = 1
						@Identifier = @Node + @Summary
						details($*)

					case "13": ### - cienaCesPortXcvrBiasLowNotification
						# SNMPv2
						# A cienaCesPortXcvrBiasLowNotification is sent if the transceiver bias falls below the
						# threshold. To enable the device to send this notification: cienaCesPortXcvrBiasChangeTrapState,
						# cienaCesLogicalPortConfigPortAllTrapState, and cienaCesPortAllTrapState need to be set to enabled.
						# These objects are set to enabled by default. Variable bindings include: cienaGlobalSeverity,
						# cienaGlobalMacAddress, cienaCesPortXcvrNotifChassisIndex, cienaCesPortXcvrNotifShelfIndex,
						# cienaCesPortXcvrNotifSlotIndex, and cienaCesPortXcvrNotifPortNumber.
						$cienaGlobalSeveritylook = "cienaGlobalSeverity." + $1
						$cienaGlobalSeverity = lookup($cienaGlobalSeveritylook,CienaVarbindValTable)
						if(match($cienaGlobalSeverity,"UNKNOWN")) {
							$cienaGlobalSeverity = $1
						} else {
