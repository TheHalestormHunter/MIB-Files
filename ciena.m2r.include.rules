						} else {
							$cienaCesLogicalPortConfigPortOperState = $cienaCesLogicalPortConfigPortOperState + " ( " + $9 + " )"
						}
						$cienaCesLogicalPortConfigPortName = $10
						$cienaCesLogicalPortConfigPortTypelook = "cienaCesLogicalPortConfigPortType." + $11
						$cienaCesLogicalPortConfigPortType = lookup($cienaCesLogicalPortConfigPortTypelook,CienaVarbindValTable)
						if(match($cienaCesLogicalPortConfigPortType,"UNKNOWN")) {
							$cienaCesLogicalPortConfigPortType = $11
						} else {
							$cienaCesLogicalPortConfigPortType = $cienaCesLogicalPortConfigPortType + " ( " + $11 + " )"
						}
						$cienaCesLogicalPortConfigPortDesc = $12
						$sysName = $13
						$sysLocation = $14
						$cienaCesChassisSystemId = $15
						$cienaCesLogicalPortConfigEttpAid = $16
						@AlertGroup = "Ciena OME Traps"
						@Agent = "ciena.m2r.include.rules"
						@Summary = "cienaCesPortNotificationPortUp: Port number " + $cienaCesPortPgIdMappingNotifPortNumber + " on slot " + $cienaCesPortPgIdMappingNotifSlotIndex + " is up"
						@Severity = 4
						@Type = 1
						@Identifier = @Node + @Summary
						details($*)

					case "4": ### - cienaCesChPortNotificationPortDown
						# SNMPv2
						# A cienaCesChPortNotificationPortDown trap signifies that the SNMP entity, acting in
						# an agent role, has detected that the link status has become operationally down
						# for one of its communication links.
						# To enable the device to send this notification:
						# - cienaCesPortEnhancedLinkTrapState needs to be set to enabled
						# - cienaCesPortAllTrapState needs to be set to enabled
						# - cienaCesLogicalPortConfigPortAllTrapState for the port needs to be set to enabled
						# - cienaCesLogicalPortConfigPortLinkUpDownTrapState for the port needs to be set to enabled
						# These objects are set to enabled by default. Variable bindings include: cienaGlobalSeverity,
						# cienaGlobalMacAddress, cienaCesChPortPgIdMappingNotifChassisIndex, cienaCesChPortPgIdMappingNotifShelfIndex,
						# cienaCesChPortPgIdMappingNotifSlotIndex, cienaCesChPortPgIdMappingNotifPortNumber,
						# cienaCesChPortPgIdMappingNotifChannelNumber,
						# cienaCesLogicalPortConfigPortAdminState, cienaCesLogicalPortConfigPortOperState,
						# cienaCesLogicalPortConfigPortName, cienaCesLogicalPortConfigPortType, cienaCesLogicalPortConfigPortDesc,
						# sysName, and sysLocation.
						$cienaGlobalSeveritylook = "cienaGlobalSeverity." + $1
						$cienaGlobalSeverity = lookup($cienaGlobalSeveritylook,CienaVarbindValTable)
						if(match($cienaGlobalSeverity,"UNKNOWN")) {
							$cienaGlobalSeverity = $1
						} else {
							$cienaGlobalSeverity = $cienaGlobalSeverity + " ( " + $1 + " )"
						}
						$cienaGlobalMacAddress = $2
						$cienaCesChPortPgIdMappingNotifChassisIndex = $3
						$cienaCesChPortPgIdMappingNotifShelfIndex = $4
						$cienaCesChPortPgIdMappingNotifSlotIndex = $5
						$cienaCesChPortPgIdMappingNotifPortNumber = $6
						$cienaCesChPortPgIdMappingNotifChannelNumber = $7
						$cienaCesLogicalPortConfigPortAdminStatelook = "cienaCesLogicalPortConfigPortAdminState." + $8
						$cienaCesLogicalPortConfigPortAdminState = lookup($cienaCesLogicalPortConfigPortAdminStatelook,CienaVarbindValTable)
						if(match($cienaCesLogicalPortConfigPortAdminState,"UNKNOWN")) {
							$cienaCesLogicalPortConfigPortAdminState = $8
						} else {
							$cienaCesLogicalPortConfigPortAdminState = $cienaCesLogicalPortConfigPortAdminState + " ( " + $8 + " )"
						}
						$cienaCesLogicalPortConfigPortOperStatelook = "cienaCesLogicalPortConfigPortOperState." + $9
						$cienaCesLogicalPortConfigPortOperState = lookup($cienaCesLogicalPortConfigPortOperStatelook,CienaVarbindValTable)
						if(match($cienaCesLogicalPortConfigPortOperState,"UNKNOWN")) {
							$cienaCesLogicalPortConfigPortOperState = $9
						} else {
							$cienaCesLogicalPortConfigPortOperState = $cienaCesLogicalPortConfigPortOperState + " ( " + $9 + " )"
						}
						$cienaCesLogicalPortConfigPortName = $10
						$cienaCesLogicalPortConfigPortTypelook = "cienaCesLogicalPortConfigPortType." + $11
						$cienaCesLogicalPortConfigPortType = lookup($cienaCesLogicalPortConfigPortTypelook,CienaVarbindValTable)
						if(match($cienaCesLogicalPortConfigPortType,"UNKNOWN")) {
							$cienaCesLogicalPortConfigPortType = $11
						} else {
							$cienaCesLogicalPortConfigPortType = $cienaCesLogicalPortConfigPortType + " ( " + $11 + " )"
						}
						$cienaCesLogicalPortConfigPortDesc = $12
						$sysName = $13
						$sysLocation = $14
						$cienaCesChassisSystemId = $15
						$cienaCesLogicalPortConfigEttpAid = $16
						$cienaCesLogicalPortLastDownReason1 = $17
						$cienaCesLogicalPortLastDownReason2 = $18
						$cienaCesLogicalPortLastDownReason3 = $19
						$cienaCesLogicalPortMaskedDownReason = $20
						@AlertGroup = "Ciena OME Traps"
						@Agent = "ciena.m2r.include.rules"
						@Summary = "cienaCesPortNotificationPortDown: Port number " + $cienaCesPortPgIdMappingNotifPortNumber + " on slot " + $cienaCesPortPgIdMappingNotifSlotIndex + " is down"
						@Severity = 4
						@Type = 1
						@Identifier = @Node + @Summary
						details($*)

					default:
						@Summary = "Unknown specific trap number (" + $specific-trap + ") received for enterprise " + $enterprise
						@Identifier = @Node + $enterprise + $generic-trap + $specific-trap + @Agent + @Manager
						@Severity = 3
						@Type = 1
						details($*)
				}

			######
			# cienaCesModuleMIBNotifications traps
			######
			case ".1.3.6.1.4.1.1271.2.2.3":	### - cienaCesModuleMIBNotificationPrefix
				switch($specific-trap) {
					case "1": ### - cienaCesModuleStateChangeNotification
						# SNMPv2
						# A cienaCesModuleStateChange notification is sent when the operational
						# state of the module is changed.
						# To enable the device to send this notification:
						# - cienaCesModuleAllModulesTrapState needs to be set to enabled.
						# - cienaCesModuleTrapState for the module needs to be set to enabled.
						# The above values are set to enabled by default. Variable bindings include:
						# cienaGlobalSeverity, cienaGlobalMacAddress, cienaCesModuleChassisNotifIndx,
						# cienaCesModuleShelfNotifIndx, cienaCesModuleSlotNotifIndx,
						# cienaCesModuleAdminState, and cienaCesModuleOperState.
						$cienaGlobalSeveritylook = "cienaGlobalSeverity." + $1
						$cienaGlobalSeverity = lookup($cienaGlobalSeveritylook,CienaVarbindValTable)
						if(match($cienaGlobalSeverity,"UNKNOWN")) {
							$cienaGlobalSeverity = $1
						} else {
							$cienaGlobalSeverity = $cienaGlobalSeverity + " ( " + $1 + " )"
						}
						$cienaGlobalMacAddress = $2
						$cienaCesModuleChassisNotifIndx = $3
						$cienaCesModuleShelfNotifIndx = $4
						$cienaCesModuleSlotNotifIndx = $5
						$cienaCesModuleAdminStatelook = "cienaCesModuleAdminState." + $6
						$cienaCesModuleAdminState = lookup($cienaCesModuleAdminStatelook,CienaVarbindValTable)
						if(match($cienaCesModuleAdminState,"UNKNOWN")) {
							$cienaCesModuleAdminState = $6
						} else {
							$cienaCesModuleAdminState = $cienaCesModuleAdminState + " ( " + $6 + " )"
						}
						$cienaCesModuleOperStatelook = "cienaCesModuleOperState." + $7
						$cienaCesModuleOperState = lookup($cienaCesModuleOperStatelook,CienaVarbindValTable)
						if(match($cienaCesModuleOperState,"UNKNOWN")) {
							$cienaCesModuleOperState = $7
						} else {
							$cienaCesModuleOperState = $cienaCesModuleOperState + " ( " + $7 + " )"
						}
						@AlertGroup = "Ciena OME Traps"
						@Agent = "ciena.m2r.include.rules"
						@Summary = "cienaCesModuleStateChangeNotification: Module operational state changed to " + $cienaCesModuleOperState
						@Severity = 4
						@Type = 1
						@Identifier = @Node + @Summary
						details($*)

					case "2": ### - cienaCesModuleHealthStatusUnknownNotification
						# SNMPv2
						# This notification is sent whenever the Health Manager detects a status change to unknown.
						# To enable the device to send this notification:
						# - cienaCesModuleAllModulesTrapState needs to be set to enabled.
						# - cienaCesModuleTrapState for the module needs to be set to enabled.
						# - cienaCesModuleAllModulesHealthTrapState needs to be set to enabled.
						# The above values are set to enabled by default. Variable bindings include: cienaGlobalSeverity,
						# cienaGlobalMacAddress, cienaCesModuleChassisNotifIndx, cienaCesModuleShelfNotifIndx,
						# cienaCesModuleSlotNotifIndx, cienaCesModuleHealthOriginType, cienaCesModuleHealthOriginName,
						# cienaCesModuleHealthOriginUnitId, cienaCesModuleHealthCategory, cienaCesModuleHealthSubCategory,
						# cienaCesModuleHealthStatus, and cienaCesModuleHealthStatusLast.
						$cienaGlobalSeveritylook = "cienaGlobalSeverity." + $1
						$cienaGlobalSeverity = lookup($cienaGlobalSeveritylook,CienaVarbindValTable)
						if(match($cienaGlobalSeverity,"UNKNOWN")) {
							$cienaGlobalSeverity = $1
						} else {
							$cienaGlobalSeverity = $cienaGlobalSeverity + " ( " + $1 + " )"
						}
						$cienaGlobalMacAddress = $2
						$cienaCesModuleChassisNotifIndx = $3
						$cienaCesModuleShelfNotifIndx = $4
						$cienaCesModuleSlotNotifIndx = $5
						$cienaCesModuleHealthOriginTypelook = "cienaCesModuleHealthOriginType." + $6
						$cienaCesModuleHealthOriginType = lookup($cienaCesModuleHealthOriginTypelook,CienaVarbindValTable)
						if(match($cienaCesModuleHealthOriginType,"UNKNOWN")) {
							$cienaCesModuleHealthOriginType = $6
						} else {
							$cienaCesModuleHealthOriginType = $cienaCesModuleHealthOriginType + " ( " + $6 + " )"
						}
						$cienaCesModuleHealthOriginName = $7
						$cienaCesModuleHealthOriginUnitId = $8
						$cienaCesModuleHealthCategorylook = "cienaCesModuleHealthCategory." + $9
						$cienaCesModuleHealthCategory = lookup($cienaCesModuleHealthCategorylook,CienaVarbindValTable)
						if(match($cienaCesModuleHealthCategory,"UNKNOWN")) {
							$cienaCesModuleHealthCategory = $9
						} else {
							$cienaCesModuleHealthCategory = $cienaCesModuleHealthCategory + " ( " + $9 + " )"
						}
						$cienaCesModuleHealthSubCategory = $10
						$cienaCesModuleHealthStatuslook = "cienaCesModuleHealthStatus." + $11
						$cienaCesModuleHealthStatus = lookup($cienaCesModuleHealthStatuslook,CienaVarbindValTable)
						if(match($cienaCesModuleHealthStatus,"UNKNOWN")) {
							$cienaCesModuleHealthStatus = $11
						} else {
							$cienaCesModuleHealthStatus = $cienaCesModuleHealthStatus + " ( " + $11 + " )"
						}
						$cienaCesModuleHealthStatusLastlook = "cienaCesModuleHealthStatusLast." + $12
						$cienaCesModuleHealthStatusLast = lookup($cienaCesModuleHealthStatusLastlook,CienaVarbindValTable)
						if(match($cienaCesModuleHealthStatusLast,"UNKNOWN")) {
							$cienaCesModuleHealthStatusLast = $12
						} else {
							$cienaCesModuleHealthStatusLast = $cienaCesModuleHealthStatusLast + " ( " + $12 + " )"
						}
						@AlertGroup = "Ciena OME Traps"
						@Agent = "ciena.m2r.include.rules"
						@Summary = "cienaCesModuleHealthStatusUnknownNotification: Health Manager detected a status change to unknown for module in slot " + $cienaCesModuleSlotNotifIndx
						@Severity = 4
						@Type = 1
						@Identifier = @Node + @Summary
						details($*)

					case "3": ### - cienaCesModuleHealthStatusWarningNotification
						# SNMPv2
						# This notification is sent whenever the Health Manager detects a status change to warning.
						# To enable the device to send this notification:
						# - cienaCesModuleAllModulesTrapState needs to be set to enabled.
						# - cienaCesModuleTrapState for the module needs to be set to enabled.
						# - cienaCesModuleAllModulesHealthTrapState needs to be set to enabled.
						# The above values are set to enabled by default. Variable bindings include:
						# cienaGlobalSeverity, cienaGlobalMacAddress, cienaCesModuleChassisNotifIndx,
						# cienaCesModuleShelfNotifIndx, cienaCesModuleSlotNotifIndx,
						# cienaCesModuleHealthOriginType, cienaCesModuleHealthOriginName,
						# cienaCesModuleHealthOriginUnitId, cienaCesModuleHealthCategory,
						# cienaCesModuleHealthSubCategory, cienaCesModuleHealthStatus, and
						# cienaCesModuleHealthStatusLast.
						$cienaGlobalSeveritylook = "cienaGlobalSeverity." + $1
						$cienaGlobalSeverity = lookup($cienaGlobalSeveritylook,CienaVarbindValTable)
						if(match($cienaGlobalSeverity,"UNKNOWN")) {
							$cienaGlobalSeverity = $1
						} else {
							$cienaGlobalSeverity = $cienaGlobalSeverity + " ( " + $1 + " )"
						}
						$cienaGlobalMacAddress = $2
						$cienaCesModuleChassisNotifIndx = $3
						$cienaCesModuleShelfNotifIndx = $4
						$cienaCesModuleSlotNotifIndx = $5
						$cienaCesModuleHealthOriginTypelook = "cienaCesModuleHealthOriginType." + $6
						$cienaCesModuleHealthOriginType = lookup($cienaCesModuleHealthOriginTypelook,CienaVarbindValTable)
						if(match($cienaCesModuleHealthOriginType,"UNKNOWN")) {
							$cienaCesModuleHealthOriginType = $6
						} else {
							$cienaCesModuleHealthOriginType = $cienaCesModuleHealthOriginType + " ( " + $6 + " )"
						}
						$cienaCesModuleHealthOriginName = $7
						$cienaCesModuleHealthOriginUnitId = $8
						$cienaCesModuleHealthCategorylook = "cienaCesModuleHealthCategory." + $9
						$cienaCesModuleHealthCategory = lookup($cienaCesModuleHealthCategorylook,CienaVarbindValTable)
						if(match($cienaCesModuleHealthCategory,"UNKNOWN")) {
							$cienaCesModuleHealthCategory = $9
						} else {
							$cienaCesModuleHealthCategory = $cienaCesModuleHealthCategory + " ( " + $9 + " )"
						}
						$cienaCesModuleHealthSubCategory = $10
						$cienaCesModuleHealthStatuslook = "cienaCesModuleHealthStatus." + $11
						$cienaCesModuleHealthStatus = lookup($cienaCesModuleHealthStatuslook,CienaVarbindValTable)
						if(match($cienaCesModuleHealthStatus,"UNKNOWN")) {
							$cienaCesModuleHealthStatus = $11
						} else {
							$cienaCesModuleHealthStatus = $cienaCesModuleHealthStatus + " ( " + $11 + " )"
						}
						$cienaCesModuleHealthStatusLastlook = "cienaCesModuleHealthStatusLast." + $12
						$cienaCesModuleHealthStatusLast = lookup($cienaCesModuleHealthStatusLastlook,CienaVarbindValTable)
						if(match($cienaCesModuleHealthStatusLast,"UNKNOWN")) {
							$cienaCesModuleHealthStatusLast = $12
						} else {
							$cienaCesModuleHealthStatusLast = $cienaCesModuleHealthStatusLast + " ( " + $12 + " )"
						}
						@AlertGroup = "Ciena OME Traps"
						@Agent = "ciena.m2r.include.rules"
						@Summary = "cienaCesModuleHealthStatusWarningNotification: Health Manager detected a status change to warning for module in slot " + $cienaCesModuleSlotNotifIndx
						@Severity = 3
						@Type = 1
						@Identifier = @Node + @Summary
						details($*)

					case "4": ### - cienaCesModuleHealthStatusFaultedNotification
						# SNMPv2
						# This notification is sent whenever the Health Manager detects a status change to faulted.
						# To enable the device to send this notification:
						# - cienaCesModuleAllModulesTrapState needs to be set to enabled.
						# - cienaCesModuleTrapState for the module needs to be set to enabled.
						# - cienaCesModuleAllModulesHealthTrapState needs to be set to enabled
						# The above values are set to enabled by default. Variable bindings include: cienaGlobalSeverity,
						# cienaGlobalMacAddress, cienaCesModuleChassisNotifIndx, cienaCesModuleShelfNotifIndx,
						# cienaCesModuleSlotNotifIndx, cienaCesModuleHealthOriginType, cienaCesModuleHealthOriginName,
						# cienaCesModuleHealthOriginUnitId, cienaCesModuleHealthCategory, cienaCesModuleHealthSubCategory,
						# cienaCesModuleHealthStatus, and cienaCesModuleHealthStatusLast.
						$cienaGlobalSeveritylook = "cienaGlobalSeverity." + $1
						$cienaGlobalSeverity = lookup($cienaGlobalSeveritylook,CienaVarbindValTable)
						if(match($cienaGlobalSeverity,"UNKNOWN")) {
							$cienaGlobalSeverity = $1
						} else {
							$cienaGlobalSeverity = $cienaGlobalSeverity + " ( " + $1 + " )"
						}
						$cienaGlobalMacAddress = $2
						$cienaCesModuleChassisNotifIndx = $3
						$cienaCesModuleShelfNotifIndx = $4
						$cienaCesModuleSlotNotifIndx = $5
						$cienaCesModuleHealthOriginTypelook = "cienaCesModuleHealthOriginType." + $6
						$cienaCesModuleHealthOriginType = lookup($cienaCesModuleHealthOriginTypelook,CienaVarbindValTable)
						if(match($cienaCesModuleHealthOriginType,"UNKNOWN")) {
							$cienaCesModuleHealthOriginType = $6
						} else {
							$cienaCesModuleHealthOriginType = $cienaCesModuleHealthOriginType + " ( " + $6 + " )"
						}
						$cienaCesModuleHealthOriginName = $7
						$cienaCesModuleHealthOriginUnitId = $8
						$cienaCesModuleHealthCategorylook = "cienaCesModuleHealthCategory." + $9
						$cienaCesModuleHealthCategory = lookup($cienaCesModuleHealthCategorylook,CienaVarbindValTable)
						if(match($cienaCesModuleHealthCategory,"UNKNOWN")) {
							$cienaCesModuleHealthCategory = $9
						} else {
							$cienaCesModuleHealthCategory = $cienaCesModuleHealthCategory + " ( " + $9 + " )"
						}
						$cienaCesModuleHealthSubCategory = $10
						$cienaCesModuleHealthStatuslook = "cienaCesModuleHealthStatus." + $11
						$cienaCesModuleHealthStatus = lookup($cienaCesModuleHealthStatuslook,CienaVarbindValTable)
						if(match($cienaCesModuleHealthStatus,"UNKNOWN")) {
							$cienaCesModuleHealthStatus = $11
						} else {
							$cienaCesModuleHealthStatus = $cienaCesModuleHealthStatus + " ( " + $11 + " )"
						}
						$cienaCesModuleHealthStatusLastlook = "cienaCesModuleHealthStatusLast." + $12
						$cienaCesModuleHealthStatusLast = lookup($cienaCesModuleHealthStatusLastlook,CienaVarbindValTable)
						if(match($cienaCesModuleHealthStatusLast,"UNKNOWN")) {
							$cienaCesModuleHealthStatusLast = $12
						} else {
							$cienaCesModuleHealthStatusLast = $cienaCesModuleHealthStatusLast + " ( " + $12 + " )"
						}
						@AlertGroup = "Ciena OME Traps"
						@Agent = "ciena.m2r.include.rules"
						@Summary = "cienaCesModuleHealthStatusFaultedNotification: Health Manager detected a status change to fault for module in slot " + $cienaCesModuleSlotNotifIndx
						@Severity = 5
						@Type = 1
						@Identifier = @Node + @Summary
						details($*)

					case "5": ### - cienaCesModuleHealthStatusDegradedNotification
						# SNMPv2
						# This notification is sent whenever the Health Manager detects a status change to degraded.
						# To enable the device to send this notification:
						# - cienaCesModuleAllModulesTrapState needs to be set to enabled.
						# - cienaCesModuleTrapState for the module needs to be set to enabled.
						# - cienaCesModuleAllModulesHealthTrapState needs to be set to enabled
						# The above values are set to enabled by default. Variable bindings include:
						# cienaGlobalSeverity, cienaGlobalMacAddress, cienaCesModuleChassisNotifIndx,
						# cienaCesModuleShelfNotifIndx, cienaCesModuleSlotNotifIndx,
						# cienaCesModuleHealthOriginType, cienaCesModuleHealthOriginName,
						# cienaCesModuleHealthOriginUnitId, cienaCesModuleHealthCategory,
						# cienaCesModuleHealthSubCategory, cienaCesModuleHealthStatus,
						# and cienaCesModuleHealthStatusLast.
						$cienaGlobalSeveritylook = "cienaGlobalSeverity." + $1
						$cienaGlobalSeverity = lookup($cienaGlobalSeveritylook,CienaVarbindValTable)
						if(match($cienaGlobalSeverity,"UNKNOWN")) {
							$cienaGlobalSeverity = $1
						} else {
							$cienaGlobalSeverity = $cienaGlobalSeverity + " ( " + $1 + " )"
						}
						$cienaGlobalMacAddress = $2
						$cienaCesModuleChassisNotifIndx = $3
						$cienaCesModuleShelfNotifIndx = $4
						$cienaCesModuleSlotNotifIndx = $5
						$cienaCesModuleHealthOriginTypelook = "cienaCesModuleHealthOriginType." + $6
						$cienaCesModuleHealthOriginType = lookup($cienaCesModuleHealthOriginTypelook,CienaVarbindValTable)
						if(match($cienaCesModuleHealthOriginType,"UNKNOWN")) {
							$cienaCesModuleHealthOriginType = $6
						} else {
							$cienaCesModuleHealthOriginType = $cienaCesModuleHealthOriginType + " ( " + $6 + " )"
						}
						$cienaCesModuleHealthOriginName = $7
						$cienaCesModuleHealthOriginUnitId = $8
						$cienaCesModuleHealthCategorylook = "cienaCesModuleHealthCategory." + $9
						$cienaCesModuleHealthCategory = lookup($cienaCesModuleHealthCategorylook,CienaVarbindValTable)
						if(match($cienaCesModuleHealthCategory,"UNKNOWN")) {
							$cienaCesModuleHealthCategory = $9
						} else {
							$cienaCesModuleHealthCategory = $cienaCesModuleHealthCategory + " ( " + $9 + " )"
						}
						$cienaCesModuleHealthSubCategory = $10
						$cienaCesModuleHealthStatuslook = "cienaCesModuleHealthStatus." + $11
						$cienaCesModuleHealthStatus = lookup($cienaCesModuleHealthStatuslook,CienaVarbindValTable)
						if(match($cienaCesModuleHealthStatus,"UNKNOWN")) {
							$cienaCesModuleHealthStatus = $11
						} else {
							$cienaCesModuleHealthStatus = $cienaCesModuleHealthStatus + " ( " + $11 + " )"
						}
						$cienaCesModuleHealthStatusLastlook = "cienaCesModuleHealthStatusLast." + $12
						$cienaCesModuleHealthStatusLast = lookup($cienaCesModuleHealthStatusLastlook,CienaVarbindValTable)
						if(match($cienaCesModuleHealthStatusLast,"UNKNOWN")) {
							$cienaCesModuleHealthStatusLast = $12
						} else {
							$cienaCesModuleHealthStatusLast = $cienaCesModuleHealthStatusLast + " ( " + $12 + " )"
						}
						@AlertGroup = "Ciena OME Traps"
						@Agent = "ciena.m2r.include.rules"
						@Summary = "cienaCesModuleHealthStatusDegradedNotification: Health Manager detected a status change to degraded for module in slot " + $cienaCesModuleSlotNotifIndx
						@Severity = 4
						@Type = 1
						@Identifier = @Node + @Summary
						details($*)

					case "6": ### - cienaCesModuleHealthStatusGoodNotification
						# SNMPv2
						# This notification is sent whenever the Health Manager detects a status change to normal.
						# To enable the device to send this notification:
						# - cienaCesModuleAllModulesTrapState needs to be set to enabled.
						# - cienaCesModuleTrapState for the module needs to be set to enabled.
						# - cienaCesModuleAllModulesHealthTrapState needs to be set to enabled
						# The above values are set to enabled by default. Variable bindings include:
						# cienaGlobalSeverity, cienaGlobalMacAddress, cienaCesModuleChassisNotifIndx,
						# cienaCesModuleShelfNotifIndx, cienaCesModuleSlotNotifIndx,
						# cienaCesModuleHealthOriginType, cienaCesModuleHealthOriginName,
						# cienaCesModuleHealthOriginUnitId, cienaCesModuleHealthCategory,
						# cienaCesModuleHealthSubCategory, cienaCesModuleHealthStatus, and
						# cienaCesModuleHealthStatusLast.
						$cienaGlobalSeveritylook = "cienaGlobalSeverity." + $1
						$cienaGlobalSeverity = lookup($cienaGlobalSeveritylook,CienaVarbindValTable)
						if(match($cienaGlobalSeverity,"UNKNOWN")) {
							$cienaGlobalSeverity = $1
						} else {
							$cienaGlobalSeverity = $cienaGlobalSeverity + " ( " + $1 + " )"
						}
						$cienaGlobalMacAddress = $2
						$cienaCesModuleChassisNotifIndx = $3
						$cienaCesModuleShelfNotifIndx = $4
						$cienaCesModuleSlotNotifIndx = $5
						$cienaCesModuleHealthOriginTypelook = "cienaCesModuleHealthOriginType." + $6
						$cienaCesModuleHealthOriginType = lookup($cienaCesModuleHealthOriginTypelook,CienaVarbindValTable)
						if(match($cienaCesModuleHealthOriginType,"UNKNOWN")) {
							$cienaCesModuleHealthOriginType = $6
						} else {
							$cienaCesModuleHealthOriginType = $cienaCesModuleHealthOriginType + " ( " + $6 + " )"
						}
						$cienaCesModuleHealthOriginName = $7
						$cienaCesModuleHealthOriginUnitId = $8
						$cienaCesModuleHealthCategorylook = "cienaCesModuleHealthCategory." + $9
						$cienaCesModuleHealthCategory = lookup($cienaCesModuleHealthCategorylook,CienaVarbindValTable)
						if(match($cienaCesModuleHealthCategory,"UNKNOWN")) {
							$cienaCesModuleHealthCategory = $9
						} else {
							$cienaCesModuleHealthCategory = $cienaCesModuleHealthCategory + " ( " + $9 + " )"
						}
						$cienaCesModuleHealthSubCategory = $10
						$cienaCesModuleHealthStatuslook = "cienaCesModuleHealthStatus." + $11
						$cienaCesModuleHealthStatus = lookup($cienaCesModuleHealthStatuslook,CienaVarbindValTable)
						if(match($cienaCesModuleHealthStatus,"UNKNOWN")) {
							$cienaCesModuleHealthStatus = $11
						} else {
							$cienaCesModuleHealthStatus = $cienaCesModuleHealthStatus + " ( " + $11 + " )"
						}
						$cienaCesModuleHealthStatusLastlook = "cienaCesModuleHealthStatusLast." + $12
						$cienaCesModuleHealthStatusLast = lookup($cienaCesModuleHealthStatusLastlook,CienaVarbindValTable)
						if(match($cienaCesModuleHealthStatusLast,"UNKNOWN")) {
							$cienaCesModuleHealthStatusLast = $12
						} else {
							$cienaCesModuleHealthStatusLast = $cienaCesModuleHealthStatusLast + " ( " + $12 + " )"
						}
						@AlertGroup = "Ciena OME Traps"
						@Agent = "ciena.m2r.include.rules"
						@Summary = "cienaCesModuleHealthStatusGoodNotification: Health Manager detected a status change to good for module in slot " + $cienaCesModuleSlotNotifIndx
						@Severity = 2
						@Type = 1
						@Identifier = @Node + @Summary
						details($*)

					case "7": ### - cienaCesModuleSensorHighTempNotification
						# SNMPv2
						# This notification is sent when the cienaCesModuleSensor temperature exceeds the high
						# temperature threshold for the module.
						# To enable the device to send this notification:
						# - cienaCesModuleAllModulesTrapState needs to be set to enabled.
						# - cienaCesModuleSensorTrapState needs to be set to enabled.
						# The above values are set to enabled by default. Variable bindings include:
						# cienaGlobalSeverity, cienaGlobalMacAddress, cienaCesModuleChassisNotifIndx,
						# cienaCesModuleShelfNotifIndx, cienaCesModuleSlotNotifIndx,
						# cienaCesModuleSensorNotifIndx, cienaCesModuleSensorDescription,
						# cienaCesModuleSensorCurrentTemp, and cienaCesModuleSensorHighTempThreshold.
						$cienaGlobalSeveritylook = "cienaGlobalSeverity." + $1
						$cienaGlobalSeverity = lookup($cienaGlobalSeveritylook,CienaVarbindValTable)
						if(match($cienaGlobalSeverity,"UNKNOWN")) {
