						}
						$cienaCesGmplsNotifEncapTunnelFaultedNodeId = $7
						@AlertGroup = "Ciena OME Traps"
						@Agent = "ciena.m2r.include.rules"
						@Summary = "cienaCesGmplsEncapCoroutedTunnelAisFaultStateChgTrap: Encap corouted tunnel " + $cienaCesGmplsNotifEncapTunnelName + " AIS fault state changed"
						@Severity = 3
						@Type = 1
						@Identifier = @Node + @Summary
						details($*)

					case "11": ### - cienaCesGmplsDecapCoroutedTunnelAisFaultStateChgTrap
						# SNMPv2
						# This notification is sent when the decap corouted tunnel AIS fault state
						# changes. Variable bindings include: cienaGlobalSeverity,
						# cienaGlobalMacAddress, cienaCesGmplsNotifDecapTunnelIndex,
						# cienaCesGmplsNotifDecapTunnelType, cienaCesGmplsNotifDecapTunnelName,
						# cienaCesGmplsNotifDecapTunnelAisFaulted and cienaCesGmplsNotifDecapTunnelFaultedNodeId.
						$cienaGlobalSeveritylook = "cienaGlobalSeverity." + $1
						$cienaGlobalSeverity = lookup($cienaGlobalSeveritylook,CienaVarbindValTable)
						if(match($cienaGlobalSeverity,"UNKNOWN")) {
							$cienaGlobalSeverity = $1
						} else {
							$cienaGlobalSeverity = $cienaGlobalSeverity + " ( " + $1 + " )"
						}
						$cienaGlobalMacAddress = $2
						$cienaCesGmplsNotifDecapTunnelIndex = $3
						$cienaCesGmplsNotifDecapTunnelTypelook = "cienaCesGmplsNotifDecapTunnelType." + $4
						$cienaCesGmplsNotifDecapTunnelType = lookup($cienaCesGmplsNotifDecapTunnelTypelook,CienaVarbindValTable)
						if(match($cienaCesGmplsNotifDecapTunnelType,"UNKNOWN")) {
							$cienaCesGmplsNotifDecapTunnelType = $4
						} else {
							$cienaCesGmplsNotifDecapTunnelType = $cienaCesGmplsNotifDecapTunnelType + " ( " + $4 + " )"
						}
						$cienaCesGmplsNotifDecapTunnelName = $5
						$cienaCesGmplsNotifDecapTunnelAisFaultedlook = "cienaCesGmplsNotifDecapTunnelAisFaulted." + $6
						$cienaCesGmplsNotifDecapTunnelAisFaulted = lookup($cienaCesGmplsNotifDecapTunnelAisFaultedlook,CienaVarbindValTable)
						if(match($cienaCesGmplsNotifDecapTunnelAisFaulted,"UNKNOWN")) {
							$cienaCesGmplsNotifDecapTunnelAisFaulted = $6
						} else {
							$cienaCesGmplsNotifDecapTunnelAisFaulted = $cienaCesGmplsNotifDecapTunnelAisFaulted + " ( " + $6 + " )"
						}
						$cienaCesGmplsNotifDecapTunnelFaultedNodeId = $7
						@AlertGroup = "Ciena OME Traps"
						@Agent = "ciena.m2r.include.rules"
						@Summary = "cienaCesGmplsDecapCoroutedTunnelAisFaultStateChgTrap: Decap corouted tunnel " + $cienaCesGmplsNotifDecapTunnelName + " AIS fault state"
						@Severity = 3
						@Type = 1
						@Identifier = @Node + @Summary
						details($*)

					case "12": ### - cienaCesGmplsAssociatedTunnelAisFaultStateChgTrap
						# SNMPv2
						# This notification is sent when the associated tunnel AIS fault state
						# changes. Variable bindings include: cienaGlobalSeverity,
						# cienaGlobalMacAddress, cienaCesGmplsNotifAssociatedTunnelIndex,
						# cienaCesGmplsNotifAssociatedTunnelType, cienaCesGmplsNotifAssociatedTunnelName,
						# cienaCesGmplsNotifAssociatedTunnelAisFaulted and cienaCesGmplsNotifAssociatedTunnelFaultedNodeId.
						$cienaGlobalSeveritylook = "cienaGlobalSeverity." + $1
						$cienaGlobalSeverity = lookup($cienaGlobalSeveritylook,CienaVarbindValTable)
						if(match($cienaGlobalSeverity,"UNKNOWN")) {
							$cienaGlobalSeverity = $1
						} else {
							$cienaGlobalSeverity = $cienaGlobalSeverity + " ( " + $1 + " )"
						}
						$cienaGlobalMacAddress = $2
						$cienaCesGmplsNotifAssociatedTunnelIndex = $3
						$cienaCesGmplsNotifAssociatedTunnelTypelook = "cienaCesGmplsNotifAssociatedTunnelType." + $4
						$cienaCesGmplsNotifAssociatedTunnelType = lookup($cienaCesGmplsNotifAssociatedTunnelTypelook,CienaVarbindValTable)
						if(match($cienaCesGmplsNotifAssociatedTunnelType,"UNKNOWN")) {
							$cienaCesGmplsNotifAssociatedTunnelType = $4
						} else {
							$cienaCesGmplsNotifAssociatedTunnelType = $cienaCesGmplsNotifAssociatedTunnelType + " ( " + $4 + " )"
						}
						$cienaCesGmplsNotifAssociatedTunnelName = $5
						$cienaCesGmplsNotifAssociatedTunnelAisFaultedlook = "cienaCesGmplsNotifAssociatedTunnelAisFaulted." + $6
						$cienaCesGmplsNotifAssociatedTunnelAisFaulted = lookup($cienaCesGmplsNotifAssociatedTunnelAisFaultedlook,CienaVarbindValTable)
						if(match($cienaCesGmplsNotifAssociatedTunnelAisFaulted,"UNKNOWN")) {
							$cienaCesGmplsNotifAssociatedTunnelAisFaulted = $6
						} else {
							$cienaCesGmplsNotifAssociatedTunnelAisFaulted = $cienaCesGmplsNotifAssociatedTunnelAisFaulted + " ( " + $6 + " )"
						}
						$cienaCesGmplsNotifAssociatedTunnelFaultedNodeId = $7
						@AlertGroup = "Ciena OME Traps"
						@Agent = "ciena.m2r.include.rules"
						@Summary = "cienaCesGmplsAssociatedTunnelAisFaultStateChgTrap: Associated tunnel AIS fault state changed for " + $cienaCesGmplsNotifAssociatedTunnelName
						@Severity = 3
						@Type = 1
						@Identifier = @Node + @Summary
						details($*)

					case "13": ### - cienaCesGmplsTunnelAisFaultErrorTrap
						# SNMPv2
						# This notification is sent when there is a fault sent for a
						# LSP whose label is not associated with any tunnel. This will happen
						# whenever the AIS admin state is disabled for the bidirectional tunnel.
						# Variable bindings include: cienaGlobalSeverity,
						# cienaGlobalMacAddress, cienaCesGmplsNotifTunnelDecapLabel,
						# and cienaCesGmplsNotifTunnelErrorMsg
						$cienaGlobalSeveritylook = "cienaGlobalSeverity." + $1
						$cienaGlobalSeverity = lookup($cienaGlobalSeveritylook,CienaVarbindValTable)
						if(match($cienaGlobalSeverity,"UNKNOWN")) {
							$cienaGlobalSeverity = $1
						} else {
							$cienaGlobalSeverity = $cienaGlobalSeverity + " ( " + $1 + " )"
						}
						$cienaGlobalMacAddress = $2
						$cienaCesGmplsNotifTunnelDecapLabel = $3
						$cienaCesGmplsNotifTunnelErrorMsg = $4
						@AlertGroup = "Ciena OME Traps"
						@Agent = "ciena.m2r.include.rules"
						@Summary = "cienaCesGmplsTunnelAisFaultErrorTrap: AIS admin state is disabled for a bidirectional tunnel"
						@Severity = 3
						@Type = 1
						@Identifier = @Node + @Summary
						details($*)

						case "14": ### - cienaCesGmplsEncapTunnelResizeResultTrap
						# SNMPv2
						# This notification is sent when the tunnel auto size is done
						# Variable bindings include: cienaGlobalSeverity,
						# cienaGlobalMacAddress, cienaCesGmplsNotifEncapTunnelIndex,
						# cienaCesGmplsNotifEncapTunnelType, cienaCesGmplsNotifEncapTunnelName,
						# cienaCesGmplsNotifEncapTunnelResult, cienaCesGmplsNotifEncapTunnelProtectionRole,
						# cienaCesGmplsNotifEncapTunnelRequestedBw and
						# cienaCesGmplsNotifEncapTunnelOperationalBw.
						$cienaGlobalSeveritylook = "cienaGlobalSeverity." + $1
						$cienaGlobalSeverity = lookup($cienaGlobalSeveritylook,CienaVarbindValTable)
						if(match($cienaGlobalSeverity,"UNKNOWN")) {
							$cienaGlobalSeverity = $1
						} else {
							$cienaGlobalSeverity = $cienaGlobalSeverity + " ( " + $1 + " )"
						}
						$cienaGlobalMacAddress = $2
						$cienaCesGmplsNotifEncapTunnelIndex = $3
						$cienaCesGmplsNotifEncapTunnelTypelook = "cienaCesGmplsNotifEncapTunnelType." + $4
						$cienaCesGmplsNotifEncapTunnelType = lookup($cienaCesGmplsNotifEncapTunnelTypelook,CienaVarbindValTable)
						if(match($cienaCesGmplsNotifEncapTunnelType,"UNKNOWN")) {
							$cienaCesGmplsNotifEncapTunnelType = $4
						} else {
							$cienaCesGmplsNotifEncapTunnelType = $cienaCesGmplsNotifEncapTunnelType + " ( " + $4 + " )"
						}
						$cienaCesGmplsNotifEncapTunnelName = $5
						$cienaCesGmplsNotifEncapTunnelResultlook = "cienaCesGmplsNotifEncapTunnelResult." + $6
						$cienaCesGmplsNotifEncapTunnelResult = lookup($cienaCesGmplsNotifEncapTunnelResultlook,CienaVarbindValTable)
						if(match($cienaCesGmplsNotifEncapTunnelResult,"UNKNOWN")) {
							$cienaCesGmplsNotifEncapTunnelResult = $6
						} else {
							$cienaCesGmplsNotifEncapTunnelResult = $cienaCesGmplsNotifEncapTunnelResult + " ( " + $6 + " )"
						}
						$cienaCesGmplsNotifEncapTunnelProtectionRolelook = "cienaCesGmplsNotifEncapTunnelProtectionRole." + $7
						$cienaCesGmplsNotifEncapTunnelProtectionRole = lookup($cienaCesGmplsNotifEncapTunnelProtectionRolelook,CienaVarbindValTable)
						if(match($cienaCesGmplsNotifEncapTunnelProtectionRole,"UNKNOWN")) {
							$cienaCesGmplsNotifEncapTunnelProtectionRole = $7
						} else {
							$cienaCesGmplsNotifEncapTunnelProtectionRole = $cienaCesGmplsNotifEncapTunnelProtectionRole + " ( " + $7 + " )"
						}
						$cienaCesGmplsNotifEncapTunnelRequestedBw = $8
						$cienaCesGmplsNotifEncapTunnelOperationalBw = $9
						@AlertGroup = "Ciena OME Traps"
						@Agent = "ciena.m2r.include.rules"
						@Summary = "cienaCesGmplsEncapTunnelResizeResultTrap: Tunnel was auto-sized"
						@Severity = 3
						@Type = 1
						@Identifier = @Node + @Summary
						details($cienaGlobalSeverity,$cienaGlobalMacAddress,$cienaCesGmplsNotifEncapTunnelIndex,$cienaCesGmplsNotifEncapTunnelType,$cienaCesGmplsNotifEncapTunnelName,$cienaCesGmplsNotifEncapTunnelResult,$cienaCesGmplsNotifEncapTunnelProtectionRole,$cienaCesGmplsNotifEncapTunnelRequestedBw,$cienaCesGmplsNotifEncapTunnelOperationalBw)

					case "15": ### - cienaCesGmplsEncapTunnelMbbResultTrap
						# SNMPv2
						# This notification is sent when the tunnel MBB done
						# Variable bindings include: cienaGlobalSeverity,
						# cienaGlobalMacAddress, cienaCesGmplsNotifEncapTunnelIndex,
						# cienaCesGmplsNotifEncapTunnelType, cienaCesGmplsNotifEncapTunnelName,
						# cienaCesGmplsNotifEncapTunnelProtectionRole,
						# cienaCesGmplsNotifEncapTunnelRequestedBw,
						# cienaCesGmplsNotifEncapTunnelOperationalBw and
						# cienaCesGmplsNotifEncapTunnelParentApp.
						$cienaGlobalSeveritylook = "cienaGlobalSeverity." + $1
						$cienaGlobalSeverity = lookup($cienaGlobalSeveritylook,CienaVarbindValTable)
						if(match($cienaGlobalSeverity,"UNKNOWN")) {
							$cienaGlobalSeverity = $1
						} else {
							$cienaGlobalSeverity = $cienaGlobalSeverity + " ( " + $1 + " )"
						}
						$cienaGlobalMacAddress = $2
						$cienaCesGmplsNotifEncapTunnelIndex = $3
						$cienaCesGmplsNotifEncapTunnelTypelook = "cienaCesGmplsNotifEncapTunnelType." + $4
						$cienaCesGmplsNotifEncapTunnelType = lookup($cienaCesGmplsNotifEncapTunnelTypelook,CienaVarbindValTable)
						if(match($cienaCesGmplsNotifEncapTunnelType,"UNKNOWN")) {
							$cienaCesGmplsNotifEncapTunnelType = $4
						} else {
							$cienaCesGmplsNotifEncapTunnelType = $cienaCesGmplsNotifEncapTunnelType + " ( " + $4 + " )"
						}
						$cienaCesGmplsNotifEncapTunnelName = $5
						$cienaCesGmplsNotifEncapTunnelResultlook = "cienaCesGmplsNotifEncapTunnelResult." + $6
						$cienaCesGmplsNotifEncapTunnelResult = lookup($cienaCesGmplsNotifEncapTunnelResultlook,CienaVarbindValTable)
						if(match($cienaCesGmplsNotifEncapTunnelResult,"UNKNOWN")) {
							$cienaCesGmplsNotifEncapTunnelResult = $6
						} else {
							$cienaCesGmplsNotifEncapTunnelResult = $cienaCesGmplsNotifEncapTunnelResult + " ( " + $6 + " )"
						}
						$cienaCesGmplsNotifEncapTunnelProtectionRolelook = "cienaCesGmplsNotifEncapTunnelProtectionRole." + $7
						$cienaCesGmplsNotifEncapTunnelProtectionRole = lookup($cienaCesGmplsNotifEncapTunnelProtectionRolelook,CienaVarbindValTable)
						if(match($cienaCesGmplsNotifEncapTunnelProtectionRole,"UNKNOWN")) {
							$cienaCesGmplsNotifEncapTunnelProtectionRole = $7
						} else {
							$cienaCesGmplsNotifEncapTunnelProtectionRole = $cienaCesGmplsNotifEncapTunnelProtectionRole + " ( " + $7 + " )"
						}
						$cienaCesGmplsNotifEncapTunnelRequestedBw = $8
						$cienaCesGmplsNotifEncapTunnelOperationalBw = $9
						$cienaCesGmplsNotifEncapTunnelMbbParentApplook = "cienaCesGmplsNotifEncapTunnelMbbParentApp." + $10
						$cienaCesGmplsNotifEncapTunnelMbbParentApp = lookup($cienaCesGmplsNotifEncapTunnelMbbParentApplook,CienaVarbindValTable)
						if(match($cienaCesGmplsNotifEncapTunnelMbbParentApp,"UNKNOWN")) {
							$cienaCesGmplsNotifEncapTunnelMbbParentApp = $10
						} else {
							$cienaCesGmplsNotifEncapTunnelMbbParentApp = $cienaCesGmplsNotifEncapTunnelMbbParentApp + " ( " + $10 + " )"
						}
						@AlertGroup = "Ciena OME Traps"
						@Agent = "ciena.m2r.include.rules"
						@Summary = "cienaCesGmplsEncapTunnelMbbResultTrap: " + $cienaCesGmplsNotifEncapTunnelName + " Tunnel MBB completed"
						@Severity = 3
						@Type = 1
						@Identifier = @Node + @Summary
						details($cienaGlobalSeverity,$cienaGlobalMacAddress,$cienaCesGmplsNotifEncapTunnelIndex,$cienaCesGmplsNotifEncapTunnelType,$cienaCesGmplsNotifEncapTunnelName,$cienaCesGmplsNotifEncapTunnelResult,$cienaCesGmplsNotifEncapTunnelProtectionRole,$cienaCesGmplsNotifEncapTunnelRequestedBw,$cienaCesGmplsNotifEncapTunnelOperationalBw,$cienaCesGmplsNotifEncapTunnelMbbParentApp)


					default:
						@Summary = "Unknown specific trap number (" + $specific-trap + ") received for enterprise " + $enterprise
						@Identifier = @Node + $enterprise + $generic-trap + $specific-trap + @Agent + @Manager
						@Severity = 3
						@Type = 1
						details($*)
				}

			######
			# cienaCesMplsPwMIBNotifications traps
			######
			case ".1.3.6.1.4.1.1271.2.2.17.2":	### - cienaCesMplsPwMIBNotifications
				switch($specific-trap) {
					case "1": ### - cienaCesMplsPwDown
						# SNMPv2
						# This notification is sent when the operational state of a pseudowire
						# has changed from up to down.
						$cienaGlobalSeveritylook = "cienaGlobalSeverity." + $1
						$cienaGlobalSeverity = lookup($cienaGlobalSeveritylook,CienaVarbindValTable)
						if(match($cienaGlobalSeverity,"UNKNOWN")) {
							$cienaGlobalSeverity = $1
						} else {
							$cienaGlobalSeverity = $cienaGlobalSeverity + " ( " + $1 + " )"
						}
						$cienaGlobalMacAddress = $2
						$cienaCesMplsPwNotifPwIndex = $3
						$cienaCesMplsPwNotifPwName = $4
						$cienaCesMplsPwNotifPwId = $5
						$cienaCesMplsPwNotifPwPeerIpAddr = $6
						@AlertGroup = "Ciena OME Traps"
						@Agent = "ciena.m2r.include.rules"
						@Summary = "cienaCesMplsPwDown: This notification is sent when the operational state of a pseudowire has changed from up to down."
						@Severity = 3
						@Type = 1
						@Identifier = @Node + @Summary
						details($*)

					case "2": ### - cienaCesMplsPwUp
						# SNMPv2
						# This notification is sent when the operational state of a pseudowire
						# has changed from down to up.
						$cienaGlobalSeveritylook = "cienaGlobalSeverity." + $1
						$cienaGlobalSeverity = lookup($cienaGlobalSeveritylook,CienaVarbindValTable)
						if(match($cienaGlobalSeverity,"UNKNOWN")) {
							$cienaGlobalSeverity = $1
						} else {
							$cienaGlobalSeverity = $cienaGlobalSeverity + " ( " + $1 + " )"
						}
						$cienaGlobalMacAddress = $2
						$cienaCesMplsPwNotifPwIndex = $3
						$cienaCesMplsPwNotifPwName = $4
						$cienaCesMplsPwNotifPwId = $5
						$cienaCesMplsPwNotifPwPeerIpAddr = $6
						@AlertGroup = "Ciena OME Traps"
						@Agent = "ciena.m2r.include.rules"
						@Summary = "cienaCesMplsPwUp: This notification is sent when the operational state of a pseudowire has changed from down to up."
						@Severity = 3
						@Type = 1
						@Identifier = @Node + @Summary
						details($*)

					case "3": ### - cienaCesMplsPwBundleActivePwChange
						# SNMPv2
						# This notification is sent when the active member of the pseudowire
						# bundle has changed.
						$cienaGlobalSeveritylook = "cienaGlobalSeverity." + $1
						$cienaGlobalSeverity = lookup($cienaGlobalSeveritylook,CienaVarbindValTable)
						if(match($cienaGlobalSeverity,"UNKNOWN")) {
							$cienaGlobalSeverity = $1
						} else {
							$cienaGlobalSeverity = $cienaGlobalSeverity + " ( " + $1 + " )"
						}
						$cienaGlobalMacAddress = $2
						$cienaCesMplsPwNotifActPwIndex = $3
						$cienaCesMplsPwNotifActPwName = $4
						$cienaCesMplsPwNotifActPwId = $5
						$cienaCesMplsPwNotifActPwPeerIpAddr = $6
						$cienaCesMplsPwNotifPriPwName = $7
						$cienaCesMplsPwNotifPriPwId = $8
						$cienaCesMplsPwNotifPriPwPeerIpAddr = $9
						@AlertGroup = "Ciena OME Traps"
						@Agent = "ciena.m2r.include.rules"
						@Summary = "cienaCesMplsPwBundleActivePwChange: This notification is sent when the active member of the pseudowire bundle has changed."
						@Severity = 3
						@Type = 1
						@Identifier = @Node + @Summary
						details($*)

					default:
						@Summary = "Unknown specific trap number (" + $specific-trap + ") received for enterprise " + $enterprise
						@Identifier = @Node + $enterprise + $generic-trap + $specific-trap + @Agent + @Manager
						@Severity = 3
						@Type = 1
						details($*)
				}

			######
			# cienaCesRapsMIBNotifications traps
			######
			case ".1.3.6.1.4.1.1271.2.2.18":	### - cienaCesRapsMIBNotificationPrefix
				switch($specific-trap) {
					case "1": ### - cienaCesRapsAlarmClearNotification
						# SNMPv2
						# A alarm notification is sent when an alarm is cleared. The cause field will indicate which alarm
						# is cleared.
						# To enable this notification, cienaCesRapsAlarmTrapState must be enabled.
						# By default this trap state is enabled. Variable bindings include:
						# cienaGlobalSeverity, cienaGlobalMacAddress,
						# cienaCesRapsVirtualRingNotifIndex,cienaCesRapsVirtualRingName,
						# and cienaCesRapsVirtualRingAlarm.
						$cienaGlobalSeveritylook = "cienaGlobalSeverity." + $1
						$cienaGlobalSeverity = lookup($cienaGlobalSeveritylook,CienaVarbindValTable)
						if(match($cienaGlobalSeverity,"UNKNOWN")) {
							$cienaGlobalSeverity = $1
						} else {
							$cienaGlobalSeverity = $cienaGlobalSeverity + " ( " + $1 + " )"
						}
						$cienaGlobalMacAddress = $2
						$cienaCesRapsVirtualRingNotifIndex = $3
						$cienaCesRapsVirtualRingName = $4
						$cienaCesRapsVirtualRingAlarmlook = "cienaCesRapsVirtualRingAlarm." + $5
						$cienaCesRapsVirtualRingAlarm = lookup($cienaCesRapsVirtualRingAlarmlook,CienaVarbindValTable)
						if(match($cienaCesRapsVirtualRingAlarm,"UNKNOWN")) {
							$cienaCesRapsVirtualRingAlarm = $5
						} else {
							$cienaCesRapsVirtualRingAlarm = $cienaCesRapsVirtualRingAlarm + " ( " + $5 + " )"
						}
						@AlertGroup = "Ciena OME Traps"
						@Agent = "ciena.m2r.include.rules"
						@Summary = "cienaCesRapsAlarmClearNotification: Carrier Ethernet Service (CES) Ring Protection Switching (RAPS) alarm cleared for ring " + $cienaCesRapsVirtualRingName
						@Severity = 3
						@Type = 1
						@Identifier = @Node + @Summary
						details($*)

					case "2": ### - cienaCesRapsAlarmProtectionSwitchingNotification
						# SNMPv2
						# A alarm notification is sent when a ring detects a Protection-Switch-Active
						# condition. To enable this notification, cienaCesRapsAlarmTrapState must be enabled.
						# By default this trap state is enabled. Variable bindings include:
						# cienaGlobalSeverity, cienaGlobalMacAddress, cienaCesRapsVirtualRingNotifIndex,
						# cienaCesRapsVirtualRingName, and cienaCesRapsVirtualRingAlarm.
						$cienaGlobalSeveritylook = "cienaGlobalSeverity." + $1
						$cienaGlobalSeverity = lookup($cienaGlobalSeveritylook,CienaVarbindValTable)
						if(match($cienaGlobalSeverity,"UNKNOWN")) {
							$cienaGlobalSeverity = $1
						} else {
							$cienaGlobalSeverity = $cienaGlobalSeverity + " ( " + $1 + " )"
						}
						$cienaGlobalMacAddress = $2
						$cienaCesRapsVirtualRingNotifIndex = $3
						$cienaCesRapsVirtualRingName = $4
						$cienaCesRapsVirtualRingAlarmlook = "cienaCesRapsVirtualRingAlarm." + $5
						$cienaCesRapsVirtualRingAlarm = lookup($cienaCesRapsVirtualRingAlarmlook,CienaVarbindValTable)
						if(match($cienaCesRapsVirtualRingAlarm,"UNKNOWN")) {
							$cienaCesRapsVirtualRingAlarm = $5
						} else {
							$cienaCesRapsVirtualRingAlarm = $cienaCesRapsVirtualRingAlarm + " ( " + $5 + " )"
						}
						@AlertGroup = "Ciena OME Traps"
						@Agent = "ciena.m2r.include.rules"
						@Summary = "cienaCesRapsAlarmProtectionSwitchingNotification"
						@Severity = 3
						@Type = 1
						@Identifier = @Node + @Summary
						details($*)

					case "3": ### - cienaCesRapsAlarmProvisionMismatchNotification
						# SNMPv2
						# A alarm notification is sent when a ring detects a Provisioning-Mismatch
						# condition. To enable this notification, cienaCesRapsAlarmTrapState must be enabled.
						# By default this trap state is enabled. Variable bindings include:
						# cienaGlobalSeverity, cienaGlobalMacAddress, cienaCesRapsVirtualRingNotifIndex,
						# cienaCesRapsVirtualRingName, and cienaCesRapsVirtualRingAlarm.
						$cienaGlobalSeveritylook = "cienaGlobalSeverity." + $1
						$cienaGlobalSeverity = lookup($cienaGlobalSeveritylook,CienaVarbindValTable)
						if(match($cienaGlobalSeverity,"UNKNOWN")) {
							$cienaGlobalSeverity = $1
						} else {
							$cienaGlobalSeverity = $cienaGlobalSeverity + " ( " + $1 + " )"
						}
						$cienaGlobalMacAddress = $2
						$cienaCesRapsVirtualRingNotifIndex = $3
						$cienaCesRapsVirtualRingName = $4
						$cienaCesRapsVirtualRingAlarmlook = "cienaCesRapsVirtualRingAlarm." + $5
						$cienaCesRapsVirtualRingAlarm = lookup($cienaCesRapsVirtualRingAlarmlook,CienaVarbindValTable)
						if(match($cienaCesRapsVirtualRingAlarm,"UNKNOWN")) {
							$cienaCesRapsVirtualRingAlarm = $5
						} else {
							$cienaCesRapsVirtualRingAlarm = $cienaCesRapsVirtualRingAlarm + " ( " + $5 + " )"
						}
						@AlertGroup = "Ciena OME Traps"
						@Agent = "ciena.m2r.include.rules"
						@Summary = "cienaCesRapsAlarmProvisionMismatchNotification: Provisioning-Mismatch condition detected"
						@Severity = 3
						@Type = 1
						@Identifier = @Node + @Summary
						details($*)

					case "4": ### - cienaCesRapsAlarmNoRapsPduReceivedNotification
						# SNMPv2
						# On a major-ring, a node is not receiving any R-APS messages on a ringlet port
						# for at least 3.5 consecutive long R-APS frame intervals (i.e. 3.5 * 5 = total 17.5 seconds)
						# while that ring port does not report any link level failures and is not administratively disabled.
						# On a sub-ring, a node is not receiving R-APS messages on either ringlet port for at least 3.5
						# consecutive long R-APS frame intervals (i.e. 3.5 * 5 = total 17.5 seconds) while that ring port
						# does not report any link level failures and is not administratively disabled.
						# To enable this notification, cienaCesRapsAlarmTrapState must be enabled.
						# By default this trap state is enabled. Variable bindings include:
						# cienaGlobalSeverity, cienaGlobalMacAddress, cienaCesRapsVirtualRingNotifIndex,
						# cienaCesRapsVirtualRingName, and cienaCesRapsVirtualRingAlarm.
						$cienaGlobalSeveritylook = "cienaGlobalSeverity." + $1
						$cienaGlobalSeverity = lookup($cienaGlobalSeveritylook,CienaVarbindValTable)
						if(match($cienaGlobalSeverity,"UNKNOWN")) {
							$cienaGlobalSeverity = $1
						} else {
							$cienaGlobalSeverity = $cienaGlobalSeverity + " ( " + $1 + " )"
						}
						$cienaGlobalMacAddress = $2
						$cienaCesRapsVirtualRingNotifIndex = $3
						$cienaCesRapsVirtualRingName = $4
						$cienaCesRapsVirtualRingAlarmlook = "cienaCesRapsVirtualRingAlarm." + $5
						$cienaCesRapsVirtualRingAlarm = lookup($cienaCesRapsVirtualRingAlarmlook,CienaVarbindValTable)
						if(match($cienaCesRapsVirtualRingAlarm,"UNKNOWN")) {
							$cienaCesRapsVirtualRingAlarm = $5
						} else {
							$cienaCesRapsVirtualRingAlarm = $cienaCesRapsVirtualRingAlarm + " ( " + $5 + " )"
						}
						@AlertGroup = "Ciena OME Traps"
						@Agent = "ciena.m2r.include.rules"
						@Summary = "cienaCesRapsAlarmNoRapsPduReceivedNotification: On a major-ring, a node is not receiving any R-APS messages on a ringlet port for at least 3.5 consecutive long R-APS frame intervals"
						@Severity = 3
						@Type = 1
						@Identifier = @Node + @Summary
						details($*)

					case "5": ### - cienaCesRapsAlarmNoRplOwnerDetectedNotification
						# SNMPv2
						# A ringlet instance that is not the RPL Owner receives no R-APS OK message while
						# it is transmitting R-APS RIM messages for 13 or more minutes.
						# To enable this notification, cienaCesRapsAlarmTrapState must be enabled.
						# By default this trap state is enabled. Variable bindings include:
						# cienaGlobalSeverity, cienaGlobalMacAddress, cienaCesRapsVirtualRingNotifIndex,
						# cienaCesRapsVirtualRingName, and cienaCesRapsVirtualRingAlarm.
						$cienaGlobalSeveritylook = "cienaGlobalSeverity." + $1
						$cienaGlobalSeverity = lookup($cienaGlobalSeveritylook,CienaVarbindValTable)
						if(match($cienaGlobalSeverity,"UNKNOWN")) {
							$cienaGlobalSeverity = $1
						} else {
							$cienaGlobalSeverity = $cienaGlobalSeverity + " ( " + $1 + " )"
						}
						$cienaGlobalMacAddress = $2
						$cienaCesRapsVirtualRingNotifIndex = $3
						$cienaCesRapsVirtualRingName = $4
						$cienaCesRapsVirtualRingAlarmExtended = $5
						@AlertGroup = "Ciena OME Traps"
						@Agent = "ciena.m2r.include.rules"
						@Summary = "cienaCesRapsAlarmNoRplOwnerDetectedNotification: A ringlet instance that is not the RPL Owner receives no R-APS OK message while it is transmitting R-APS RIM messages for 13 or more minutes."
						@Severity = 3
						@Type = 1
						@Identifier = @Node + @Summary
						details($*)

					default:
						@Summary = "Unknown specific trap number (" + $specific-trap + ") received for enterprise " + $enterprise
						@Identifier = @Node + $enterprise + $generic-trap + $specific-trap + @Agent + @Manager
						@Severity = 3
						@Type = 1
						details($*)
				}

			######
			# cienaCesBfdSessionMIBNotification traps
			######
			case ".1.3.6.1.4.1.1271.2.2.19":	### - cienaCesBfdSessionMIBNotificationPrefix
				switch($specific-trap) {
					case "1": ### - cienaCesBfdSessionOperStateChangeTrap
						# SNMPv2
						# A notification is sent whenever the BFD session operational state has changed. To enable this notification, the
						# cienaCesBfdSessionOperTrapState object must be enabled (which is enabled by default). Variable bindings
						# include: cienaGlobalSeverity, cienaGlobalMacAddress, cienaCesBfdSessionName, cienaCesBfdSessionIndex,
						# cienaCesBfdSessionAdminState, and cienaCesBfdSessionOperState.
						$cienaGlobalSeveritylook = "cienaGlobalSeverity." + $1
						$cienaGlobalSeverity = lookup($cienaGlobalSeveritylook,CienaVarbindValTable)
						if(match($cienaGlobalSeverity,"UNKNOWN")) {
							$cienaGlobalSeverity = $1
						} else {
							$cienaGlobalSeverity = $cienaGlobalSeverity + " ( " + $1 + " )"
						}
						$cienaGlobalMacAddress = $2
						$cienaCesBfdSessionName = $3
						$cienaCesBfdSessionIndex = $4
						$cienaCesBfdSessionAdminStatelook = "cienaCesBfdSessionAdminState." + $5
						$cienaCesBfdSessionAdminState = lookup($cienaCesBfdSessionAdminStatelook,CienaVarbindValTable)
						if(match($cienaCesBfdSessionAdminState,"UNKNOWN")) {
							$cienaCesBfdSessionAdminState = $5
						} else {
							$cienaCesBfdSessionAdminState = $cienaCesBfdSessionAdminState + " ( " + $5 + " )"
						}
						$cienaCesBfdSessionOperStatelook = "cienaCesBfdSessionOperState." + $6
						$cienaCesBfdSessionOperState = lookup($cienaCesBfdSessionOperStatelook,CienaVarbindValTable)
						if(match($cienaCesBfdSessionOperState,"UNKNOWN")) {
							$cienaCesBfdSessionOperState = $6
						} else {
							$cienaCesBfdSessionOperState = $cienaCesBfdSessionOperState + " ( " + $6 + " )"
						}
						@AlertGroup = "Ciena OME Traps"
						@Agent = "ciena.m2r.include.rules"
						@Summary = "cienaCesBfdSessionOperStateChangeTrap: BFD session operational state has changed"
						@Severity = 3
						@Type = 1
						@Identifier = @Node + @Summary
						details($*)

					default:
						@Summary = "Unknown specific trap number (" + $specific-trap + ") received for enterprise " + $enterprise
						@Identifier = @Node + $enterprise + $generic-trap + $specific-trap + @Agent + @Manager
						@Severity = 3
						@Type = 1
						details($*)
				}

			######
			# cienaCesMgmtInterfaceMIBNotifications traps
			######
			case ".1.3.6.1.4.1.1271.2.2.27":	### - cienaCesMgmtInterfaceMIBNotificationPrefix
				switch($specific-trap) {
					case "1": ### - cienaCesInetMgmtAddrChangeNotification
						# SNMPv2
						# A cienaCesInetMgmtAddrChangeNotification is sent when the
						# inet address of the associated interface changes.
						$cienaGlobalSeveritylook = "cienaGlobalSeverity." + $1
						$cienaGlobalSeverity = lookup($cienaGlobalSeveritylook,CienaVarbindValTable)
						if(match($cienaGlobalSeverity,"UNKNOWN")) {
							$cienaGlobalSeverity = $1
						} else {
							$cienaGlobalSeverity = $cienaGlobalSeverity + " ( " + $1 + " )"
						}
						$cienaGlobalMacAddress = $2
						$cienaCesInetMgmtInterfaceNotifIndex = $3
						$cienaCesInetMgmtInterfaceNotifAddrTypelook = "cienaCesInetMgmtInterfaceNotifAddrType." + $4
						$cienaCesInetMgmtInterfaceNotifAddrType = lookup($cienaCesInetMgmtInterfaceNotifAddrTypelook,CienaVarbindValTable)
						if(match($cienaCesInetMgmtInterfaceNotifAddrType,"UNKNOWN")) {
							$cienaCesInetMgmtInterfaceNotifAddrType = $4
						} else {
							$cienaCesInetMgmtInterfaceNotifAddrType = $cienaCesInetMgmtInterfaceNotifAddrType + " ( " + $4 + " )"
						}
						$cienaCesInetMgmtInterfaceNotifAddr = $5
						$cienaCesInetMgmtInterfaceAddrPrefixLength = $6
						$cienaCesInetMgmtInterfaceName = $7
						@AlertGroup = "Ciena OME Traps"
						@Agent = "ciena.m2r.include.rules"
						@Summary = "cienaCesInetMgmtAddrChangeNotification: A cienaCesInetMgmtAddrChangeNotification is sent when the inet address of the associated interface changes."
						@Severity = 3
						@Type = 1
						@Identifier = @Node + @Summary
						details($*)

					case "2": ### - cienaCesInetMgmtAddrAddedNotification
						# SNMPv2
						# A cienaCesInetMgmtAddrChangeNotification is sent when a new interface
						# is added.
						$cienaGlobalSeveritylook = "cienaGlobalSeverity." + $1
						$cienaGlobalSeverity = lookup($cienaGlobalSeveritylook,CienaVarbindValTable)
						if(match($cienaGlobalSeverity,"UNKNOWN")) {
							$cienaGlobalSeverity = $1
						} else {
							$cienaGlobalSeverity = $cienaGlobalSeverity + " ( " + $1 + " )"
						}
						$cienaGlobalMacAddress = $2
						$cienaCesInetMgmtInterfaceNotifIndex = $3
						$cienaCesInetMgmtInterfaceNotifAddrTypelook = "cienaCesInetMgmtInterfaceNotifAddrType." + $4
						$cienaCesInetMgmtInterfaceNotifAddrType = lookup($cienaCesInetMgmtInterfaceNotifAddrTypelook,CienaVarbindValTable)
						if(match($cienaCesInetMgmtInterfaceNotifAddrType,"UNKNOWN")) {
							$cienaCesInetMgmtInterfaceNotifAddrType = $4
						} else {
							$cienaCesInetMgmtInterfaceNotifAddrType = $cienaCesInetMgmtInterfaceNotifAddrType + " ( " + $4 + " )"
						}
						$cienaCesInetMgmtInterfaceNotifAddr = $5
						$cienaCesInetMgmtInterfaceAddrPrefixLength = $6
						$cienaCesInetMgmtInterfaceName = $7
						@AlertGroup = "Ciena OME Traps"
						@Agent = "ciena.m2r.include.rules"
						@Summary = "cienaCesInetMgmtAddrAddedNotification: A cienaCesInetMgmtAddrChangeNotification is sent when a new interface is added."
						@Severity = 3
						@Type = 1
						@Identifier = @Node + @Summary
						details($*)

					case "3": ### - cienaCesInetMgmtAddrRemovedNotification
						# SNMPv2
						# A cienaCesInetMgmtAddrChangeNotification is sent when an interface
						# is removed.
						$cienaGlobalSeveritylook = "cienaGlobalSeverity." + $1
						$cienaGlobalSeverity = lookup($cienaGlobalSeveritylook,CienaVarbindValTable)
						if(match($cienaGlobalSeverity,"UNKNOWN")) {
							$cienaGlobalSeverity = $1
						} else {
							$cienaGlobalSeverity = $cienaGlobalSeverity + " ( " + $1 + " )"
						}
						$cienaGlobalMacAddress = $2
						$cienaCesInetMgmtInterfaceNotifIndex = $3
						$cienaCesInetMgmtInterfaceNotifAddrTypelook = "cienaCesInetMgmtInterfaceNotifAddrType." + $4
						$cienaCesInetMgmtInterfaceNotifAddrType = lookup($cienaCesInetMgmtInterfaceNotifAddrTypelook,CienaVarbindValTable)
						if(match($cienaCesInetMgmtInterfaceNotifAddrType,"UNKNOWN")) {
							$cienaCesInetMgmtInterfaceNotifAddrType = $4
						} else {
							$cienaCesInetMgmtInterfaceNotifAddrType = $cienaCesInetMgmtInterfaceNotifAddrType + " ( " + $4 + " )"
						}
						$cienaCesInetMgmtInterfaceNotifAddr = $5
						$cienaCesInetMgmtInterfaceAddrPrefixLength = $6
						$cienaCesInetMgmtInterfaceName = $7
						@AlertGroup = "Ciena OME Traps"
						@Agent = "ciena.m2r.include.rules"
						@Summary = "cienaCesInetMgmtAddrRemovedNotification: A cienaCesInetMgmtAddrChangeNotification is sent when an interface is removed."
						@Severity = 3
						@Type = 1
						@Identifier = @Node + @Summary
						details($*)

					case "4": ### - cienaCesInetGatewayAddrChangeNotification
						# SNMPv2
						# A cienaCesInetGatewayAddrChangeNotification is sent
						# when the address associated with the gateway is changed.
						$cienaGlobalSeveritylook = "cienaGlobalSeverity." + $1
						$cienaGlobalSeverity = lookup($cienaGlobalSeveritylook,CienaVarbindValTable)
						if(match($cienaGlobalSeverity,"UNKNOWN")) {
							$cienaGlobalSeverity = $1
						} else {
							$cienaGlobalSeverity = $cienaGlobalSeverity + " ( " + $1 + " )"
						}
						$cienaGlobalMacAddress = $2
						$cienaCesInetGatewayNotifAddrTypelook = "cienaCesInetGatewayNotifAddrType." + $3
						$cienaCesInetGatewayNotifAddrType = lookup($cienaCesInetGatewayNotifAddrTypelook,CienaVarbindValTable)
						if(match($cienaCesInetGatewayNotifAddrType,"UNKNOWN")) {
							$cienaCesInetGatewayNotifAddrType = $3
						} else {
							$cienaCesInetGatewayNotifAddrType = $cienaCesInetGatewayNotifAddrType + " ( " + $3 + " )"
						}
						$cienaCesInetGatewayNotifAddr = $4
						@AlertGroup = "Ciena OME Traps"
						@Agent = "ciena.m2r.include.rules"
						@Summary = "cienaCesInetGatewayAddrChangeNotification: A cienaCesInetGatewayAddrChangeNotification is sent when the address associated with the gateway is changed."
						@Severity = 3
						@Type = 1
						@Identifier = @Node + @Summary
						details($*)

					case "5": ### - cienaCesInetGatewayAddedNotification
						# SNMPv2
						# A cienaCesInetGatewayAddrAddNotification is sent
						# when a new gateway is added.
						$cienaGlobalSeveritylook = "cienaGlobalSeverity." + $1
						$cienaGlobalSeverity = lookup($cienaGlobalSeveritylook,CienaVarbindValTable)
						if(match($cienaGlobalSeverity,"UNKNOWN")) {
							$cienaGlobalSeverity = $1
						} else {
							$cienaGlobalSeverity = $cienaGlobalSeverity + " ( " + $1 + " )"
						}
						$cienaGlobalMacAddress = $2
						$cienaCesInetGatewayNotifAddrTypelook = "cienaCesInetGatewayNotifAddrType." + $3
						$cienaCesInetGatewayNotifAddrType = lookup($cienaCesInetGatewayNotifAddrTypelook,CienaVarbindValTable)
						if(match($cienaCesInetGatewayNotifAddrType,"UNKNOWN")) {
							$cienaCesInetGatewayNotifAddrType = $3
						} else {
							$cienaCesInetGatewayNotifAddrType = $cienaCesInetGatewayNotifAddrType + " ( " + $3 + " )"
						}
						$cienaCesInetGatewayNotifAddr = $4
						@AlertGroup = "Ciena OME Traps"
						@Agent = "ciena.m2r.include.rules"
						@Summary = "cienaCesInetGatewayAddedNotification: A cienaCesInetGatewayAddrAddNotification is sent when a new gateway is added."
						@Severity = 3
						@Type = 1
						@Identifier = @Node + @Summary
						details($*)

					case "6": ### - cienaCesInetGatewayRemovedNotification
						# SNMPv2
						# A cienaCesInetGatewayRemovedNotification is sent
						# when a gateway is removed.
						$cienaGlobalSeveritylook = "cienaGlobalSeverity." + $1
						$cienaGlobalSeverity = lookup($cienaGlobalSeveritylook,CienaVarbindValTable)
						if(match($cienaGlobalSeverity,"UNKNOWN")) {
							$cienaGlobalSeverity = $1
						} else {
							$cienaGlobalSeverity = $cienaGlobalSeverity + " ( " + $1 + " )"
						}
						$cienaGlobalMacAddress = $2
						$cienaCesInetGatewayNotifAddrTypelook = "cienaCesInetGatewayNotifAddrType." + $3
						$cienaCesInetGatewayNotifAddrType = lookup($cienaCesInetGatewayNotifAddrTypelook,CienaVarbindValTable)
						if(match($cienaCesInetGatewayNotifAddrType,"UNKNOWN")) {
							$cienaCesInetGatewayNotifAddrType = $3
						} else {
							$cienaCesInetGatewayNotifAddrType = $cienaCesInetGatewayNotifAddrType + " ( " + $3 + " )"
						}
						$cienaCesInetGatewayNotifAddr = $4
						@AlertGroup = "Ciena OME Traps"
						@Agent = "ciena.m2r.include.rules"
						@Summary = "cienaCesInetGatewayRemovedNotification: A cienaCesInetGatewayRemovedNotification is sent when a gateway is removed."
						@Severity = 3
						@Type = 1
						@Identifier = @Node + @Summary
						details($*)

					default:
						@Summary = "Unknown specific trap number (" + $specific-trap + ") received for enterprise " + $enterprise
						@Identifier = @Node + $enterprise + $generic-trap + $specific-trap + @Agent + @Manager
						@Severity = 3
						@Type = 1
						details($*)
				}

			######
			# cienaCesTimeSyncMIBNotifications traps
			######
			case ".1.3.6.1.4.1.1271.2.2.28":	### - cienaCesTimeSyncMIBNotificationPrefix
				switch($specific-trap) {
					case "1": ### - cienaCesSyncInputPUStateChangeNotification
						# SNMPv2
						# Sent when a timing reference source failed.
						$cienaGlobalSeveritylook = "cienaGlobalSeverity." + $1
						$cienaGlobalSeverity = lookup($cienaGlobalSeveritylook,CienaVarbindValTable)
						if(match($cienaGlobalSeverity,"UNKNOWN")) {
							$cienaGlobalSeverity = $1
						} else {
							$cienaGlobalSeverity = $cienaGlobalSeverity + " ( " + $1 + " )"
						}
						$cienaGlobalMacAddress = $2
						$cienaCesInputPUEntityName = $3
						$cienaCesInputPUPGEntityName = $4
						$cienaCesInputPUTimingInterfaceName = $5
						$cienaCesInputPUTimingInterfaceProtocollook = "cienaCesInputPUTimingInterfaceProtocol." + $6
						$cienaCesInputPUTimingInterfaceProtocol = lookup($cienaCesInputPUTimingInterfaceProtocollook,CienaVarbindValTable)
						if(match($cienaCesInputPUTimingInterfaceProtocol,"UNKNOWN")) {
							$cienaCesInputPUTimingInterfaceProtocol = $6
						} else {
							$cienaCesInputPUTimingInterfaceProtocol = $cienaCesInputPUTimingInterfaceProtocol + " ( " + $6 + " )"
						}
						$cienaCesInputPUOperationalStatuslook = "cienaCesInputPUOperationalStatus." + $7
						$cienaCesInputPUOperationalStatus = lookup($cienaCesInputPUOperationalStatuslook,CienaVarbindValTable)
						if(match($cienaCesInputPUOperationalStatus,"UNKNOWN")) {
							$cienaCesInputPUOperationalStatus = $7
						} else {
							$cienaCesInputPUOperationalStatus = $cienaCesInputPUOperationalStatus + " ( " + $7 + " )"
						}
						@AlertGroup = "Ciena OME Traps"
						@Agent = "ciena.m2r.include.rules"
						@Summary = "cienaCesSyncInputPUStateChangeNotification: Sent when a timing reference source failed."
						@Severity = 3
						@Type = 1
						@Identifier = @Node + @Summary
						details($*)

					case "2": ### - cienaCesSyncInputProtectionGroupStateChangeNotification
						# SNMPv2
						# Sent when system timing could not lock into a reference source
						# and entered hold over state.
						$cienaGlobalSeveritylook = "cienaGlobalSeverity." + $1
						$cienaGlobalSeverity = lookup($cienaGlobalSeveritylook,CienaVarbindValTable)
						if(match($cienaGlobalSeverity,"UNKNOWN")) {
							$cienaGlobalSeverity = $1
						} else {
							$cienaGlobalSeverity = $cienaGlobalSeverity + " ( " + $1 + " )"
						}
						$cienaGlobalMacAddress = $2
						$cienaCesInputPGEntityName = $3
						$cienaCesInputPGOperationalStatuslook = "cienaCesInputPGOperationalStatus." + $4
						$cienaCesInputPGOperationalStatus = lookup($cienaCesInputPGOperationalStatuslook,CienaVarbindValTable)
						if(match($cienaCesInputPGOperationalStatus,"UNKNOWN")) {
							$cienaCesInputPGOperationalStatus = $4
						} else {
							$cienaCesInputPGOperationalStatus = $cienaCesInputPGOperationalStatus + " ( " + $4 + " )"
						}
						$cienaCesInputPGSelectedReference = $5
						@AlertGroup = "Ciena OME Traps"
						@Agent = "ciena.m2r.include.rules"
						@Summary = "cienaCesSyncInputProtectionGroupStateChangeNotification: Sent when system timing could not lock into a reference source and entered hold over state."
						@Severity = 3
						@Type = 1
						@Identifier = @Node + @Summary
						details($*)

					case "3": ### - cienaCesSyncModuleSlotClockStateChangeNotification
						# SNMPv2
						# Sent when a module slot experiences a timing state change.
						$cienaGlobalSeveritylook = "cienaGlobalSeverity." + $1
						$cienaGlobalSeverity = lookup($cienaGlobalSeveritylook,CienaVarbindValTable)
						if(match($cienaGlobalSeverity,"UNKNOWN")) {
							$cienaGlobalSeverity = $1
						} else {
							$cienaGlobalSeverity = $cienaGlobalSeverity + " ( " + $1 + " )"
						}
						$cienaGlobalMacAddress = $2
						$cienaCesModuleSlotName = $3
						$cienaCesSyncModuleSlotClockStatuslook = "cienaCesSyncModuleSlotClockStatus." + $4
						$cienaCesSyncModuleSlotClockStatus = lookup($cienaCesSyncModuleSlotClockStatuslook,CienaVarbindValTable)
						if(match($cienaCesSyncModuleSlotClockStatus,"UNKNOWN")) {
							$cienaCesSyncModuleSlotClockStatus = $4
						} else {
							$cienaCesSyncModuleSlotClockStatus = $cienaCesSyncModuleSlotClockStatus + " ( " + $4 + " )"
						}
						@AlertGroup = "Ciena OME Traps"
						@Agent = "ciena.m2r.include.rules"
						@Summary = "cienaCesSyncModuleSlotClockStateChangeNotification: Sent when a module slot experiences a timing state change."
						@Severity = 3
						@Type = 1
						@Identifier = @Node + @Summary
						details($*)

					default:
						@Summary = "Unknown specific trap number (" + $specific-trap + ") received for enterprise " + $enterprise
						@Identifier = @Node + $enterprise + $generic-trap + $specific-trap + @Agent + @Manager
						@Severity = 3
						@Type = 1
						details($*)
				}

			######
			# cienaCesVlliNotifications traps
			######
			case ".1.3.6.1.4.1.1271.2.2.99":	### - cienaCesVlliNotificationPrefix
				switch($specific-trap) {
					case "1": ### - cienaCesVlliFaultTrap
						# SNMPv2
						# A notification is sent whenever the instance fault action is triggered.
						$cienaGlobalSeveritylook = "cienaGlobalSeverity." + $1
						$cienaGlobalSeverity = lookup($cienaGlobalSeveritylook,CienaVarbindValTable)
						if(match($cienaGlobalSeverity,"UNKNOWN")) {
							$cienaGlobalSeverity = $1
						} else {
							$cienaGlobalSeverity = $cienaGlobalSeverity + " ( " + $1 + " )"
						}
						$cienaGlobalMacAddress = $2
						$cienaCesVlliInstanceGrpId = $3
						$cienaCesVlliInstanceId = $4
						$cienaCesVlliInstanceGroupName = $5
						$cienaCesVlliInstanceName = $6
						@AlertGroup = "Ciena OME Traps"
						@Agent = "ciena.m2r.include.rules"
						@Summary = "cienaCesVlliFaultTrap: Instance fault action has been triggered"
						@Severity = 3
						@Type = 1
						@Identifier = @Node + @Summary
						details($*)

					case "2": ### - cienaCesVlliRecoveryTrap
						# SNMPv2
						# A notification is sent whenever the instance recovery action is triggered.
						$cienaGlobalSeveritylook = "cienaGlobalSeverity." + $1
						$cienaGlobalSeverity = lookup($cienaGlobalSeveritylook,CienaVarbindValTable)
						if(match($cienaGlobalSeverity,"UNKNOWN")) {
							$cienaGlobalSeverity = $1
						} else {
							$cienaGlobalSeverity = $cienaGlobalSeverity + " ( " + $1 + " )"
						}
						$cienaGlobalMacAddress = $2
						$cienaCesVlliInstanceGrpId = $3
						$cienaCesVlliInstanceId = $4
						$cienaCesVlliInstanceGroupName = $5
						$cienaCesVlliInstanceName = $6
						@AlertGroup = "Ciena OME Traps"
						@Agent = "ciena.m2r.include.rules"
						@Summary = "cienaCesVlliRecoveryTrap: Instance recovery action has been triggered"
						@Severity = 3
						@Type = 1
						@Identifier = @Node + @Summary
						details($*)

					default:
						@Summary = "Unknown specific trap number (" + $specific-trap + ") received for enterprise " + $enterprise
						@Identifier = @Node + $enterprise + $generic-trap + $specific-trap + @Agent + @Manager
						@Severity = 3
						@Type = 1
						details($*)
				}

			######
			# ome6500ExtNotificationPrefix traps
			######
			case ".1.3.6.1.4.1.1271.29.6.1":	### - ome6500ExtAlarmObjects
				switch($specific-trap) {
					case "301": ### - ome6500ExtAlarmClear
						# SNMPv2
						# Ciena OME6500 notification for an NE alarm clearing
						$ome6500AlarmActiveResourceIdlook = "ome6500AlarmActiveResourceId." + $1
						$ome6500AlarmActiveResourceId = lookup($ome6500AlarmActiveResourceIdlook,CienaVarbindValTable)
						if(match($ome6500AlarmActiveResourceId,"UNKNOWN")) {
							$ome6500AlarmActiveResourceId = $1
						} else {
							$ome6500AlarmActiveResourceId = $ome6500AlarmActiveResourceId + " ( " + $1 + " )"
						}
						$ome6500AlarmActiveDateAndTime = $2
						$ome6500AlarmActiveDescription = $3
						$ome6500ExtAlarmActiveEventTypelook = "ome6500ExtAlarmActiveEventType." + $4
						$ome6500ExtAlarmActiveEventType = lookup($ome6500ExtAlarmActiveEventTypelook,CienaVarbindValTable)
						if(match($ome6500ExtAlarmActiveEventType,"UNKNOWN")) {
							$ome6500ExtAlarmActiveEventType = $4
						} else {
							$ome6500ExtAlarmActiveEventType = $ome6500ExtAlarmActiveEventType + " ( " + $4 + " )"
						}
						$ome6500ExtAlarmActiveProbableCauselook = "ome6500ExtAlarmActiveProbableCause." + $5
						$ome6500ExtAlarmActiveProbableCause = lookup($ome6500ExtAlarmActiveProbableCauselook,CienaVarbindValTable)
						if(match($ome6500ExtAlarmActiveProbableCause,"UNKNOWN")) {
							$ome6500ExtAlarmActiveProbableCause = $5
						} else {
							$ome6500ExtAlarmActiveProbableCause = $ome6500ExtAlarmActiveProbableCause + " ( " + $5 + " )"
						}
						$ome6500ExtAlarmActiveAdditionalText = $6
						$ome6500ExtAlarmActiveDocumentationPointer = $7
						$ome6500ExtAlarmActiveResourceDescription = $8
						$ome6500ExtAlarmActiveSequenceNumber = $9
						@AlertGroup = "Ciena OME Traps"
						@Agent = "ciena.m2r.include.rules"
						@Summary = "ome6500ExtAlarmClear: Ciena OME6500 notification for an NE alarm clearing - " + $ome6500AlarmActiveDescription
						@Severity = 0
						@Type = 1
						@Identifier = @Node + @Summary
						details($*)

					case "302": ### - ome6500ExtAlarmWarning
						# SNMPv2
						# Ciena OME6500 notification for an NE alarm of warning severity
						$ome6500AlarmActiveResourceIdlook = "ome6500AlarmActiveResourceId." + $1
						$ome6500AlarmActiveResourceId = lookup($ome6500AlarmActiveResourceIdlook,CienaVarbindValTable)
						if(match($ome6500AlarmActiveResourceId,"UNKNOWN")) {
							$ome6500AlarmActiveResourceId = $1
						} else {
							$ome6500AlarmActiveResourceId = $ome6500AlarmActiveResourceId + " ( " + $1 + " )"
						}
						$ome6500AlarmActiveDateAndTime = $2
						$ome6500AlarmActiveDescription = $3
						$ome6500ExtAlarmActiveEventTypelook = "ome6500ExtAlarmActiveEventType." + $4
						$ome6500ExtAlarmActiveEventType = lookup($ome6500ExtAlarmActiveEventTypelook,CienaVarbindValTable)
						if(match($ome6500ExtAlarmActiveEventType,"UNKNOWN")) {
							$ome6500ExtAlarmActiveEventType = $4
						} else {
							$ome6500ExtAlarmActiveEventType = $ome6500ExtAlarmActiveEventType + " ( " + $4 + " )"
						}
						$ome6500ExtAlarmActiveProbableCauselook = "ome6500ExtAlarmActiveProbableCause." + $5
						$ome6500ExtAlarmActiveProbableCause = lookup($ome6500ExtAlarmActiveProbableCauselook,CienaVarbindValTable)
						if(match($ome6500ExtAlarmActiveProbableCause,"UNKNOWN")) {
							$ome6500ExtAlarmActiveProbableCause = $5
						} else {
							$ome6500ExtAlarmActiveProbableCause = $ome6500ExtAlarmActiveProbableCause + " ( " + $5 + " )"
						}
						$ome6500ExtAlarmActiveAdditionalText = $6
						$ome6500ExtAlarmActiveDocumentationPointer = $7
						$ome6500ExtAlarmActiveResourceDescription = $8
						$ome6500ExtAlarmActiveManualClearlook = "ome6500ExtAlarmActiveManualClear." + $9
						$ome6500ExtAlarmActiveManualClear = lookup($ome6500ExtAlarmActiveManualClearlook,CienaVarbindValTable)
						if(match($ome6500ExtAlarmActiveManualClear,"UNKNOWN")) {
							$ome6500ExtAlarmActiveManualClear = $9
						} else {
							$ome6500ExtAlarmActiveManualClear = $ome6500ExtAlarmActiveManualClear + " ( " + $9 + " )"
						}
						$ome6500ExtAlarmActiveSequenceNumber = $10
						@AlertGroup = "Ciena OME Traps"
						@Agent = "ciena.m2r.include.rules"
						@Summary = "ome6500ExtAlarmWarning: Warning Severity Alarm: " + $ome6500AlarmActiveDescription
						@Severity = 3
						@Type = 1
						@Identifier = @Node + @Summary
						details($*)

					case "303": ### - ome6500ExtAlarmMinor
						# SNMPv2
						# Ciena OME6500 notification for an NE alarm of minor severity
						$ome6500AlarmActiveResourceIdlook = "ome6500AlarmActiveResourceId." + $1
						$ome6500AlarmActiveResourceId = lookup($ome6500AlarmActiveResourceIdlook,CienaVarbindValTable)
						if(match($ome6500AlarmActiveResourceId,"UNKNOWN")) {
							$ome6500AlarmActiveResourceId = $1
						} else {
							$ome6500AlarmActiveResourceId = $ome6500AlarmActiveResourceId + " ( " + $1 + " )"
						}
						$ome6500AlarmActiveDateAndTime = $2
						$ome6500AlarmActiveDescription = $3
						$ome6500ExtAlarmActiveEventTypelook = "ome6500ExtAlarmActiveEventType." + $4
						$ome6500ExtAlarmActiveEventType = lookup($ome6500ExtAlarmActiveEventTypelook,CienaVarbindValTable)
						if(match($ome6500ExtAlarmActiveEventType,"UNKNOWN")) {
							$ome6500ExtAlarmActiveEventType = $4
						} else {
							$ome6500ExtAlarmActiveEventType = $ome6500ExtAlarmActiveEventType + " ( " + $4 + " )"
						}
						$ome6500ExtAlarmActiveProbableCauselook = "ome6500ExtAlarmActiveProbableCause." + $5
						$ome6500ExtAlarmActiveProbableCause = lookup($ome6500ExtAlarmActiveProbableCauselook,CienaVarbindValTable)
						if(match($ome6500ExtAlarmActiveProbableCause,"UNKNOWN")) {
							$ome6500ExtAlarmActiveProbableCause = $5
						} else {
							$ome6500ExtAlarmActiveProbableCause = $ome6500ExtAlarmActiveProbableCause + " ( " + $5 + " )"
						}
						$ome6500ExtAlarmActiveAdditionalText = $6
						$ome6500ExtAlarmActiveDocumentationPointer = $7
						$ome6500ExtAlarmActiveResourceDescription = $8
						$ome6500ExtAlarmActiveManualClearlook = "ome6500ExtAlarmActiveManualClear." + $9
						$ome6500ExtAlarmActiveManualClear = lookup($ome6500ExtAlarmActiveManualClearlook,CienaVarbindValTable)
						if(match($ome6500ExtAlarmActiveManualClear,"UNKNOWN")) {
							$ome6500ExtAlarmActiveManualClear = $9
						} else {
							$ome6500ExtAlarmActiveManualClear = $ome6500ExtAlarmActiveManualClear + " ( " + $9 + " )"
						}
						$ome6500ExtAlarmActiveSequenceNumber = $10
						@AlertGroup = "Ciena OME Traps"
						@Agent = "ciena.m2r.include.rules"
						@Summary = "ome6500ExtAlarmMinor: Minor Severity Alarm: " + $ome6500AlarmActiveDescription
						@Severity = 3
						@Type = 1
						@Identifier = @Node + @Summary
						details($*)

					case "304": ### - ome6500ExtAlarmMajor
						# SNMPv2
						# Ciena OME6500 notification for an NE alarm of major severity
						$ome6500AlarmActiveResourceIdlook = "ome6500AlarmActiveResourceId." + $1
						$ome6500AlarmActiveResourceId = lookup($ome6500AlarmActiveResourceIdlook,CienaVarbindValTable)
						if(match($ome6500AlarmActiveResourceId,"UNKNOWN")) {
							$ome6500AlarmActiveResourceId = $1
						} else {
							$ome6500AlarmActiveResourceId = $ome6500AlarmActiveResourceId + " ( " + $1 + " )"
						}
						$ome6500AlarmActiveDateAndTime = $2
						$ome6500AlarmActiveDescription = $3
						$ome6500ExtAlarmActiveEventTypelook = "ome6500ExtAlarmActiveEventType." + $4
						$ome6500ExtAlarmActiveEventType = lookup($ome6500ExtAlarmActiveEventTypelook,CienaVarbindValTable)
						if(match($ome6500ExtAlarmActiveEventType,"UNKNOWN")) {
							$ome6500ExtAlarmActiveEventType = $4
						} else {
							$ome6500ExtAlarmActiveEventType = $ome6500ExtAlarmActiveEventType + " ( " + $4 + " )"
						}
						$ome6500ExtAlarmActiveProbableCauselook = "ome6500ExtAlarmActiveProbableCause." + $5
						$ome6500ExtAlarmActiveProbableCause = lookup($ome6500ExtAlarmActiveProbableCauselook,CienaVarbindValTable)
						if(match($ome6500ExtAlarmActiveProbableCause,"UNKNOWN")) {
							$ome6500ExtAlarmActiveProbableCause = $5
						} else {
							$ome6500ExtAlarmActiveProbableCause = $ome6500ExtAlarmActiveProbableCause + " ( " + $5 + " )"
						}
						$ome6500ExtAlarmActiveAdditionalText = $6
						$ome6500ExtAlarmActiveDocumentationPointer = $7
						$ome6500ExtAlarmActiveResourceDescription = $8
						$ome6500ExtAlarmActiveManualClearlook = "ome6500ExtAlarmActiveManualClear." + $9
						$ome6500ExtAlarmActiveManualClear = lookup($ome6500ExtAlarmActiveManualClearlook,CienaVarbindValTable)
						if(match($ome6500ExtAlarmActiveManualClear,"UNKNOWN")) {
							$ome6500ExtAlarmActiveManualClear = $9
						} else {
							$ome6500ExtAlarmActiveManualClear = $ome6500ExtAlarmActiveManualClear + " ( " + $9 + " )"
						}
						$ome6500ExtAlarmActiveSequenceNumber = $10
						@AlertGroup = "Ciena OME Traps"
						@Agent = "ciena.m2r.include.rules"
						@Summary = "ome6500ExtAlarmMajor: Major Severity Alarm: " + $ome6500AlarmActiveDescription
						@Severity = 4
						@Type = 1
						@Identifier = @Node + @Summary
						details($*)

					case "305": ### - ome6500ExtAlarmCritical
						# SNMPv2
						# Ciena OME6500 notification for an NE alarm of critical severity
						$ome6500AlarmActiveResourceIdlook = "ome6500AlarmActiveResourceId." + $1
						$ome6500AlarmActiveResourceId = lookup($ome6500AlarmActiveResourceIdlook,CienaVarbindValTable)
						if(match($ome6500AlarmActiveResourceId,"UNKNOWN")) {
							$ome6500AlarmActiveResourceId = $1
						} else {
							$ome6500AlarmActiveResourceId = $ome6500AlarmActiveResourceId + " ( " + $1 + " )"
						}
						$ome6500AlarmActiveDateAndTime = $2
						$ome6500AlarmActiveDescription = $3
						$ome6500ExtAlarmActiveEventTypelook = "ome6500ExtAlarmActiveEventType." + $4
						$ome6500ExtAlarmActiveEventType = lookup($ome6500ExtAlarmActiveEventTypelook,CienaVarbindValTable)
						if(match($ome6500ExtAlarmActiveEventType,"UNKNOWN")) {
							$ome6500ExtAlarmActiveEventType = $4
						} else {
							$ome6500ExtAlarmActiveEventType = $ome6500ExtAlarmActiveEventType + " ( " + $4 + " )"
						}
						$ome6500ExtAlarmActiveProbableCauselook = "ome6500ExtAlarmActiveProbableCause." + $5
						$ome6500ExtAlarmActiveProbableCause = lookup($ome6500ExtAlarmActiveProbableCauselook,CienaVarbindValTable)
						if(match($ome6500ExtAlarmActiveProbableCause,"UNKNOWN")) {
							$ome6500ExtAlarmActiveProbableCause = $5
						} else {
							$ome6500ExtAlarmActiveProbableCause = $ome6500ExtAlarmActiveProbableCause + " ( " + $5 + " )"
						}
						$ome6500ExtAlarmActiveAdditionalText = $6
						$ome6500ExtAlarmActiveDocumentationPointer = $7
						$ome6500ExtAlarmActiveResourceDescription = $8
						$ome6500ExtAlarmActiveManualClearlook = "ome6500ExtAlarmActiveManualClear." + $9
						$ome6500ExtAlarmActiveManualClear = lookup($ome6500ExtAlarmActiveManualClearlook,CienaVarbindValTable)
						if(match($ome6500ExtAlarmActiveManualClear,"UNKNOWN")) {
							$ome6500ExtAlarmActiveManualClear = $9
						} else {
							$ome6500ExtAlarmActiveManualClear = $ome6500ExtAlarmActiveManualClear + " ( " + $9 + " )"
						}
						$ome6500ExtAlarmActiveSequenceNumber = $10
						@AlertGroup = "Ciena OME Traps"
						@Agent = "ciena.m2r.include.rules"
						@Summary = "ome6500ExtAlarmCritical: Critical Severity Alarm: " + $ome6500AlarmActiveDescription
						@Severity = 5
						@Type = 1
						@Identifier = @Node + @Summary
						details($*)

					case "306": ### - ome6500ExtAlarmMessage
						# SNMPv2
						# An informational message. This notification does not
						# correspond to an alarm so would not be stored in the
						# active alarm table and it does not have a corresponing
						# clear.
						$ome6500ExtAlarmMessageResource = $1
						$ome6500ExtAlarmMessageResourceDescription = $2
						$ome6500ExtAlarmMessageDateAndTime = $3
						$ome6500ExtAlarmMessageDocumentationPointer = $4
						$ome6500ExtAlarmMessageInfo = $5
						@AlertGroup = "Ciena OME Traps"
						@Agent = "ciena.m2r.include.rules"
						@Summary = "ome6500ExtAlarmMessage: Informational Severity Message"
						@Severity = 2
						@Type = 1
						@Identifier = @Node + @Summary
						details($*)

            default:
  						@Summary = "Unknown specific trap number (" + $specific-trap + ") received for enterprise " + $enterprise
  						@Identifier = @Node + $enterprise + $generic-trap + $specific-trap + @Agent + @Manager
  						@Severity = 3
  						@Type = 1
  						details($*)

				}

# New Rules for release 12.41

######
# hcAlarmNotifPrefix traps
######
case ".1.3.6.1.2.1.16.29.2":	### - hcAlarmNotifications
	switch($specific-trap) {
		case "1": ### - hcRisingAlarm
			# SNMPv2
			# The SNMP notification that is generated when a high
			# capacity alarm entry crosses its rising threshold and
			# generates an event that is configured for sending SNMP
			# traps.
			#
			# The hcAlarmEntry object instances identified in the OBJECTS
			#
			# clause are from the entry that causes this notification to
			# be generated.
			$hcAlarmVariable = $1
			$hcAlarmSampleTypelook = "hcAlarmSampleType." + $2
			$hcAlarmSampleType = lookup($hcAlarmSampleTypelook,CienaVarbindValTable)
			if(match($hcAlarmSampleType,"UNKNOWN")) {
				$hcAlarmSampleType = $2
			} else {
				$hcAlarmSampleType = $hcAlarmSampleType + " ( " + $2 + " )"
			}
			$hcAlarmAbsValue = $3
			$hcAlarmValueStatuslook = "hcAlarmValueStatus." + $4
			$hcAlarmValueStatus = lookup($hcAlarmValueStatuslook,CienaVarbindValTable)
			if(match($hcAlarmValueStatus,"UNKNOWN")) {
				$hcAlarmValueStatus = $4
			} else {
				$hcAlarmValueStatus = $hcAlarmValueStatus + " ( " + $4 + " )"
			}
			$hcAlarmRisingThreshAbsValueLo = $5
			$hcAlarmRisingThreshAbsValueHi = $6
			$hcAlarmRisingThresholdValStatuslook = "hcAlarmRisingThresholdValStatus." + $7
			$hcAlarmRisingThresholdValStatus = lookup($hcAlarmRisingThresholdValStatuslook,CienaVarbindValTable)
			if(match($hcAlarmRisingThresholdValStatus,"UNKNOWN")) {
				$hcAlarmRisingThresholdValStatus = $7
			} else {
				$hcAlarmRisingThresholdValStatus = $hcAlarmRisingThresholdValStatus + " ( " + $7 + " )"
			}
			$hcAlarmRisingEventIndex = $8
			@AlertGroup = "Ciena OME Traps"
			@Agent = "ciena.m2r.include.rules"
			@Summary = "hcRisingAlarm: high capacity alarm crossed threshold"
			@Severity = 3
			@Type = 1
			@Identifier = @Node + @Summary
			details($hcAlarmVariable,$hcAlarmSampleType,$hcAlarmAbsValue,$hcAlarmValueStatus,$hcAlarmRisingThreshAbsValueLo,$hcAlarmRisingThreshAbsValueHi,$hcAlarmRisingThresholdValStatus,$hcAlarmRisingEventIndex)

		case "2": ### - hcFallingAlarm
			# SNMPv2
			# The SNMP notification that is generated when a high
			# capacity alarm entry crosses its falling threshold and
			# generates an event that is configured for sending SNMP
			# traps.
			#
			# The hcAlarmEntry object instances identified in the OBJECTS
			# clause are from the entry that causes this notification to
			# be generated.
			$hcAlarmVariable = $1
			$hcAlarmSampleTypelook = "hcAlarmSampleType." + $2
			$hcAlarmSampleType = lookup($hcAlarmSampleTypelook,CienaVarbindValTable)
			if(match($hcAlarmSampleType,"UNKNOWN")) {
				$hcAlarmSampleType = $2
			} else {
				$hcAlarmSampleType = $hcAlarmSampleType + " ( " + $2 + " )"
			}
			$hcAlarmAbsValue = $3
			$hcAlarmValueStatuslook = "hcAlarmValueStatus." + $4
			$hcAlarmValueStatus = lookup($hcAlarmValueStatuslook,CienaVarbindValTable)
			if(match($hcAlarmValueStatus,"UNKNOWN")) {
				$hcAlarmValueStatus = $4
			} else {
				$hcAlarmValueStatus = $hcAlarmValueStatus + " ( " + $4 + " )"
			}
			$hcAlarmFallingThreshAbsValueLo = $5
			$hcAlarmFallingThreshAbsValueHi = $6
			$hcAlarmFallingThresholdValStatuslook = "hcAlarmFallingThresholdValStatus." + $7
			$hcAlarmFallingThresholdValStatus = lookup($hcAlarmFallingThresholdValStatuslook,CienaVarbindValTable)
			if(match($hcAlarmFallingThresholdValStatus,"UNKNOWN")) {
				$hcAlarmFallingThresholdValStatus = $7
			} else {
				$hcAlarmFallingThresholdValStatus = $hcAlarmFallingThresholdValStatus + " ( " + $7 + " )"
			}
			$hcAlarmFallingEventIndex = $8
			@AlertGroup = "Ciena OME Traps"
			@Agent = "ciena.m2r.include.rules"
			@Summary = "hcFallingAlarm: high capacity alarm crossed threshold - clear"
			@Severity = 3
			@Type = 1
			@Identifier = @Node + @Summary
			details($hcAlarmVariable,$hcAlarmSampleType,$hcAlarmAbsValue,$hcAlarmValueStatus,$hcAlarmFallingThreshAbsValueLo,$hcAlarmFallingThreshAbsValueHi,$hcAlarmFallingThresholdValStatus,$hcAlarmFallingEventIndex)

		default:
			@Summary = "Unknown specific trap number (" + $specific-trap + ") received for enterprise " + $enterprise
			@Identifier = @Node + $enterprise + $generic-trap + $specific-trap + @Agent + @Manager
			@Severity = 3
			@Type = 1
			details($*)
	}

######
# cienaCesIclMIBNotifications traps
######
case ".1.3.6.1.4.1.1271.2.1.32.2":	### - cienaCesIclMIBNotificationPrefix
	switch($specific-trap) {
		case "1": ### - cienaCesIclStateChange
			# SNMPv2
			# This notification is sent when ICL oper state changes.
			# Var binding cienaCesIclIndex represents the ICL index.
			@AlertGroup = "Ciena OME Traps"
			@Agent = "ciena.m2r.include.rules"
			@Summary = "cienaCesIclStateChange: ICL operational state changed"
			@Severity = 3
			@Type = 1
			@Identifier = @Node + @Summary
		default:
			@Summary = "Unknown specific trap number (" + $specific-trap + ") received for enterprise " + $enterprise
			@Identifier = @Node + $enterprise + $generic-trap + $specific-trap + @Agent + @Manager
			@Severity = 3
			@Type = 1
			details($*)
	}

	######
	# cienaCesLoopDetectionMIBNotifications traps
	######
	case ".1.3.6.1.4.1.1271.2.1.50.2":	### - cienaCesLoopDetectionMIBNotificationPrefix
		switch($specific-trap) {
			case "1": ### - cienaCesLoopDetectionLoopFound
				# SNMPv2
				# A cienaCesLoopDetectionLoopFound supports the ability to
				# notify the existence of a loop within a network.
				$cienaGlobalSeveritylook = "cienaGlobalSeverity." + $1
				$cienaGlobalSeverity = lookup($cienaGlobalSeveritylook,CienaVarbindValTable)
				if(match($cienaGlobalSeverity,"UNKNOWN")) {
					$cienaGlobalSeverity = $1
				} else {
					$cienaGlobalSeverity = $cienaGlobalSeverity + " ( " + $1 + " )"
				}
				$cienaGlobalMacAddress = $2
				$cienaCesLoopDetectionCfmServiceIndex = $3
				$cienaCesLoopDetectionPortName = $4
				@AlertGroup = "Ciena OME Traps"
				@Agent = "ciena.m2r.include.rules"
				@Summary = "cienaCesLoopDetectionLoopFound: a network loop was detected on port: " + $cienaCesLoopDetectionPortName
				@Severity = 4
				@Type = 1
				@Identifier = @Node + @Summary
				details($cienaGlobalSeverity,$cienaGlobalMacAddress,$cienaCesLoopDetectionCfmServiceIndex,$cienaCesLoopDetectionPortName)

			case "2": ### - cienaCesLoopDetectionLoopClear
				# SNMPv2
				# A cienaCesLoopDetectionLoopClear is sent whenever loop gets
				# cleared on Port.
				$cienaGlobalSeveritylook = "cienaGlobalSeverity." + $1
				$cienaGlobalSeverity = lookup($cienaGlobalSeveritylook,CienaVarbindValTable)
				if(match($cienaGlobalSeverity,"UNKNOWN")) {
					$cienaGlobalSeverity = $1
				} else {
					$cienaGlobalSeverity = $cienaGlobalSeverity + " ( " + $1 + " )"
				}
				$cienaGlobalMacAddress = $2
				$cienaCesLoopDetectionCfmServiceIndex = $3
				$cienaCesLoopDetectionPortName = $4
				@AlertGroup = "Ciena OME Traps"
				@Agent = "ciena.m2r.include.rules"
				@Summary = "cienaCesLoopDetectionLoopClear: A network loop on port: " + $cienaCesLoopDetectionPortName + " has cleared"
				@Severity = 4
				@Type = 1
				@Identifier = @Node + @Summary
				details($cienaGlobalSeverity,$cienaGlobalMacAddress,$cienaCesLoopDetectionCfmServiceIndex,$cienaCesLoopDetectionPortName)

			case "3": ### - cienaCesLoopDetectionPortOperActionSet
				# SNMPv2
				# A cienaCesLoopDetectionPortOperActionSet supports the ability to
				# notify that a loop termination action has been taken.
				$cienaGlobalSeveritylook = "cienaGlobalSeverity." + $1
				$cienaGlobalSeverity = lookup($cienaGlobalSeveritylook,CienaVarbindValTable)
				if(match($cienaGlobalSeverity,"UNKNOWN")) {
					$cienaGlobalSeverity = $1
				} else {
					$cienaGlobalSeverity = $cienaGlobalSeverity + " ( " + $1 + " )"
				}
				$cienaGlobalMacAddress = $2
				$cienaCesLoopDetectionPortName = $3
				@AlertGroup = "Ciena OME Traps"
				@Agent = "ciena.m2r.include.rules"
				@Summary = "cienaCesLoopDetectionPortOperActionSet: A cienaCesLoopDetectionPortOperActionSet supports the ability to notify that a loop termination action has been taken."
				@Severity = 3
				@Type = 1
				@Identifier = @Node + @Summary
				details($cienaGlobalSeverity,$cienaGlobalMacAddress,$cienaCesLoopDetectionPortName)

			case "4": ### - cienaCesLoopDetectionPortOperActionClear
				# SNMPv2
				# A cienaCesLoopDetectionPortOperActionClear supports the ability to
				# notify that a loop termination action has been cleared.
				$cienaGlobalSeveritylook = "cienaGlobalSeverity." + $1
				$cienaGlobalSeverity = lookup($cienaGlobalSeveritylook,CienaVarbindValTable)
				if(match($cienaGlobalSeverity,"UNKNOWN")) {
					$cienaGlobalSeverity = $1
				} else {
					$cienaGlobalSeverity = $cienaGlobalSeverity + " ( " + $1 + " )"
				}
				$cienaGlobalMacAddress = $2
				$cienaCesLoopDetectionPortName = $3
				@AlertGroup = "Ciena OME Traps"
				@Agent = "ciena.m2r.include.rules"
				@Summary = "cienaCesLoopDetectionPortOperActionClear: A cienaCesLoopDetectionPortOperActionClear supports the ability to notify that a loop termination action has been cleared."
				@Severity = 3
				@Type = 1
				@Identifier = @Node + @Summary
				details($cienaGlobalSeverity,$cienaGlobalMacAddress,$cienaCesLoopDetectionPortName)

			default:
				@Summary = "Unknown specific trap number (" + $specific-trap + ") received for enterprise " + $enterprise
				@Identifier = @Node + $enterprise + $generic-trap + $specific-trap + @Agent + @Manager
				@Severity = 3
				@Type = 1
				details($*)
		}

		######
	# cienaCesExtLagMIBNotifications traps
	######
	case ".1.3.6.1.4.1.1271.2.2.21":	### - cienaCesExtLagMIBNotificationPrefix
		switch($specific-trap) {
			case "1": ### - cienaCesExtLagMclagStateChange
				# SNMPv2
				# This notification is sent when MC-LAG oper state changes.
				# Var binding cienaCesExtAggId represents the MC-LAG PGID.
				$cienaGlobalSeveritylook = "cienaGlobalSeverity." + $1
				$cienaGlobalSeverity = lookup($cienaGlobalSeveritylook,CienaVarbindValTable)
				if(match($cienaGlobalSeverity,"UNKNOWN")) {
					$cienaGlobalSeverity = $1
				} else {
					$cienaGlobalSeverity = $cienaGlobalSeverity + " ( " + $1 + " )"
				}
				$cienaGlobalMacAddress = $2
				$cienaCesExtAggIndex = $3
				$cienaCesExtAggRedundancyStatelook = "cienaCesExtAggRedundancyState." + $4
				$cienaCesExtAggRedundancyState = lookup($cienaCesExtAggRedundancyStatelook,CienaVarbindValTable)
				if(match($cienaCesExtAggRedundancyState,"UNKNOWN")) {
					$cienaCesExtAggRedundancyState = $4
				} else {
					$cienaCesExtAggRedundancyState = $cienaCesExtAggRedundancyState + " ( " + $4 + " )"
				}
				@AlertGroup = "Ciena OME Traps"
				@Agent = "ciena.m2r.include.rules"
				@Summary = "cienaCesExtLagMclagStateChange: MC-LAG oper state changed. MC-LAG PGID: " + $cienaCesExtAggId
				@Severity = 3
				@Type = 1
				@Identifier = @Node + @Summary
				details($cienaGlobalSeverity,$cienaGlobalMacAddress,$cienaCesExtAggIndex,$cienaCesExtAggRedundancyState)

			default:
				@Summary = "Unknown specific trap number (" + $specific-trap + ") received for enterprise " + $enterprise
				@Identifier = @Node + $enterprise + $generic-trap + $specific-trap + @Agent + @Manager
				@Severity = 3
				@Type = 1
				details($*)
		}

######
# cienaCesConfigMgmtMIBNotifications traps
######
case ".1.3.6.1.4.1.1271.2.2.36":	### - cienaCesConfigMgmtMIBNotificationsPrefix
	switch($specific-trap) {
		case "1": ### - cienaCesConfigMgmtConfigSavedNotification
			# SNMPv2
			# This notification is sent when the configuration is saved.
			$cienaGlobalSeveritylook = "cienaGlobalSeverity." + $1
			$cienaGlobalSeverity = lookup($cienaGlobalSeveritylook,CienaVarbindValTable)
			if(match($cienaGlobalSeverity,"UNKNOWN")) {
				$cienaGlobalSeverity = $1
			} else {
				$cienaGlobalSeverity = $cienaGlobalSeverity + " ( " + $1 + " )"
			}
			$cienaCesConfigMgmtConfigLastSaved = $2
			$cienaCesConfigMgmtConfigLastChanged = $3
			@AlertGroup = "Ciena OME Traps"
			@Agent = "ciena.m2r.include.rules"
			@Summary = "cienaCesConfigMgmtConfigSavedNotification: Config saved"
			@Severity = 3
			@Type = 1
			@Identifier = @Node + @Summary
			details($cienaGlobalSeverity,$cienaCesConfigMgmtConfigLastSaved,$cienaCesConfigMgmtConfigLastChanged)

		case "2": ### - cienaCesConfigMgmtConfigChangeNotification
			# SNMPv2
			# This notification is sent when the configuration on the device changes.
			#
			# A hysteresis mechanism is evaluated before sending in an effort to limit the
			# number of events generated. This mechanism will send out one notification
			# when an accumulation rate threshold is crossed. If the context/user/origin
			# of a configuration change does not match the currently tracked
			# context/user/origin, then this notification will automatically be sent.
			# The hysteresis algorithm will then be evaluated based on the new
			# context/user/origin.
			$cienaGlobalSeveritylook = "cienaGlobalSeverity." + $1
			$cienaGlobalSeverity = lookup($cienaGlobalSeveritylook,CienaVarbindValTable)
			if(match($cienaGlobalSeverity,"UNKNOWN")) {
				$cienaGlobalSeverity = $1
			} else {
				$cienaGlobalSeverity = $cienaGlobalSeverity + " ( " + $1 + " )"
			}
			$cienaCesConfigMgmtConfigLastContextlook = "cienaCesConfigMgmtConfigLastContext." + $2
			$cienaCesConfigMgmtConfigLastContext = lookup($cienaCesConfigMgmtConfigLastContextlook,CienaVarbindValTable)
			if(match($cienaCesConfigMgmtConfigLastContext,"UNKNOWN")) {
				$cienaCesConfigMgmtConfigLastContext = $2
			} else {
				$cienaCesConfigMgmtConfigLastContext = $cienaCesConfigMgmtConfigLastContext + " ( " + $2 + " )"
			}
			$cienaCesConfigMgmtConfigLastUser = $3
			$cienaCesConfigMgmtConfigLastOrigin = $4
			$cienaCesConfigMgmtConfigLastChanged = $5
			@AlertGroup = "Ciena OME Traps"
			@Agent = "ciena.m2r.include.rules"
			@Summary = "cienaCesConfigMgmtConfigChangeNotification: Device config changed"
			@Severity = 3
			@Type = 1
			@Identifier = @Node + @Summary
			details($cienaGlobalSeverity,$cienaCesConfigMgmtConfigLastContext,$cienaCesConfigMgmtConfigLastUser,$cienaCesConfigMgmtConfigLastOrigin,$cienaCesConfigMgmtConfigLastChanged)

		default:
			@Summary = "Unknown specific trap number (" + $specific-trap + ") received for enterprise " + $enterprise
			@Identifier = @Node + $enterprise + $generic-trap + $specific-trap + @Agent + @Manager
			@Severity = 3
			@Type = 1
			details($*)
	}

