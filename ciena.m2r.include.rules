						$nnExtAlarmActiveManualClear = lookup($nnExtAlarmActiveManualClearlook,CienaVarbindValTable)
						if(match($nnExtAlarmActiveManualClear,"UNKNOWN")) {
							$nnExtAlarmActiveManualClear = $9
						} else {
