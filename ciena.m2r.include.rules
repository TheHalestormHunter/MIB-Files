						}
						$cienaGlobalMacAddress = $2
						$cienaCesPortXcvrNotifChassisIndex = $3
						$cienaCesPortXcvrNotifShelfIndex = $4
						$cienaCesPortXcvrNotifSlotIndex = $5
						$cienaCesPortXcvrNotifPortNumber = $6
						@AlertGroup = "Ciena OME Traps"
						@Agent = "ciena.m2r.include.rules"
						@Summary = "cienaCesPortXcvrBiasLowNotification: Low transceiver bias for port: " + $cienaCesPortXcvrNotifPortNumber + " slot " + $cienaCesPortXcvrNotifSlotIndex
						@Severity = 3
						@Type = 1
						@Identifier = @Node + @Summary
						details($*)

					case "14": ### - cienaCesPortXcvrBiasNormalNotification
						# SNMPv2
						# A cienaCesPortXcvrBiasNormalNotification is sent when the transceiver bias returns to normal
						# state. To enable the device to send this notification: cienaCesPortXcvrBiasChangeTrapState,
						# cienaCesLogicalPortConfigPortAllTrapState, and cienaCesPortAllTrapState need to be set to enabled.
						# These objects are set to enabled by default. Variable bindings include: cienaGlobalSeverity,
						# cienaGlobalMacAddress, cienaCesPortXcvrNotifChassisIndex, cienaCesPortXcvrNotifShelfIndex,
						# cienaCesPortXcvrNotifSlotIndex, and cienaCesPortXcvrNotifPortNumber.
						$cienaGlobalSeveritylook = "cienaGlobalSeverity." + $1
						$cienaGlobalSeverity = lookup($cienaGlobalSeveritylook,CienaVarbindValTable)
						if(match($cienaGlobalSeverity,"UNKNOWN")) {
							$cienaGlobalSeverity = $1
						} else {
							$cienaGlobalSeverity = $cienaGlobalSeverity + " ( " + $1 + " )"
						}
						$cienaGlobalMacAddress = $2
						$cienaCesPortXcvrNotifChassisIndex = $3
						$cienaCesPortXcvrNotifShelfIndex = $4
						$cienaCesPortXcvrNotifSlotIndex = $5
						$cienaCesPortXcvrNotifPortNumber = $6
						@AlertGroup = "Ciena OME Traps"
						@Agent = "ciena.m2r.include.rules"
						@Summary = "cienaCesPortXcvrBiasNormalNotification: Transceiver bias for port: " + $cienaCesPortXcvrNotifPortNumber + " slot " + $cienaCesPortXcvrNotifSlotIndex + "Returned to normal"
						@Severity = 3
						@Type = 1
						@Identifier = @Node + @Summary
						details($*)

					case "15": ### - cienaCesPortXcvrTxPowerHighNotification
						# SNMPv2
						# A cienaCesPortXcvrTxPowerHighNotification is sent if the transceiver TxPower exceeds the
						# threshold. To enable the device to send this notification: cienaCesPortXcvrTxPowerChangeTrapState,
						# cienaCesLogicalPortConfigPortAllTrapState, and cienaCesPortAllTrapState need to be set to enabled.
						# These objects are set to enabled by default. Variable bindings include: cienaGlobalSeverity,
						# cienaGlobalMacAddress, cienaCesPortXcvrNotifChassisIndex, cienaCesPortXcvrNotifShelfIndex,
						# cienaCesPortXcvrNotifSlotIndex, and cienaCesPortXcvrNotifPortNumber.
						$cienaGlobalSeveritylook = "cienaGlobalSeverity." + $1
						$cienaGlobalSeverity = lookup($cienaGlobalSeveritylook,CienaVarbindValTable)
						if(match($cienaGlobalSeverity,"UNKNOWN")) {
							$cienaGlobalSeverity = $1
						} else {
							$cienaGlobalSeverity = $cienaGlobalSeverity + " ( " + $1 + " )"
						}
						$cienaGlobalMacAddress = $2
						$cienaCesPortXcvrNotifChassisIndex = $3
						$cienaCesPortXcvrNotifShelfIndex = $4
						$cienaCesPortXcvrNotifSlotIndex = $5
						$cienaCesPortXcvrNotifPortNumber = $6
						@AlertGroup = "Ciena OME Traps"
						@Agent = "ciena.m2r.include.rules"
						@Summary = "cienaCesPortXcvrTxPowerHighNotification: High transceiver TX Power for port: " + $cienaCesPortXcvrNotifPortNumber + " slot " + $cienaCesPortXcvrNotifSlotIndex
						@Severity = 4
						@Type = 1
						@Identifier = @Node + @Summary
						details($*)

					case "16": ### - cienaCesPortXcvrTxPowerLowNotification
						# SNMPv2
						# A cienaCesPortXcvrTxPowerLowNotification is sent if the transceiver TxPower falls below
						# the threshold. To enable the device to send this notification: cienaCesPortXcvrTxPowerChangeTrapState,
						# cienaCesLogicalPortConfigPortAllTrapState, and cienaCesPortAllTrapState need to be set to enabled.
						# These objects are set to enabled by default. Variable bindings include: cienaGlobalSeverity,
						# cienaGlobalMacAddress, cienaCesPortXcvrNotifChassisIndex, cienaCesPortXcvrNotifShelfIndex,
						# cienaCesPortXcvrNotifSlotIndex, and cienaCesPortXcvrNotifPortNumber.
						$cienaGlobalSeveritylook = "cienaGlobalSeverity." + $1
						$cienaGlobalSeverity = lookup($cienaGlobalSeveritylook,CienaVarbindValTable)
						if(match($cienaGlobalSeverity,"UNKNOWN")) {
							$cienaGlobalSeverity = $1
						} else {
							$cienaGlobalSeverity = $cienaGlobalSeverity + " ( " + $1 + " )"
						}
						$cienaGlobalMacAddress = $2
						$cienaCesPortXcvrNotifChassisIndex = $3
						$cienaCesPortXcvrNotifShelfIndex = $4
						$cienaCesPortXcvrNotifSlotIndex = $5
						$cienaCesPortXcvrNotifPortNumber = $6
						@AlertGroup = "Ciena OME Traps"
						@Agent = "ciena.m2r.include.rules"
						@Summary = "cienaCesPortXcvrTxPowerLowNotification: Low transceiver TX Power for port: " + $cienaCesPortXcvrNotifPortNumber + " slot " + $cienaCesPortXcvrNotifSlotIndex
						@Severity = 4
						@Type = 1
						@Identifier = @Node + @Summary
						details($*)

					case "17": ### - cienaCesPortXcvrTxPowerNormalNotification
						# SNMPv2
						# A cienaCesPortXcvrTxPowerNormalNotification is sent when the transceiver TxPower returns to
						# normal state. To enable the device to send this notification: cienaCesPortXcvrTxPowerChangeTrapState,
						# cienaCesLogicalPortConfigPortAllTrapState, and cienaCesPortAllTrapState need to be set to enabled.
						# These above values are set to enabled by default. Variable bindings include: cienaGlobalSeverity,
						# cienaGlobalMacAddress, cienaCesPortXcvrNotifChassisIndex, cienaCesPortXcvrNotifShelfIndex,
						# cienaCesPortXcvrNotifSlotIndex, and cienaCesPortXcvrNotifPortNumber.
						$cienaGlobalSeveritylook = "cienaGlobalSeverity." + $1
						$cienaGlobalSeverity = lookup($cienaGlobalSeveritylook,CienaVarbindValTable)
						if(match($cienaGlobalSeverity,"UNKNOWN")) {
							$cienaGlobalSeverity = $1
						} else {
							$cienaGlobalSeverity = $cienaGlobalSeverity + " ( " + $1 + " )"
						}
						$cienaGlobalMacAddress = $2
						$cienaCesPortXcvrNotifChassisIndex = $3
						$cienaCesPortXcvrNotifShelfIndex = $4
						$cienaCesPortXcvrNotifSlotIndex = $5
						$cienaCesPortXcvrNotifPortNumber = $6
						@AlertGroup = "Ciena OME Traps"
						@Agent = "ciena.m2r.include.rules"
						@Summary = "cienaCesPortXcvrTxPowerNormalNotification: Transceiver TX Power for port: " + $cienaCesPortXcvrNotifPortNumber + " slot " + $cienaCesPortXcvrNotifSlotIndex + " restored"
						@Severity = 4
						@Type = 1
						@Identifier = @Node + @Summary
						details($*)

					case "18": ### - cienaCesPortXcvrRxPowerHighNotification
						# SNMPv2
						# A cienaCesPortXcvrRxPowerHighNotification is sent if the transceiver RxPower exceeds
						# the threshold. To enable the device to send this notification: cienaCesPortXcvrRxPowerChangeTrapState,
						# cienaCesLogicalPortConfigPortAllTrapState, and cienaCesPortAllTrapState need to be set to enabled.
						# These objects are set to enabled by default. Variable bindings include: cienaGlobalSeverity,
						# cienaGlobalMacAddress, cienaCesPortXcvrNotifChassisIndex, cienaCesPortXcvrNotifShelfIndex,
						# cienaCesPortXcvrNotifSlotIndex, and cienaCesPortXcvrNotifPortNumber.
						$cienaGlobalSeveritylook = "cienaGlobalSeverity." + $1
						$cienaGlobalSeverity = lookup($cienaGlobalSeveritylook,CienaVarbindValTable)
						if(match($cienaGlobalSeverity,"UNKNOWN")) {
							$cienaGlobalSeverity = $1
						} else {
							$cienaGlobalSeverity = $cienaGlobalSeverity + " ( " + $1 + " )"
						}
						$cienaGlobalMacAddress = $2
						$cienaCesPortXcvrNotifChassisIndex = $3
						$cienaCesPortXcvrNotifShelfIndex = $4
						$cienaCesPortXcvrNotifSlotIndex = $5
						$cienaCesPortXcvrNotifPortNumber = $6
						@AlertGroup = "Ciena OME Traps"
						@Agent = "ciena.m2r.include.rules"
						@Summary = "cienaCesPortXcvrRxPowerHighNotification: High transceiver RX Power for port: " + $cienaCesPortXcvrNotifPortNumber + " slot " + $cienaCesPortXcvrNotifSlotIndex
						@Severity = 4
						@Type = 1
						@Identifier = @Node + @Summary
						details($*)

					case "19": ### - cienaCesPortXcvrRxPowerLowNotification
						# SNMPv2
						# A cienaCesPortXcvrRxPowerLowNotification is sent if the transceiver RxPower falls below
						# the the threshold. To enable the device to send this notification:
						# cienaCesPortXcvrRxPowerChangeTrapState, cienaCesLogicalPortConfigPortAllTrapState,
						# cienaCesPortAllTrapState needs to be set to enabled. These objects are set to enabled
						# by default. Variable bindings include: cienaGlobalSeverity, cienaGlobalMacAddress,
						# cienaCesPortXcvrNotifChassisIndex, cienaCesPortXcvrNotifShelfIndex, cienaCesPortXcvrNotifSlotIndex,
						# and cienaCesPortXcvrNotifPortNumber.
						$cienaGlobalSeveritylook = "cienaGlobalSeverity." + $1
						$cienaGlobalSeverity = lookup($cienaGlobalSeveritylook,CienaVarbindValTable)
						if(match($cienaGlobalSeverity,"UNKNOWN")) {
							$cienaGlobalSeverity = $1
						} else {
							$cienaGlobalSeverity = $cienaGlobalSeverity + " ( " + $1 + " )"
						}
						$cienaGlobalMacAddress = $2
						$cienaCesPortXcvrNotifChassisIndex = $3
						$cienaCesPortXcvrNotifShelfIndex = $4
						$cienaCesPortXcvrNotifSlotIndex = $5
						$cienaCesPortXcvrNotifPortNumber = $6
						@AlertGroup = "Ciena OME Traps"
						@Agent = "ciena.m2r.include.rules"
						@Summary = "cienaCesPortXcvrRxPowerLowNotification: Low transceiver RX Power for port: " + $cienaCesPortXcvrNotifPortNumber + " slot " + $cienaCesPortXcvrNotifSlotIndex
						@Severity = 4
						@Type = 1
						@Identifier = @Node + @Summary
						details($*)

					case "20": ### - cienaCesPortXcvrRxPowerNormalNotification
						# SNMPv2
						# A cienaCesPortXcvrRxPowerNormalNotification is sent when the transceiver RxPower returns
						# to normal state. To enable the device to send this notification:
						# cienaCesPortXcvrRxPowerChangeTrapState, cienaCesLogicalPortConfigPortAllTrapState, and
						# cienaCesPortAllTrapState needs to be set to enabled. These objects are set to enabled by
						# default. Variable bindings include: cienaGlobalSeverity, cienaGlobalMacAddress,
						# cienaCesPortXcvrNotifChassisIndex, cienaCesPortXcvrNotifShelfIndex, cienaCesPortXcvrNotifSlotIndex,
						# and cienaCesPortXcvrNotifPortNumber.
						$cienaGlobalSeveritylook = "cienaGlobalSeverity." + $1
						$cienaGlobalSeverity = lookup($cienaGlobalSeveritylook,CienaVarbindValTable)
						if(match($cienaGlobalSeverity,"UNKNOWN")) {
							$cienaGlobalSeverity = $1
						} else {
							$cienaGlobalSeverity = $cienaGlobalSeverity + " ( " + $1 + " )"
						}
						$cienaGlobalMacAddress = $2
						$cienaCesPortXcvrNotifChassisIndex = $3
						$cienaCesPortXcvrNotifShelfIndex = $4
						$cienaCesPortXcvrNotifSlotIndex = $5
						$cienaCesPortXcvrNotifPortNumber = $6
						@AlertGroup = "Ciena OME Traps"
						@Agent = "ciena.m2r.include.rules"
						@Summary = "cienaCesPortXcvrRxPowerNormalNotification: Transceiver RX Power for port: " + $cienaCesPortXcvrNotifPortNumber + " slot " + $cienaCesPortXcvrNotifSlotIndex + " restored"
						@Severity = 4
						@Type = 1
						@Identifier = @Node + @Summary
						details($*)

					case "21": ### - cienaCesPortXcvrSpeedInfoMissingNotification
						# SNMPv2
						# A cienaCesPortXcvrSpeedInfoMissingNotification is sent if the transceiver speed
						# information is not found. To enable the device to send this notification:
						# cienaCesPortXcvrSpeedInfoTrapState, cienaCesLogicalPortConfigPortAllTrapState, and
						# cienaCesPortAllTrapState need to be set to enabled. These objects are set to enabled
						# by default. Variable bindings include: cienaGlobalSeverity, cienaGlobalMacAddress,
						# cienaCesPortXcvrNotifChassisIndex, cienaCesPortXcvrNotifShelfIndex,
						# cienaCesPortXcvrNotifSlotIndex, and cienaCesPortXcvrNotifPortNumber.
						$cienaGlobalSeveritylook = "cienaGlobalSeverity." + $1
						$cienaGlobalSeverity = lookup($cienaGlobalSeveritylook,CienaVarbindValTable)
						if(match($cienaGlobalSeverity,"UNKNOWN")) {
							$cienaGlobalSeverity = $1
						} else {
							$cienaGlobalSeverity = $cienaGlobalSeverity + " ( " + $1 + " )"
						}
						$cienaGlobalMacAddress = $2
						$cienaCesPortXcvrNotifChassisIndex = $3
						$cienaCesPortXcvrNotifShelfIndex = $4
						$cienaCesPortXcvrNotifSlotIndex = $5
						$cienaCesPortXcvrNotifPortNumber = $6
						@AlertGroup = "Ciena OME Traps"
						@Agent = "ciena.m2r.include.rules"
						@Summary = "cienaCesPortXcvrSpeedInfoMissingNotification: Transceiver speed information not found for port: " + $cienaCesPortXcvrNotifPortNumber + " slot " + $cienaCesPortXcvrNotifSlotIndex
						@Severity = 3
						@Type = 1
						@Identifier = @Node + @Summary
						details($*)

						case "22": ### - cienaCesPortXcvrUncertifiedNotification
						# SNMPv2
						# A cienaCesPortXcvrUncertifiedNotification is sent if the transceiver is not
						# certified for use by Ciena. To enable the device to send this notification:
						# cienaCesPortXcvrUncertifiedTrapState,  cienaCesLogicalPortConfigPortAllTrapState,
						# and cesPortAllTrapState need to be set to enabled. cienaCesPortXcvrUncertifiedTrapState
						# is set to disabled by default. Variable bindings include: cienaGlobalSeverity, cienaGlobalMacAddress,
						# cienaCesPortXcvrNotifChassisIndex, cienaCesPortXcvrNotifShelfIndex,
						# cienaCesPortXcvrNotifSlotIndex, and cienaCesPortXcvrNotifPortNumber.
						$cienaGlobalSeveritylook = "cienaGlobalSeverity." + $1
						$cienaGlobalSeverity = lookup($cienaGlobalSeveritylook,CienaVarbindValTable)
						if(match($cienaGlobalSeverity,"UNKNOWN")) {
							$cienaGlobalSeverity = $1
						} else {
							$cienaGlobalSeverity = $cienaGlobalSeverity + " ( " + $1 + " )"
						}
						$cienaGlobalMacAddress = $2
						$cienaCesPortXcvrNotifChassisIndex = $3
						$cienaCesPortXcvrNotifShelfIndex = $4
						$cienaCesPortXcvrNotifSlotIndex = $5
						$cienaCesPortXcvrNotifPortNumber = $6
						@AlertGroup = "Ciena OME Traps"
						@Agent = "ciena.m2r.include.rules"
						@Summary = "cienaCesPortXcvrUncertifiedNotification: Transceiver not certified for use for port: " + $cienaCesPortXcvrNotifPortNumber + " slot " + $cienaCesPortXcvrNotifSlotIndex
						@Severity = 3
						@Type = 1
						@Identifier = @Node + @Summary
						details($cienaGlobalSeverity,$cienaGlobalMacAddress,$cienaCesPortXcvrNotifChassisIndex,$cienaCesPortXcvrNotifShelfIndex,$cienaCesPortXcvrNotifSlotIndex,$cienaCesPortXcvrNotifPortNumber)

					default:
						@Summary = "Unknown specific trap number (" + $specific-trap + ") received for enterprise " + $enterprise
						@Identifier = @Node + $enterprise + $generic-trap + $specific-trap + @Agent + @Manager
						@Severity = 3
						@Type = 1
						details($*)
				}

			######
			# cienaCesRstpMIBNotifications traps
			######
			case ".1.3.6.1.4.1.1271.2.2.10":	### - cienaCesRstpMIBNotificationPrefix
				switch($specific-trap) {
					case "1": ### - cienaCesRstpPortBackupNotification
						# SNMPv2
						# A cienaCesRstpPortBackupNotification is sent when the
						# device detects a self loop (such as, the same cable connected to
						# two ports on the same device). To enable the device to send this
						# notification: cienaCesPortAllTrapState, cienaCesLogicalPortConfigPortAllTrapState
						# for the port, and cienaCesRstpPortBackupTrapState must be set to enabled. These
						# objects are set to enabled by default. Variable bindings include: cienaGlobalSeverity,
						# cienaGlobalMacAddress, cienaCesPortPgIdMappingNotifChassisIndex,
						# cienaCesPortPgIdMappingNotifShelfIndex, cienaCesPortPgIdMappingNotifSlotIndex,
						# cienaCesPortPgIdMappingNotifPortNumber, and dot1dStpPort.
						$cienaGlobalSeveritylook = "cienaGlobalSeverity." + $1
						$cienaGlobalSeverity = lookup($cienaGlobalSeveritylook,CienaVarbindValTable)
						if(match($cienaGlobalSeverity,"UNKNOWN")) {
							$cienaGlobalSeverity = $1
						} else {
							$cienaGlobalSeverity = $cienaGlobalSeverity + " ( " + $1 + " )"
						}
						$cienaGlobalMacAddress = $2
						$cienaCesPortPgIdMappingNotifChassisIndex = $3
						$cienaCesPortPgIdMappingNotifShelfIndex = $4
						$cienaCesPortPgIdMappingNotifSlotIndex = $5
						$cienaCesPortPgIdMappingNotifPortNumber = $6
						$dot1dStpPort = $7
						@AlertGroup = "Ciena OME Traps"
						@Agent = "ciena.m2r.include.rules"
						@Summary = "cienaCesRstpPortBackupNotification: Chassis Network Loop Detected"
						@Severity = 4
						@Type = 1
						@Identifier = @Node + @Summary
						details($*)

					case "2": ### - cienaCesRstpPvstBpduReceivedNotification
						# SNMPv2
						# A cienaCesRstpPvstBpduReceivedNotification is sent when a PVST BPDU is received
						# on the port. This trap is sent out every minute. To enable the device to send this
						# notification: cienaCesPortAllTrapState, cienaCesLogicalPortConfigPortAllTrapState
						# for the port, and cienaCesRstpPortPvstBPduReceivedTrapState must be set to enabled.
						# These objects are set to enabled by default. Variable bindings include:
						# cienaGlobalSeverity, cienaGlobalMacAddress, cienaCesPortPgIdMappingNotifChassisIndex,
						# cienaCesPortPgIdMappingNotifShelfIndex, cienaCesPortPgIdMappingNotifSlotIndex,
						# cienaCesPortPgIdMappingNotifPortNumber, and dot1dStpPort.
						$cienaGlobalSeveritylook = "cienaGlobalSeverity." + $1
						$cienaGlobalSeverity = lookup($cienaGlobalSeveritylook,CienaVarbindValTable)
						if(match($cienaGlobalSeverity,"UNKNOWN")) {
							$cienaGlobalSeverity = $1
						} else {
							$cienaGlobalSeverity = $cienaGlobalSeverity + " ( " + $1 + " )"
						}
						$cienaGlobalMacAddress = $2
						$cienaCesPortPgIdMappingNotifChassisIndex = $3
						$cienaCesPortPgIdMappingNotifShelfIndex = $4
						$cienaCesPortPgIdMappingNotifSlotIndex = $5
						$cienaCesPortPgIdMappingNotifPortNumber = $6
						$dot1dStpPort = $7
						@AlertGroup = "Ciena OME Traps"
						@Agent = "ciena.m2r.include.rules"
						@Summary = "cienaCesRstpPvstBpduReceivedNotification: Per Vlan Spanning Tree (PVST) bridge protocol data unit (BPDU) recieved for port " + $cienaCesPortPgIdMappingNotifPortNumber + " slot " + $cienaCesPortPgIdMappingNotifSlotIndex
						@Severity = 3
						@Type = 1
						@Identifier = @Node + @Summary
						details($*)

					case "3": ### - cienaCesRstpSelfLoopNotification
						# SNMPv2
						# A cienaCesRstpSelfLoopNotification is sent when the device detects the same
						# cable connected to a port in a loop back. Also, if loop-back blocking is enabled
						# on the device, RSTP blocks this port (self disable). To enable the device to send
						# this notification: cienaCesPortAllTrapState, cienaCesLogicalPortConfigPortAllTrapState
						# for the port, and cienaCesRstpPortSelfLoopTrapState must be set to enabled. These
						# are set to enabled by default. Variable bindings include: cienaGlobalSeverity,
						# cienaGlobalMacAddress, cienaCesPortPgIdMappingNotifChassisIndex,
						# cienaCesPortPgIdMappingNotifShelfIndex, cienaCesPortPgIdMappingNotifSlotIndex,
						# cienaCesPortPgIdMappingNotifPortNumber, and dot1dStpPort.
						$cienaGlobalSeveritylook = "cienaGlobalSeverity." + $1
						$cienaGlobalSeverity = lookup($cienaGlobalSeveritylook,CienaVarbindValTable)
						if(match($cienaGlobalSeverity,"UNKNOWN")) {
							$cienaGlobalSeverity = $1
						} else {
							$cienaGlobalSeverity = $cienaGlobalSeverity + " ( " + $1 + " )"
						}
						$cienaGlobalMacAddress = $2
						$cienaCesPortPgIdMappingNotifChassisIndex = $3
						$cienaCesPortPgIdMappingNotifShelfIndex = $4
						$cienaCesPortPgIdMappingNotifSlotIndex = $5
						$cienaCesPortPgIdMappingNotifPortNumber = $6
						$dot1dStpPort = $7
						@AlertGroup = "Ciena OME Traps"
						@Agent = "ciena.m2r.include.rules"
						@Summary = "cienaCesRstpSelfLoopNotification: Chassis Network Loop Detected"
						@Severity = 4
						@Type = 1
						@Identifier = @Node + @Summary
						details($*)

					case "4": ### - cienaCesRstpPortOperEdgeNotification
						# SNMPv2
						# A cienaCesRstpPortOperEdgeNotification trap is sent when the device detects a port
						# RSTP OperEdge change. To enable the device to send this notification:
						# cienaCesPortAllTrapState, cienaCesLogicalPortConfigPortAllTrapState for the port,
						# and cienaCesRstpPortOperEdgeTrapState must be set to enabled. These objects are set
						# to enabled by default. Variable bindings include: cienaGlobalSeverity,
						# cienaGlobalMacAddress, cienaCesPortPgIdMappingNotifChassisIndex,
						# cienaCesPortPgIdMappingNotifShelfIndex, cienaCesPortPgIdMappingNotifSlotIndex,
						# cienaCesPortPgIdMappingNotifPortNumber, dot1dStpPort, and dot1dStpPortOperEdgePort.
						$cienaGlobalSeveritylook = "cienaGlobalSeverity." + $1
						$cienaGlobalSeverity = lookup($cienaGlobalSeveritylook,CienaVarbindValTable)
						if(match($cienaGlobalSeverity,"UNKNOWN")) {
							$cienaGlobalSeverity = $1
						} else {
							$cienaGlobalSeverity = $cienaGlobalSeverity + " ( " + $1 + " )"
						}
						$cienaGlobalMacAddress = $2
						$cienaCesPortPgIdMappingNotifChassisIndex = $3
						$cienaCesPortPgIdMappingNotifShelfIndex = $4
						$cienaCesPortPgIdMappingNotifSlotIndex = $5
						$cienaCesPortPgIdMappingNotifPortNumber = $6
						$dot1dStpPort = $7
						$dot1dStpPortOperEdgePortlook = "dot1dStpPortOperEdgePort." + $8
						$dot1dStpPortOperEdgePort = lookup($dot1dStpPortOperEdgePortlook,CienaVarbindValTable)
						if(match($dot1dStpPortOperEdgePort,"UNKNOWN")) {
							$dot1dStpPortOperEdgePort = $8
						} else {
							$dot1dStpPortOperEdgePort = $dot1dStpPortOperEdgePort + " ( " + $8 + " )"
						}
						@AlertGroup = "Ciena OME Traps"
						@Agent = "ciena.m2r.include.rules"
						@Summary = "cienaCesRstpPortOperEdgeNotification: Rapid Spanning Tree Protocol (RSTP) OperEdge change detected"
						@Severity = 3
						@Type = 1
						@Identifier = @Node + @Summary
						details($*)

					case "5": ### - cienaCesRstpPortFlapNotification
						# SNMPv2
						# A cienaCesRstpPortFlapNotification trap is sent when the device detects a port
						# flapping. This trap is generated if the device detects that a port flapped more
						# than once within 1 minute timer period and it has not sent trap within last 5
						# minutes. To enable the device to send this notification: cienaCesPortAllTrapState,
						# cienaCesLogicalPortConfigPortAllTrapState for the port, and
						# cienaCesRstpPortFlapTrapState must be set to enable. These objects are set to
						# enabled by default. Variable bindings include: cienaGlobalSeverity,
						# cienaGlobalMacAddress, cienaCesPortPgIdMappingNotifChassisIndex,
						# cienaCesPortPgIdMappingNotifShelfIndex, cienaCesPortPgIdMappingNotifSlotIndex,
						# cienaCesPortPgIdMappingNotifPortNumber, and dot1dStpPort.
						$cienaGlobalSeveritylook = "cienaGlobalSeverity." + $1
						$cienaGlobalSeverity = lookup($cienaGlobalSeveritylook,CienaVarbindValTable)
						if(match($cienaGlobalSeverity,"UNKNOWN")) {
							$cienaGlobalSeverity = $1
						} else {
							$cienaGlobalSeverity = $cienaGlobalSeverity + " ( " + $1 + " )"
						}
						$cienaGlobalMacAddress = $2
						$cienaCesPortPgIdMappingNotifChassisIndex = $3
						$cienaCesPortPgIdMappingNotifShelfIndex = $4
						$cienaCesPortPgIdMappingNotifSlotIndex = $5
						$cienaCesPortPgIdMappingNotifPortNumber = $6
						$dot1dStpPort = $7
						@AlertGroup = "Ciena OME Traps"
						@Agent = "ciena.m2r.include.rules"
						@Summary = "cienaCesRstpPortFlapNotification: Port Flap detected for port " + $cienaCesPortPgIdMappingNotifPortNumber + " slot " +  $cienaCesPortPgIdMappingNotifSlotIndex
						@Severity = 4
						@Type = 1
						@Identifier = @Node + @Summary
						details($*)

					case "6": ### - cienaCesRstpBridgeRootPortLostNotification
						# SNMPv2
						# A cienaCesRstpBridgeRootPortLostNotification trap is sent when the device detects
						# that the bridge root port is lost. This trap indicates either the link failure or
						# link partner RSTP disabled. To enable the device to send this notification:
						# cienaCesPortAllTrapState, cienaCesLogicalPortConfigPortAllTrapState for the port, and
						# cienaCesRstpBridgeRootPortLostTrapState must be set to enabled. These objects are set
						# to enabled by default. Variable bindings include: cienaGlobalSeverity,
						# cienaGlobalMacAddress, cienaCesPortPgIdMappingNotifChassisIndex,
						# cienaCesPortPgIdMappingNotifShelfIndex, cienaCesPortPgIdMappingNotifSlotIndex,
						# cienaCesPortPgIdMappingNotifPortNumber, and dot1dStpPort.
						$cienaGlobalSeveritylook = "cienaGlobalSeverity." + $1
						$cienaGlobalSeverity = lookup($cienaGlobalSeveritylook,CienaVarbindValTable)
						if(match($cienaGlobalSeverity,"UNKNOWN")) {
							$cienaGlobalSeverity = $1
						} else {
							$cienaGlobalSeverity = $cienaGlobalSeverity + " ( " + $1 + " )"
						}
						$cienaGlobalMacAddress = $2
						$cienaCesPortPgIdMappingNotifChassisIndex = $3
						$cienaCesPortPgIdMappingNotifShelfIndex = $4
						$cienaCesPortPgIdMappingNotifSlotIndex = $5
						$cienaCesPortPgIdMappingNotifPortNumber = $6
						$dot1dStpPort = $7
						@AlertGroup = "Ciena OME Traps"
						@Agent = "ciena.m2r.include.rules"
						@Summary = "cienaCesRstpBridgeRootPortLostNotification: Bridge root port lost for port " + $cienaCesPortPgIdMappingNotifPortNumber + " slot " +  $cienaCesPortPgIdMappingNotifSlotIndex
						@Severity = 3
						@Type = 1
						@Identifier = @Node + @Summary
						details($*)

					default:
						@Summary = "Unknown specific trap number (" + $specific-trap + ") received for enterprise " + $enterprise
						@Identifier = @Node + $enterprise + $generic-trap + $specific-trap + @Agent + @Manager
						@Severity = 3
						@Type = 1
						details($*)
				}

			######
			# cienaCesFeatureLicenseMIBNotifications traps
			######
			case ".1.3.6.1.4.1.1271.2.2.11":	### - cienaCesFeatureLicenseMIBNotificationPrefix
				switch($specific-trap) {
					case "1": ### - cienaCesPremiumFeatureLicenseNotInstalledNotification
						# SNMPv2
						# This notification is sent when a premium feature license is uninstalled from the system.
						# To enable the device to send this trap, cienaCesFeatureLicenseStatusTrapState needs to
						# be set to enabled. The cienaCesFeatureLicenseStatusTrapState is enabled by default.
						# Variable bindings include: cienaGlobalSeverity, cienaGlobalMacAddress,
						# cienaCesPremiumFeatureLicenseName, cienaCesPremiumFeatureLicenseOperStatus,
						# and cienaCesPremiumFeatureLicenseDomainName.
						$cienaGlobalSeveritylook = "cienaGlobalSeverity." + $1
						$cienaGlobalSeverity = lookup($cienaGlobalSeveritylook,CienaVarbindValTable)
						if(match($cienaGlobalSeverity,"UNKNOWN")) {
							$cienaGlobalSeverity = $1
						} else {
							$cienaGlobalSeverity = $cienaGlobalSeverity + " ( " + $1 + " )"
						}
						$cienaGlobalMacAddress = $2
						$cienaCesPremiumFeatureLicenseName = $3
						$cienaCesPremiumFeatureLicenseOperStatuslook = "cienaCesPremiumFeatureLicenseOperStatus." + $4
						$cienaCesPremiumFeatureLicenseOperStatus = lookup($cienaCesPremiumFeatureLicenseOperStatuslook,CienaVarbindValTable)
						if(match($cienaCesPremiumFeatureLicenseOperStatus,"UNKNOWN")) {
							$cienaCesPremiumFeatureLicenseOperStatus = $4
						} else {
							$cienaCesPremiumFeatureLicenseOperStatus = $cienaCesPremiumFeatureLicenseOperStatus + " ( " + $4 + " )"
						}
						$cienaCesPremiumFeatureLicenseDomainName = $5
						@AlertGroup = "Ciena OME Traps"
						@Agent = "ciena.m2r.include.rules"
						@Summary = "cienaCesPremiumFeatureLicenseNotInstalledNotification: Needed premium feature license isn't installed"
						@Severity = 4
						@Type = 1
						@Identifier = @Node + @Summary
						details($*)

					case "2": ### - cienaCesPremiumFeatureLicensePartialStatusNotification
						# SNMPv2
						# This notification is sent when there are fewer licenses available in the pool.
						# To enable the device to send this trap, cienaCesFeatureLicenseStatusTrapState
						# needs to be set to enabled. The cienaCesFeatureLicenseStatusTrapState is enabled
						# by default. Variable bindings include: cienaGlobalSeverity, cienaGlobalMacAddress,
						# cienaCesPremiumFeatureLicenseName, cienaCesPremiumFeatureLicenseOperStatus,
						# and cienaCesPremiumFeatureLicenseDomainName.
						$cienaGlobalSeveritylook = "cienaGlobalSeverity." + $1
						$cienaGlobalSeverity = lookup($cienaGlobalSeveritylook,CienaVarbindValTable)
						if(match($cienaGlobalSeverity,"UNKNOWN")) {
							$cienaGlobalSeverity = $1
						} else {
							$cienaGlobalSeverity = $cienaGlobalSeverity + " ( " + $1 + " )"
						}
						$cienaGlobalMacAddress = $2
						$cienaCesPremiumFeatureLicenseName = $3
						$cienaCesPremiumFeatureLicenseOperStatuslook = "cienaCesPremiumFeatureLicenseOperStatus." + $4
						$cienaCesPremiumFeatureLicenseOperStatus = lookup($cienaCesPremiumFeatureLicenseOperStatuslook,CienaVarbindValTable)
						if(match($cienaCesPremiumFeatureLicenseOperStatus,"UNKNOWN")) {
							$cienaCesPremiumFeatureLicenseOperStatus = $4
						} else {
							$cienaCesPremiumFeatureLicenseOperStatus = $cienaCesPremiumFeatureLicenseOperStatus + " ( " + $4 + " )"
						}
						$cienaCesPremiumFeatureLicenseDomainName = $5
						@AlertGroup = "Ciena OME Traps"
						@Agent = "ciena.m2r.include.rules"
						@Summary = "cienaCesPremiumFeatureLicensePartialStatusNotification: Fewer licenses available in pool for premium features"
						@Severity = 3
						@Type = 1
						@Identifier = @Node + @Summary
						details($*)

					case "3": ### - cienaCesPremiumFeatureLicenseInstallErrorNotification
						# SNMPv2
						# This notification is sent when there was an unsuccessful installation
						# of a premium feature license on the slot. To enable the device to send
						# this trap, cienaCesFeatureLicenseInstallErrorTrapState needs to be set
						# to enabled. The cienaCesFeatureLicenseInstallErrorTrapState is enabled
						# by default. Variable bindings include: cienaGlobalSeverity,
						# cienaGlobalMacAddress,cienaCesModuleChassisIndx, cienaCesModuleShelfIndx,
						# cienaCesModuleSlotIndx, and cienaCesPremiumFeatureLicenseInstallUnsuccessfulReason.
						$cienaGlobalSeveritylook = "cienaGlobalSeverity." + $1
						$cienaGlobalSeverity = lookup($cienaGlobalSeveritylook,CienaVarbindValTable)
						if(match($cienaGlobalSeverity,"UNKNOWN")) {
							$cienaGlobalSeverity = $1
						} else {
							$cienaGlobalSeverity = $cienaGlobalSeverity + " ( " + $1 + " )"
						}
						$cienaGlobalMacAddress = $2
						$cienaCesModuleChassisIndx = $3
						$cienaCesModuleShelfIndx = $4
						$cienaCesModuleSlotIndx = $5
						$cienaCesPremiumFeatureLicenseInstallUnsuccessfulReason = $6
						@AlertGroup = "Ciena OME Traps"
						@Agent = "ciena.m2r.include.rules"
						@Summary = "cienaCesPremiumFeatureLicenseInstallErrorNotification: Premium feature license installation failure"
						@Severity = 4
						@Type = 1
						@Identifier = @Node + @Summary
						details($*)

					case "4": ### - cienaCesPremiumFeatureLicenseInstalledNotification
						# SNMPv2
						# This notification is sent when a premium feature license is installed on the system.
						# To enable the device to send this trap, cienaCesFeatureLicenseStatusTrapState needs to
						# be set to enabled. The cienaCesFeatureLicenseStatusTrapState is enabled by default.
						# Variable bindings include: cienaGlobalSeverity, cienaGlobalMacAddress,
						# cienaCesPremiumFeatureLicenseName, cienaCesPremiumFeatureLicenseOperStatus,
						# and cienaCesPremiumFeatureLicenseDomainName.
						$cienaGlobalSeveritylook = "cienaGlobalSeverity." + $1
						$cienaGlobalSeverity = lookup($cienaGlobalSeveritylook,CienaVarbindValTable)
						if(match($cienaGlobalSeverity,"UNKNOWN")) {
							$cienaGlobalSeverity = $1
						} else {
							$cienaGlobalSeverity = $cienaGlobalSeverity + " ( " + $1 + " )"
						}
						$cienaGlobalMacAddress = $2
						$cienaCesPremiumFeatureLicenseName = $3
						$cienaCesPremiumFeatureLicenseOperStatuslook = "cienaCesPremiumFeatureLicenseOperStatus." + $4
						$cienaCesPremiumFeatureLicenseOperStatus = lookup($cienaCesPremiumFeatureLicenseOperStatuslook,CienaVarbindValTable)
						if(match($cienaCesPremiumFeatureLicenseOperStatus,"UNKNOWN")) {
							$cienaCesPremiumFeatureLicenseOperStatus = $4
						} else {
							$cienaCesPremiumFeatureLicenseOperStatus = $cienaCesPremiumFeatureLicenseOperStatus + " ( " + $4 + " )"
						}
						$cienaCesPremiumFeatureLicenseDomainName = $5
						@AlertGroup = "Ciena OME Traps"
						@Agent = "ciena.m2r.include.rules"
						@Summary = "cienaCesPremiumFeatureLicenseInstalledNotification: Premium feature license has been installed"
						@Severity = 3
						@Type = 1
						@Identifier = @Node + @Summary
						details($*)

					case "5": ### - cienaCesPremiumFeatureLicenseUsageViolationNotification
						# SNMPv2
						# This notification is sent whenever there is license usage violation.
						# To enable the device to send this trap, cienaCesFeatureLicenseStatusTrapState
						# needs to be set to enabled. The cienaCesFeatureLicenseStatusTrapState is enabled
						# by default. Variable bindings include: cienaGlobalSeverity, cienaGlobalMacAddress,
						# cienaCesPremiumFeatureLicenseName, cienaCesPremiumFeatureLicenseOperStatus,
						# and cienaCesPremiumFeatureLicenseDomainName.
						$cienaGlobalSeveritylook = "cienaGlobalSeverity." + $1
						$cienaGlobalSeverity = lookup($cienaGlobalSeveritylook,CienaVarbindValTable)
						if(match($cienaGlobalSeverity,"UNKNOWN")) {
							$cienaGlobalSeverity = $1
						} else {
							$cienaGlobalSeverity = $cienaGlobalSeverity + " ( " + $1 + " )"
						}
						$cienaGlobalMacAddress = $2
						$cienaCesPremiumFeatureLicenseName = $3
						$cienaCesPremiumFeatureLicenseOperStatuslook = "cienaCesPremiumFeatureLicenseOperStatus." + $4
						$cienaCesPremiumFeatureLicenseOperStatus = lookup($cienaCesPremiumFeatureLicenseOperStatuslook,CienaVarbindValTable)
						if(match($cienaCesPremiumFeatureLicenseOperStatus,"UNKNOWN")) {
							$cienaCesPremiumFeatureLicenseOperStatus = $4
						} else {
							$cienaCesPremiumFeatureLicenseOperStatus = $cienaCesPremiumFeatureLicenseOperStatus + " ( " + $4 + " )"
						}
						$cienaCesPremiumFeatureLicenseDomainName = $5
						@AlertGroup = "Ciena OME Traps"
						@Agent = "ciena.m2r.include.rules"
						@Summary = "cienaCesPremiumFeatureLicenseUsageViolationNotification: License usage violation has occurred"
						@Severity = 4
						@Type = 1
						@Identifier = @Node + @Summary
						details($*)

					default:
						@Summary = "Unknown specific trap number (" + $specific-trap + ") received for enterprise " + $enterprise
						@Identifier = @Node + $enterprise + $generic-trap + $specific-trap + @Agent + @Manager
						@Severity = 3
						@Type = 1
						details($*)
				}

			######
			# cienaCesSwXgradeMIBNotifications traps
			######
			case ".1.3.6.1.4.1.1271.2.2.13":	### - cienaCesSwXgradeMIBNotificationPrefix
				switch($specific-trap) {
					case "1": ### - cienaCesSwXgradeCompletion
						# SNMPv2
						# A cienaCesSwXgradeCompletion notification is sent at the
						# completion of a cienaCesSwXgradeOp (download/install/activate/
						# ... etc). To enable the device to send this trap,
						# cienaCesSwXgradeCompletionTrapState must be set to enabled. The
						# cienaCesSwXgradeCompletionTrapState is enabled by default. Variable
						# bindings include: cienaGlobalSeverity, cienaGlobalMacAddress,
						# cienaCesSwXgradeOp, cienaCesSwXgradeStatus, and
						# cienaCesSwXgradeGracefulUpgrade.
						$cienaGlobalSeveritylook = "cienaGlobalSeverity." + $1
						$cienaGlobalSeverity = lookup($cienaGlobalSeveritylook,CienaVarbindValTable)
						if(match($cienaGlobalSeverity,"UNKNOWN")) {
							$cienaGlobalSeverity = $1
						} else {
							$cienaGlobalSeverity = $cienaGlobalSeverity + " ( " + $1 + " )"
						}
						$cienaGlobalMacAddress = $2
						$cienaCesSwXgradeOplook = "cienaCesSwXgradeOp." + $3
						$cienaCesSwXgradeOp = lookup($cienaCesSwXgradeOplook,CienaVarbindValTable)
						if(match($cienaCesSwXgradeOp,"UNKNOWN")) {
							$cienaCesSwXgradeOp = $3
						} else {
							$cienaCesSwXgradeOp = $cienaCesSwXgradeOp + " ( " + $3 + " )"
						}
						$cienaCesSwXgradeStatuslook = "cienaCesSwXgradeStatus." + $4
						$cienaCesSwXgradeStatus = lookup($cienaCesSwXgradeStatuslook,CienaVarbindValTable)
						if(match($cienaCesSwXgradeStatus,"UNKNOWN")) {
							$cienaCesSwXgradeStatus = $4
						} else {
							$cienaCesSwXgradeStatus = $cienaCesSwXgradeStatus + " ( " + $4 + " )"
						}
						$cienaCesSwXgradeGracefulUpgradelook = "cienaCesSwXgradeGracefulUpgrade." + $5
						$cienaCesSwXgradeGracefulUpgrade = lookup($cienaCesSwXgradeGracefulUpgradelook,CienaVarbindValTable)
						if(match($cienaCesSwXgradeGracefulUpgrade,"UNKNOWN")) {
							$cienaCesSwXgradeGracefulUpgrade = $5
						} else {
							$cienaCesSwXgradeGracefulUpgrade = $cienaCesSwXgradeGracefulUpgrade + " ( " + $5 + " )"
						}
						@AlertGroup = "Ciena OME Traps"
						@Agent = "ciena.m2r.include.rules"
						@Summary = "cienaCesSwXgradeCompletion"
						@Severity = 3
						@Type = 1
						@Identifier = @Node + @Summary
						details($*)

					default:
						@Summary = "Unknown specific trap number (" + $specific-trap + ") received for enterprise " + $enterprise
						@Identifier = @Node + $enterprise + $generic-trap + $specific-trap + @Agent + @Manager
						@Severity = 3
						@Type = 1
						details($*)
				}

			######
			# cienaCesSystemConfigMIBNotifications traps
			######
			case ".1.3.6.1.4.1.1271.2.2.14":	### - cienaCesSystemConfigMIBNotificationPrefix
				switch($specific-trap) {
					case "1": ### - cienaCesImproperCmdInConfigFile
						# SNMPv2
						# A cienaCesImproperCmdInConfigFile notification signifies that the SNMP entity, acting in
						# an agent role, has detected that improper commands were found in the
						# configuration file while processing the cienaCesSystemConfigFileName. The
						# cienaCesSystemConfigErrLinesTotal specifies the number of the lines in the
						# configuration file that failed. To enable the device to send this notification:
						# cienaCesSystemConfigImproperCmdTrapState must be set to enabled.
						# cienaCesSystemConfigImproperCmdTrapState is enabled by default. Variable bindings
						# include: cienaGlobalSeverity, cienaGlobalMacAddress, cienaCesSystemConfigFileName, and
						# cienaCesSystemConfigErrLinesTotal.
						$cienaGlobalSeveritylook = "cienaGlobalSeverity." + $1
						$cienaGlobalSeverity = lookup($cienaGlobalSeveritylook,CienaVarbindValTable)
						if(match($cienaGlobalSeverity,"UNKNOWN")) {
							$cienaGlobalSeverity = $1
						} else {
							$cienaGlobalSeverity = $cienaGlobalSeverity + " ( " + $1 + " )"
						}
						$cienaGlobalMacAddress = $2
						$cienaCesSystemConfigFileName = $3
						$cienaCesSystemConfigErrLinesTotallook = "cienaCesSystemConfigErrLinesTotal." + $4
						$cienaCesSystemConfigErrLinesTotal = lookup($cienaCesSystemConfigErrLinesTotallook,CienaVarbindValTable)
						if(match($cienaCesSystemConfigErrLinesTotal,"UNKNOWN")) {
							$cienaCesSystemConfigErrLinesTotal = $4
						} else {
							$cienaCesSystemConfigErrLinesTotal = $cienaCesSystemConfigErrLinesTotal + " ( " + $4 + " )"
						}
						@AlertGroup = "Ciena OME Traps"
						@Agent = "ciena.m2r.include.rules"
						@Summary = "cienaCesImproperCmdInConfigFile: Improper commands found in config file: " + $cienaCesSystemConfigFileName
						@Severity = 4
						@Type = 1
						@Identifier = @Node + @Summary
						details($*)

						case "2": ### - cienaCesCommandFileCompletedNotification
						# SNMPv2
						# Indicates that a command file has been successfully downloaded
						# and executed.
						$cienaGlobalSeveritylook = "cienaGlobalSeverity." + $1
						$cienaGlobalSeverity = lookup($cienaGlobalSeveritylook,CienaVarbindValTable)
						if(match($cienaGlobalSeverity,"UNKNOWN")) {
							$cienaGlobalSeverity = $1
						} else {
							$cienaGlobalSeverity = $cienaGlobalSeverity + " ( " + $1 + " )"
						}
						$cienaGlobalMacAddress = $2
						$cienaCesCommandFileHost = $3
						$cienaCesCommandFileName = $4
						@AlertGroup = "Ciena OME Traps"
						@Agent = "ciena.m2r.include.rules"
						@Summary = "cienaCesCommandFileCompletedNotification: A Command file has been successfully downloaded and executed."
						@Severity = 3
						@Type = 1
						@Identifier = @Node + @Summary
						details($cienaGlobalSeverity,$cienaGlobalMacAddress,$cienaCesCommandFileHost,$cienaCesCommandFileName)

					case "3": ### - cienaCesCommandFileFailedNotification
						# SNMPv2
						# Indicates that a failure occurred while downloading or executing
						# a command file.
						$cienaGlobalSeveritylook = "cienaGlobalSeverity." + $1
						$cienaGlobalSeverity = lookup($cienaGlobalSeveritylook,CienaVarbindValTable)
						if(match($cienaGlobalSeverity,"UNKNOWN")) {
							$cienaGlobalSeverity = $1
						} else {
							$cienaGlobalSeverity = $cienaGlobalSeverity + " ( " + $1 + " )"
						}
						$cienaGlobalMacAddress = $2
						$cienaCesCommandFileHost = $3
						$cienaCesCommandFileName = $4
						$cienaCesCommandFileError = $5
						@AlertGroup = "Ciena OME Traps"
						@Agent = "ciena.m2r.include.rules"
						@Summary = "cienaCesCommandFileFailedNotification: Failure occurred while downloading or executing a command file"
						@Severity = 3
						@Type = 1
						@Identifier = @Node + @Summary
						details($cienaGlobalSeverity,$cienaGlobalMacAddress,$cienaCesCommandFileHost,$cienaCesCommandFileName,$cienaCesCommandFileError)

					default:
						@Summary = "Unknown specific trap number (" + $specific-trap + ") received for enterprise " + $enterprise
						@Identifier = @Node + $enterprise + $generic-trap + $specific-trap + @Agent + @Manager
						@Severity = 3
						@Type = 1
						details($*)
				}

			######
			# cienaCesOamNotifMIBNotification traps
			######
			case ".1.3.6.1.4.1.1271.2.2.15":	### - cienaCesOamNotifMIBNotificationPrefix
				switch($specific-trap) {
					case "1": ### - cienaCesOamLinkEventTrap
						# SNMPv2
						# A cienaCesOamLinkEventTrap notification is sent whenever a local or remote link event is detected
						# and recorded in the cienaCesOamEventLogTable.
						# To enable the device to send this trap, cienaCesOamLinkEventTrapState needs to be set to enabled.
						# The cienaCesOamLinkEventTrapState is enabled by default. Variable bindings include:
						# cienaGlobalSeverity, cienaGlobalMacAddress, cienaCesOamEventNotifChassisIndex,
						# cienaCesOamEventNotifShelfIndex, cienaCesOamEventNotifSlotIndex, cienaCesOamEventNotifPortNumber,
						# cienaCesOamEventLogType, and cienaCesOamEventLogLocation.
						$cienaGlobalSeveritylook = "cienaGlobalSeverity." + $1
						$cienaGlobalSeverity = lookup($cienaGlobalSeveritylook,CienaVarbindValTable)
						if(match($cienaGlobalSeverity,"UNKNOWN")) {
							$cienaGlobalSeverity = $1
						} else {
							$cienaGlobalSeverity = $cienaGlobalSeverity + " ( " + $1 + " )"
						}
						$cienaGlobalMacAddress = $2
						$cienaCesOamEventNotifChassisIndex = $3
						$cienaCesOamEventNotifShelfIndex = $4
						$cienaCesOamEventNotifSlotIndex = $5
						$cienaCesOamEventNotifPortNumber = $6
						$cienaCesOamEventLogTypelook = "cienaCesOamEventLogType." + $7
						$cienaCesOamEventLogType = lookup($cienaCesOamEventLogTypelook,CienaVarbindValTable)
						if(match($cienaCesOamEventLogType,"UNKNOWN")) {
							$cienaCesOamEventLogType = $7
						} else {
							$cienaCesOamEventLogType = $cienaCesOamEventLogType + " ( " + $7 + " )"
						}
						$cienaCesOamEventLogLocationlook = "cienaCesOamEventLogLocation." + $8
						$cienaCesOamEventLogLocation = lookup($cienaCesOamEventLogLocationlook,CienaVarbindValTable)
						if(match($cienaCesOamEventLogLocation,"UNKNOWN")) {
							$cienaCesOamEventLogLocation = $8
						} else {
							$cienaCesOamEventLogLocation = $cienaCesOamEventLogLocation + " ( " + $8 + " )"
						}
						@AlertGroup = "Ciena OME Traps"
						@Agent = "ciena.m2r.include.rules"
						@Summary = "cienaCesOamLinkEventTrap: Local or remote link event detected and logged"
						@Severity = 3
						@Type = 1
						@Identifier = @Node + @Summary
						details($*)

					default:
						@Summary = "Unknown specific trap number (" + $specific-trap + ") received for enterprise " + $enterprise
						@Identifier = @Node + $enterprise + $generic-trap + $specific-trap + @Agent + @Manager
						@Severity = 3
						@Type = 1
						details($*)
				}

			######
			# cienaCesFileTransferMIBNotifications traps
			######
			case ".1.3.6.1.4.1.1271.2.2.16":	### - cienaCesFileTransferMIBNotificationPrefix
				switch($specific-trap) {
					case "1": ### - cienaCesFTransferCompletion
						# SNMPv2
						# A cienaCesFTransferCompletion notification is sent at the completion
						# of a file transfer request. The cienaCesFileTransferCompletionTrapState
						# must be enabled to generate this notification. Variable bindings include:
						# cienaGlobalSeverity, cienaGlobalMacAddress, cienaCesFTransferRemoteFilename,
						# cienaCesFTransferLocalFilename, cienaCesFTransferNotificationStatus, and
						# cienaCesFTransferNotificationInfo.
						$cienaGlobalSeveritylook = "cienaGlobalSeverity." + $1
						$cienaGlobalSeverity = lookup($cienaGlobalSeveritylook,CienaVarbindValTable)
						if(match($cienaGlobalSeverity,"UNKNOWN")) {
							$cienaGlobalSeverity = $1
						} else {
							$cienaGlobalSeverity = $cienaGlobalSeverity + " ( " + $1 + " )"
						}
						$cienaGlobalMacAddress = $2
						$cienaCesFTransferRemoteFilename = $3
						$cienaCesFTransferLocalFilename = $4
						$cienaCesFTransferNotificationStatuslook = "cienaCesFTransferNotificationStatus." + $5
						$cienaCesFTransferNotificationStatus = lookup($cienaCesFTransferNotificationStatuslook,CienaVarbindValTable)
						if(match($cienaCesFTransferNotificationStatus,"UNKNOWN")) {
							$cienaCesFTransferNotificationStatus = $5
						} else {
							$cienaCesFTransferNotificationStatus = $cienaCesFTransferNotificationStatus + " ( " + $5 + " )"
						}
						$cienaCesFTransferNotificationInfo = $6
						@AlertGroup = "Ciena OME Traps"
						@Agent = "ciena.m2r.include.rules"
						@Summary = "cienaCesFTransferCompletion: File transfer completed"
						@Severity = 3
						@Type = 1
						@Identifier = @Node + @Summary
						details($*)

					default:
						@Summary = "Unknown specific trap number (" + $specific-trap + ") received for enterprise " + $enterprise
						@Identifier = @Node + $enterprise + $generic-trap + $specific-trap + @Agent + @Manager
						@Severity = 3
						@Type = 1
						details($*)
				}

			######
			# cienaCesMplsMIBNotifications traps
			######
			case ".1.3.6.1.4.1.1271.2.2.17":	### - cienaCesMplsMIBNotificationPrefix
				switch($specific-trap) {
					case "1": ### - cienaCesMplsTunnelOperStateChgTrap
						# SNMPv2
						# This notification is sent when the operational state of an encap
						# tunnel changes. Variable bindings include: cienaGlobalSeverity,
						# cienaGlobalMacAddress, cienaCesMplsNotifEncapTunnelIndex,
						# cienaCesMplsNotifEncapTunnelType, cienaCesMplsNotifEncapTunnelName,
						# cienaCesMplsNotifEncapTunnelAdminState, and
						# cienaCesMplsNotifEncapTunnelOperState.
						$cienaGlobalSeveritylook = "cienaGlobalSeverity." + $1
						$cienaGlobalSeverity = lookup($cienaGlobalSeveritylook,CienaVarbindValTable)
						if(match($cienaGlobalSeverity,"UNKNOWN")) {
							$cienaGlobalSeverity = $1
						} else {
							$cienaGlobalSeverity = $cienaGlobalSeverity + " ( " + $1 + " )"
						}
						$cienaGlobalMacAddress = $2
						$cienaCesMplsNotifEncapTunnelIndex = $3
						$cienaCesMplsNotifEncapTunnelTypelook = "cienaCesMplsNotifEncapTunnelType." + $4
						$cienaCesMplsNotifEncapTunnelType = lookup($cienaCesMplsNotifEncapTunnelTypelook,CienaVarbindValTable)
						if(match($cienaCesMplsNotifEncapTunnelType,"UNKNOWN")) {
							$cienaCesMplsNotifEncapTunnelType = $4
						} else {
							$cienaCesMplsNotifEncapTunnelType = $cienaCesMplsNotifEncapTunnelType + " ( " + $4 + " )"
						}
						$cienaCesMplsNotifEncapTunnelName = $5
						$cienaCesMplsNotifEncapTunnelAdminStatelook = "cienaCesMplsNotifEncapTunnelAdminState." + $6
						$cienaCesMplsNotifEncapTunnelAdminState = lookup($cienaCesMplsNotifEncapTunnelAdminStatelook,CienaVarbindValTable)
						if(match($cienaCesMplsNotifEncapTunnelAdminState,"UNKNOWN")) {
							$cienaCesMplsNotifEncapTunnelAdminState = $6
						} else {
							$cienaCesMplsNotifEncapTunnelAdminState = $cienaCesMplsNotifEncapTunnelAdminState + " ( " + $6 + " )"
						}
						$cienaCesMplsNotifEncapTunnelOperStatelook = "cienaCesMplsNotifEncapTunnelOperState." + $7
						$cienaCesMplsNotifEncapTunnelOperState = lookup($cienaCesMplsNotifEncapTunnelOperStatelook,CienaVarbindValTable)
						if(match($cienaCesMplsNotifEncapTunnelOperState,"UNKNOWN")) {
							$cienaCesMplsNotifEncapTunnelOperState = $7
						} else {
							$cienaCesMplsNotifEncapTunnelOperState = $cienaCesMplsNotifEncapTunnelOperState + " ( " + $7 + " )"
						}
						@AlertGroup = "Ciena OME Traps"
						@Agent = "ciena.m2r.include.rules"
						@Summary = "cienaCesMplsTunnelOperStateChgTrap: MPLS Tunnel state changed to " + $cienaCesMplsNotifEncapTunnelOperState
						@Severity = 4
						@Type = 1
						@Identifier = @Node + @Summary
						details($*)

					case "2": ### - cienaCesMplsEncapTunnelGrpActiveEncapTunnelChange
						# SNMPv2
						# This notification is sent whenever the active encap tunnel in
						# a tunnel group changes.
						$cienaGlobalSeveritylook = "cienaGlobalSeverity." + $1
						$cienaGlobalSeverity = lookup($cienaGlobalSeveritylook,CienaVarbindValTable)
						if(match($cienaGlobalSeverity,"UNKNOWN")) {
							$cienaGlobalSeverity = $1
						} else {
							$cienaGlobalSeverity = $cienaGlobalSeverity + " ( " + $1 + " )"
						}
						$cienaGlobalMacAddress = $2
						$cienaCesMplsNotifEncapTunnelGrpIndex = $3
						$cienaCesMplsNotifEncapTunnelGrpName = $4
						$cienaCesMplsNotifEncapTunnelGrpActiveEncapTunlIndex = $5
						$cienaCesMplsNotifEncapTunnelGrpActiveEncapTunlName = $6
						$cienaCesMplsNotifEncapTunnelGrpActiveEncapTunlTypelook = "cienaCesMplsNotifEncapTunnelGrpActiveEncapTunlType." + $7
						$cienaCesMplsNotifEncapTunnelGrpActiveEncapTunlType = lookup($cienaCesMplsNotifEncapTunnelGrpActiveEncapTunlTypelook,CienaVarbindValTable)
						if(match($cienaCesMplsNotifEncapTunnelGrpActiveEncapTunlType,"UNKNOWN")) {
							$cienaCesMplsNotifEncapTunnelGrpActiveEncapTunlType = $7
						} else {
							$cienaCesMplsNotifEncapTunnelGrpActiveEncapTunlType = $cienaCesMplsNotifEncapTunnelGrpActiveEncapTunlType + " ( " + $7 + " )"
						}
						@AlertGroup = "Ciena OME Traps"
						@Agent = "ciena.m2r.include.rules"
						@Summary = "cienaCesMplsEncapTunnelGrpActiveEncapTunnelChange: Active encap tunnel in a tunnel group " + $cienaCesMplsNotifEncapTunnelGrpName + " changed"
						@Severity = 3
						@Type = 1
						@Identifier = @Node + @Summary
						details($*)

					case "3": ### - cienaCesMplsTransitTunnelOperStateChgTrap
						# SNMPv2
						# This notification is sent when the operational state of a transit
						# tunnel changes. Variable bindings include: cienaGlobalSeverity,
						# cienaGlobalMacAddress, cienaCesMplsNotifTransitTunnelIndex,
						# cienaCesMplsNotifTransitTunnelType, cienaCesMplsNotifTransitTunnelName,
						# cienaCesMplsNotifTransitTunnelAdminState, and cienaCesMplsNotifTransitTunnelOperState.
						$cienaGlobalSeveritylook = "cienaGlobalSeverity." + $1
						$cienaGlobalSeverity = lookup($cienaGlobalSeveritylook,CienaVarbindValTable)
						if(match($cienaGlobalSeverity,"UNKNOWN")) {
							$cienaGlobalSeverity = $1
						} else {
							$cienaGlobalSeverity = $cienaGlobalSeverity + " ( " + $1 + " )"
						}
						$cienaGlobalMacAddress = $2
						$cienaCesMplsNotifTransitTunnelIndex = $3
						$cienaCesMplsNotifTransitTunnelTypelook = "cienaCesMplsNotifTransitTunnelType." + $4
						$cienaCesMplsNotifTransitTunnelType = lookup($cienaCesMplsNotifTransitTunnelTypelook,CienaVarbindValTable)
						if(match($cienaCesMplsNotifTransitTunnelType,"UNKNOWN")) {
							$cienaCesMplsNotifTransitTunnelType = $4
						} else {
							$cienaCesMplsNotifTransitTunnelType = $cienaCesMplsNotifTransitTunnelType + " ( " + $4 + " )"
						}
						$cienaCesMplsNotifTransitTunnelName = $5
						$cienaCesMplsNotifTransitTunnelAdminStatelook = "cienaCesMplsNotifTransitTunnelAdminState." + $6
						$cienaCesMplsNotifTransitTunnelAdminState = lookup($cienaCesMplsNotifTransitTunnelAdminStatelook,CienaVarbindValTable)
						if(match($cienaCesMplsNotifTransitTunnelAdminState,"UNKNOWN")) {
							$cienaCesMplsNotifTransitTunnelAdminState = $6
						} else {
							$cienaCesMplsNotifTransitTunnelAdminState = $cienaCesMplsNotifTransitTunnelAdminState + " ( " + $6 + " )"
						}
						$cienaCesMplsNotifTransitTunnelOperStatelook = "cienaCesMplsNotifTransitTunnelOperState." + $7
						$cienaCesMplsNotifTransitTunnelOperState = lookup($cienaCesMplsNotifTransitTunnelOperStatelook,CienaVarbindValTable)
						if(match($cienaCesMplsNotifTransitTunnelOperState,"UNKNOWN")) {
							$cienaCesMplsNotifTransitTunnelOperState = $7
						} else {
							$cienaCesMplsNotifTransitTunnelOperState = $cienaCesMplsNotifTransitTunnelOperState + " ( " + $7 + " )"
						}
						@AlertGroup = "Ciena OME Traps"
						@Agent = "ciena.m2r.include.rules"
						@Summary = "cienaCesMplsTransitTunnelOperStateChgTrap: Operational state of transit tunnel: " + $cienaCesMplsNotifTransitTunnelName + " changed to " + $cienaCesMplsNotifTransitTunnelOperState
						@Severity = 4
						@Type = 1
						@Identifier = @Node + @Summary
						details($*)

					case "6": ### - cienaCesMplsAssociatedTunnelOperStateChgTrap
						# SNMPv2
						# This notification is sent when the operational state of an associated
						# tunnel changes. Variable bindings include: cienaGlobalSeverity,
						# cienaGlobalMacAddress, cienaCesMplsNotifAssociatedTunnelIndex,
						# cienaCesMplsNotifAssociatedTunnelType, cienaCesMplsNotifAssociatedTunnelName,
						# cienaCesMplsNotifAssociatedTunnelAdminState, and
						# cienaCesMplsNotifAssociatedTunnelOperState.
						$cienaGlobalSeveritylook = "cienaGlobalSeverity." + $1
						$cienaGlobalSeverity = lookup($cienaGlobalSeveritylook,CienaVarbindValTable)
						if(match($cienaGlobalSeverity,"UNKNOWN")) {
							$cienaGlobalSeverity = $1
						} else {
							$cienaGlobalSeverity = $cienaGlobalSeverity + " ( " + $1 + " )"
						}
						$cienaGlobalMacAddress = $2
						$cienaCesMplsNotifAssociatedTunnelIndex = $3
						$cienaCesMplsNotifAssociatedTunnelTypelook = "cienaCesMplsNotifAssociatedTunnelType." + $4
						$cienaCesMplsNotifAssociatedTunnelType = lookup($cienaCesMplsNotifAssociatedTunnelTypelook,CienaVarbindValTable)
						if(match($cienaCesMplsNotifAssociatedTunnelType,"UNKNOWN")) {
							$cienaCesMplsNotifAssociatedTunnelType = $4
						} else {
							$cienaCesMplsNotifAssociatedTunnelType = $cienaCesMplsNotifAssociatedTunnelType + " ( " + $4 + " )"
						}
						$cienaCesMplsNotifAssociatedTunnelName = $5
						$cienaCesMplsNotifAssociatedTunnelAdminStatelook = "cienaCesMplsNotifAssociatedTunnelAdminState." + $6
						$cienaCesMplsNotifAssociatedTunnelAdminState = lookup($cienaCesMplsNotifAssociatedTunnelAdminStatelook,CienaVarbindValTable)
						if(match($cienaCesMplsNotifAssociatedTunnelAdminState,"UNKNOWN")) {
							$cienaCesMplsNotifAssociatedTunnelAdminState = $6
						} else {
							$cienaCesMplsNotifAssociatedTunnelAdminState = $cienaCesMplsNotifAssociatedTunnelAdminState + " ( " + $6 + " )"
						}
						$cienaCesMplsNotifAssociatedTunnelOperStatelook = "cienaCesMplsNotifAssociatedTunnelOperState." + $7
						$cienaCesMplsNotifAssociatedTunnelOperState = lookup($cienaCesMplsNotifAssociatedTunnelOperStatelook,CienaVarbindValTable)
						if(match($cienaCesMplsNotifAssociatedTunnelOperState,"UNKNOWN")) {
							$cienaCesMplsNotifAssociatedTunnelOperState = $7
						} else {
							$cienaCesMplsNotifAssociatedTunnelOperState = $cienaCesMplsNotifAssociatedTunnelOperState + " ( " + $7 + " )"
						}
						@AlertGroup = "Ciena OME Traps"
						@Agent = "ciena.m2r.include.rules"
						@Summary = "cienaCesMplsAssociatedTunnelOperStateChgTrap: MPLS Tunnel operational state has changed to " + $cienaCesMplsNotifAssociatedTunnelOperState
						@Severity = 4
						@Type = 1
						@Identifier = @Node + @Summary
						details($*)

						case "7": ### - cienaCesMplsCacInterfaceThresholdTrap
						# SNMPv2
						# This notification is sent when LSP bandwith usage exceeds the threshold.
						# Variable bindings include: cienaGlobalSeverity,
						# cienaGlobalMacAddress, cienaCesMplsNotifCasInterfaceIndex,
						# cienaCesMplsNotifCacInterfaceClassType, cienaCesMplsNotifCacInterfaceName,
						# cienaCesMplsNotifCacInterfaceThreshold.
						$cienaGlobalSeveritylook = "cienaGlobalSeverity." + $1
						$cienaGlobalSeverity = lookup($cienaGlobalSeveritylook,CienaVarbindValTable)
						if(match($cienaGlobalSeverity,"UNKNOWN")) {
							$cienaGlobalSeverity = $1
						} else {
							$cienaGlobalSeverity = $cienaGlobalSeverity + " ( " + $1 + " )"
						}
						$cienaGlobalMacAddress = $2
						$cienaCesMplsNotifCacInterfaceIndex = $3
						$cienaCesMplsNotifCacInterfaceClassType = $4
						$cienaCesMplsNotifCacInterfaceName = $5
						$cienaCesMplsNotifCacInterfaceThreshold = $6
						@AlertGroup = "Ciena OME Traps"
						@Agent = "ciena.m2r.include.rules"
						@Summary = "cienaCesMplsCacInterfaceThresholdTrap: LSP bandwith usage exceeded threshold for " + $cienaCesMplsNotifCacInterfaceName
						@Severity = 3
						@Type = 1
						@Identifier = @Node + @Summary
						details($cienaGlobalSeverity,$cienaGlobalMacAddress,$cienaCesMplsNotifCacInterfaceIndex,$cienaCesMplsNotifCacInterfaceClassType,$cienaCesMplsNotifCacInterfaceName,$cienaCesMplsNotifCacInterfaceThreshold)

					default:
						@Summary = "Unknown specific trap number (" + $specific-trap + ") received for enterprise " + $enterprise
						@Identifier = @Node + $enterprise + $generic-trap + $specific-trap + @Agent + @Manager
						@Severity = 3
						@Type = 1
						details($*)
				}

			######
			# cienaCesGmplsMIBNotifications traps
			######
			case ".1.3.6.1.4.1.1271.2.2.17.1":	### - cienaCesGmplsMIBNotifications
				switch($specific-trap) {
					case "1": ### - cienaCesGmplsEncapUnidirTunnelOperStateChgTrap
						# SNMPv2
						# This notification is sent when the operational state of an encap
						# uni-direction tunnel changes. Variable bindings include: cienaGlobalSeverity,
						# cienaGlobalMacAddress, cienaCesGmplsNotifEncapTunnelIndex,
						# cienaCesGmplsNotifEncapTunnelType, cienaCesGmplsNotifEncapTunnelName,
						# cienaCesGmplsNotifEncapTunnelAdminState, and
						# cienaCesGmplsNotifEncapTunnelOperState.
						$cienaGlobalSeveritylook = "cienaGlobalSeverity." + $1
						$cienaGlobalSeverity = lookup($cienaGlobalSeveritylook,CienaVarbindValTable)
						if(match($cienaGlobalSeverity,"UNKNOWN")) {
							$cienaGlobalSeverity = $1
						} else {
							$cienaGlobalSeverity = $cienaGlobalSeverity + " ( " + $1 + " )"
						}
						$cienaGlobalMacAddress = $2
						$cienaCesGmplsNotifEncapTunnelIndex = $3
						$cienaCesGmplsNotifEncapTunnelTypelook = "cienaCesGmplsNotifEncapTunnelType." + $4
						$cienaCesGmplsNotifEncapTunnelType = lookup($cienaCesGmplsNotifEncapTunnelTypelook,CienaVarbindValTable)
						if(match($cienaCesGmplsNotifEncapTunnelType,"UNKNOWN")) {
							$cienaCesGmplsNotifEncapTunnelType = $4
						} else {
							$cienaCesGmplsNotifEncapTunnelType = $cienaCesGmplsNotifEncapTunnelType + " ( " + $4 + " )"
						}
						$cienaCesGmplsNotifEncapTunnelName = $5
						$cienaCesGmplsNotifEncapTunnelAdminStatelook = "cienaCesGmplsNotifEncapTunnelAdminState." + $6
						$cienaCesGmplsNotifEncapTunnelAdminState = lookup($cienaCesGmplsNotifEncapTunnelAdminStatelook,CienaVarbindValTable)
						if(match($cienaCesGmplsNotifEncapTunnelAdminState,"UNKNOWN")) {
							$cienaCesGmplsNotifEncapTunnelAdminState = $6
						} else {
							$cienaCesGmplsNotifEncapTunnelAdminState = $cienaCesGmplsNotifEncapTunnelAdminState + " ( " + $6 + " )"
						}
						$cienaCesGmplsNotifEncapTunnelOperStatelook = "cienaCesGmplsNotifEncapTunnelOperState." + $7
						$cienaCesGmplsNotifEncapTunnelOperState = lookup($cienaCesGmplsNotifEncapTunnelOperStatelook,CienaVarbindValTable)
						if(match($cienaCesGmplsNotifEncapTunnelOperState,"UNKNOWN")) {
							$cienaCesGmplsNotifEncapTunnelOperState = $7
						} else {
							$cienaCesGmplsNotifEncapTunnelOperState = $cienaCesGmplsNotifEncapTunnelOperState + " ( " + $7 + " )"
						}
						@AlertGroup = "Ciena OME Traps"
						@Agent = "ciena.m2r.include.rules"
						@Summary = "cienaCesGmplsEncapUnidirTunnelOperStateChgTrap: Operational status of encap uni-direction tunnel changed to " + $cienaCesGmplsNotifEncapTunnelOperState
						@Severity = 3
						@Type = 1
						@Identifier = @Node + @Summary
						details($*)

					case "2": ### - cienaCesGmplsEncapCoroutedTunnelOperStateChgTrap
						# SNMPv2
						# This notification is sent when the operational state of an encap
						# corouted tunnel changes. Variable bindings include: cienaGlobalSeverity,
						# cienaGlobalMacAddress, cienaCesGmplsNotifEncapTunnelIndex,
						# cienaCesGmplsNotifEncapTunnelType, cienaCesGmplsNotifEncapTunnelName,
						# cienaCesGmplsNotifEncapTunnelAdminState, and
						# cienaCesGmplsNotifEncapTunnelOperState.
						$cienaGlobalSeveritylook = "cienaGlobalSeverity." + $1
						$cienaGlobalSeverity = lookup($cienaGlobalSeveritylook,CienaVarbindValTable)
						if(match($cienaGlobalSeverity,"UNKNOWN")) {
							$cienaGlobalSeverity = $1
						} else {
							$cienaGlobalSeverity = $cienaGlobalSeverity + " ( " + $1 + " )"
						}
						$cienaGlobalMacAddress = $2
						$cienaCesGmplsNotifEncapTunnelIndex = $3
						$cienaCesGmplsNotifEncapTunnelTypelook = "cienaCesGmplsNotifEncapTunnelType." + $4
						$cienaCesGmplsNotifEncapTunnelType = lookup($cienaCesGmplsNotifEncapTunnelTypelook,CienaVarbindValTable)
						if(match($cienaCesGmplsNotifEncapTunnelType,"UNKNOWN")) {
							$cienaCesGmplsNotifEncapTunnelType = $4
						} else {
							$cienaCesGmplsNotifEncapTunnelType = $cienaCesGmplsNotifEncapTunnelType + " ( " + $4 + " )"
						}
