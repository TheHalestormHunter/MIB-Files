						}
						$cienaCesLogicalPortConfigPortOperStatelook = "cienaCesLogicalPortConfigPortOperState." + $8
						$cienaCesLogicalPortConfigPortOperState = lookup($cienaCesLogicalPortConfigPortOperStatelook,CienaVarbindValTable)
						if(match($cienaCesLogicalPortConfigPortOperState,"UNKNOWN")) {
