						case "23": ### - cienaCesCfmSyntheticLossSessionSignalDegradeFaultTrapSet
						# SNMPv2
						# A notification is sent whenever the signal degrade fault is detected during
						# a Synthetic Loss Measurement test.
						$cienaGlobalSeveritylook = "cienaGlobalSeverity." + $1
						$cienaGlobalSeverity = lookup($cienaGlobalSeveritylook,CienaVarbindValTable)
						if(match($cienaGlobalSeverity,"UNKNOWN")) {
							$cienaGlobalSeverity = $1
						} else {
							$cienaGlobalSeverity = $cienaGlobalSeverity + " ( " + $1 + " )"
						}
						$cienaGlobalMacAddress = $2
						$cienaCesCfmServiceName = $3
						$cienaCesCfmSyntheticLossSessionFrameLossNear = $4
						$cienaCesCfmSyntheticLossSessionFrameLossFar = $5
						$cienaCesCfmSyntheticLossSessionSdSetThreshold = $6
						@AlertGroup = "Ciena OME Traps"
						@Agent = "ciena.m2r.include.rules"
						@Summary = "cienaCesCfmSyntheticLossSessionSignalDegradeFaultTrapSet: Signal degrade fault is detected during a Synthetic Loss Measurement test"
						@Severity = 3
						@Type = 1
						@Identifier = @Node + @Summary
						details($cienaGlobalSeverity,$cienaGlobalMacAddress,$cienaCesCfmServiceName,$cienaCesCfmSyntheticLossSessionFrameLossNear,$cienaCesCfmSyntheticLossSessionFrameLossFar,$cienaCesCfmSyntheticLossSessionSdSetThreshold)

					case "24": ### - cienaCesCfmSyntheticLossSessionSignalDegradeFaultTrapClear
						# SNMPv2
						# A notification is sent whenever the signal degrade fault is cleared during
						# a Synthetic Loss Measurement test.
						$cienaGlobalSeveritylook = "cienaGlobalSeverity." + $1
						$cienaGlobalSeverity = lookup($cienaGlobalSeveritylook,CienaVarbindValTable)
						if(match($cienaGlobalSeverity,"UNKNOWN")) {
							$cienaGlobalSeverity = $1
						} else {
							$cienaGlobalSeverity = $cienaGlobalSeverity + " ( " + $1 + " )"
						}
						$cienaGlobalMacAddress = $2
						$cienaCesCfmServiceName = $3
						$cienaCesCfmSyntheticLossSessionFrameLossNear = $4
						$cienaCesCfmSyntheticLossSessionFrameLossFar = $5
						$cienaCesCfmSyntheticLossSessionSdClearThreshold = $6
						@AlertGroup = "Ciena OME Traps"
						@Agent = "ciena.m2r.include.rules"
						@Summary = "cienaCesCfmSyntheticLossSessionSignalDegradeFaultTrapClear: Signal degrade fault cleared during a Synthetic Loss Measurement test"
						@Severity = 3
						@Type = 1
						@Identifier = @Node + @Summary
						details($cienaGlobalSeverity,$cienaGlobalMacAddress,$cienaCesCfmServiceName,$cienaCesCfmSyntheticLossSessionFrameLossNear,$cienaCesCfmSyntheticLossSessionFrameLossFar,$cienaCesCfmSyntheticLossSessionSdClearThreshold)

					default:
						@Summary = "Unknown specific trap number (" + $specific-trap + ") received for enterprise " + $enterprise
						@Identifier = @Node + $enterprise + $generic-trap + $specific-trap + @Agent + @Manager
						@Severity = 3
						@Type = 1
						details($*)
				}

			######
			# cienaCesPbtMIBNotifications traps
			######
			case ".1.3.6.1.4.1.1271.2.2.6":	### - cienaCesPbtMIBNotificationPrefix
				switch($specific-trap) {
					case "1": ### - cienaCesPbtTunnelActivateNotification
						# SNMPv2
						# This notification is sent when a PBB-TE tunnel of the given tunnel group
						#
						# is activated. A tunnel is said to be activated when its forwarding
						#
						# state becomes enabled. To send this trap, the SNMP global trap state
						#
						# 'cienaCesPbtFaultTrapState' needs to be set to enabled. This state is
						# 'enabled' by default. Variable bindings include: cienaGlobalSeverity,
						# cienaGlobalMacAddress, cienaCesPbtEncapTnlNotifIndex,
						# cienaCesPbtEncapTnlName, cienaCesPbtTnlGroupIndex, cienaCesPbtTnlGroupName,
						# cienaCesPbtEncapTnlFwdState, and cienaCesPbtEncapTnlBvid.
						$cienaGlobalSeveritylook = "cienaGlobalSeverity." + $1
						$cienaGlobalSeverity = lookup($cienaGlobalSeveritylook,CienaVarbindValTable)
						if(match($cienaGlobalSeverity,"UNKNOWN")) {
							$cienaGlobalSeverity = $1
						} else {
							$cienaGlobalSeverity = $cienaGlobalSeverity + " ( " + $1 + " )"
						}
						$cienaGlobalMacAddress = $2
						$cienaCesPbtEncapTnlNotifIndex = $3
						$cienaCesPbtEncapTnlName = $4
						$cienaCesPbtTnlGroupIndex = $5
						$cienaCesPbtTnlGroupName = $6
						$cienaCesPbtEncapTnlFwdStatelook = "cienaCesPbtEncapTnlFwdState." + $7
						$cienaCesPbtEncapTnlFwdState = lookup($cienaCesPbtEncapTnlFwdStatelook,CienaVarbindValTable)
						if(match($cienaCesPbtEncapTnlFwdState,"UNKNOWN")) {
							$cienaCesPbtEncapTnlFwdState = $7
						} else {
							$cienaCesPbtEncapTnlFwdState = $cienaCesPbtEncapTnlFwdState + " ( " + $7 + " )"
						}
						$cienaCesPbtEncapTnlBvid = $8
						@AlertGroup = "Ciena OME Traps"
						@Agent = "ciena.m2r.include.rules"
						@Summary = "cienaCesPbtTunnelActivateNotification"
						@Severity = 3
						@Type = 1
						@Identifier = @Node + @Summary
						details($*)

					case "2": ### - cienaCesPbtTunnelDeactivateNotification
						# SNMPv2
						# This notification is sent when a PBB-TE tunnel of the given tunnel group
						#
						# is deactivated. A tunnel is said to be deactivated when its forwarding
						#
						# state becomes disabled. To send this trap, the SNMP global trap state
						#
						# 'cienaCesPbtFaultTrapState' needs to be set to enabled. This state is 'enabled'
						# by default. Variable bindings include: cienaGlobalSeverity, cienaGlobalMacAddress,
						# cienaCesPbtEncapTnlNotifIndex, cienaCesPbtEncapTnlName, cienaCesPbtTnlGroupIndex,
						# cienaCesPbtTnlGroupName, cienaCesPbtEncapTnlFwdState, and cienaCesPbtEncapTnlBvid.
						$cienaGlobalSeveritylook = "cienaGlobalSeverity." + $1
						$cienaGlobalSeverity = lookup($cienaGlobalSeveritylook,CienaVarbindValTable)
						if(match($cienaGlobalSeverity,"UNKNOWN")) {
							$cienaGlobalSeverity = $1
						} else {
							$cienaGlobalSeverity = $cienaGlobalSeverity + " ( " + $1 + " )"
						}
						$cienaGlobalMacAddress = $2
						$cienaCesPbtEncapTnlNotifIndex = $3
						$cienaCesPbtEncapTnlName = $4
						$cienaCesPbtTnlGroupIndex = $5
						$cienaCesPbtTnlGroupName = $6
						$cienaCesPbtEncapTnlFwdStatelook = "cienaCesPbtEncapTnlFwdState." + $7
						$cienaCesPbtEncapTnlFwdState = lookup($cienaCesPbtEncapTnlFwdStatelook,CienaVarbindValTable)
						if(match($cienaCesPbtEncapTnlFwdState,"UNKNOWN")) {
							$cienaCesPbtEncapTnlFwdState = $7
						} else {
							$cienaCesPbtEncapTnlFwdState = $cienaCesPbtEncapTnlFwdState + " ( " + $7 + " )"
						}
						$cienaCesPbtEncapTnlBvid = $8
						@AlertGroup = "Ciena OME Traps"
						@Agent = "ciena.m2r.include.rules"
						@Summary = "cienaCesPbtTunnelDeactivateNotification"
						@Severity = 3
						@Type = 1
						@Identifier = @Node + @Summary
						details($*)

					case "3": ### - cienaCesPbtTunnelReversionNotification
						# SNMPv2
						# Upon failure of the primary tunnel, traffic is moved over to the backup
						#
						# tunnel at the tunnel ingress. Tunnel reversion signifies the restoration of
						#
						# traffic from this backup tunnel (now active) to the primary (now standby)
						#
						# after the primary tunnel is restored. This notification is generated when
						# this reversion occurs. To send this trap, the SNMP global trap state
						# 'cienaCesPbtFaultTrapState' needs to be set to enabled. This state is 'enabled'
						# by default. Variable bindings include: cienaGlobalSeverity, cienaGlobalMacAddress,
						# cienaCesPbtTnlGroupIndex, cienaCesPbtTnlGroupName,
						# cienaCesPbtEncapTnlReversionToPairIndex, and cienaCesPbtEncapTnlReversionFromPairIndex.
						$cienaGlobalSeveritylook = "cienaGlobalSeverity." + $1
						$cienaGlobalSeverity = lookup($cienaGlobalSeveritylook,CienaVarbindValTable)
						if(match($cienaGlobalSeverity,"UNKNOWN")) {
							$cienaGlobalSeverity = $1
						} else {
							$cienaGlobalSeverity = $cienaGlobalSeverity + " ( " + $1 + " )"
						}
						$cienaGlobalMacAddress = $2
						$cienaCesPbtTnlGroupIndex = $3
						$cienaCesPbtTnlGroupName = $4
						$cienaCesPbtEncapTnlReversionToPairIndex = $5
						$cienaCesPbtEncapTnlReversionFromPairIndex = $6
						@AlertGroup = "Ciena OME Traps"
						@Agent = "ciena.m2r.include.rules"
						@Summary = "cienaCesPbtTunnelReversionNotification"
						@Severity = 3
						@Type = 1
						@Identifier = @Node + @Summary
						details($*)

					default:
						@Summary = "Unknown specific trap number (" + $specific-trap + ") received for enterprise " + $enterprise
						@Identifier = @Node + $enterprise + $generic-trap + $specific-trap + @Agent + @Manager
						@Severity = 3
						@Type = 1
						details($*)
				}

			######
			# cienaCesDpMIBNotifications traps
			######
			case ".1.3.6.1.4.1.1271.2.2.7":	### - cienaCesDpMIBNotificationPrefix
				switch($specific-trap) {
					case "1": ### - cienaCesDpTsMeterFloodContainerUcastThresholdExceeded
						# SNMPv2
						# A cienaCesDpTsMeterFloodContainerUcastThresholdExceeded is sent
						# when for a given container profile, the number of unknown unicast
						# packets received becomes greater than or equal to the
						# configuration packet limit, and the value of unknown unicast packet
						# received at the last sampling interval was less than
						# the configuration packet limit. To enable the device to send this notification
						# cienaCesDataplaneUcastTrapState needs to be set to enabled. The
						# cienaCesDataplaneUcastTrapState is set to enabled by default. Variable bindings includd
						# cienaGlobalSeverity, cienaGlobalMacAddress, cienaCesDpTsMeterFloodContainerNotifProfileIndex,
						# cienaCesDpTsMeterFloodContainerNotifAttachmentLiType,
						# cienaCesDpTsMeterFloodContainerNotifAttachmentLiIndex,
						# cienaCesDpTsMeterFloodContainerProfileName, and
						# cienaCesDpTsMeterFloodContainerAttachmentInterfaceName

						$cienaGlobalSeveritylook = "cienaGlobalSeverity." + $1
						$cienaGlobalSeverity = lookup($cienaGlobalSeveritylook,CienaVarbindValTable)
						if(match($cienaGlobalSeverity,"UNKNOWN")) {
							$cienaGlobalSeverity = $1
						} else {
							$cienaGlobalSeverity = $cienaGlobalSeverity + " ( " + $1 + " )"
						}
						$cienaGlobalMacAddress = $2
						$cienaCesDpTsMeterFloodContainerNotifProfileIndexlook = "cienaCesDpTsMeterFloodContainerNotifProfileIndex." + $3
						$cienaCesDpTsMeterFloodContainerNotifProfileIndex = lookup($cienaCesDpTsMeterFloodContainerNotifProfileIndexlook,CienaVarbindValTable)
						if(match($cienaCesDpTsMeterFloodContainerNotifProfileIndex,"UNKNOWN")) {
							$cienaCesDpTsMeterFloodContainerNotifProfileIndex = $3
						} else {
							$cienaCesDpTsMeterFloodContainerNotifProfileIndex = $cienaCesDpTsMeterFloodContainerNotifProfileIndex + " ( " + $3 + " )"
						}
						$cienaCesDpTsMeterFloodContainerNotifAttachmentLiTypelook = "cienaCesDpTsMeterFloodContainerNotifAttachmentLiType." + $4
						$cienaCesDpTsMeterFloodContainerNotifAttachmentLiType = lookup($cienaCesDpTsMeterFloodContainerNotifAttachmentLiTypelook,CienaVarbindValTable)
						if(match($cienaCesDpTsMeterFloodContainerNotifAttachmentLiType,"UNKNOWN")) {
							$cienaCesDpTsMeterFloodContainerNotifAttachmentLiType = $4
						} else {
							$cienaCesDpTsMeterFloodContainerNotifAttachmentLiType = $cienaCesDpTsMeterFloodContainerNotifAttachmentLiType + " ( " + $4 + " )"
						}
						$cienaCesDpTsMeterFloodContainerNotifAttachmentLiIndexlook = "cienaCesDpTsMeterFloodContainerNotifAttachmentLiIndex." + $5
						$cienaCesDpTsMeterFloodContainerNotifAttachmentLiIndex = lookup($cienaCesDpTsMeterFloodContainerNotifAttachmentLiIndexlook,CienaVarbindValTable)
						if(match($cienaCesDpTsMeterFloodContainerNotifAttachmentLiIndex,"UNKNOWN")) {
							$cienaCesDpTsMeterFloodContainerNotifAttachmentLiIndex = $5
						} else {
							$cienaCesDpTsMeterFloodContainerNotifAttachmentLiIndex = $cienaCesDpTsMeterFloodContainerNotifAttachmentLiIndex + " ( " + $5 + " )"
						}
						$cienaCesDpTsMeterFloodContainerProfileName = $6
						$cienaCesDpTsMeterFloodContainerAttachmentInterfaceName = $7
						@AlertGroup = "Ciena OME Traps"
						@Agent = "ciena.m2r.include.rules"
						@Summary = "cienaCesDpTsMeterFloodContainerUcastThresholdExceeded: Number of unknown unicast packets for profile exceeded threshold"
						@Severity = 3
						@Type = 1
						@Identifier = @Node + @Summary
						details($*)

					case "2": ### - cienaCesDpTsMeterFloodContainerUcastThresholdNormal
						# SNMPv2
						# A cienaCesDpTsMeterFloodContainerUcastThresholdNormal is sent
						# when for a given container profile, the total number of
						# unknown unicast packet received becomes less than the
						# configured packet limit, and the value of unknown unicast
						# packets received at the last sampling interval
						# was greater than or equal to the configured packet limit.
						# To enable the device to send this notification, cienaCesDataplaneUcastTrapState
						# needs to be set to enabled. The cienaCesDataplaneUcastTrapState is set to
						# enabled by default. Variable bindings include: cienaGlobalSeverity,
						# cienaGlobalMacAddress, cienaCesDpTsMeterFloodContainerNotifProfileIndex,
						# cienaCesDpTsMeterFloodContainerNotifAttachmentLiType,
						# cienaCesDpTsMeterFloodContainerNotifAttachmentLiIndex,
						# cienaCesDpTsMeterFloodContainerProfileName, and
						# cienaCesDpTsMeterFloodContainerAttachmentInterfaceName.

						$cienaGlobalSeveritylook = "cienaGlobalSeverity." + $1
						$cienaGlobalSeverity = lookup($cienaGlobalSeveritylook,CienaVarbindValTable)
						if(match($cienaGlobalSeverity,"UNKNOWN")) {
							$cienaGlobalSeverity = $1
						} else {
							$cienaGlobalSeverity = $cienaGlobalSeverity + " ( " + $1 + " )"
						}
						$cienaGlobalMacAddress = $2
						$cienaCesDpTsMeterFloodContainerNotifProfileIndexlook = "cienaCesDpTsMeterFloodContainerNotifProfileIndex." + $3
						$cienaCesDpTsMeterFloodContainerNotifProfileIndex = lookup($cienaCesDpTsMeterFloodContainerNotifProfileIndexlook,CienaVarbindValTable)
						if(match($cienaCesDpTsMeterFloodContainerNotifProfileIndex,"UNKNOWN")) {
							$cienaCesDpTsMeterFloodContainerNotifProfileIndex = $3
						} else {
							$cienaCesDpTsMeterFloodContainerNotifProfileIndex = $cienaCesDpTsMeterFloodContainerNotifProfileIndex + " ( " + $3 + " )"
						}
						$cienaCesDpTsMeterFloodContainerNotifAttachmentLiTypelook = "cienaCesDpTsMeterFloodContainerNotifAttachmentLiType." + $4
						$cienaCesDpTsMeterFloodContainerNotifAttachmentLiType = lookup($cienaCesDpTsMeterFloodContainerNotifAttachmentLiTypelook,CienaVarbindValTable)
						if(match($cienaCesDpTsMeterFloodContainerNotifAttachmentLiType,"UNKNOWN")) {
							$cienaCesDpTsMeterFloodContainerNotifAttachmentLiType = $4
						} else {
							$cienaCesDpTsMeterFloodContainerNotifAttachmentLiType = $cienaCesDpTsMeterFloodContainerNotifAttachmentLiType + " ( " + $4 + " )"
						}
						$cienaCesDpTsMeterFloodContainerNotifAttachmentLiIndexlook = "cienaCesDpTsMeterFloodContainerNotifAttachmentLiIndex." + $5
						$cienaCesDpTsMeterFloodContainerNotifAttachmentLiIndex = lookup($cienaCesDpTsMeterFloodContainerNotifAttachmentLiIndexlook,CienaVarbindValTable)
						if(match($cienaCesDpTsMeterFloodContainerNotifAttachmentLiIndex,"UNKNOWN")) {
							$cienaCesDpTsMeterFloodContainerNotifAttachmentLiIndex = $5
						} else {
							$cienaCesDpTsMeterFloodContainerNotifAttachmentLiIndex = $cienaCesDpTsMeterFloodContainerNotifAttachmentLiIndex + " ( " + $5 + " )"
						}
						$cienaCesDpTsMeterFloodContainerProfileName = $6
						$cienaCesDpTsMeterFloodContainerAttachmentInterfaceName = $7
						@AlertGroup = "Ciena OME Traps"
						@Agent = "ciena.m2r.include.rules"
						@Summary = "cienaCesDpTsMeterFloodContainerUcastThresholdNormal: Number of unknown unicast packets for profile back within threshold"
						@Severity = 3
						@Type = 1
						@Identifier = @Node + @Summary
						details($*)

					case "3": ### - cienaCesDpTsMeterFloodContainerBcastThresholdExceeded
						# SNMPv2
						# A cienaCesDpTsMeterFloodContainerBcastThresholdExceeded is sent
						# when for a given container profile, the number of broadcast
						# packets received becomes greater than or equal to the
						# configured packet limit, and the value of broadcast packets
						# received at the last sampling interval is less than
						# the configured packet limit. To enable the device to send this notification,
						# cienaCesDataplaneBcastTrapState needs to be set to enabled. The
						# cienaCesDataplaneBcastTrapState is set to enabled by default. Variable
						# bindings include: cienaGlobalSeverity, cienaGlobalMacAddress,
						# cienaCesDpTsMeterFloodContainerNotifProfileIndex,
						# cienaCesDpTsMeterFloodContainerNotifAttachmentLiType,
						# cienaCesDpTsMeterFloodContainerNotifAttachmentLiIndex,
						# cienaCesDpTsMeterFloodContainerProfileName, and
						# cienaCesDpTsMeterFloodContainerAttachmentInterfaceName.

						$cienaGlobalSeveritylook = "cienaGlobalSeverity." + $1
						$cienaGlobalSeverity = lookup($cienaGlobalSeveritylook,CienaVarbindValTable)
						if(match($cienaGlobalSeverity,"UNKNOWN")) {
							$cienaGlobalSeverity = $1
						} else {
							$cienaGlobalSeverity = $cienaGlobalSeverity + " ( " + $1 + " )"
						}
						$cienaGlobalMacAddress = $2
						$cienaCesDpTsMeterFloodContainerNotifProfileIndexlook = "cienaCesDpTsMeterFloodContainerNotifProfileIndex." + $3
						$cienaCesDpTsMeterFloodContainerNotifProfileIndex = lookup($cienaCesDpTsMeterFloodContainerNotifProfileIndexlook,CienaVarbindValTable)
						if(match($cienaCesDpTsMeterFloodContainerNotifProfileIndex,"UNKNOWN")) {
							$cienaCesDpTsMeterFloodContainerNotifProfileIndex = $3
						} else {
							$cienaCesDpTsMeterFloodContainerNotifProfileIndex = $cienaCesDpTsMeterFloodContainerNotifProfileIndex + " ( " + $3 + " )"
						}
						$cienaCesDpTsMeterFloodContainerNotifAttachmentLiTypelook = "cienaCesDpTsMeterFloodContainerNotifAttachmentLiType." + $4
						$cienaCesDpTsMeterFloodContainerNotifAttachmentLiType = lookup($cienaCesDpTsMeterFloodContainerNotifAttachmentLiTypelook,CienaVarbindValTable)
						if(match($cienaCesDpTsMeterFloodContainerNotifAttachmentLiType,"UNKNOWN")) {
							$cienaCesDpTsMeterFloodContainerNotifAttachmentLiType = $4
						} else {
							$cienaCesDpTsMeterFloodContainerNotifAttachmentLiType = $cienaCesDpTsMeterFloodContainerNotifAttachmentLiType + " ( " + $4 + " )"
						}
						$cienaCesDpTsMeterFloodContainerNotifAttachmentLiIndexlook = "cienaCesDpTsMeterFloodContainerNotifAttachmentLiIndex." + $5
						$cienaCesDpTsMeterFloodContainerNotifAttachmentLiIndex = lookup($cienaCesDpTsMeterFloodContainerNotifAttachmentLiIndexlook,CienaVarbindValTable)
						if(match($cienaCesDpTsMeterFloodContainerNotifAttachmentLiIndex,"UNKNOWN")) {
							$cienaCesDpTsMeterFloodContainerNotifAttachmentLiIndex = $5
						} else {
							$cienaCesDpTsMeterFloodContainerNotifAttachmentLiIndex = $cienaCesDpTsMeterFloodContainerNotifAttachmentLiIndex + " ( " + $5 + " )"
						}
						$cienaCesDpTsMeterFloodContainerProfileName = $6
						$cienaCesDpTsMeterFloodContainerAttachmentInterfaceName = $7
						@AlertGroup = "Ciena OME Traps"
						@Agent = "ciena.m2r.include.rules"
						@Summary = "cienaCesDpTsMeterFloodContainerBcastThresholdExceeded: Number of broadcast packets for profile exceeded threshold"
						@Severity = 3
						@Type = 1
						@Identifier = @Node + @Summary
						details($*)

					case "4": ### - cienaCesDpTsMeterFloodContainerBcastThresholdNormal
						# SNMPv2
						# A cienaCesDpTsMeterFloodContainerBcastThresholdNormal is sent
						# when for a given container profile, the total number of
						# broadcast packets received becomes less than the
						# configured packet limit, and the value of  broadcast
						# packets received at the last sampling interval
						# is greater than or equal to the configured packet limit.
						# To enable the device to send this notification, cienaCesDataplaneBcastTrapState
						# needs to be set to enabled. The cienaCesDataplaneBcastTrapState is set to
						# enabled by default. Variable bindings include: cienaGlobalSeverity,
						# cienaGlobalMacAddress, cienaCesDpTsMeterFloodContainerNotifProfileIndex,
						# cienaCesDpTsMeterFloodContainerNotifAttachmentLiType,
						# cienaCesDpTsMeterFloodContainerNotifAttachmentLiIndex,
						# cienaCesDpTsMeterFloodContainerProfileName, and
						# cienaCesDpTsMeterFloodContainerAttachmentInterfaceName.

						$cienaGlobalSeveritylook = "cienaGlobalSeverity." + $1
						$cienaGlobalSeverity = lookup($cienaGlobalSeveritylook,CienaVarbindValTable)
						if(match($cienaGlobalSeverity,"UNKNOWN")) {
							$cienaGlobalSeverity = $1
						} else {
							$cienaGlobalSeverity = $cienaGlobalSeverity + " ( " + $1 + " )"
						}
						$cienaGlobalMacAddress = $2
						$cienaCesDpTsMeterFloodContainerNotifProfileIndexlook = "cienaCesDpTsMeterFloodContainerNotifProfileIndex." + $3
						$cienaCesDpTsMeterFloodContainerNotifProfileIndex = lookup($cienaCesDpTsMeterFloodContainerNotifProfileIndexlook,CienaVarbindValTable)
						if(match($cienaCesDpTsMeterFloodContainerNotifProfileIndex,"UNKNOWN")) {
							$cienaCesDpTsMeterFloodContainerNotifProfileIndex = $3
						} else {
							$cienaCesDpTsMeterFloodContainerNotifProfileIndex = $cienaCesDpTsMeterFloodContainerNotifProfileIndex + " ( " + $3 + " )"
						}
						$cienaCesDpTsMeterFloodContainerNotifAttachmentLiTypelook = "cienaCesDpTsMeterFloodContainerNotifAttachmentLiType." + $4
						$cienaCesDpTsMeterFloodContainerNotifAttachmentLiType = lookup($cienaCesDpTsMeterFloodContainerNotifAttachmentLiTypelook,CienaVarbindValTable)
						if(match($cienaCesDpTsMeterFloodContainerNotifAttachmentLiType,"UNKNOWN")) {
							$cienaCesDpTsMeterFloodContainerNotifAttachmentLiType = $4
						} else {
