			######
			# cienaCesPortNotificationMIBNotifications traps
			######
			case ".1.3.6.1.4.1.1271.2.2.2":	### - cienaCesPortNotificationMIBNotificationPrefix
				switch($specific-trap) {
					case "1": ### - cienaCesPortNotificationPortDown
						# SNMPv2
						# A cienaCesLogicalPortNotificationPortDown trap signifies that the SNMP entity, acting in
						# an agent role, has detected that the link status has become operationally down
						# for one of its communication links.
						# To enable the device to send this notification:
						# -	cienaCesPortEnhancedLinkTrapState needs to be set to enabled
						# -	cienaCesPortAllTrapState needs to be set to enabled
						# -   cienaCesLogicalPortConfigPortAllTrapState for the port needs to be set to enabled
						# -	cienaCesLogicalPortConfigPortLinkUpDownTrapState for the port needs to be set to enabled
						# These objects are set to enabled by default. Variable bindings include: cienaGlobalSeverity,
						# cienaGlobalMacAddress, cienaCesPortPgIdMappingNotifChassisIndex, cienaCesPortPgIdMappingNotifShelfIndex,
						# cienaCesPortPgIdMappingNotifSlotIndex, cienaCesPortPgIdMappingNotifPortNumber,
						# cienaCesLogicalPortConfigPortAdminState, cienaCesLogicalPortConfigPortOperState,
						# cienaCesLogicalPortConfigPortName, cienaCesLogicalPortConfigPortType, cienaCesLogicalPortConfigPortDesc,
						# sysName, and sysLocation.
						$cienaGlobalSeveritylook = "cienaGlobalSeverity." + $1
						$cienaGlobalSeverity = lookup($cienaGlobalSeveritylook,CienaVarbindValTable)
						if(match($cienaGlobalSeverity,"UNKNOWN")) {
							$cienaGlobalSeverity = $1
						} else {
							$cienaGlobalSeverity = $cienaGlobalSeverity + " ( " + $1 + " )"
						}
						$cienaGlobalMacAddress = $2
						$cienaCesPortPgIdMappingNotifChassisIndex = $3
						$cienaCesPortPgIdMappingNotifShelfIndex = $4
						$cienaCesPortPgIdMappingNotifSlotIndex = $5
						$cienaCesPortPgIdMappingNotifPortNumber = $6
						$cienaCesLogicalPortConfigPortAdminStatelook = "cienaCesLogicalPortConfigPortAdminState." + $7
						$cienaCesLogicalPortConfigPortAdminState = lookup($cienaCesLogicalPortConfigPortAdminStatelook,CienaVarbindValTable)
						if(match($cienaCesLogicalPortConfigPortAdminState,"UNKNOWN")) {
							$cienaCesLogicalPortConfigPortAdminState = $7
						} else {
							$cienaCesLogicalPortConfigPortAdminState = $cienaCesLogicalPortConfigPortAdminState + " ( " + $7 + " )"
						}
						$cienaCesLogicalPortConfigPortOperStatelook = "cienaCesLogicalPortConfigPortOperState." + $8
						$cienaCesLogicalPortConfigPortOperState = lookup($cienaCesLogicalPortConfigPortOperStatelook,CienaVarbindValTable)
						if(match($cienaCesLogicalPortConfigPortOperState,"UNKNOWN")) {
							$cienaCesLogicalPortConfigPortOperState = $8
						} else {
							$cienaCesLogicalPortConfigPortOperState = $cienaCesLogicalPortConfigPortOperState + " ( " + $8 + " )"
						}
						$cienaCesLogicalPortConfigPortName = $9
						$cienaCesLogicalPortConfigPortTypelook = "cienaCesLogicalPortConfigPortType." + $10
						$cienaCesLogicalPortConfigPortType = lookup($cienaCesLogicalPortConfigPortTypelook,CienaVarbindValTable)
						if(match($cienaCesLogicalPortConfigPortType,"UNKNOWN")) {
							$cienaCesLogicalPortConfigPortType = $10
						} else {
							$cienaCesLogicalPortConfigPortType = $cienaCesLogicalPortConfigPortType + " ( " + $10 + " )"
						}
						$cienaCesLogicalPortConfigPortDesc = $11
						$sysName = $12
						$sysLocation = $13
						$cienaCesChassisSystemId = $14
						$cienaCesLogicalPortConfigEttpAid = $15
						$cienaCesLogicalPortLastDownReason1 = $16
						$cienaCesLogicalPortLastDownReason2 = $17
						$cienaCesLogicalPortLastDownReason3 = $18
						$cienaCesLogicalPortMaskedDownReason = $19
						@AlertGroup = "Ciena OME Traps"
						@Agent = "ciena.m2r.include.rules"
						@Summary = "cienaCesPortNotificationPortDown: Port number " + $cienaCesPortPgIdMappingNotifPortNumber + " on slot " + $cienaCesPortPgIdMappingNotifSlotIndex + " is down"
						@Severity = 4
						@Type = 1
						@Identifier = @Node + @Summary
						details($*)

					case "2": ### - cienaCesPortNotificationPortUp
						# SNMPv2
						# A cienaCesLogicalPortNotificationPortUp trap signifies that the SNMP entity, acting in
						# an agent role, has detected the link status has become operationally up for
						# one of its communication links.
						# To enable the device to send this notification:
						# -	cienaCesPortEnhancedLinkTrapState needs to be set to enabled
						# -	cienaCesPortAllTrapState needs to be set to enabled
						# -   cienaCesLogicalPortConfigPortAllTrapState for the port needs to be set to enabled
						# -	cienaCesLogicalPortConfigPortLinkUpDownTrapState for the port needs to be set to enabled
						# These objects are set to enabled by default. Variable bindings include: cienaGlobalSeverity,
						# cienaGlobalMacAddress, cienaCesPortPgIdMappingNotifChassisIndex,
						# cienaCesPortPgIdMappingNotifShelfIndex, cienaCesPortPgIdMappingNotifSlotIndex,
