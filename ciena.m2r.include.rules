						$cienaCesChassisIOMAlarmOutputStatelook = "cienaCesChassisIOMAlarmOutputState." + $3
						$cienaCesChassisIOMAlarmOutputState = lookup($cienaCesChassisIOMAlarmOutputStatelook,CienaVarbindValTable)
						if(match($cienaCesChassisIOMAlarmOutputState,"UNKNOWN")) {
							$cienaCesChassisIOMAlarmOutputState = $3
						} else {
							$cienaCesChassisIOMAlarmOutputState = $cienaCesChassisIOMAlarmOutputState + " ( " + $3 + " )"
						}
						@AlertGroup = "Ciena OME Traps"
						@Agent = "ciena.m2r.include.rules"
						@Summary = "cienaCesChassisIOMAlarmOutputStateChangeNotification: Chassis Input / Output Module Alarm Output state has changed to " + $cienaCesChassisIOMAlarmOutputState
						@Severity = 4
						@Type = 1
						@Identifier = @Node + @Summary
						details($*)

					case "23": ### - cienaCesChassisIOMAlarmInputStateChangeNotification
						# SNMPv2
						# This notification is generated when the value of cienaCesChassisIOMAlarmInputState changes.
						$cienaGlobalSeveritylook = "cienaGlobalSeverity." + $1
						$cienaGlobalSeverity = lookup($cienaGlobalSeveritylook,CienaVarbindValTable)
						if(match($cienaGlobalSeverity,"UNKNOWN")) {
							$cienaGlobalSeverity = $1
						} else {
							$cienaGlobalSeverity = $cienaGlobalSeverity + " ( " + $1 + " )"
						}
						$cienaCesChassisIOMAlarmInputDescription = $2
						$cienaCesChassisIOMAlarmInputStatelook = "cienaCesChassisIOMAlarmInputState." + $3
						$cienaCesChassisIOMAlarmInputState = lookup($cienaCesChassisIOMAlarmInputStatelook,CienaVarbindValTable)
						if(match($cienaCesChassisIOMAlarmInputState,"UNKNOWN")) {
							$cienaCesChassisIOMAlarmInputState = $3
						} else {
							$cienaCesChassisIOMAlarmInputState = $cienaCesChassisIOMAlarmInputState + " ( " + $3 + " )"
						}
						@AlertGroup = "Ciena OME Traps"
						@Agent = "ciena.m2r.include.rules"
						@Summary = "cienaCesChassisIOMAlarmInputStateChangeNotification: Chassis Input / Output Module Alarm Input state has changed to " + $cienaCesChassisIOMAlarmInputState
						@Severity = 4
						@Type = 1
						@Identifier = @Node + @Summary
						details($*)

					case "24": ### - cienaCesChassisUsbFlashEnabledNotification
						# SNMPv2
						# This notification is generated when CTX USB hubs are enabled via user config.
						$cienaGlobalSeveritylook = "cienaGlobalSeverity." + $1
						$cienaGlobalSeverity = lookup($cienaGlobalSeveritylook,CienaVarbindValTable)
						if(match($cienaGlobalSeverity,"UNKNOWN")) {
							$cienaGlobalSeverity = $1
						} else {
							$cienaGlobalSeverity = $cienaGlobalSeverity + " ( " + $1 + " )"
						}
						@AlertGroup = "Ciena OME Traps"
						@Agent = "ciena.m2r.include.rules"
						@Summary = "cienaCesChassisUsbFlashEnabledNotification: CTX USB hubs enabled via user config"
						@Severity = 3
						@Type = 1
						@Identifier = @Node + @Summary
						details($*)

					case "25": ### - cienaCesChassisUsbFlashDisabledNotification
						# SNMPv2
						# This notification is generated when CTX USB hubs are disabled via user config.
						$cienaGlobalSeveritylook = "cienaGlobalSeverity." + $1
						$cienaGlobalSeverity = lookup($cienaGlobalSeveritylook,CienaVarbindValTable)
						if(match($cienaGlobalSeverity,"UNKNOWN")) {
							$cienaGlobalSeverity = $1
						} else {
							$cienaGlobalSeverity = $cienaGlobalSeverity + " ( " + $1 + " )"
						}
						@AlertGroup = "Ciena OME Traps"
						@Agent = "ciena.m2r.include.rules"
						@Summary = "cienaCesChassisUsbFlashDisabledNotification: CTX USB hubs disabled via user config"
						@Severity = 3
						@Type = 1
						@Identifier = @Node + @Summary
						details($*)

					case "26": ### - cienaCesChassisAirFilterServiceNotification
						# SNMPv2
						# This notification is generated when the air filter service interval is reached.
						$cienaGlobalSeveritylook = "cienaGlobalSeverity." + $1
						$cienaGlobalSeverity = lookup($cienaGlobalSeveritylook,CienaVarbindValTable)
						if(match($cienaGlobalSeverity,"UNKNOWN")) {
							$cienaGlobalSeverity = $1
						} else {
							$cienaGlobalSeverity = $cienaGlobalSeverity + " ( " + $1 + " )"
						}
						$cienaCesChassisMacAddress = $2
						@AlertGroup = "Ciena OME Traps"
						@Agent = "ciena.m2r.include.rules"
						@Summary = "cienaCesChassisAirFilterServiceNotification: Air filter should be serviced"
						@Severity = 3
						@Type = 1
						@Identifier = @Node + @Summary
						details($*)

					case "27": ### - cienaCesChassisAlarmCutoffNotification
						# SNMPv2
						# A cienaCesChassisAlarmCutoffNotification is sent if:
						# 1) The alarm cutoff button on either CM is pushed.
						# 2) The CLI alarm cutoff command is issued.
						# 3) The SNMP alarm cutoff command is issued.
						# To enable the device to send this trap:
						# cienaCesChassisAlarmCutoffTrapState needs to be set to enabled.
						$cienaGlobalSeveritylook = "cienaGlobalSeverity." + $1
						$cienaGlobalSeverity = lookup($cienaGlobalSeveritylook,CienaVarbindValTable)
						if(match($cienaGlobalSeverity,"UNKNOWN")) {
							$cienaGlobalSeverity = $1
						} else {
							$cienaGlobalSeverity = $cienaGlobalSeverity + " ( " + $1 + " )"
						}
						$cienaCesChassisAlarmCutoffOriginlook = "cienaCesChassisAlarmCutoffOrigin." + $2
						$cienaCesChassisAlarmCutoffOrigin = lookup($cienaCesChassisAlarmCutoffOriginlook,CienaVarbindValTable)
						if(match($cienaCesChassisAlarmCutoffOrigin,"UNKNOWN")) {
							$cienaCesChassisAlarmCutoffOrigin = $2
						} else {
							$cienaCesChassisAlarmCutoffOrigin = $cienaCesChassisAlarmCutoffOrigin + " ( " + $2 + " )"
						}
						@AlertGroup = "Ciena OME Traps"
						@Agent = "ciena.m2r.include.rules"
						@Summary = "cienaCesChassisAlarmCutoffNotification: CLI or SNMP alarm cutoff command has been issued"
						@Severity = 3
						@Type = 1
						@Identifier = @Node + @Summary
						details($*)

						case "28": ### - cienaCesChassisDyingGaspNotification
												# SNMPv2
												# This notification is sent when the system losses power
												$cienaCesChassisDeviceId = $1
												$cienaCesChassisSerialNumber = $2
												$cienaCesChassisMacAddress = $3
												$cienaCesChassisMfgDate = $4
												$cienaCesChassisParamVersion = $5
												$cienaGlobalSeveritylook = "cienaGlobalSeverity." + $6
												$cienaGlobalSeverity = lookup($cienaGlobalSeveritylook,CienaVarbindValTable)
												if(match($cienaGlobalSeverity,"UNKNOWN")) {
													$cienaGlobalSeverity = $6
												} else {
													$cienaGlobalSeverity = $cienaGlobalSeverity + " ( " + $6 + " )"
												}
												@AlertGroup = "Ciena OME Traps"
												@Agent = "ciena.m2r.include.rules"
												@Summary = "cienaCesChassisDyingGaspNotification: Chassis Loss of power"
												@Severity = 5
												@Type = 1
												@Identifier = @Node + @Summary
												details($cienaCesChassisDeviceId,$cienaCesChassisSerialNumber,$cienaCesChassisMacAddress,$cienaCesChassisMfgDate,$cienaCesChassisParamVersion,$cienaGlobalSeverity)

					default:
						@Summary = "Unknown specific trap number (" + $specific-trap + ") received for enterprise " + $enterprise
						@Identifier = @Node + $enterprise + $generic-trap + $specific-trap + @Agent + @Manager
						@Severity = 3
						@Type = 1
						details($*)
				}

			######
			# cienaCesCfmNotifMIBNotification traps
			######
			case ".1.3.6.1.4.1.1271.2.2.5":	### - cienaCesCfmNotifMIBNotificationPrefix
				switch($specific-trap) {
					case "1": ### - cienaCesCfmFaultTrapSet
						# SNMPv2
						# A notification is sent whenever the fault is detected. Setting the
						# cienaCesCfmFaultTrapState object to 'disabled' causes this trap to be
						# suppressed. Variable bindings include cienaGlobalSeverity,
						# cienaGlobalMacAddress, cienaCesCfmServiceName,
						# cienaCesCfmServiceType, cienaCesCfmServiceValue,
						# cienaCesCfmServiceAdminState, cienaCesCfmServiceOperState,
						# cienaCesCfmServiceMdLevel, cienaCesCfmServiceFaultTime,
						# cienaCesCfmServiceFaultType, cienaCesCfmServiceFaultDesc,
						# cienaCesCfmServiceFaultMep, and cienaCesCfmServiceVsPbtName.
						$cienaGlobalSeveritylook = "cienaGlobalSeverity." + $1
						$cienaGlobalSeverity = lookup($cienaGlobalSeveritylook,CienaVarbindValTable)
						if(match($cienaGlobalSeverity,"UNKNOWN")) {
							$cienaGlobalSeverity = $1
						} else {
							$cienaGlobalSeverity = $cienaGlobalSeverity + " ( " + $1 + " )"
						}
						$cienaGlobalMacAddress = $2
						$cienaCesCfmServiceName = $3
						$cienaCesCfmServiceTypelook = "cienaCesCfmServiceType." + $4
						$cienaCesCfmServiceType = lookup($cienaCesCfmServiceTypelook,CienaVarbindValTable)
						if(match($cienaCesCfmServiceType,"UNKNOWN")) {
							$cienaCesCfmServiceType = $4
						} else {
							$cienaCesCfmServiceType = $cienaCesCfmServiceType + " ( " + $4 + " )"
						}
						$cienaCesCfmServiceValuelook = "cienaCesCfmServiceValue." + $5
						$cienaCesCfmServiceValue = lookup($cienaCesCfmServiceValuelook,CienaVarbindValTable)
						if(match($cienaCesCfmServiceValue,"UNKNOWN")) {
							$cienaCesCfmServiceValue = $5
						} else {
							$cienaCesCfmServiceValue = $cienaCesCfmServiceValue + " ( " + $5 + " )"
						}
						$cienaCesCfmServiceAdminStatelook = "cienaCesCfmServiceAdminState." + $6
						$cienaCesCfmServiceAdminState = lookup($cienaCesCfmServiceAdminStatelook,CienaVarbindValTable)
						if(match($cienaCesCfmServiceAdminState,"UNKNOWN")) {
							$cienaCesCfmServiceAdminState = $6
						} else {
							$cienaCesCfmServiceAdminState = $cienaCesCfmServiceAdminState + " ( " + $6 + " )"
						}
						$cienaCesCfmServiceOperStatelook = "cienaCesCfmServiceOperState." + $7
						$cienaCesCfmServiceOperState = lookup($cienaCesCfmServiceOperStatelook,CienaVarbindValTable)
						if(match($cienaCesCfmServiceOperState,"UNKNOWN")) {
							$cienaCesCfmServiceOperState = $7
						} else {
							$cienaCesCfmServiceOperState = $cienaCesCfmServiceOperState + " ( " + $7 + " )"
						}
						$cienaCesCfmServiceMdLevellook = "cienaCesCfmServiceMdLevel." + $8
						$cienaCesCfmServiceMdLevel = lookup($cienaCesCfmServiceMdLevellook,CienaVarbindValTable)
						if(match($cienaCesCfmServiceMdLevel,"UNKNOWN")) {
							$cienaCesCfmServiceMdLevel = $8
						} else {
							$cienaCesCfmServiceMdLevel = $cienaCesCfmServiceMdLevel + " ( " + $8 + " )"
						}
						$cienaCesCfmServiceFaultTime = $9
						$cienaCesCfmServiceFaultTypelook = "cienaCesCfmServiceFaultType." + $10
						$cienaCesCfmServiceFaultType = lookup($cienaCesCfmServiceFaultTypelook,CienaVarbindValTable)
						if(match($cienaCesCfmServiceFaultType,"UNKNOWN")) {
							$cienaCesCfmServiceFaultType = $10
						} else {
							$cienaCesCfmServiceFaultType = $cienaCesCfmServiceFaultType + " ( " + $10 + " )"
						}
						$cienaCesCfmServiceFaultDesc = $11
						$cienaCesCfmServiceFaultMeplook = "cienaCesCfmServiceFaultMep." + $12
						$cienaCesCfmServiceFaultMep = lookup($cienaCesCfmServiceFaultMeplook,CienaVarbindValTable)
						if(match($cienaCesCfmServiceFaultMep,"UNKNOWN")) {
							$cienaCesCfmServiceFaultMep = $12
						} else {
							$cienaCesCfmServiceFaultMep = $cienaCesCfmServiceFaultMep + " ( " + $12 + " )"
						}
						$cienaCesCfmServiceVsPbtName = $13
						@AlertGroup = "Ciena OME Traps"
						@Agent = "ciena.m2r.include.rules"
						@Summary = "cienaCesCfmFaultTrapSet: Chassis fault detected - " + $cienaCesCfmServiceFaultDesc
						@Severity = 4
						@Type = 1
						@Identifier = @Node + @Summary
						details($*)

					case "2": ### - cienaCesCfmFaultTrapClear
						# SNMPv2
						# A notification is sent whenever the fault is resolved and cleared. Setting the
						# cienaCesCfmFaultTrapState object to 'disabled' causes this trap to be
						# suppressed. Variable bindings include: cienaGlobalSeverity,
						# cienaGlobalMacAddress, cienaCesCfmServiceName,
						# cienaCesCfmServiceType, cienaCesCfmServiceValue,
						# cienaCesCfmServiceAdminState, cienaCesCfmServiceOperState,
						# cienaCesCfmServiceMdLevel, and cienaCesCfmServiceVsPbtName.
						$cienaGlobalSeveritylook = "cienaGlobalSeverity." + $1
						$cienaGlobalSeverity = lookup($cienaGlobalSeveritylook,CienaVarbindValTable)
						if(match($cienaGlobalSeverity,"UNKNOWN")) {
							$cienaGlobalSeverity = $1
						} else {
							$cienaGlobalSeverity = $cienaGlobalSeverity + " ( " + $1 + " )"
						}
						$cienaGlobalMacAddress = $2
						$cienaCesCfmServiceName = $3
						$cienaCesCfmServiceTypelook = "cienaCesCfmServiceType." + $4
						$cienaCesCfmServiceType = lookup($cienaCesCfmServiceTypelook,CienaVarbindValTable)
						if(match($cienaCesCfmServiceType,"UNKNOWN")) {
							$cienaCesCfmServiceType = $4
						} else {
							$cienaCesCfmServiceType = $cienaCesCfmServiceType + " ( " + $4 + " )"
						}
						$cienaCesCfmServiceValuelook = "cienaCesCfmServiceValue." + $5
						$cienaCesCfmServiceValue = lookup($cienaCesCfmServiceValuelook,CienaVarbindValTable)
						if(match($cienaCesCfmServiceValue,"UNKNOWN")) {
							$cienaCesCfmServiceValue = $5
						} else {
							$cienaCesCfmServiceValue = $cienaCesCfmServiceValue + " ( " + $5 + " )"
						}
						$cienaCesCfmServiceAdminStatelook = "cienaCesCfmServiceAdminState." + $6
						$cienaCesCfmServiceAdminState = lookup($cienaCesCfmServiceAdminStatelook,CienaVarbindValTable)
						if(match($cienaCesCfmServiceAdminState,"UNKNOWN")) {
							$cienaCesCfmServiceAdminState = $6
						} else {
							$cienaCesCfmServiceAdminState = $cienaCesCfmServiceAdminState + " ( " + $6 + " )"
						}
						$cienaCesCfmServiceOperStatelook = "cienaCesCfmServiceOperState." + $7
						$cienaCesCfmServiceOperState = lookup($cienaCesCfmServiceOperStatelook,CienaVarbindValTable)
