						} else {
							$cienaCesLogicalPortConfigPortOperState = $cienaCesLogicalPortConfigPortOperState + " ( " + $8 + " )"
						}
						$cienaCesLogicalPortConfigPortName = $9
						$cienaCesLogicalPortConfigPortTypelook = "cienaCesLogicalPortConfigPortType." + $10
						$cienaCesLogicalPortConfigPortType = lookup($cienaCesLogicalPortConfigPortTypelook,CienaVarbindValTable)
						if(match($cienaCesLogicalPortConfigPortType,"UNKNOWN")) {
							$cienaCesLogicalPortConfigPortType = $10
						} else {
							$cienaCesLogicalPortConfigPortType = $cienaCesLogicalPortConfigPortType + " ( " + $10 + " )"
						}
						$cienaCesLogicalPortConfigPortDesc = $11
						$sysName = $12
						$sysLocation = $13
						$cienaCesChassisSystemId = $14
						$cienaCesLogicalPortConfigEttpAid = $15
						@AlertGroup = "Ciena OME Traps"
						@Agent = "ciena.m2r.include.rules"
						@Summary = "cienaCesPortNotificationPortUp: Port number " + $cienaCesPortPgIdMappingNotifPortNumber + " on slot " + $cienaCesPortPgIdMappingNotifSlotIndex + " is up"
						@Severity = 4
						@Type = 1
						@Identifier = @Node + @Summary
						details($*)

					case "3": ### - cienaCesChPortNotificationPortUp
						# SNMPv2
						# A cienaCesChPortNotificationPortUp trap signifies that the SNMP entity, acting in
						# an agent role, has detected the link status has become operationally up for
						# one of its communication links.
						# To enable the device to send this notification:
